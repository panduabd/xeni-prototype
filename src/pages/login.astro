---
// Login page - minimal layout without sidebar
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Sign in — Xeni</title>
    <style is:global>
      @keyframes float {
        0%,
        100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-6px);
        }
      }
      @keyframes pulse-ring {
        0% {
          transform: scale(0.95);
          opacity: 0.7;
        }
        50% {
          transform: scale(1.05);
          opacity: 0.3;
        }
        100% {
          transform: scale(0.95);
          opacity: 0.7;
        }
      }
      @keyframes slide-up {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-float {
        animation: float 4s ease-in-out infinite;
      }
      .animate-pulse-ring {
        animation: pulse-ring 3s ease-in-out infinite;
      }
      .animate-slide-up {
        animation: slide-up 0.5s ease-out forwards;
      }
      .delay-100 {
        animation-delay: 0.1s;
      }
      .delay-200 {
        animation-delay: 0.2s;
      }
      .delay-300 {
        animation-delay: 0.3s;
      }
      .delay-400 {
        animation-delay: 0.4s;
      }
    </style>
  </head>

  <body
    class="min-h-screen w-full bg-gradient-to-br from-slate-50 via-gray-50 to-stone-100 text-[#111827] font-sans antialiased flex items-center justify-center p-4"
  >
    <!-- Ambient background decoration -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-blue-100/40 blur-3xl animate-pulse-ring"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] rounded-full bg-violet-100/40 blur-3xl animate-pulse-ring"
        style="animation-delay: 1.5s;"
      >
      </div>
    </div>

    <!-- Main card -->
    <main class="relative w-full max-w-[420px] animate-slide-up">
      <!-- Logo & Header -->
      <div class="text-center mb-8">
        <div
          class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-gray-900 to-gray-700 text-white mb-5 shadow-lg shadow-gray-900/20 animate-float"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <h1 class="text-[26px] font-bold tracking-tight text-gray-900 mb-1.5">
          Welcome back
        </h1>
        <p class="text-[15px] text-gray-500 font-normal">
          Sign in to continue creating with Xeni
        </p>
      </div>

      <!-- Card body -->
      <div
        class="bg-white/80 backdrop-blur-xl rounded-3xl border border-white/60 shadow-xl shadow-gray-200/50 p-7 space-y-4"
      >
        <!-- Social Login Buttons -->
        <div class="space-y-3">
          <button
            type="button"
            class="w-full h-11 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 flex items-center justify-center gap-3 text-[14px] font-medium text-gray-700 shadow-sm shadow-gray-100 cursor-pointer group"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path
                fill="#4285F4"
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              ></path>
              <path
                fill="#34A853"
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              ></path>
              <path
                fill="#FBBC05"
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              ></path>
              <path
                fill="#EA4335"
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              ></path>
            </svg>
            <span
              class="group-hover:translate-x-0.5 transition-transform duration-200"
              >Continue with Google</span
            >
          </button>

          <button
            type="button"
            class="w-full h-11 rounded-xl border border-gray-200 bg-white hover:bg-gray-50 hover:border-gray-300 transition-all duration-200 flex items-center justify-center gap-3 text-[14px] font-medium text-gray-700 shadow-sm shadow-gray-100 cursor-pointer group"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.22 7.13-.57 1.5-1.31 2.99-2.27 4.08zm-5.85-15.1c.07-2.04 1.76-3.79 3.78-3.94.29 2.32-1.93 4.48-3.78 3.94z"
              ></path>
            </svg>
            <span
              class="group-hover:translate-x-0.5 transition-transform duration-200"
              >Continue with Apple</span
            >
          </button>
        </div>

        <!-- Divider -->
        <div class="relative py-1">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <div class="relative flex justify-center">
            <span
              class="bg-white/80 px-3 text-[12px] font-medium text-gray-400 uppercase tracking-wider"
              >or</span
            >
          </div>
        </div>

        <!-- Email Input -->
        <div class="space-y-3">
          <div class="relative">
            <input
              type="email"
              id="email"
              placeholder="Enter your email address"
              class="w-full h-11 px-4 rounded-xl border border-gray-200 bg-gray-50/50 text-[14px] text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-300 transition-all duration-200"
            />
            <div
              class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </div>
          </div>

          <!-- Continue Button -->
          <button
            type="button"
            class="w-full h-11 rounded-xl bg-gray-900 hover:bg-gray-800 text-white text-[14px] font-semibold transition-all duration-200 shadow-lg shadow-gray-900/20 hover:shadow-gray-900/30 hover:scale-[1.02] active:scale-[0.98] cursor-pointer"
          >
            Continue
          </button>
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-8 text-center space-y-4 animate-slide-up delay-200">
        <p class="text-[13px] text-gray-400">
          By continuing, you agree to our
          <a
            href="#"
            class="text-gray-600 hover:text-gray-900 underline underline-offset-2 transition-colors"
            >Terms of Service</a
          >
          and
          <a
            href="#"
            class="text-gray-600 hover:text-gray-900 underline underline-offset-2 transition-colors"
            >Privacy Policy</a
          >
        </p>
        <div class="flex items-center justify-center gap-2 text-gray-400">
          <span class="text-[12px] font-medium">from</span>
          <span class="text-[14px] font-bold text-gray-700 tracking-tight"
            >Xeni</span
          >
        </div>
        <p class="text-[12px] text-gray-300">
          © 2026 Xeni. All rights reserved.
        </p>
      </div>
    </main>
  </body>
</html>
