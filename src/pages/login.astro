---
// Login page - minimal layout without sidebar
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Sign in — Xeni</title>
    <style is:global>
      @keyframes slide-up {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-slide-up {
        animation: slide-up 0.5s ease-out forwards;
      }
      .delay-200 {
        animation-delay: 0.2s;
      }
    </style>
  </head>

  <body
    class="min-h-screen w-full bg-[#FAFAF9] text-[#111827] font-sans antialiased flex items-center justify-center p-4"
  >
    <!-- Logo top-left -->
    <a
      href="/"
      class="fixed top-5 left-5 flex items-center gap-2 text-[#111827] hover:opacity-70 transition-opacity cursor-pointer z-50"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
        <path d="M2 17l10 5 10-5"></path>
        <path d="M2 12l10 5 10-5"></path>
      </svg>
      <span class="text-[15px] font-bold tracking-tight">Xeni</span>
    </a>

    <!-- Main content -->
    <main class="relative w-full max-w-[380px] animate-slide-up">
      <!-- Header -->
      <div class="text-center mb-6">
        <h1 class="text-[22px] font-semibold tracking-tight text-[#111827] mb-1">
          Sign in or sign up
        </h1>
        <p class="text-[13px] text-[#667085] font-normal">
          Start creating with Xeni
        </p>
      </div>

      <!-- Buttons -->
      <div class="space-y-2.5">
        <button
          type="button"
          class="w-full h-10 rounded-lg border border-[#E5E7EB] bg-white hover:bg-[#F3F4F6] hover:border-[#D1D5DB] transition-all duration-150 flex items-center justify-center gap-2.5 text-[13px] font-medium text-[#374151] cursor-pointer"
        >
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24">
            <path
              fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            ></path>
            <path
              fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            ></path>
            <path
              fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            ></path>
            <path
              fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            ></path>
          </svg>
          Continue with Google
        </button>

        <button
          type="button"
          class="w-full h-10 rounded-lg border border-[#E5E7EB] bg-white hover:bg-[#F3F4F6] hover:border-[#D1D5DB] transition-all duration-150 flex items-center justify-center gap-2.5 text-[13px] font-medium text-[#374151] cursor-pointer"
        >
          <svg
            class="w-[18px] h-[18px]"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.22 7.13-.57 1.5-1.31 2.99-2.27 4.08zm-5.85-15.1c.07-2.04 1.76-3.79 3.78-3.94.29 2.32-1.93 4.48-3.78 3.94z"
            ></path>
          </svg>
          Continue with Apple
        </button>
      </div>

      <!-- Divider -->
      <div class="relative py-4">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-[#E5E7EB]"></div>
        </div>
        <div class="relative flex justify-center">
          <span
            class="bg-[#FAFAF9] px-3 text-[11px] font-medium text-[#9CA3AF] uppercase tracking-wider"
            >or</span
          >
        </div>
      </div>

      <!-- Email Input -->
      <div class="space-y-2.5">
        <div class="relative">
          <input
            type="email"
            id="email"
            placeholder="Enter your email address"
            class="w-full h-10 px-3.5 rounded-lg border border-[#E5E7EB] bg-white text-[13px] text-[#111827] placeholder:text-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#111827]/8 focus:border-[#D1D5DB] transition-all duration-150"
          />
          <div
            class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9CA3AF]"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
        </div>

        <!-- Continue Button -->
        <button
          id="btn-continue"
          type="button"
          class="w-full h-10 rounded-lg bg-[#111827] hover:bg-black text-white text-[13px] font-semibold transition-all duration-150 cursor-pointer"
        >
          Continue
        </button>
      </div>

      <!-- Footer -->
      <div class="mt-8 text-center space-y-3 animate-slide-up delay-200">
        <p class="text-[12px] text-[#9CA3AF]">
          By continuing, you agree to our
          <a
            href="#"
            class="text-[#6B7280] hover:text-[#111827] underline underline-offset-2 transition-colors"
            >Terms of Service</a
          >
          and
          <a
            href="#"
            class="text-[#6B7280] hover:text-[#111827] underline underline-offset-2 transition-colors"
            >Privacy Policy</a
          >
        </p>
        <p class="text-[11px] text-[#D1D5DB]">
          © 2026 Xeni. All rights reserved.
        </p>
      </div>
    </main>
    <script is:inline>
      document.getElementById('btn-continue')?.addEventListener('click', () => {
        window.location.href = '/studio';
      });
    </script>
  </body>
</html>
