---
import AppLayout from "../layouts/AppLayout.astro";
import ReferencesModal from "../components/modals/ReferencesModal.astro";
import XeniButton from "../components/XeniButton.astro";

const dnaList = [
  { id: "all", name: "All Business" },
  { id: "Fresh Juice Co.", name: "Fresh Juice Co." },
  { id: "Acme Corp", name: "Acme Corp" },
  { id: "Luxe Beauty", name: "Luxe Beauty" },
  { id: "Tech Startup", name: "Tech Startup" },
  { id: "TechFlow Systems", name: "TechFlow Systems" },
  { id: "Daily Brew Cafe", name: "Daily Brew Cafe" },
  { id: "FitLife Gym", name: "FitLife Gym" },
  { id: "EcoGreen Solutions", name: "EcoGreen Solutions" },
  { id: "Urban Outfitters", name: "Urban Outfitters" },
  { id: "Pixel Perfect Studio", name: "Pixel Perfect Studio" },
  { id: "Nova Logistics", name: "Nova Logistics" },
  { id: "Summit Outdoors", name: "Summit Outdoors" },
  { id: "Glow Skincare", name: "Glow Skincare" },
  { id: "Byte Labs", name: "Byte Labs" },
  { id: "Vista Real Estate", name: "Vista Real Estate" },
  { id: "Peak Performance", name: "Peak Performance" },
  { id: "Swift Delivery", name: "Swift Delivery" },
  { id: "Bloom Florist", name: "Bloom Florist" },
  { id: "Oceanic Seafood", name: "Oceanic Seafood" },
  { id: "Apex Consulting", name: "Apex Consulting" }
];
---

<AppLayout title="Content Automation - Xeni" activePage="content-automation">
  <div class="w-full min-h-full flex flex-col px-6 pb-32 -mt-12">
    <!-- Title + Controls Row -->
    <div
      class="w-full pt-1 pb-5 flex items-center justify-between gap-4 shrink-0"
    >
      <!-- Left: Title + Info -->
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-wand text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Content Automation
        </h1>
        <i
          class="ti ti-info-circle text-[16px] text-[#98a2b3] cursor-help"
          title="Konten dibuat setiap jam 2 pagi WIB. Kredit hanya terpotong saat konten dibuat."
        ></i>
      </div>

      <!-- Right: Status Mini Badges -->
      <div class="hidden items-center gap-2">
        <span
          class="flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#ECFDF3] border border-[#D1FADF] text-[11px] font-bold text-[#027A48] transition-all duration-200 hover:scale-[1.03] shadow-sm cursor-help"
          title="Active automations"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#12B76A]"></span>
          <span id="status-active">0</span> Active Automation
        </span>
        <span
          class="flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#F2F4F7] border border-[#EAECF0] text-[11px] font-bold text-[#344054] transition-all duration-200 hover:scale-[1.03] shadow-sm cursor-help"
          title="Draft contents"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#475467]"></span>
          <span id="status-draft">0</span> Draft
        </span>
        <span
          class="flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#F5F3FF] border border-[#D6BBFB] text-[11px] font-bold text-[#6941C6] transition-all duration-200 hover:scale-[1.03] shadow-sm cursor-help"
          title="Scheduled contents"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#7F56D9]"></span>
          <span id="status-scheduled">0</span> Scheduled
        </span>
      </div>
    </div>

    <!-- Tabs Row -->
    <div class="w-full mb-6 flex items-center gap-4">
      <div
        class="flex items-center gap-1 p-1 bg-white rounded-xl border border-[#eaecf0] w-fit"
      >
        <button
          id="tab-automations"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold bg-[#111827] text-white transition-all cursor-pointer"
          data-tab="automations"
        >
          Automations
        </button>
        <button
          id="tab-generated"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          data-tab="generated"
        >
          Outputs
          <span
            id="generated-badge"
            class="ml-1.5 px-1.5 h-4 rounded-full bg-[#FEF3C7] text-[#B45309] text-[10px] font-bold hidden"
            >0</span
          >
        </button>
        <button
          id="tab-scheduled"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          data-tab="scheduled"
        >
          Scheduled
          <span
            id="scheduled-badge"
            class="ml-1.5 px-1.5 h-4 rounded-full bg-[#F5F3FF] text-[#7C3AED] text-[10px] font-bold hidden"
            >0</span
          >
        </button>
      </div>
    </div>

    <!-- TAB: AUTOMATIONS -->
    <div id="tab-content-automations" class="w-full flex-1">
      <!-- Automation Filters -->
      <div class="flex items-center justify-between gap-2 mb-4">
        <div class="flex items-center gap-2">
          <div class="relative" id="business-filter-wrapper">
            <button
              id="btn-business-filter"
              class="flex items-center gap-1.5 px-4 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
            </button>
            <div id="business-filter-dropdown" class="hidden absolute top-full left-0 mt-1.5 w-56 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden flex flex-col">
              <!-- Mini Search -->
              <div class="p-2 border-b border-[#eaecf0] bg-[#F9FAFB]">
                <div class="relative">
                  <i class="ti ti-search absolute left-2.5 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[11px]"></i>
                  <input type="text" class="biz-search-input w-full h-8 pl-7 pr-2 text-[12px] bg-white border border-[#D0D5DD] rounded-lg focus:outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827]" placeholder="Search..." />
                </div>
              </div>
              <!-- List -->
              <div class="flex flex-col p-1 max-h-[220px] overflow-y-auto custom-scrollbar biz-options-container">
                {dnaList.map(item => (
                  <button class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-brand={item.id}>
                    {item.name}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Search -->
          <div class="relative flex-1 max-w-xs">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="automation-search"
              type="text"
              placeholder="Search by campaign or business..."
              class="w-80 h-9 pl-8 pr-2 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>
        </div>

        <!-- Create Button (only for Automations tab) -->
        <button
          id="btn-add-automation"
          class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold border border-[#374151] shadow-[0_3px_0_0_#374151] hover:bg-black active:translate-y-[1px] active:shadow-[0_1px_0_0_#374151] transition-all cursor-pointer flex items-center gap-2"
        >
          <i class="ti ti-plus text-[14px]"></i>
          Create Automation
        </button>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="w-full hidden">
        <div class="text-center space-y-4">
          <div
            class="w-16 h-16 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center mx-auto"
          >
            <i class="ti ti-calendar text-[32px] text-[#D1D5DB]"></i>
          </div>
          <div class="space-y-1">
            <h2 class="text-[18px] font-bold text-[#344054]">
              No automation yet
            </h2>
            <p class="text-[14px] text-[#667085] font-medium">
              Create your first automation to start scheduling content.
            </p>
          </div>
          <button
            id="btn-empty-add"
            class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold border border-[#374151] shadow-[0_3px_0_0_#374151] hover:bg-black active:translate-y-[1px] active:shadow-[0_1px_0_0_#374151] transition-all cursor-pointer flex items-center gap-2 mx-auto"
          >
            <i class="ti ti-plus text-[14px]"></i>
            Add Automation
          </button>
        </div>
      </div>

      <!-- Table -->
      <div id="automations-table" class="w-full hidden">
        <div
          class="bg-white rounded-3xl border border-[#eaecf0] overflow-hidden"
        >
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#eaecf0]">
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >BUSINESS</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Task Name</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Schedule</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Content Types</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Status</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider text-right"
                    >Actions</th
                  >
                </tr>
              </thead>
              <tbody id="automations-tbody">
                <!-- Rows injected via JS -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: GENERATED -->
    <div
      id="tab-content-generated"
      class="w-full flex-1 hidden"
    >
      <!-- Filter Bar -->
      <div
        class="flex items-center justify-between gap-4 mb-4 flex-wrap w-full"
      >
        <!-- Left Side: Filters & Search -->
        <div class="flex items-center gap-2">
          <!-- Business Filter -->
          <div class="relative">
            <button
              id="btn-output-business-filter"
              class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="output-business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px]"></i>
            </button>
            <div id="output-business-filter-dropdown" class="hidden absolute top-full left-0 mt-1.5 w-56 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden flex flex-col">
              <!-- Mini Search -->
              <div class="p-2 border-b border-[#eaecf0] bg-[#F9FAFB]">
                <div class="relative">
                  <i class="ti ti-search absolute left-2.5 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[11px]"></i>
                  <input type="text" class="biz-search-input w-full h-8 pl-7 pr-2 text-[12px] bg-white border border-[#D0D5DD] rounded-lg focus:outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827]" placeholder="Search..." />
                </div>
              </div>
              <!-- List -->
              <div class="flex flex-col p-1 max-h-[220px] overflow-y-auto custom-scrollbar biz-options-container">
                {dnaList.map(item => (
                  <button class="output-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-brand={item.id}>
                    {item.name}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Search -->
          <div class="relative w-64">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="output-search"
              type="text"
              placeholder="Search outputs..."
              class="w-full h-9 pl-8 pr-3 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#111827] focus:shadow-[0_0_0_3px_rgba(0,0,0,0.06)] transition-all"
            />
          </div>
        </div>

        <div class="flex items-center gap-2 ml-auto">
          <!-- Status Filter -->
          <div class="relative">
            <button
              id="btn-output-status-filter"
              class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-filter text-[14px]"></i>
              <span id="output-status-filter-label">Approved</span>
              <i class="ti ti-chevron-down text-[12px]"></i>
            </button>
            <div
              id="output-status-filter-dropdown"
              class="hidden absolute top-full right-0 mt-1.5 w-40 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
            >
              <div class="flex flex-col p-1.5">
                <button
                  class="output-status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-status="approved">Approved</button
                >
                <button
                  class="output-status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-status="rejected">Rejected</button
                >
              </div>
            </div>
          </div>

          <!-- Bulk Actions (Subtle Dark Component Style) -->
          <div id="approved-bulk-header" class="hidden items-center gap-2">
            <span
              id="selected-count"
              class="text-[12px] font-semibold text-[#344054] bg-[#F2F4F7] px-3 h-9 rounded-xl border border-[#D0D5DD] flex items-center justify-center"
              >0 terpilih</span
            >

            <button
              onclick="openBulkScheduleModal()"
              class="h-9 px-3.5 rounded-xl bg-[#111827] hover:bg-[#000] text-white text-[12px] font-bold transition-all cursor-pointer flex items-center gap-1.5 shadow-sm"
            >
              <i class="ti ti-calendar-event text-[12px]"></i>
              Schedule
            </button>

            <button
              onclick="bulkPublishSelected()"
              class="h-9 px-3.5 rounded-xl border border-[#D0D5DD] bg-white text-[#344054] text-[12px] font-semibold hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center gap-1.5 shadow-sm"
            >
              <i class="ti ti-send text-[12px]"></i>
              Publish Now
            </button>

            <button
              onclick="bulkDeleteSelected()"
              class="h-9 w-9 rounded-xl border border-[#D0D5DD] bg-white text-[#111827] hover:bg-[#F3F4F6] transition-all cursor-pointer flex items-center justify-center shadow-sm"
              title="Delete Selected"
            >
              <i class="ti ti-trash text-[14px]"></i>
            </button>

            <button
              onclick="deselectAllApproved()"
              class="h-9 px-3 rounded-xl border border-[#D0D5DD] bg-white text-[#344054] text-[12px] font-semibold hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center justify-center shadow-sm"
            >
              Deselect All
            </button>
          </div>
        </div>
      </div>

      <!-- Two Panel Layout: Draft (left 25%) + Right Panel (75%) -->
      <div class="flex gap-4 w-full">
        <!-- LEFT PANEL: Draft List (25%) -->
        <div class="w-[25%] min-w-60 flex flex-col gap-3">
          <div class="flex items-center justify-between px-1">
            <div class="flex items-center gap-2">
              <h3 class="text-[13px] font-bold text-[#111827]">Draft</h3>
              <span
                class="inline-flex items-center gap-1 px-1.5 h-[18px] rounded-full bg-[#111827] text-[9px] font-bold text-white tracking-wide"
              >
                <i class="ti ti-alert-circle text-[9px]"></i>
                Needs Approval
              </span>
            </div>
            <span
              id="draft-count"
              class="text-[11px] font-medium text-[#667085] bg-[#F3F4F6] px-2 py-0.5 rounded-full"
              >0</span
            >
          </div>
          <div id="draft-list" class="flex flex-col gap-2">
            <!-- Draft items injected via JS -->
          </div>
          <div
            id="draft-show-more-container"
            class="hidden justify-center pt-2"
          >
            <button
              id="btn-draft-show-more"
              class="w-full h-8 rounded-xl border border-[#eaecf0] bg-white text-[11px] font-semibold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center justify-center gap-1 shadow-sm"
            >
              <i class="ti ti-chevron-down text-[12px]"></i>
              Show More
            </button>
          </div>
          <div
            id="draft-empty"
            class="hidden flex-col items-center justify-center py-8 text-center"
          >
            <i class="ti ti-clipboard-check text-[24px] text-[#D1D5DB] mb-2"
            ></i>
            <p class="text-[12px] text-[#98a2b3]">No drafts pending</p>
          </div>
        </div>

        <!-- RIGHT PANEL: Approved Grid (75%) -->
        <div id="right-panel-approved" class="w-[75%] flex flex-col gap-3">
          <div class="flex items-center justify-between px-1 h-8">
            <div id="approved-normal-header" class="flex items-center gap-2">
              <h3 class="text-[13px] font-bold text-[#111827]">Approved</h3>
              <span
                id="approved-count"
                class="text-[11px] font-medium text-[#667085] bg-[#F3F4F6] px-2 py-0.5 rounded-full"
                >0</span
              >
            </div>
          </div>
          <div id="approved-grid" class="columns-3 gap-3">
            <!-- Approved cards injected via JS -->
          </div>
          <div
            id="approved-empty"
            class="hidden flex-col items-center justify-center py-16 text-center"
          >
            <i class="ti ti-photo text-[32px] text-[#D1D5DB] mb-2"></i>
            <p class="text-[14px] text-[#667085] font-medium">
              No approved content yet
            </p>
            <p class="text-[12px] text-[#98a2b3]">
              Approved content will appear here
            </p>
          </div>
        </div>

        <!-- RIGHT PANEL: Rejected Grid (75%) - hidden by default -->
        <div id="right-panel-rejected" class="w-[75%] hidden flex-col gap-3">
          <div class="flex items-center justify-between px-1 h-8">
            <div class="flex items-center gap-2">
              <h3 class="text-[13px] font-bold text-[#111827]">Rejected</h3>
              <span
                id="rejected-count"
                class="text-[11px] font-medium text-[#667085] bg-[#F3F4F6] px-2 py-0.5 rounded-full"
                >0</span
              >
            </div>
          </div>
          <!-- Rejected alert -->
          <div
            class="flex items-start gap-2.5 p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]"
          >
            <i
              class="ti ti-alert-triangle text-[16px] text-[#111827] shrink-0 mt-0.5"
            ></i>
            <p class="text-[12px] text-[#667085] leading-relaxed">
              Rejected content will be <span class="font-bold text-[#111827]"
                >permanently deleted after 30 days</span
              >. Review and recover items before they are removed.
            </p>
          </div>
          <div id="rejected-grid" class="columns-3 gap-3">
            <!-- Rejected cards injected via JS -->
          </div>
          <div
            id="rejected-empty"
            class="hidden flex-col items-center justify-center py-16 text-center"
          >
            <i class="ti ti-circle-x text-[32px] text-[#D1D5DB] mb-2"></i>
            <p class="text-[14px] text-[#667085] font-medium">
              No rejected content
            </p>
            <p class="text-[12px] text-[#98a2b3]">
              Rejected content will appear here
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: SCHEDULED -->
    <div
      id="tab-content-scheduled"
      class="w-full flex-1 hidden"
    >
      <!-- Scheduled Header -->
      <div class="flex items-center justify-between gap-2 mb-4">
        <div class="flex items-center gap-2">
          <!-- Business Filter -->
          <div class="relative">
            <button
              id="btn-scheduled-business-filter"
              class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="scheduled-business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px]"></i>
            </button>
            <div id="scheduled-business-filter-dropdown" class="hidden absolute top-full left-0 mt-1.5 w-56 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden flex flex-col">
              <!-- Mini Search -->
              <div class="p-2 border-b border-[#eaecf0] bg-[#F9FAFB]">
                <div class="relative">
                  <i class="ti ti-search absolute left-2.5 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[11px]"></i>
                  <input type="text" class="biz-search-input w-full h-8 pl-7 pr-2 text-[12px] bg-white border border-[#D0D5DD] rounded-lg focus:outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827]" placeholder="Search..." />
                </div>
              </div>
              <!-- List -->
              <div class="flex flex-col p-1 max-h-[220px] overflow-y-auto custom-scrollbar biz-options-container">
                {dnaList.map(item => (
                  <button class="scheduled-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-brand={item.id}>
                    {item.name}
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Status Filter -->
          <div class="relative">
            <button
              id="btn-scheduled-status-filter"
