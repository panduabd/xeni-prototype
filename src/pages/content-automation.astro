  // ═══════════════════════════════════════════
  // TOAST NOTIFICATION
  // ═══════════════════════════════════════════
  function showToast(message) {
    const container = document.getElementById("toast-container");
    const template = document.getElementById("toast-template");
    const toast = template.cloneNode(true);
    toast.id = "";
    toast.classList.remove("hidden");
    toast.classList.add("flex");
    toast.querySelector(".toast-message").textContent = message;
    container.appendChild(toast);

    // Animate in
    requestAnimationFrame(() => {
      toast.classList.remove("translate-y-2", "opacity-0");
    });

    // Remove after 3s
    setTimeout(() => {
      toast.classList.add("translate-y-2", "opacity-0");
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  // ═══════════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════════
  function init() {
    loadAutomations();
    loadGenerated();
    renderAutomations();
    renderGenerated();
    renderScheduled();
    bindEvents();
    renderCalendar();
    renderWeeklyCalendar();

    // Check URL parameters or hash to switch to correct tab on load
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get("tab");
    if (tabParam === "generated") {
      switchTab("generated");
    } else if (tabParam === "scheduled") {
      switchTab("scheduled");
    } else if (
      window.location.hash === "#generated" ||
      window.location.hash === "#outputs"
    ) {
      switchTab("generated");
    }
  }

  // ═══════════════════════════════════════════
  // TAB SWITCHING
  // ═══════════════════════════════════════════
  function switchTab(tab) {
    // Reset all tabs
    [els.tabAutomations, els.tabGenerated, els.tabScheduled].forEach((btn) => {
      btn.classList.remove("bg-[#111827]", "text-white");
      btn.classList.add(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
    });
    [
      els.tabContentAutomations,
      els.tabContentGenerated,
      els.tabContentScheduled,
    ].forEach((content) => {
      content.classList.add("hidden");
    });

    // Activate selected tab
    if (tab === "automations") {
      els.tabAutomations.classList.add("bg-[#111827]", "text-white");
      els.tabAutomations.classList.remove(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
      els.tabContentAutomations.classList.remove("hidden");
      els.btnAdd.classList.remove("hidden");
      els.btnAdd.classList.add("flex");
    } else if (tab === "generated") {
      els.tabGenerated.classList.add("bg-[#111827]", "text-white");
      els.tabGenerated.classList.remove(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
      els.tabContentGenerated.classList.remove("hidden");
      els.btnAdd.classList.add("hidden");
      els.btnAdd.classList.remove("flex");
      draftLimit = 3;
    } else if (tab === "scheduled") {
      els.tabScheduled.classList.add("bg-[#111827]", "text-white");
      els.tabScheduled.classList.remove(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
      els.tabContentScheduled.classList.remove("hidden");
      els.btnAdd.classList.add("hidden");
      els.btnAdd.classList.remove("flex");
      renderScheduled();
    }
  }

  // ═══════════════════════════════════════════
  // GENERATED CONTENT
  // ═══════════════════════════════════════════
  function loadGenerated() {
    // Always use fresh mock data (deterministic, not from localStorage)
    generatedContent = createMockGenerated();
    saveGenerated();
  }

  function saveGenerated() {
    localStorage.setItem(
      GENERATED_STORAGE_KEY,
      JSON.stringify(generatedContent),
    );
  }

  function createMockGenerated() {
    const now = new Date();
    const brands = ["Fresh Juice Co.", "Tech Startup", "Luxe Beauty"];
    const platforms = ["Facebook", "Threads", "Instagram", "TikTok"];
    const types = ["Single Post", "Carousel", "Story", "Ad Creatives"];
    const titles = [
      "Summer Promo Collection",
      "Product Highlight 101",
      "Behind the Scenes Setup",
      "Customer Testimonial",
      "Flash Sale Alert",
      "5 Tips for Success",
      "Did You Know?",
      "Weekend Vibes",
      "New Feature Drop",
      "Top 5 List",
    ];

    const items = [];

    // Create 3 automation groups for drafts (each with 5 outputs)
    for (let g = 0; g < 3; g++) {
      const brand = brands[g];
      const autoName = `Campaign ${titles[g]}`;
      const createdAt = new Date(
        now.getTime() - (g + 1) * 2 * 60 * 60 * 1000,
      ).toISOString();
      for (let i = 0; i < 5; i++) {
        items.push({
          id: `gen_draft_${g}_${i}`,
          title: `${titles[i % titles.length]} - Variation ${i + 1}`,
          brand,
          contentType: types[i % 4],
          platform: platforms[i % 3],
          caption: MOCK_CAPTIONS[i % 4],
          pillar: "Promo",
          carouselSlides: types[i % 4] === "Carousel" ? 3 : 1,
          status: "draft",
          automationName: autoName,
          createdAt,
          scheduledAt: null,
          publishedAt: null,
          views: 0,
          likes: 0,
          comments: 0,
          failReason: null,
          rejectedAt: null,
          approvedAt: null,
          autoComment: { enabled: false, text: "", link: "", keywords: "" },
          autoDm: { enabled: false, text: "", link: "", keywords: "" },
        });
      }
    }

    // Create 35 other items (approved, rejected, scheduled, published) to populate the calendar beautifully
    for (let i = 0; i < 35; i++) {
      const statusPool = [
        "approved",
        "approved",
        "rejected",
        "scheduled",
        "scheduled",
        "published",
        "published",
      ];
      const status = statusPool[i % statusPool.length];
      const type = types[i % 4];
      const createdAt = new Date(
        now.getTime() - (i + 1) * 8 * 60 * 60 * 1000,
      ).toISOString();

      // Published items get engagement data
      const isPublished = status === "published";
      const reach = isPublished ? Math.floor(Math.random() * 5000) + 500 : 0;
      const likes = isPublished ? Math.floor(Math.random() * 300) + 50 : 0;
      const comments = isPublished ? Math.floor(Math.random() * 50) + 5 : 0;
      const shares = isPublished ? Math.floor(Math.random() * 30) + 2 : 0;
      const saves = isPublished ? Math.floor(Math.random() * 80) + 10 : 0;
      const profileVisits = isPublished
        ? Math.floor(Math.random() * 200) + 20
        : 0;
      const follows = isPublished ? Math.floor(Math.random() * 15) + 1 : 0;
      const engagementRate = isPublished
        ? (((likes + comments + shares + saves) / reach) * 100).toFixed(1)
        : 0;

      // Distribute dates throughout the current month dynamically
      const targetYear = now.getFullYear();
      const targetMonth = now.getMonth();
      const currentDay = now.getDate();

      let itemDay;
      if (status === "scheduled") {
        // Scheduled items are in the FUTURE: from tomorrow up to 10 days out
        itemDay = currentDay + 1 + (i % 10);
      } else if (status === "published") {
        // Published items are in the PAST: from yesterday back to 10 days ago (capped at day 1)
        itemDay = Math.max(1, currentDay - 1 - (i % 10));
      } else {
        // Other items spread throughout the month
        itemDay = 1 + (i % 28);
      }

      const scheduledHour = 9 + (i % 8); // 9:00 to 16:00
      const scheduledMinute = (i * 15) % 60; // 0, 15, 30, 45

      items.push({
        id: `gen_${status}_${i}`,
        title: titles[i % titles.length],
        brand: brands[i % 3],
        contentType: type,
        platform: platforms[i % 3],
        caption: MOCK_CAPTIONS[i % 4],
        pillar: i % 2 === 0 ? "Educational" : "Promo",
        carouselSlides: type === "Carousel" ? 3 : 1,
        status,
        automationName: "General Campaign",
        createdAt,
        scheduledAt:
          status === "scheduled"
            ? new Date(targetYear, targetMonth, itemDay, scheduledHour, scheduledMinute).toISOString()
            : status === "published"
              ? new Date(targetYear, targetMonth, itemDay, scheduledHour, scheduledMinute).toISOString()
              : null,
        publishedAt: isPublished
          ? new Date(targetYear, targetMonth, itemDay, scheduledHour, scheduledMinute).toISOString()
          : null,
        views: reach,
        likes,
        comments,
        shares,
        saves,
        profileVisits,
        follows,
        engagementRate,
        failReason: null,
        rejectedAt: null,
        approvedAt: null,
        autoComment: { enabled: false, text: "", link: "", keywords: "" },
        autoDm: { enabled: false, text: "", link: "", keywords: "" },
      });
    }

    return items;
  }

  function renderGenerated() {
    // Apply filters
    let filtered = generatedContent.filter((item) => {
      if (
        currentBusinessFilter !== "all" &&
        item.brand !== currentBusinessFilter
      )
        return false;
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        const haystack =
          `${item.title} ${item.brand} ${item.caption}`.toLowerCase();
        if (!haystack.includes(q)) return false;
      }
      return true;
    });

    filtered.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

    const needsAttentionCount = generatedContent.filter(
      (g) => g.status === "draft" || g.status === "approved",
    ).length;
    els.generatedBadge.textContent = needsAttentionCount;
    els.generatedBadge.classList.toggle("hidden", needsAttentionCount === 0);

    const drafts = filtered.filter((item) => item.status === "draft");
    const approved = filtered.filter((item) => item.status === "approved");
    const rejected = filtered.filter((item) => item.status === "rejected");

    // Render Draft Panel (Left)
    const draftList = document.getElementById("draft-list");
    const draftEmpty = document.getElementById("draft-empty");
    const draftCount = document.getElementById("draft-count");
    const draftShowMoreContainer = document.getElementById(
      "draft-show-more-container",
    );
    if (draftCount) draftCount.textContent = drafts.length;
    if (els.draftTopCount) els.draftTopCount.textContent = drafts.length;

    if (drafts.length === 0) {
      if (draftList) draftList.innerHTML = "";
      if (draftEmpty) draftEmpty.classList.remove("hidden");
      if (draftShowMoreContainer) {
        draftShowMoreContainer.classList.add("hidden");
        draftShowMoreContainer.classList.remove("flex");
      }
    } else {
      if (draftEmpty) draftEmpty.classList.add("hidden");
      if (draftList) {
        const slicedDrafts = drafts.slice(0, draftLimit);
        draftList.innerHTML = slicedDrafts
          .map((item) => renderDraftItem(item))
          .join("");
      }
      if (draftShowMoreContainer) {
        if (drafts.length > draftLimit) {
          draftShowMoreContainer.classList.remove("hidden");
          draftShowMoreContainer.classList.add("flex");
        } else {
          draftShowMoreContainer.classList.add("hidden");
          draftShowMoreContainer.classList.remove("flex");
        }
      }
    }

    // Toggle right panels based on status filter
    const rightApproved = document.getElementById("right-panel-approved");
    const rightRejected = document.getElementById("right-panel-rejected");

    if (outputStatusFilter === "rejected") {
      if (rightApproved) {
        rightApproved.classList.add("hidden");
        rightApproved.classList.remove("flex");
      }
      if (rightRejected) {
        rightRejected.classList.remove("hidden");
        rightRejected.classList.add("flex");
      }
      // Render rejected grid
      const rejectedGrid = document.getElementById("rejected-grid");
      const rejectedEmpty = document.getElementById("rejected-empty");
      const rejectedCount = document.getElementById("rejected-count");
      if (rejectedCount) rejectedCount.textContent = rejected.length;
      if (rejected.length === 0) {
        if (rejectedGrid) rejectedGrid.innerHTML = "";
        if (rejectedEmpty) rejectedEmpty.classList.remove("hidden");
      } else {
        if (rejectedEmpty) rejectedEmpty.classList.add("hidden");
        if (rejectedGrid)
          rejectedGrid.innerHTML = renderApprovedGrid(rejected, true);
      }
    } else {
      if (rightApproved) {
        rightApproved.classList.remove("hidden");
        rightApproved.classList.add("flex");
      }
      if (rightRejected) {
        rightRejected.classList.add("hidden");
        rightRejected.classList.remove("flex");
      }
      // Render Approved Panel
      const approvedGrid = document.getElementById("approved-grid");
      const approvedEmpty = document.getElementById("approved-empty");
      const approvedCount = document.getElementById("approved-count");
      if (approvedCount) approvedCount.textContent = approved.length;
      if (approved.length === 0) {
        if (approvedGrid) approvedGrid.innerHTML = "";
        if (approvedEmpty) approvedEmpty.classList.remove("hidden");
      } else {
        if (approvedEmpty) approvedEmpty.classList.add("hidden");
        if (approvedGrid) approvedGrid.innerHTML = renderApprovedGrid(approved);
      }
    }
  }

  function renderDraftItem(item) {
    const dateStr = formatRelativeDate(item.createdAt);
    const typeIconMap = {
      "Single Post": "ti-photo",
      Carousel: "ti-carousel-horizontal",
      "Ad Creatives": "ti-speakerphone",
      Story: "ti-device-mobile",
    };
    const typeIcon = typeIconMap[item.contentType] || "ti-file";

    return `
    <div class="group flex items-start gap-3 p-3 rounded-xl bg-white border border-[#eaecf0] hover:border-[#2563EB] hover:shadow-sm transition-all cursor-pointer" onclick="openPreviewModal('${item.id}')">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#FEF3C7] to-[#FDE68A] flex items-center justify-center shrink-0 relative">
        <i class="ti ${typeIcon} text-[16px] text-[#B45309]"></i>
      </div>
      <div class="flex-1 min-w-0 space-y-1">
        <p class="text-[12px] font-bold text-[#111827] truncate leading-tight">${escapeHtml(item.automationName)}</p>
        <div class="flex items-center gap-1.5">
          <span class="px-1.5 py-0.5 rounded-md bg-[#F3F4F6] text-[10px] font-medium text-[#667085]">${escapeHtml(item.brand)}</span>
          <span class="text-[10px] text-[#98a2b3]">${dateStr}</span>
        </div>
      </div>
    </div>
  `;
  }

  function renderApprovedGrid(items, isRejected = false) {
    const sorted = [...items].sort(
      (a, b) => new Date(b.createdAt) - new Date(a.createdAt),
    );

    const typeIconMap = {
      "Single Post": "ti-photo",
      Carousel: "ti-carousel-horizontal",
      "Ad Creatives": "ti-speakerphone",
      Story: "ti-device-mobile",
    };

    const brandGradients = {
      "Fresh Juice Co.": "from-[#34D399] to-[#059669]",
      "Tech Startup": "from-[#60A5FA] to-[#2563EB]",
      "Luxe Beauty": "from-[#F472B6] to-[#DB2777]",
    };

    return sorted
      .map((item) => {
        const typeIcon = typeIconMap[item.contentType] || "ti-file";
        const dateStr = formatRelativeDate(item.createdAt);
        const brandGrad =
