  function openPreviewModal(genId) {
    previewingContentId = genId;
    
    // If the modal is currently hidden, this is a fresh entry point. Reset iteration history.
    const pm = document.getElementById("modal-preview");
    if (pm && pm.classList.contains("hidden")) {
        sessionApprovedIds = [];
    }

    const item = generatedContent.find((g) => g.id === genId);
    if (!item) return;

    const statusConfig = {
      draft: {
        bg: "bg-[#F3F4F6]",
        text: "text-[#344054]",
        border: "border-[#D0D5DD]",
        label: "Draft",
      },
      approved: {
        bg: "bg-[#F3F4F6]",
        text: "text-[#111827]",
        border: "border-[#D0D5DD]",
        label: "Approved",
      },
      rejected: {
        bg: "bg-[#F3F4F6]",
        text: "text-[#344054]",
        border: "border-[#D0D5DD]",
        label: "Rejected",
      },
      scheduled: {
        bg: "bg-[#F3F4F6]",
        text: "text-[#111827]",
        border: "border-[#D0D5DD]",
        label: "Scheduled",
      },
      published: {
        bg: "bg-[#111827]",
        text: "text-white",
        border: "border-[#111827]",
        label: "Published",
      },
    };
    const cfg = statusConfig[item.status] || statusConfig.draft;

    // Header
    const titleHeader = document.getElementById("preview-title-header");
    const statusBadge = document.getElementById("preview-status-badge");
    const draftCounter = document.getElementById("preview-draft-counter");
    if (titleHeader) titleHeader.textContent = item.title;
    if (statusBadge) {
      statusBadge.className = `inline-flex items-center px-2 h-5 rounded-full text-[10px] font-bold ${cfg.bg} ${cfg.text} border ${cfg.border}`;
      statusBadge.textContent = cfg.label;
    }
    // Draft counter: show for draft items with automation group
    if (draftCounter) {
      if (item.status === "draft" && item.automationName) {
        const groupDrafts = generatedContent.filter(
          (g) =>
            g.automationName === item.automationName && g.status === "draft",
        );
        const currentIndex = groupDrafts.findIndex((g) => g.id === item.id);
        const position = currentIndex >= 0 ? currentIndex + 1 : 1;
        draftCounter.textContent = `${position} of ${groupDrafts.length}`;
        draftCounter.classList.remove("hidden");
      } else {
        draftCounter.classList.add("hidden");
      }
    }

    // Image - set aspect ratio based on type
    const imgContainer = document.getElementById("preview-image-container");
    const isStory = item.contentType === "Story";
    const isCarousel = item.contentType === "Carousel";
    previewCarouselTotal = item.carouselSlides || 1;
    previewCarouselIndex = 0;

    if (imgContainer) {
      imgContainer.className = `w-full ${isStory ? "aspect-[9/16]" : "aspect-[3/4]"} flex items-center justify-center relative`;
      const sizeLabel = isStory ? "1080 × 1920" : "1080 × 1350";
      imgContainer.innerHTML = `
        <div class="text-center space-y-2">
          <i class="ti ${isCarousel ? "ti-carousel-horizontal" : "ti-photo"} text-[40px] text-[#4B5563]"></i>
          <p class="text-[11px] text-[#6B7280]">${sizeLabel}</p>
        </div>
      `;
    }

    // Carousel controls
    updateCarouselControls();

    // Caption
    const captionInput = document.getElementById("preview-caption-input");
    if (captionInput) {
      captionInput.value = item.caption || "";
      originalCaption = item.caption || "";
    }
    const saveBtn = document.getElementById("btn-save-caption");
    if (saveBtn) saveBtn.classList.add("hidden");

    // Meta
    const platformEl = document.getElementById("preview-platform");
    const typeEl = document.getElementById("preview-type");
    const brandEl = document.getElementById("preview-brand");
    const pillarEl = document.getElementById("preview-pillar");
    if (platformEl) platformEl.textContent = item.platform || "-";
    if (typeEl) typeEl.textContent = item.contentType;
    if (brandEl) brandEl.textContent = item.brand;
    if (pillarEl) pillarEl.textContent = item.pillar || "-";

    // Right tabs (show for approved/scheduled/published, hide for draft/rejected)
    const rightTabs = document.getElementById("preview-right-tabs");
    const engagementAction = document.getElementById(
      "preview-engagement-action",
    );
    if (
      item.status === "approved" ||
      item.status === "scheduled" ||
      item.status === "published"
    ) {
      if (rightTabs) rightTabs.classList.remove("hidden");
      if (engagementAction) {
        engagementAction.classList.remove("hidden");
        // Update engagement indicator
        const indicator = document.getElementById(
          "preview-engagement-indicator",
        );
        if (indicator) {
          const eng = item.autoEngagement || {};
          const isActive = Object.values(eng).some((v) => v);
          indicator.classList.toggle("hidden", !isActive);
          indicator.classList.toggle("flex", isActive);
        }
      }
      switchPreviewTab("content");
    } else {
      if (rightTabs) rightTabs.classList.add("hidden");
      if (engagementAction) engagementAction.classList.add("hidden");
    }

    // Performance tab data
    const perfEmpty = document.getElementById("preview-performance-empty");
    const perfData = document.getElementById("preview-performance-data");
    if (item.status === "published") {
      if (perfEmpty) perfEmpty.classList.add("hidden");
      if (perfData) perfData.classList.remove("hidden");
      const reachEl = document.getElementById("preview-reach");
      const engagementRateEl = document.getElementById(
        "preview-engagement-rate",
      );
      const savesEl = document.getElementById("preview-saves");
      const profileVisitsEl = document.getElementById("preview-profile-visits");
      const sharesEl = document.getElementById("preview-shares");
      const followsEl = document.getElementById("preview-follows");
      if (reachEl) reachEl.textContent = item.views || 0;
      if (engagementRateEl)
        engagementRateEl.textContent = item.engagementRate + "%";
      if (savesEl) savesEl.textContent = item.saves || 0;
      if (profileVisitsEl)
        profileVisitsEl.textContent = item.profileVisits || 0;
      if (sharesEl) sharesEl.textContent = item.shares || 0;
      if (followsEl) followsEl.textContent = item.follows || 0;
    } else {
      if (perfEmpty) perfEmpty.classList.remove("hidden");
      if (perfData) perfData.classList.add("hidden");
    }

    // Actions - show correct footer
    const actions = document.getElementById("preview-actions");
    const approvedActions = document.getElementById("preview-approved-actions");
    const rejectedActions = document.getElementById("preview-rejected-actions");
    const rejectAlert = document.getElementById("preview-reject-alert");
    if (actions) actions.classList.add("hidden");
    if (approvedActions) approvedActions.classList.add("hidden");
    if (rejectedActions) rejectedActions.classList.add("hidden");
    if (rejectAlert) rejectAlert.classList.add("hidden");

    if (item.status === "draft") {
      if (actions) {
        actions.classList.remove("hidden");
        actions.classList.add("flex");
      }
      if (rejectAlert) {
        rejectAlert.classList.remove("hidden");
        rejectAlert.classList.add("flex");
      }
    } else if (item.status === "approved") {
      if (approvedActions) {
        approvedActions.classList.remove("hidden");
        approvedActions.classList.add("flex");
      }
    } else if (item.status === "rejected") {
      if (rejectedActions) {
        rejectedActions.classList.remove("hidden");
        rejectedActions.classList.add("flex");
      }
    }

    // Open modal
    const modal = document.getElementById("modal-preview");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
  }

  function updateCarouselControls() {
    const prevBtn = document.getElementById("preview-carousel-prev");
    const nextBtn = document.getElementById("preview-carousel-next");
    const badge = document.getElementById("preview-carousel-badge");
    if (previewCarouselTotal <= 1) {
      if (prevBtn) prevBtn.classList.add("hidden");
      if (nextBtn) nextBtn.classList.add("hidden");
      if (badge) badge.classList.add("hidden");
      return;
    }
    if (badge) {
      badge.classList.remove("hidden");
      badge.textContent = `${previewCarouselIndex + 1}/${previewCarouselTotal}`;
    }
    if (prevBtn) prevBtn.classList.toggle("hidden", previewCarouselIndex === 0);
    if (nextBtn)
      nextBtn.classList.toggle(
        "hidden",
        previewCarouselIndex === previewCarouselTotal - 1,
      );
  }

  function switchPreviewTab(tab) {
    const contentTab = document.getElementById("preview-content-tab");
    const perfTab = document.getElementById("preview-performance-tab");
    const tabContent = document.getElementById("preview-tab-content");
    const tabPerf = document.getElementById("preview-tab-performance");
    if (tab === "content") {
      if (contentTab) contentTab.classList.remove("hidden");
      if (perfTab) perfTab.classList.add("hidden");
      if (tabContent) {
        tabContent.classList.add("bg-white", "text-[#111827]", "shadow-sm");
        tabContent.classList.remove("text-[#667085]");
      }
      if (tabPerf) {
        tabPerf.classList.remove("bg-white", "text-[#111827]", "shadow-sm");
        tabPerf.classList.add("text-[#667085]");
      }
    } else {
      if (contentTab) contentTab.classList.add("hidden");
      if (perfTab) perfTab.classList.remove("hidden");
      if (tabPerf) {
        tabPerf.classList.add("bg-white", "text-[#111827]", "shadow-sm");
        tabPerf.classList.remove("text-[#667085]");
      }
      if (tabContent) {
        tabContent.classList.remove("bg-white", "text-[#111827]", "shadow-sm");
        tabContent.classList.add("text-[#667085]");
      }
    }
  }

  function closePreviewModal() {
    const modal = document.getElementById("modal-preview");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    previewingContentId = null;
  }

  function approveContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "approved";
    item.approvedAt = new Date().toISOString();
    saveGenerated();
    renderGenerated();

    // Track for summary
    if (!sessionApprovedIds.includes(item.id)) sessionApprovedIds.push(item.id);

    // Find next draft in same automation group
    const nextDraft = findNextDraftInGroup(item);
    if (nextDraft) {
      transitionToNextDraft(nextDraft);
    } else {
      // ALL DONE - Transmit to summary portal instead of closing!
      const groupName = item.automationName || "Review Group";
      showBatchApprovalSummary(groupName);
      showToast("Session Completed!");
    }
  }

  function rejectContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "rejected";
    item.rejectedAt = new Date().toISOString();
    saveGenerated();
    renderGenerated();

    // Find next draft in same automation group
    const nextDraft = findNextDraftInGroup(item);
    if (nextDraft) {
      transitionToNextDraft(nextDraft);
    } else {
      closePreviewModal();
      showToast("Content rejected. No more drafts in this group.");
    }
  }

  function findNextDraftInGroup(currentItem) {
    if (!currentItem.automationName) return null;
    const groupDrafts = generatedContent.filter(
      (g) =>
        g.automationName === currentItem.automationName &&
        g.status === "draft" &&
        g.id !== currentItem.id,
    );
    return groupDrafts.length > 0 ? groupDrafts[0] : null;
  }

  function transitionToNextDraft(nextItem) {
    const panel = document.getElementById("preview-panel");
    if (panel) {
      panel.classList.add("fade-out-slide");
      setTimeout(() => {
        panel.classList.remove("fade-out-slide");
        openPreviewModal(nextItem.id);
        panel.classList.add("fade-in-slide");
        setTimeout(() => panel.classList.remove("fade-in-slide"), 300);
      }, 300);
    } else {
      openPreviewModal(nextItem.id);
    }
  }

  function unapproveContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "draft";
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content moved back to draft.");
  }

  function recoverToDraft() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "draft";
    item.rejectedAt = null;
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content recovered to draft!");
  }

  function publishSingleNow() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "published";
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content published!");
  }

  function openBulkScheduleModalSingle() {
    openPreviewScheduleModal();
  }
  // ═══════════════════════════════════════════
  // BATCH APPROVAL SUMMARY MODULE
  // ═══════════════════════════════════════════
  function showBatchApprovalSummary(groupTitle) {
    // Pull actual objects for relevant IDs from session memory
    const approvedItems = generatedContent.filter(g => sessionApprovedIds.includes(g.id));
    
    closePreviewModal(); // Ensure clean exit of current view
    
    const gName = document.getElementById("summary-group-name");
    const countNum = document.getElementById("summary-count");
    if (gName) gName.textContent = groupTitle;
    if (countNum) countNum.textContent = approvedItems.length;

    const gridEl = document.getElementById("summary-grid");
    if (gridEl) {
       if (approvedItems.length === 0) {
          gridEl.innerHTML = `<div class="col-span-4 text-center py-12 text-[#98A2B3] font-medium">No new items available to display.</div>`;
       } else {
          gridEl.innerHTML = approvedItems.map(item => {
             const isStory = item.contentType === "Story";
             const typeIco = (item.contentType === "Carousel") ? "ti-carousel-horizontal" : "ti-photo";
             const aspectClass = isStory ? "aspect-[9/16]" : "aspect-[3/4]";
             
             return `
               <div class="inline-block w-full break-inside-avoid mb-4">
                 <label class="relative flex flex-col gap-2.5 bg-white border border-[#eaecf0] rounded-[24px] p-2.5 cursor-pointer group hover:border-[#2563EB] hover:shadow-md transition-all select-none ring-2 ring-[#2563EB]/20">
                     <!-- Checkbox and image wrapper -->
                     <div class="relative w-full ${aspectClass} rounded-[16px] bg-[#1f2937] flex items-center justify-center overflow-hidden shrink-0 shadow-inner">
                         <input type="checkbox" value="${item.id}" checked class="summary-item-check sr-only peer" onchange="updateSummarySelectedCount(); this.closest('label').classList.toggle('ring-2', this.checked); this.closest('label').classList.toggle('ring-[#2563EB]/20', this.checked);" />
                         
                         <div class="absolute top-2.5 right-2.5 w-[20px] h-[20px] rounded-[6px] bg-black/20 backdrop-blur-md border border-white/40 flex items-center justify-center transition-all peer-checked:bg-[#2563EB] peer-checked:border-transparent z-20 shadow-sm peer-checked:[&_i]:opacity-100">
                            <i class="ti ti-check text-[12px] text-white opacity-0 transition-opacity"></i>
                         </div>

                         <div class="opacity-30 group-hover:opacity-60 transition-opacity duration-300">
                            <i class="ti ${typeIco} text-[32px] text-white"></i>
                         </div>
                     </div>
                     <div class="px-1 pb-1 flex flex-col gap-1">
                         <p class="text-[11px] font-bold text-[#111827] leading-snug line-clamp-2" title="${escapeHtml(item.title)}">${escapeHtml(item.title || "Untitled Content")}</p>
                         <div class="flex items-center gap-1 px-1.5 h-5 w-fit rounded-full bg-[#F3F4F6] text-[9px] font-bold text-[#667085] border border-[#E5E7EB] mt-0.5">
                            <i class="ti ${typeIco} text-[10px]"></i>
                            <span class="uppercase tracking-wider">${item.contentType}</span>
                         </div>
                     </div>
                 </label>
               </div>
             `;
          }).join("");
       }
    }
    
    // Initial setup for selection counters
    updateSummarySelectedCount();

    const sumModal = document.getElementById("modal-approval-summary");
    if (sumModal) {
       sumModal.classList.remove("hidden");
       sumModal.classList.add("flex");
    }
  }

  window.updateSummarySelectedCount = function() {
      const count = document.querySelectorAll(".summary-item-check:checked").length;
      const countEl = document.getElementById("summary-count");
      if (countEl) countEl.textContent = count;
  };

  function getSummaryCheckedIds() {
     const boxes = document.querySelectorAll(".summary-item-check:checked");
     return Array.from(boxes).map(b => b.value);
  }

  function closeSummaryPortal() {
      const sumModal = document.getElementById("modal-approval-summary");
      if (sumModal) {
         sumModal.classList.add("hidden");
         sumModal.classList.remove("flex");
      }
      sessionApprovedIds = []; // Safe reset upon final closure
  }
  
  function initSummaryFeatureEvents() {
     const selectAll = document.getElementById("summary-select-all");
     if (selectAll) {
         selectAll.checked = true;
         selectAll.addEventListener("change", (e) => {
             document.querySelectorAll(".summary-item-check").forEach(cb => {
                 cb.checked = e.target.checked;
                 const lbl = cb.closest('label');
                 if (lbl) {
                     lbl.classList.toggle('ring-2', cb.checked);
                     lbl.classList.toggle('ring-[#2563EB]/20', cb.checked);
                 }
             });
             updateSummarySelectedCount();
         });
     }
     
     const btnLater = document.getElementById("summary-btn-later");
     const btnClose = document.getElementById("btn-close-summary");
     [btnLater, btnClose].forEach(btn => {
         if(btn) btn.addEventListener("click", closeSummaryPortal);
     });

     const btnPublish = document.getElementById("summary-btn-publish");
     if(btnPublish) {
         btnPublish.addEventListener("click", () => {
             const ids = getSummaryCheckedIds();
             if (ids.length === 0) return showToast("Please select items to publish.");
             
             ids.forEach(id => {
                 const itm = generatedContent.find(g => g.id === id);
                 if (itm) {
                     itm.status = "published";
                     itm.publishedAt = new Date().toISOString();
                 }
             });
             
             saveGenerated();
             renderGenerated();
             closeSummaryPortal();
             showToast(`🚀 Successfully published ${ids.length} item(s) directly!`);
         });
     }

     const btnSchedule = document.getElementById("summary-btn-schedule");
     if(btnSchedule) {
         btnSchedule.addEventListener("click", () => {
             const ids = getSummaryCheckedIds();
             if (ids.length === 0) return showToast("Please select items to schedule.");
             
             // Handover directly into system's existing Bulk system
             selectedApprovedIds = ids;
             closeSummaryPortal();
             // Standard system invoke
             if (typeof openBulkScheduleModal === 'function') openBulkScheduleModal();
         });
     }
  }


  function openPreviewScheduleModal() {
    if (!previewingContentId) return;
    selectedApprovedIds = [previewingContentId];

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const dateStr = tomorrow.toISOString().split("T")[0];

    const dateInput = document.getElementById("preview-schedule-date");
    const timeInput = document.getElementById("preview-schedule-time");
    if (dateInput) dateInput.value = dateStr;
    if (timeInput) timeInput.value = "08:00";

    closePreviewModal();
    const modal = document.getElementById("modal-preview-schedule");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
  }

  function closePreviewScheduleModal() {
    const modal = document.getElementById("modal-preview-schedule");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    selectedApprovedIds = [];
  }

  function confirmPreviewSchedule() {
    const itemId =
      selectedApprovedIds.length === 1
        ? selectedApprovedIds[0]
        : previewingContentId;
    if (!itemId) return;
    const item = generatedContent.find((g) => g.id === itemId);
    if (!item) return;

    const dateVal = document.getElementById("preview-schedule-date").value;
    const timeVal = document.getElementById("preview-schedule-time").value;
    if (!dateVal || !timeVal) {
      showToast("Please fill in date and time");
      return;
    }

    item.status = "scheduled";
    item.scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();

    saveGenerated();
    showToast("Content scheduled successfully!");
    selectedApprovedIds = [];
    updateBulkHeader();
    closePreviewScheduleModal();
    renderGenerated();
    renderScheduled();
  }

  function saveCaptionChanges() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const captionInput = document.getElementById("preview-caption-input");
    if (captionInput) {
      item.caption = captionInput.value;
      originalCaption = captionInput.value;
      saveGenerated();
      showToast("Caption saved!");
      const saveBtn = document.getElementById("btn-save-caption");
      if (saveBtn) saveBtn.classList.add("hidden");
    }
  }

  function openRegenerateModal() {
    const modal = document.getElementById("modal-regenerate");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
    const prompt = document.getElementById("regenerate-prompt");
    if (prompt) prompt.value = "";
  }

  function closeRegenerateModal() {
    const modal = document.getElementById("modal-regenerate");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  }

  function submitRegenerate() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    // Simulate regeneration
    const newCaptions = [
      "✨ Fresh new look for your feed! Drop a 🔥 if you love it #ContentCreation",
      "Making waves with this one 🌊 What do you think? Let us know below! #BrandNew",
      "Your daily dose of inspiration is here 💡 Save this for later! #ContentMarketing",
      "New content, who dis? 😎 Tag someone who needs to see this! #SocialMedia",
    ];
    const newCaption =
      newCaptions[Math.floor(Math.random() * newCaptions.length)];
    item.caption = newCaption;
    saveGenerated();
    const captionInput = document.getElementById("preview-caption-input");
    if (captionInput) {
      captionInput.value = newCaption;
      originalCaption = newCaption;
    }
    closeRegenerateModal();
    showToast("Caption regenerated!");
  }

  function openEngagementFromPreview() {
    if (!previewingContentId) return;
    editingAutomationId = previewingContentId;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    const eng = item.autoEngagement || {
      deleteComment: false,
      replyComment: false,
      likeComment: false,
      dmComment: false,
      replyStory: false,
      replyDm: false,
    };

    const delCb = document.getElementById("toggle-delete-comment");
    const repCb = document.getElementById("toggle-reply-comment");
    const likeCb = document.getElementById("toggle-like-comment");
    const dmCb = document.getElementById("toggle-dm-comment");
    const storyCb = document.getElementById("toggle-reply-story");
    const dmReplyCb = document.getElementById("toggle-reply-dm");

    if (delCb) delCb.checked = eng.deleteComment;
    if (repCb) repCb.checked = eng.replyComment;
    if (likeCb) likeCb.checked = eng.likeComment;
    if (dmCb) dmCb.checked = eng.dmComment;
    if (storyCb) storyCb.checked = eng.replyStory;
    if (dmReplyCb) dmReplyCb.checked = eng.replyDm;

    // Mark coming from preview & hide parent modal first
    engOpenedFromPreview = true;
    const prevModal = document.getElementById("modal-preview");
    if (prevModal) {
       prevModal.classList.add("hidden");
       prevModal.classList.remove("flex");
    }

    const modal = document.getElementById("modal-auto-engagement");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
  }

  // ═══════════════════════════════════════════
  // SINGLE SCHEDULE MODAL
  // ═══════════════════════════════════════════
  let singleScheduleEngagement = {};

  function openSingleScheduleModal() {
    if (selectedApprovedIds.length !== 1) return;
    const item = generatedContent.find((g) => g.id === selectedApprovedIds[0]);
    if (!item) return;

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const dateStr = tomorrow.toISOString().split("T")[0];

    document.getElementById("single-schedule-date").value = dateStr;
    document.getElementById("single-schedule-time").value = "08:00";

    // Load engagement settings for this item
    singleScheduleEngagement = item.autoEngagement
      ? { ...item.autoEngagement }
      : {};
    updateSingleScheduleEngagementIndicator();

    const modal = document.getElementById("modal-single-schedule");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  function closeSingleScheduleModal() {
    const modal = document.getElementById("modal-single-schedule");
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    singleScheduleEngagement = {};
  }

  function confirmSingleSchedule() {
    if (selectedApprovedIds.length !== 1) return;
    const item = generatedContent.find((g) => g.id === selectedApprovedIds[0]);
    if (!item) return;

    const dateVal = document.getElementById("single-schedule-date").value;
    const timeVal = document.getElementById("single-schedule-time").value;
    if (!dateVal || !timeVal) {
      showToast("Please fill in date and time");
      return;
    }

    item.status = "scheduled";
    item.scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();

    // Apply engagement settings if any were set
    if (Object.keys(singleScheduleEngagement).length > 0) {
      item.autoEngagement = { ...singleScheduleEngagement };
    }

    saveGenerated();
    showToast("Content scheduled successfully!");
    selectedApprovedIds = [];
    updateBulkHeader();
    closeSingleScheduleModal();
    renderGenerated();
    renderScheduled();
  }

  function openEngagementFromSingleSchedule() {
    if (selectedApprovedIds.length !== 1) return;
    const item = generatedContent.find((g) => g.id === selectedApprovedIds[0]);
    if (!item) return;
    // Temporarily set previewingContentId so engagement modal works
    previewingContentId = selectedApprovedIds[0];
    openCommentModal(selectedApprovedIds[0]);
  }

  function updateSingleScheduleEngagementIndicator() {
    const indicator = document.getElementById(
      "single-schedule-engagement-indicator",
    );
    if (!indicator) return;
    const isActive = Object.values(singleScheduleEngagement).some((v) => v);
    indicator.classList.toggle("hidden", !isActive);
  }

  // ═══════════════════════════════════════════
  // BULK SCHEDULE ENGAGEMENT
  // ═══════════════════════════════════════════
  let bulkScheduleEngagement = {};

  function openEngagementFromBulkSchedule() {
    if (selectedApprovedIds.length === 0) return;
    // Use the first selected item as the reference for engagement settings
    const firstId = selectedApprovedIds[0];
    const item = generatedContent.find((g) => g.id === firstId);
    if (!item) return;
    // Temporarily set previewingContentId so engagement modal works
    previewingContentId = firstId;
    openCommentModal(firstId);
  }

  function updateBulkScheduleEngagementIndicator() {
    const indicator = document.getElementById(
      "bulk-schedule-engagement-indicator",
    );
    if (!indicator) return;
    const isActive = Object.values(bulkScheduleEngagement).some((v) => v);
    indicator.classList.toggle("hidden", !isActive);
  }

  function openPreviewAutomation(autoId) {
    const auto = automations.find((a) => a.id === autoId);
    if (!auto) return;

    editingAutoId = auto.id;

    // Populate wizardData
    wizardData.name = auto.name;
    wizardData.dna = auto.dna;
    wizardData.recurring = auto.recurring;
    wizardData.selectedDates = JSON.parse(JSON.stringify(auto.selectedDates));

    // Set UI elements
    els.inputName.value = auto.name;
    els.dnaSelectedName.textContent = auto.dna
      ? auto.dna.name
      : "Select Business DNA";
    els.dnaSelectedDesc.textContent = auto.dna
      ? auto.dna.desc
      : "Choose a business profile for AI grounding";
    els.recurringRadios.forEach((r) => {
      r.checked = r.value === auto.recurring;
    });
    if (auto.recurring === "weekly") {
      els.weeklyRepeatWrapper.classList.remove("hidden");
      els.repeatForWrapper.classList.add("hidden");
    } else if (auto.recurring === "monthly") {
      els.weeklyRepeatWrapper.classList.add("hidden");
      els.repeatForWrapper.classList.remove("hidden");
    } else {
      els.weeklyRepeatWrapper.classList.add("hidden");
      els.repeatForWrapper.classList.add("hidden");
    }

    // Update labels and step
    currentStep = 1;
    const titleEl = document.getElementById("wizard-title");
    if (titleEl) titleEl.textContent = "Edit Automation";
    const btnStart = document.getElementById("btn-start-automation");
    if (btnStart) btnStart.textContent = "Save Changes";

    goToStep(1);
    renderCalendar();
    renderWeeklyCalendar();

    // Open modal
    els.modalAdd.classList.remove("hidden");
    els.modalAdd.classList.add("flex");
  }

  function closePreviewAutomation() {
    const modal = document.getElementById("modal-preview-automation");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  }

  // ═══════════════════════════════════════════
  // EDIT & DUPLICATE CONTENT
  // ═══════════════════════════════════════════
  function editAndDuplicateContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    // Create a duplicate as new draft
    const newItem = {
      ...item,
      id: "gen_" + Date.now(),
      status: "draft",
      scheduledAt: null,
      createdAt: new Date().toISOString(),
      title: item.title + " (Copy)",
    };

    generatedContent.push(newItem);
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content duplicated as new draft!");
  }

  // ═══════════════════════════════════════════
  // SCHEDULE MODAL
  // ═══════════════════════════════════════════
  function openScheduleModal() {
    if (!previewingContentId) return;
    // Set default to tomorrow at 9am
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    tomorrow.setHours(9, 0, 0, 0);
    els.scheduleDate.value = tomorrow.toISOString().split("T")[0];
    els.scheduleTime.value = "09:00";
    els.modalSchedule.classList.remove("hidden");
    els.modalSchedule.classList.add("flex");
  }

  function closeScheduleModalFn() {
    els.modalSchedule.classList.add("hidden");
    els.modalSchedule.classList.remove("flex");
  }

  function confirmSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const dateVal = els.scheduleDate.value;
    const timeVal = els.scheduleTime.value;
    if (dateVal && timeVal) {
      item.scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();
    }
    item.status = "scheduled";
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled successfully!");
  }

  function publishNow() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "scheduled";
    item.scheduledAt = new Date().toISOString();
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content will be published now!");
  }

  function publishIn1Hour() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const in1h = new Date(Date.now() + 60 * 60 * 1000);
    item.status = "scheduled";
    item.scheduledAt = in1h.toISOString();
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled for 1 hour from now!");
  }

  function cancelSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    if (!confirm("Cancel this scheduled upload?")) return;
    item.status = "approved";
    item.scheduledAt = null;
    saveGenerated();
    renderGenerated();
    renderScheduled();
    openPreviewModal(previewingContentId);
    showToast("Schedule cancelled.");
  }

  function rescheduleContent() {
    openScheduleModal();
  }

  // ═══════════════════════════════════════════
  // AUTO ENGAGEMENT MODAL
  // ═══════════════════════════════════════════
  function closeEngagementModalFn() {
    els.modalEngagement.classList.add("hidden");
    els.modalEngagement.classList.remove("flex");
    editingAutomationId = null;
  }

  function saveEngagement() {
    if (!editingAutomationId) return;
    const item = generatedContent.find((g) => g.id === editingAutomationId);
    if (!item) return;

    item.autoComment = {
      enabled: els.commentToggle.checked,
      text: els.commentText.value.trim(),
      link: els.commentLink.value.trim(),
      keywords: els.commentKeywords.value.trim(),
    };
    item.autoDm = {
      enabled: els.dmToggle.checked,
      text: els.dmText.value.trim(),
      link: els.dmLink.value.trim(),
      keywords: els.dmKeywords.value.trim(),
    };

    saveGenerated();
    renderGenerated();
    closeEngagementModalFn();
    showToast("Auto Engagement settings saved!");
  }

  function loadAutomations() {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) automations = JSON.parse(stored);
    } catch (e) {
      automations = [];
    }
  }

  function saveAutomations() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(automations));
  }

  // ═══════════════════════════════════════════
  // RENDER AUTOMATIONS TABLE
  // ═══════════════════════════════════════════
  function renderAutomations() {
    const activeCount = automations.filter((a) => a.status === "active").length;
    const scheduledCount = automations.filter(
      (a) => a.status === "paused",
    ).length;
    els.activeCount.textContent = activeCount;
    els.scheduledCount.textContent = scheduledCount;

    if (automations.length === 0) {
      els.emptyState.classList.remove("hidden");
      els.emptyState.classList.add(
        "flex",
        "flex-col",
        "items-center",
        "justify-center",
        "py-24",
      );
      els.table.classList.add("hidden");
      return;
    }

    els.emptyState.classList.add("hidden");
    els.emptyState.classList.remove(
      "flex",
      "flex-col",
      "items-center",
      "justify-center",
      "py-24",
    );
    els.table.classList.remove("hidden");

    els.tbody.innerHTML = automations
      .map((auto) => {
        const dateCount = Object.keys(auto.selectedDates).length;
        const contentTypes = [
          ...new Set(
            Object.values(auto.selectedDates)
              .flat()
              .map((s) => s.contentType),
          ),
        ];
        const typeLabels = contentTypes
          .map(
            (t) =>
              `<span class="inline-flex items-center gap-1 px-2 h-6 rounded-full bg-[#F9FAFB] border border-[#eaecf0] text-[11px] font-medium text-[#667085]">
                <i class="ti ${CONTENT_ICONS[t] || "ti-file"} text-[12px]"></i>
                ${t}
              </span>`,
          )
          .join("");

        return `
        <tr class="border-b border-[#eaecf0] hover:bg-[#F9FAFB] transition-colors group">
          <td class="px-5 py-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0">
                <i class="ti ti-brand-abstract text-[18px] text-[#667085]"></i>
              </div>
              <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.dna?.name || "-")}</span>
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.name)}</span>
          </td>
          <td class="px-5 py-4">
            <span class="text-[13px] text-[#667085]">${dateCount} tanggal · ${recurringLabel(auto.recurring)}</span>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-1.5 flex-wrap">
              ${typeLabels}
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="inline-flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]">
              <span class="w-1.5 h-1.5 rounded-full ${auto.status === "active" ? "bg-[#22C55E]" : "bg-[#F04438]"}"></span>
              ${auto.status === "active" ? "Active" : "Paused"}
            </span>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center justify-end gap-1">
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer"
                title="View details"
                onclick="openPreviewAutomation('${auto.id}')"
              >
                <i class="ti ti-eye text-[15px]"></i>
              </button>
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer"
                title="${auto.status === "active" ? "Pause automation" : "Resume automation"}"
                onclick="toggleAutomationStatus('${auto.id}')"
              >
                <i class="ti ${auto.status === "active" ? "ti-player-pause" : "ti-player-play"} text-[15px]"></i>
              </button>
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#FEF3F2] flex items-center justify-center text-[#667085] hover:text-[#D92D20] transition-colors cursor-pointer"
                title="Hapus automation"
                onclick="deleteAutomation('${auto.id}')"
              >
                <i class="ti ti-trash text-[15px]"></i>
              </button>
            </div>
          </td>
        </tr>
      `;
      })
      .join("");
  }

  function recurringLabel(value) {
    const labels = {
      once: "One Time Only",
      monthly: "Same Dates Every Month",
      weekly: "Same Days Every Week",
    };
    return labels[value] || value;
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function addAutomationRefTag(name) {
    const container = els.automationRefTags;
    if (!container) return;
    const tag = document.createElement("span");
    tag.className =
      "inline-flex items-center gap-1 px-2 h-6 rounded-full bg-white border border-[#D0D5DD] text-[11px] font-bold text-[#344054] shadow-sm";
    tag.innerHTML = `
      <span class="w-4 h-4 rounded-full bg-[#d1d5db] shrink-0"></span>
      <span class="truncate max-w-[120px]">${escapeHtml(name)}</span>
      <button class="flex items-center justify-center text-[#98a2b3] hover:text-[#d92d20] transition-colors"><i class="ti ti-x text-[12px]"></i></button>
    `;
    tag.querySelector("button").addEventListener("click", () => tag.remove());
    container.appendChild(tag);
  }

  // ═══════════════════════════════════════════
  // WIZARD NAVIGATION
  // ═══════════════════════════════════════════
  function goToStep(step) {
    currentStep = step;
    els.stepPanels.forEach((p) => p.classList.add("hidden"));
    document.getElementById(`step-${step}`).classList.remove("hidden");

    els.stepDots.forEach((dot) => {
      const num = parseInt(dot.dataset.step);
      const circle = dot.querySelector("div");
      const label = dot.querySelector("span");
      if (num === step) {
        circle.className =
          "w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#111827]";
      } else if (num < step) {
        circle.className =
          "w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#667085]";
      } else {
        circle.className =
          "w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#667085]";
      }
    });

    els.btnBack.classList.toggle("hidden", step === 1);
    els.btnNext.classList.toggle("hidden", step === 3);
    els.btnStart.classList.toggle("hidden", step !== 3);

    if (step === 3) {
      // Sync recurring radio availability with schedule mode from Step 2
      if (wizardData.scheduleMode === "weekly") {
        // Weekly mode in Step 2: enable Weekly radio option
        if (els.radioRecurringWeekly) {
          els.radioRecurringWeekly.disabled = false;
        }
        if (els.labelRecurringWeekly)
          els.labelRecurringWeekly.classList.remove("opacity-60");
        if (els.divRecurringWeekly)
          els.divRecurringWeekly.classList.remove("opacity-60");
        if (els.recurringModeInfo)
          els.recurringModeInfo.textContent =
            "Mode Weekly aktif. Pilih Weekly repetition untuk mengulang konten setiap minggu pada hari yang sama.";
      } else {
        // Monthly mode in Step 2: disable weekly radio
        if (els.radioRecurringWeekly) {
          els.radioRecurringWeekly.disabled = true;
          els.radioRecurringWeekly.checked = false;
        }
        if (els.labelRecurringWeekly)
          els.labelRecurringWeekly.classList.add("opacity-60");
        if (els.divRecurringWeekly)
          els.divRecurringWeekly.classList.add("opacity-60");
        if (els.recurringModeInfo)
          els.recurringModeInfo.textContent =
            "Weekly repetition dinonaktifkan karena mode Monthly dipilih di Step 2. Pilih One Time Only atau Monthly.";
        // If weekly was selected, switch to once
        if (wizardData.recurring === "weekly") {
          wizardData.recurring = "once";
          const onceRadio = document.querySelector(
            'input[name="recurring"][value="once"]',
          );
          if (onceRadio) onceRadio.checked = true;
        }
      }
      updateReview();
    }
  }

  function validateStep(step) {
    if (step === 1) {
      if (!wizardData.name.trim()) {
        showToast("Campaign name is required");
        return false;
      }
      if (!wizardData.dna) {
        showToast("Please select a Business DNA");
        return false;
      }
    }
    if (step === 2) {
      if (Object.keys(wizardData.selectedDates).length === 0) {
        showToast("Please select at least 1 date");
        return false;
      }
    }
    return true;
  }

  function updateReview() {
    els.reviewName.textContent = wizardData.name || "-";
    els.reviewDna.textContent = wizardData.dna?.name || "-";

    // Render recurring preview
    renderRecurringPreview();

    // Render schedule cards
    const dates = Object.keys(wizardData.selectedDates).sort();
    const monthNames = [
      "Jan",
      "Feb",
      "Mar",
      "Apr",
      "May",
      "Jun",
      "Jul",
      "Aug",
      "Sep",
      "Oct",
      "Nov",
      "Dec",
    ];

    if (dates.length === 0) {
      els.reviewScheduleCards.innerHTML = `<div class="col-span-2 text-center py-4 text-[12px] text-[#98a2b3]">No dates selected</div>`;
    } else {
      const grouped = {};
      dates.forEach((dk) => {
        const [y, m, d] = dk.split("-");
        const dayName = new Date(dk).toLocaleDateString("en-US", {
          weekday: "short",
        });
        const key = `${d} ${monthNames[parseInt(m) - 1]}`;
        if (!grouped[key]) {
          grouped[key] = { dayName, automations: [] };
        }
        wizardData.selectedDates[dk].forEach((slot) => {
          grouped[key].automations.push(slot);
        });
      });

      els.reviewScheduleCards.innerHTML = Object.entries(grouped)
        .map(
          ([dateLabel, data]) => `
        <div class="p-3 rounded-xl bg-white border border-[#eaecf0] space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-[12px] font-bold text-[#111827]">${dateLabel}</span>
            <span class="text-[10px] text-[#667085]">${data.dayName}</span>
          </div>
          <div class="space-y-1.5">
            ${data.automations
              .map(
                (a) => `
              <div class="flex items-center gap-2">
                <i class="ti ${CONTENT_ICONS[a.contentType] || "ti-file"} text-[12px] text-[#667085]"></i>
                <span class="text-[11px] text-[#667085]">${a.contentType}${a.category ? " · " + escapeHtml(a.category) : ""}${a.variations > 1 ? " · " + a.variations + "x" : ""}</span>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `,
        )
        .join("");
    }

    // Update footer credit — Single Post & Story counts as 2
    // For recurring (monthly/weekly), multiply by repeat count
    const baseVariations = Object.values(wizardData.selectedDates).reduce(
      (total, slots) => {
        return (
          total +
          slots.reduce((sum, s) => {
            const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
            return sum + (s.variations || 1) * multiplier;
          }, 0)
        );
      },
      0,
    );
    const recurringMultiplier =
      wizardData.recurring === "monthly" || wizardData.recurring === "weekly"
        ? wizardData.repeatFor || 1
        : 1;
    els.footerCredit.textContent = baseVariations * recurringMultiplier;

    // Update selected dates count label
    if (els.selectedDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }
  }

  // ═══════════════════════════════════════════
  // RECURRING PREVIEW
  // ═══════════════════════════════════════════
  function renderRecurringPreview() {
    const isMonthly = wizardData.recurring === "monthly";
    const isWeekly = wizardData.recurring === "weekly";

    els.repeatForWrapper.classList.toggle("hidden", !isMonthly && !isWeekly);
    els.weeklyRepeatWrapper.classList.toggle("hidden", !isWeekly);
    els.recurringPreview.classList.toggle("hidden", !isMonthly && !isWeekly);

    if (!isMonthly && !isWeekly) {
      els.recurringInfo.textContent =
        "Content will be generated once on selected dates.";
      return;
    }

    const selectedDateKeys = Object.keys(wizardData.selectedDates).sort();
    if (selectedDateKeys.length === 0) {
      els.recurringPreviewGrid.innerHTML = "";
      return;
    }

    const monthNames = [
      "Jan",
      "Feb",
      "Mar",
      "Apr",
      "May",
      "Jun",
      "Jul",
      "Aug",
      "Sep",
      "Oct",
      "Nov",
      "Dec",
    ];
    const dayNames = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];

    // Parse first date reliably
    const [fy, fm, fd] = selectedDateKeys[0].split("-").map(Number);
    const firstDate = new Date(fy, fm - 1, fd);
    const repeatCount = parseInt(wizardData.repeatFor) || 3;
    let previewHTML = "";

    if (isMonthly) {
      els.recurringInfo.textContent =
        "Selected dates will repeat every month. If a date doesn't exist in a month, it will be scheduled on the last day of that month.";

      const selectedDays = selectedDateKeys.map((dk) =>
        parseInt(dk.split("-")[2]),
      );

      for (let i = 1; i <= repeatCount; i++) {
        const previewMonth = new Date(
          firstDate.getFullYear(),
          firstDate.getMonth() + i,
          1,
        );
        const monthLabel = monthNames[previewMonth.getMonth()];
        const yearLabel = previewMonth.getFullYear();

        const datePills = selectedDays
          .map((day) => {
            const daysInMonth = new Date(
              previewMonth.getFullYear(),
              previewMonth.getMonth() + 1,
              0,
            ).getDate();
            const actualDay = Math.min(day, daysInMonth);
            const dateObj = new Date(
              previewMonth.getFullYear(),
              previewMonth.getMonth(),
              actualDay,
            );
            const dow = dayNames[dateObj.getDay()];

            return `
            <div class="flex flex-col items-center gap-0.5">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#EFF6FF] border border-[#dbeafe] text-[11px] font-bold text-[#2563EB]">
                ${actualDay}
              </span>
              <span class="text-[9px] text-[#98a2b3]">${dow}</span>
            </div>
          `;
          })
          .join("");

        previewHTML += `
          <div class="p-2.5 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] space-y-1.5">
            <div class="text-[11px] font-bold text-[#111827] text-center">${monthLabel} ${yearLabel}</div>
            <div class="flex flex-wrap items-center justify-center gap-1.5">
              ${datePills}
            </div>
          </div>
        `;
      }
    } else if (isWeekly) {
      // Get unique day-of-week from selected dates
      const selectedDays = new Set();
      const fullDayNames = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ];
      selectedDateKeys.forEach((dk) => {
        const d = new Date(dk);
        selectedDays.add(d.getDay());
      });
      const sortedDays = Array.from(selectedDays).sort((a, b) => a - b);
      const dayNamesList = sortedDays.map((d) => fullDayNames[d]).join(", ");

      els.recurringInfo.textContent = `Content will repeat every week on ${dayNamesList}.`;

      // Update weekly days info box
      if (els.weeklyDaysInfo) {
        els.weeklyDaysInfo.textContent = `Every ${dayNamesList}`;
      }

      // Generate weekly preview: show next N weeks
      // Find the Sunday of the week containing the first selected date
      const firstSelectedDate = new Date(selectedDateKeys[0]);
      const firstWeekSunday = new Date(firstSelectedDate);
      firstWeekSunday.setDate(
        firstWeekSunday.getDate() - firstWeekSunday.getDay(),
      );
      firstWeekSunday.setHours(0, 0, 0, 0);

      for (let i = 1; i <= repeatCount; i++) {
        const weekStart = new Date(firstWeekSunday);
        weekStart.setDate(weekStart.getDate() + i * 7);
        const weekLabelStart = weekStart.toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
        });
        const weekEnd = new Date(weekStart);
        weekEnd.setDate(weekEnd.getDate() + 6);
        const weekLabelEnd = weekEnd.toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
        });

        // Find matching dates in this week
        const weekDatePills = [];
        sortedDays.forEach((dow) => {
          const matchDate = new Date(weekStart);
          matchDate.setDate(matchDate.getDate() + dow);
          const actualDay = matchDate.getDate();
          const dowShort = dayNames[matchDate.getDay()];
          weekDatePills.push(`
            <div class="flex flex-col items-center gap-0.5">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#EFF6FF] border border-[#dbeafe] text-[11px] font-bold text-[#2563EB]">
                ${actualDay}
              </span>
              <span class="text-[9px] text-[#98a2b3]">${dowShort}</span>
            </div>
          `);
        });

        previewHTML += `
          <div class="p-2.5 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] space-y-1.5">
            <div class="text-[11px] font-bold text-[#111827] text-center">Week ${i} · ${weekLabelStart} – ${weekLabelEnd}</div>
            <div class="flex flex-wrap items-center justify-center gap-1.5">
              ${weekDatePills.join("")}
            </div>
          </div>
        `;
      }
    }

    els.recurringPreviewGrid.innerHTML = previewHTML;
  }

  // ═══════════════════════════════════════════
  // AI SUGGESTION
  // ═══════════════════════════════════════════
  function applyAiSuggestion() {
    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    // Strategy: pick ~8-10 dates, avoid weekends, space ~3-4 days apart
    const suggestedDates = [];
    let lastPicked = 0;
    const minGap = 3;
    const maxGap = 5;

    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(year, month, day);
      const dayOfWeek = date.getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
      const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

      // Skip weekends and already selected dates
      if (isWeekend || wizardData.selectedDates[dateKey]) continue;

      // Pick first available weekday
      if (suggestedDates.length === 0) {
        suggestedDates.push(dateKey);
        lastPicked = day;
        continue;
      }

      const gap = day - lastPicked;
      if (gap >= minGap && gap <= maxGap) {
        suggestedDates.push(dateKey);
        lastPicked = day;
      }

      // Stop once we have enough
      if (suggestedDates.length >= 10) break;
    }

    // Fill remaining if we didn't get enough (relax gap constraint)
    if (suggestedDates.length < 8) {
      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day);
        const dayOfWeek = date.getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

        if (
          isWeekend ||
          wizardData.selectedDates[dateKey] ||
          suggestedDates.includes(dateKey)
        )
          continue;

        suggestedDates.push(dateKey);
        if (suggestedDates.length >= 8) break;
      }
    }

    // Add default automation to each suggested date
    suggestedDates.forEach((dateKey) => {
      if (!wizardData.selectedDates[dateKey]) {
        wizardData.selectedDates[dateKey] = [];
      }
      wizardData.selectedDates[dateKey].push({
        contentType: "Single Post",
        category: "",
        prompt: "",
        variations: 1,
      });
    });

    renderCalendar();
    showToast(`AI added ${suggestedDates.length} optimal posting dates!`);
  }

  // ═══════════════════════════════════════════
  // AI SUGGESTION WEEKLY
  // ═══════════════════════════════════════════
  function applyAiSuggestionWeekly() {
    const weekStart = new Date(wizardData.currentWeekDate);
    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
    weekStart.setHours(0, 0, 0, 0);

    const suggestedDates = [];
    for (let i = 1; i <= 5; i++) {
      const weekDate = new Date(weekStart);
      weekDate.setDate(weekDate.getDate() + i);
      const dayOfWeek = weekDate.getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
      const dateKey = `${weekDate.getFullYear()}-${String(weekDate.getMonth() + 1).padStart(2, "0")}-${String(weekDate.getDate()).padStart(2, "0")}`;

      if (isWeekend || wizardData.selectedDates[dateKey]) continue;
      suggestedDates.push(dateKey);
    }

    suggestedDates.forEach((dateKey) => {
      if (!wizardData.selectedDates[dateKey]) {
        wizardData.selectedDates[dateKey] = [];
      }
      wizardData.selectedDates[dateKey].push({
        contentType: "Single Post",
        category: "",
        prompt: "",
        variations: 1,
      });
    });

    renderWeeklyCalendar();
    showToast(`AI added ${suggestedDates.length} optimal posting dates!`);
  }

  // ═══════════════════════════════════════════
  // CALENDAR
  // ═══════════════════════════════════════════
  function renderCalendar() {
    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();
    const monthNames = [
      "January",
      "February",
      "March",
      "April",
      "May",
      "June",
      "July",
      "August",
      "September",
      "October",
      "November",
      "December",
    ];
    els.calMonthYear.textContent = `${monthNames[month]} ${year}`;

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    let html = "";
    // Empty cells before first day
    for (let i = 0; i < firstDay; i++) {
      html += "<div></div>";
    }
    // Days
    for (let day = 1; day <= daysInMonth; day++) {
      const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      const isSelected = wizardData.selectedDates[dateKey];
      const hasSlots = isSelected && isSelected.length > 0;
      const slotCount = hasSlots ? isSelected.length : 0;
      const isWeekend = [0, 6].includes(new Date(year, month, day).getDay());
      const totalVariations = isSelected
        ? isSelected.reduce((sum, s) => {
            const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
            return sum + (s.variations || 1) * multiplier;
          }, 0)
        : 0;

      html += `
        <button
          class="cal-day relative w-full aspect-square rounded-lg flex flex-col items-center justify-center text-[12px] font-medium transition-all cursor-pointer
            ${isSelected ? "bg-[#111827] text-white" : isWeekend ? "text-[#D92D20] hover:bg-[#FEF3F2]" : "text-[#111827] hover:bg-[#F9FAFB]"}"
          data-date="${dateKey}"
        >
          <span>${day}</span>
          ${
            isSelected
              ? `
            <span class="cal-counter absolute -top-2 -right-2 w-7 h-7 rounded-full bg-[#2563EB] text-white text-[11px] font-bold flex items-center justify-center gap-0.5 shadow-sm hover:bg-[#1d4ed8] transition-colors cursor-pointer" data-date="${dateKey}">
              ${totalVariations}
              <i class="ti ti-chevron-right text-[9px]"></i>
            </span>
          `
              : ""
          }
        </button>
      `;
    }
    els.calGrid.innerHTML = html;

    // Update monthly selected dates count
    if (els.selectedDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }

    // Calendar day clicks
    els.calGrid.querySelectorAll(".cal-day").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const dateKey = btn.dataset.date;
        // If clicking the counter badge, open detail dropdown
        if (e.target.closest(".cal-counter")) {
          e.stopPropagation();
          openDateDetailPopover(dateKey, btn);
        } else if (wizardData.selectedDates[dateKey]?.length > 0) {
          // Date has automations - open detail dropdown
          openDateDetailPopover(dateKey, btn);
        } else {
          // Empty date - open form popover
          openAutomationPopover(dateKey, btn);
        }
      });
    });
  }

  // ═══════════════════════════════════════════
  // WEEKLY CALENDAR
  // ═══════════════════════════════════════════
  function renderWeeklyCalendar() {
    const weekStart = new Date(wizardData.currentWeekDate);
    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
    weekStart.setHours(0, 0, 0, 0);

    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 6);
    weekEnd.setHours(23, 59, 59, 999);

    els.calWeekLabel.textContent = `${weekStart.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${weekEnd.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    let html = "";
    const dayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    for (let i = 0; i < 7; i++) {
      const dayDate = new Date(weekStart);
      dayDate.setDate(dayDate.getDate() + i);
      const isToday = dayDate.toDateString() === new Date().toDateString();
      const isPast = dayDate < today;
      const isWeekend = i === 0 || i === 6;
      const dateKey = `${dayDate.getFullYear()}-${String(dayDate.getMonth() + 1).padStart(2, "0")}-${String(dayDate.getDate()).padStart(2, "0")}`;
      const isSelected = wizardData.selectedDates[dateKey];
      const hasSlots = isSelected && isSelected.length > 0;
      const totalVariations = isSelected
        ? isSelected.reduce((sum, s) => {
            const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
            return sum + (s.variations || 1) * multiplier;
          }, 0)
        : 0;

      html += `
        <button
          class="cal-day relative w-full aspect-square rounded-lg flex flex-col items-center justify-center text-[12px] font-medium transition-all cursor-pointer
            ${isSelected ? "bg-[#111827] text-white" : isWeekend ? "text-[#D92D20] hover:bg-[#FEF3F2]" : "text-[#111827] hover:bg-[#F9FAFB]"}"
          data-date="${dateKey}"
        >
          <span>${dayDate.getDate()}</span>
          ${
            isSelected
              ? `
            <span class="cal-counter absolute -top-2 -right-2 w-7 h-7 rounded-full bg-[#2563EB] text-white text-[11px] font-bold flex items-center justify-center gap-0.5 shadow-sm hover:bg-[#1d4ed8] transition-colors cursor-pointer" data-date="${dateKey}">
              ${totalVariations}
              <i class="ti ti-chevron-right text-[9px]"></i>
            </span>
          `
              : ""
          }
        </button>
      `;
    }

    els.calWeekGrid.innerHTML = html;

    // Update weekly selected dates count
    if (els.selectedWeeklyDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedWeeklyDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }

    // Calendar day clicks
    els.calWeekGrid.querySelectorAll(".cal-day").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const dateKey = btn.dataset.date;
        if (e.target.closest(".cal-counter")) {
          e.stopPropagation();
          openDateDetailPopover(dateKey, btn);
        } else if (wizardData.selectedDates[dateKey]?.length > 0) {
          openDateDetailPopover(dateKey, btn);
        } else {
          openAutomationPopover(dateKey, btn);
        }
      });
    });
  }

  // ═══════════════════════════════════════════
  // AUTOMATION POPOVER
  // ═══════════════════════════════════════════
  function openAutomationPopover(dateKey, targetBtn, editIndex = -1) {
    activePopoverDate = dateKey;
    const slots = wizardData.selectedDates[dateKey] || [];
    const [y, m, d] = dateKey.split("-");
    els.slotPopoverDate.textContent = `${d} ${["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][parseInt(m) - 1]} ${y}`;

    // If editing, populate fields
    if (editIndex >= 0 && slots[editIndex]) {
      const slot = slots[editIndex];
      els.slotContentType.value = slot.contentType;
      els.slotCategory.value = slot.category || "";
      els.slotPrompt.value = slot.prompt || "";
      els.automationVariations.value = slot.variations || 1;
      els.btnAddSlot.textContent = "Update Automation";
      els.btnAddSlot.dataset.editIndex = editIndex;
      if (els.contentTypeDesc) {
        els.contentTypeDesc.textContent =
          CONTENT_TYPE_DESCS[slot.contentType] || "";
      }
    } else {
      // Reset inputs
      els.slotContentType.value = "Single Post";
      els.slotCategory.value = "";
      els.slotPrompt.value = "";
      els.automationVariations.value = 1;
      els.btnAddSlot.textContent = "Add";
      els.btnAddSlot.dataset.editIndex = "";
      if (els.contentTypeDesc) {
        els.contentTypeDesc.textContent =
          CONTENT_TYPE_DESCS["Single Post"] || "";
      }
    }

    // Position popover to the right of the clicked button, vertically centered
    const rect = targetBtn.getBoundingClientRect();
    const popoverWidth = 288; // w-72 = 18rem = 288px
    const popoverHeight = 380;
    const gap = 12;

    // Default: place to the right
    let left = rect.right + gap;

    // If too far right, place to the left
    const viewportWidth = window.innerWidth;
    if (left + popoverWidth > viewportWidth - 16) {
      left = rect.left - popoverWidth - gap;
    }

    // Vertically center with the clicked button
    let top = rect.top + rect.height / 2 - popoverHeight / 2;

    // Keep within viewport (don't stick to top/bottom)
    if (top < 16) top = 16;
    if (top + popoverHeight > window.innerHeight - 16) {
      top = window.innerHeight - popoverHeight - 16;
    }

    els.slotPopover.style.left = `${left}px`;
    els.slotPopover.style.top = `${top}px`;
    els.slotPopover.classList.remove("hidden");

    // Update count
    const slotCount = slots.length;
    const totalVars = slots.reduce((sum, s) => sum + (s.variations || 1), 0);
    document.getElementById("automation-remaining").textContent =
      `${slotCount} automation${slotCount !== 1 ? "s" : ""} · ${totalVars} total`;
    els.btnAddSlot.disabled = false;
    els.btnAddSlot.style.opacity = "1";
  }

  function closeAutomationPopover() {
    els.slotPopover.classList.add("hidden");
    activePopoverDate = null;
  }

