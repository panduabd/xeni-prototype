  };

  function openManualSchedule() {
    const m = document.getElementById("modal-manual-schedule");
    if (m) {
      m.classList.remove("hidden");
      m.classList.add("flex");
    }
    document.body.style.overflow = "hidden";
    
    // Reset date to today
    const dateInput = document.getElementById("manual-schedule-date");
    const timeInput = document.getElementById("manual-schedule-time");
    if (dateInput && !dateInput.value) {
      const now = new Date();
      dateInput.value = now.toISOString().split("T")[0];
    }
    if (timeInput && !timeInput.value) {
       timeInput.value = "12:00";
    }
  }

  function closeManualSchedule() {
    const m = document.getElementById("modal-manual-schedule");
    if (m) {
      m.classList.add("hidden");
      m.classList.remove("flex");
    }
    document.body.style.overflow = "";
  }

  function rebuildManualAccountState() {
     const checkboxes = document.querySelectorAll(".manual-account-cb:checked");
     const badgeContainer = document.getElementById("selected-accounts-badges");
     const label = document.getElementById("manual-publish-label");
     
     badgeContainer.innerHTML = "";
     const selected = [];
     
     checkboxes.forEach(cb => {
        selected.push(cb.value);
        // create visual pill
        const labelTxt = cb.nextElementSibling.nextElementSibling.innerText;
        const iconClass = cb.nextElementSibling.className;
        
        const pill = document.createElement("div");
        pill.className = "inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-[#D0D5DD] rounded-full shadow-sm text-[12px] font-bold text-[#344054] hover:border-[#98a2b3] transition-all animate-in zoom-in-95 duration-150 group cursor-default";
        pill.innerHTML = `
          <i class="${iconClass} !text-[13px]"></i> 
          ${labelTxt}
          <button type="button" class="ml-0.5 w-4 h-4 rounded-full flex items-center justify-center text-[#98a2b3] hover:bg-[#F3F4F6] hover:text-[#EF4444] transition-colors cursor-pointer">
             <i class="ti ti-x text-[10px]"></i>
          </button>
        `;
        
        // Wire the Close Action handler
        const removeBtn = pill.querySelector("button");
        if (removeBtn) {
           removeBtn.addEventListener("click", (e) => {
              e.preventDefault();
              e.stopPropagation();
              cb.checked = false; // UNCHECK SOURCE
              rebuildManualAccountState(); // RE-TRIGGER SELF FOR TOTAL SYNC
              
              // Re-sync downstream logic
              if (typeof syncManualSimulator === 'function') {
                 syncManualSimulator();
              }
           });
        }
        
        badgeContainer.appendChild(pill);
     });
     
     manualScheduleState.platforms = selected;
     
     if (selected.length > 0) {
        label.textContent = `${selected.length} account(s) selected`;
        label.className = "text-[#111827] font-bold";
     } else {
        label.textContent = "Select destination accounts...";
        label.className = "text-[#98a2b3]";
     }
  }

  function initManualScheduleEvents() {
    const triggerBtn = document.getElementById("btn-open-manual-schedule");
    const modal = document.getElementById("modal-manual-schedule");
    const closeBtn = document.getElementById("btn-close-manual-schedule");
    const pubTrigger = document.getElementById("manual-publish-trigger");
    const pubDropdown = document.getElementById("manual-publish-dropdown");
    const dnaSelect = document.getElementById("manual-select-dna");
    const captionInput = document.getElementById("manual-caption-input");
    const confirmBtn = document.getElementById("btn-manual-confirm-schedule");

    if (triggerBtn)
      triggerBtn.addEventListener("click", () => openManualSchedule());
    if (closeBtn)
      closeBtn.addEventListener("click", () => closeManualSchedule());

    // Dna Watch
    if (dnaSelect) {
      dnaSelect.addEventListener("change", (e) => {
        manualScheduleState.dna = e.target.value;
      });
    }

    // Publish Multi-select toggle
    if (pubTrigger && pubDropdown) {
      pubTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        pubDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", () => {
        if (pubDropdown) pubDropdown.classList.add("hidden");
      });
      pubDropdown.addEventListener("click", (e) => e.stopPropagation());
    }

    // AI Prompt Modal Handlers
    const aiTriggerBtn = document.getElementById("btn-manual-ai-gen");
    const aiPromptModal = document.getElementById("manual-ai-prompt-modal");
    const aiCloseBtn = document.getElementById("btn-close-ai-prompt");
    const aiFinalGenBtn = document.getElementById("btn-manual-ai-generate-final");
    const aiPromptInput = document.getElementById("ai-additional-prompt-input");

    if (aiTriggerBtn && aiPromptModal) {
       aiTriggerBtn.addEventListener("click", () => {
          if (captionInput && captionInput.disabled) return; // Prevent when disabled (e.g. story)
          aiPromptModal.classList.remove("hidden");
          aiPromptModal.classList.add("flex");
          if (aiPromptInput) {
             aiPromptInput.value = "";
             aiPromptInput.focus();
          }
       });
    }

    if (aiCloseBtn && aiPromptModal) {
       aiCloseBtn.addEventListener("click", () => {
          aiPromptModal.classList.add("hidden");
          aiPromptModal.classList.remove("flex");
       });
    }

    if (aiFinalGenBtn && aiPromptModal) {
       aiFinalGenBtn.addEventListener("click", () => {
          // Simulated AI Generation flow
          aiFinalGenBtn.innerHTML = `<i class="ti ti-loader-2 animate-spin"></i> Generating...`;
          aiFinalGenBtn.classList.add("opacity-75", "pointer-events-none");

          setTimeout(() => {
             aiFinalGenBtn.innerHTML = `Generate Caption`;
             aiFinalGenBtn.classList.remove("opacity-75", "pointer-events-none");
             aiPromptModal.classList.add("hidden");
             aiPromptModal.classList.remove("flex");
             
             if (captionInput) {
                const promptText = aiPromptInput ? aiPromptInput.value.trim() : "";
                const dnaText = manualScheduleState.dna || "Our Brand";
                const generatedText = `✨ Fresh inspiration arrived for ${dnaText}! ` + 
                  (promptText ? `Incorporating: "${promptText}". ` : "") +
                  `Explore this season's trendsetters and see why we're redefining modern living. 🌟 Link in bio #Inspiration #Innovation`;
                
                captionInput.value = generatedText;
                
                const plat = manualScheduleState.currentPlatform;
                if (!manualScheduleState.platformConfigs[plat]) {
                  manualScheduleState.platformConfigs[plat] = { type: "Feeds", caption: "", images: [] };
                }
                manualScheduleState.platformConfigs[plat].caption = generatedText;
                
                // AUTO SYNC PREVIEW IMMEDIATELY IF AI GENERATED
                syncManualSimulator();
                
                showToast("AI caption generated successfully!");
             }
          }, 1200);
       });
    }


    // Live input syncing with memory isolation
    if (captionInput) {
      captionInput.addEventListener("input", (e) => {
        const plat = manualScheduleState.currentPlatform;
        if (!manualScheduleState.platformConfigs[plat]) {
          manualScheduleState.platformConfigs[plat] = {
            type: "Feeds",
            caption: "",
            images: [],
          };
        }
        manualScheduleState.platformConfigs[plat].caption = e.target.value;
        syncManualSimulator(); // LIVE PREVIEW SYNC
      });
    }

    // Post Type Radio triggers
    document
      .querySelectorAll('input[name="manualPostType"]')
      .forEach((radio) => {
        radio.addEventListener("change", (e) => {
          const plat = manualScheduleState.currentPlatform;
          if (!manualScheduleState.platformConfigs[plat]) {
            manualScheduleState.platformConfigs[plat] = {
              type: "Feeds",
              caption: "",
              images: [],
            };
          }
          manualScheduleState.platformConfigs[plat].type = e.target.value;
          syncManualSimulator(); // SYNC ON TYPE CHANGE

          // Handle Caption Disable on Story
          if (captionInput) {
             if (e.target.value === "Story") {
                captionInput.disabled = true;
                captionInput.classList.add("bg-gray-50", "text-gray-400");
                captionInput.placeholder = "Caption not available for Stories";
             } else {
                captionInput.disabled = false;
                captionInput.classList.remove("bg-gray-50", "text-gray-400");
                captionInput.placeholder = "Write what you want to share... Each platform has isolated memory!";
             }
          }
        });
      });

     // Account Checkboxes logic
     const manualAccCheckboxes = document.querySelectorAll(".manual-account-cb");
     manualAccCheckboxes.forEach(cb => {
        cb.addEventListener("change", () => {
           rebuildManualAccountState();
           syncManualSimulator(); // RE-SYNC BRAND ON ACCOUNT CHANGE
        });
     });

     // Platform Context Switchers (Tabs)
     const platformTabContainer = document.getElementById("manual-platform-tabs");
     if (platformTabContainer) {
        const tabs = platformTabContainer.querySelectorAll("button");
        tabs.forEach(tab => {
           tab.addEventListener("click", () => {
              // Determine platform based on inner text
              const text = tab.innerText.toLowerCase().trim();
              manualScheduleState.currentPlatform = text.includes("facebook") ? "facebook" : "instagram";
              
              // Visual class toggles for tab selection
              tabs.forEach(t => {
                 t.className = "px-4 h-8 rounded-lg flex items-center gap-2 text-[12px] font-medium text-[#667085] hover:bg-gray-200/50 transition-all cursor-pointer whitespace-nowrap";
              });
              tab.className = "px-4 h-8 rounded-lg bg-white shadow-sm flex items-center gap-2 text-[12px] font-bold text-[#111827] border border-[#eaecf0] transition-all cursor-pointer whitespace-nowrap";
              
              // Re-load from isolated memory
              const cfg = manualScheduleState.platformConfigs[manualScheduleState.currentPlatform] || { caption: "", type: "Feeds" };
              if (captionInput) {
                 captionInput.value = cfg.caption;
                 // Enforce disable logic for Story upon switch
                 if (cfg.type === "Story") {
                    captionInput.disabled = true;
                    captionInput.classList.add("bg-gray-50", "text-gray-400");
                    captionInput.placeholder = "Caption not available for Stories";
                 } else {
                    captionInput.disabled = false;
                    captionInput.classList.remove("bg-gray-50", "text-gray-400");
                    captionInput.placeholder = "Write what you want to share... Each platform has isolated memory!";
                 }
              }
              
              // Update radio button selected type
              document.querySelectorAll('input[name="manualPostType"]').forEach(r => {
                 r.checked = (r.value === cfg.type);
              });

              syncManualSimulator(); // SYNC ON TAB CHANGE
           });
        });
     }

    // Initial sync upon first bind
    syncManualSimulator();

    // Confirm btn simulation
    if (confirmBtn) {
      confirmBtn.addEventListener("click", () => submitManualSchedule());
    }
  }

  function submitManualSchedule() {
    const confirmBtn = document.getElementById("btn-manual-confirm-schedule");
    if (!confirmBtn) return;

    // Form Check
    if (!manualScheduleState.dna) {
      showToast("Please select a Business DNA", "error");
      return;
    }
    if (manualScheduleState.platforms.length === 0) {
      showToast("Please select at least 1 publish destination", "error");
      return;
    }

    confirmBtn.innerHTML = `<i class="ti ti-loader-2 animate-spin"></i> Scheduling...`;
    confirmBtn.classList.add("opacity-75", "pointer-events-none");

    setTimeout(() => {
      confirmBtn.innerHTML = `<i class="ti ti-calendar-event"></i> Schedule`;
      confirmBtn.classList.remove("opacity-75", "pointer-events-none");
      closeManualSchedule();

      // Simulated add to feed
      const newItem = {
        id: "gen-manual-" + Date.now(),
        title: "Manual Post (" + manualScheduleState.platformConfigs[manualScheduleState.currentPlatform].type + ")",
        brand: manualScheduleState.dna,
        status: "scheduled",
        type: manualScheduleState.platformConfigs[manualScheduleState.currentPlatform].type,
        scheduledAt: document.getElementById("manual-schedule-date").value + " " + document.getElementById("manual-schedule-time").value + ":00",
        thumbnail: manualScheduleState.platformConfigs[manualScheduleState.currentPlatform].images[0] || "https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=800&auto=format&fit=crop",
        caption: manualScheduleState.platformConfigs[manualScheduleState.currentPlatform].caption || "Manually composed schedule item."
      };

      generatedContent.unshift(newItem);
      renderScheduled();
      showToast("Post successfully scheduled!");
    }, 1500);
  }

  function syncManualSimulator() {
     const config = manualScheduleState.platformConfigs[manualScheduleState.currentPlatform];
     if (!config) return;

     const simBrandName = document.getElementById("sim-brand-name");
     const simBrandBody = document.getElementById("sim-brand-body");
     const simCaptionText = document.getElementById("sim-caption-text");
     const simPrimaryImage = document.getElementById("sim-primary-image");
     const simImagePlaceholder = document.getElementById("sim-image-placeholder");
     const simPlatformIcon = document.getElementById("sim-platform-icon");
     const simNetworkName = document.getElementById("sim-network-name");

     // Determine Display Name based on selected DNA OR first checked checkbox
     let brandName = "Your Brand";
     if (manualScheduleState.dna) {
        brandName = manualScheduleState.dna;
     } else {
        const firstChecked = document.querySelector(".manual-account-cb:checked");
        if (firstChecked) {
           brandName = firstChecked.nextElementSibling.nextElementSibling.innerText;
        }
     }

     if (simBrandName) simBrandName.innerText = brandName;
     if (simBrandBody) simBrandBody.innerText = brandName.toLowerCase().replace(/\s+/g, '') + " ";

     // Update Caption OR type indicator for stories
     if (simCaptionText) {
        if (config.type === "Story") {
           simCaptionText.innerText = "[This format includes interactive elements, interactive text overlays and zero written body caption.]";
           simCaptionText.className = "text-[#667085] italic text-[11px]";
        } else {
           simCaptionText.innerText = config.caption || "Your caption will render beautifully here.";
           simCaptionText.className = "text-[#344054] whitespace-pre-wrap break-words";
        }
     }

     // Image Isolation check
     if (simPrimaryImage && simImagePlaceholder) {
        if (config.images && config.images.length > 0) {
           simPrimaryImage.src = config.images[0];
           simPrimaryImage.classList.remove("hidden");
           simImagePlaceholder.classList.add("hidden");
        } else {
           simPrimaryImage.classList.add("hidden");
           simImagePlaceholder.classList.remove("hidden");
        }
     }

     // Update Network Meta
     if (simNetworkName && simPlatformIcon) {
        const isInsta = manualScheduleState.currentPlatform === "instagram";
        simPlatformIcon.className = `ti ti-brand-${manualScheduleState.currentPlatform} text-[14px] ${isInsta ? "text-[#E1306C]" : "text-[#1877F2]"}`;
        simNetworkName.innerText = `${isInsta ? "Instagram" : "Facebook"} ${config.type} Preview`;
     }
  }

  function openCalendarDayModal(dateString) {
    // dateString format can be "2026-05-12"
    const targetDate = new Date(dateString);
    const titleEl = document.getElementById("cal-day-modal-title");
    const containerEl = document.getElementById("cal-day-items-container");
    const modal = document.getElementById("modal-calendar-day");

    if (!titleEl || !containerEl || !modal) return;

    // Set header title formatted nicely
    titleEl.innerHTML = `<i class="ti ti-calendar-event text-[#667085]"></i> ${targetDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;

    // Filter scheduled content for THIS SPECIFIC DAY
    const dayItems = generatedContent.filter(item => {
       const itemDate = new Date(item.status === 'published' ? item.publishedAt : item.scheduledAt);
       return itemDate.toDateString() === targetDate.toDateString();
    });

    containerEl.innerHTML = "";

    if (dayItems.length === 0) {
       containerEl.innerHTML = `
         <div class="flex flex-col items-center justify-center py-8 px-4 text-center">
            <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center border border-[#eaecf0] mb-2">
               <i class="ti ti-calendar-x text-[#98a2b3]"></i>
            </div>
            <p class="text-[11px] font-medium text-[#667085]">No items scheduled for this day.</p>
         </div>
       `;
    } else {
       dayItems.forEach(item => {
          const isPublished = item.status === 'published';
          const timeStr = new Date(isPublished ? item.publishedAt : item.scheduledAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
          
          const row = document.createElement("div");
          row.className = "p-2.5 bg-[#F9FAFB] hover:bg-white border border-[#eaecf0] rounded-xl flex items-center gap-3 transition-all group cursor-pointer";
          row.onclick = (e) => {
             modal.classList.add("hidden");
             openPreviewModal(item.id);
          };
          
          row.innerHTML = `
             <div class="w-8 h-8 rounded-lg bg-[#111827] overflow-hidden flex items-center justify-center shrink-0 border border-[#374151]">
                <i class="ti ti-photo text-white opacity-40 text-[12px]"></i>
             </div>
             <div class="flex-1 min-w-0">
                <div class="text-[11px] font-bold text-[#111827] truncate">${escapeHtml(item.title || "Schedule Item")}</div>
                <div class="text-[10px] font-medium ${isPublished ? 'text-[#667085]' : 'text-[#7C3AED]'} flex items-center gap-1">
                   <i class="ti ti-clock text-[9px]"></i> ${timeStr}
                </div>
             </div>
             <div class="w-6 h-6 rounded-md flex items-center justify-center text-[#98a2b3] group-hover:text-[#111827] group-hover:bg-white transition-colors border border-transparent group-hover:border-[#eaecf0]">
                <i class="ti ti-chevron-right text-[13px]"></i>
             </div>
          `;
          containerEl.appendChild(row);
       });
    }

    // Open
    modal.classList.remove("hidden");
    modal.classList.add("flex");

    // Pre-fill manual schedule inputs just in case they click Create New Post
    const mDate = document.getElementById("manual-schedule-date");
    if (mDate) {
       mDate.value = dateString;
    }
  }

  // Register system initializing callback
  setTimeout(() => {
     initManualScheduleEvents();
  }, 500);

  window.openManualSchedule = openManualSchedule;
  window.openCalendarDayModal = openCalendarDayModal;
  window.syncManualSimulator = syncManualSimulator;

  // ═══════════════════════════════════════════
  // Universal logic for all business filter dynamic search inputs
  // ═══════════════════════════════════════════
  document.querySelectorAll(".biz-search-input").forEach(input => {
    input.addEventListener("click", e => e.stopPropagation());
    input.addEventListener("input", (e) => {
      const term = e.target.value.toLowerCase();
      const dropdown = input.closest(".absolute");
      if (dropdown) {
        const buttons = dropdown.querySelectorAll("button[data-brand]");
        buttons.forEach(btn => {
          const match = btn.textContent.toLowerCase().includes(term);
          btn.style.display = match ? "block" : "none";
        });
      }
    });
  });

  // ═══════════════════════════════════════════
  // ENGAGEMENT TEMPLATE MODULE
  // ═══════════════════════════════════════════
  function initEngagementTemplateEvents() {
     const trigger = document.getElementById("btn-eng-template-trigger");
     const dropdown = document.getElementById("dropdown-eng-template");
     const btnSave = document.getElementById("btn-eng-save-tmpl");
     const btnLoad = document.getElementById("btn-eng-load-tmpl");
     
     const modalSave = document.getElementById("modal-eng-save-tmpl");
     const modalLoad = document.getElementById("modal-eng-load-tmpl");
     
     // Dropdown Toggle
     if (trigger && dropdown) {
        trigger.addEventListener("click", (e) => {
           e.stopPropagation();
           dropdown.classList.toggle("hidden");
        });
        document.addEventListener("click", () => { if(dropdown) dropdown.classList.add("hidden"); });
     }
     
     // Open Save
     if (btnSave && modalSave) {
        btnSave.addEventListener("click", () => {
           modalSave.classList.remove("hidden");
           modalSave.classList.add("flex");
           if(dropdown) dropdown.classList.add("hidden");
        });
     }
     
     // Close Save handlers
     const btnCloseSave = document.getElementById("btn-close-eng-save-tmpl");
     const btnConfirmSave = document.getElementById("btn-confirm-eng-save-tmpl");
     if (btnCloseSave) {
        btnCloseSave.addEventListener("click", () => {
           modalSave.classList.add("hidden");
           modalSave.classList.remove("flex");
        });
     }
     if (btnConfirmSave) {
        btnConfirmSave.addEventListener("click", () => {
           const inp = document.getElementById("inp-eng-tmpl-name");
           const val = inp ? inp.value.trim() : "New Template";
           if (!val) return;
           modalSave.classList.add("hidden");
           modalSave.classList.remove("flex");
           showToast(`Template "${val}" saved successfully!`);
           if(inp) inp.value = "";
        });
     }
     
     // Open Load
     if (btnLoad && modalLoad) {
        btnLoad.addEventListener("click", () => {
           modalLoad.classList.remove("hidden");
           modalLoad.classList.add("flex");
           if(dropdown) dropdown.classList.add("hidden");
        });
     }
     
     // Close Load handlers
     const btnCloseLoad = document.getElementById("btn-close-eng-load-tmpl");
     const btnConfirmLoad = document.getElementById("btn-confirm-eng-load-tmpl");
     if (btnCloseLoad) {
        btnCloseLoad.addEventListener("click", () => {
           modalLoad.classList.add("hidden");
           modalLoad.classList.remove("flex");
        });
     }
     if (btnConfirmLoad) {
        btnConfirmLoad.addEventListener("click", () => {
           modalLoad.classList.add("hidden");
           modalLoad.classList.remove("flex");
           
           // Apply mock preset settings
           const tcDelete = document.getElementById("toggle-delete-comment");
           const tcReply = document.getElementById("toggle-reply-comment");
           const tcLike = document.getElementById("toggle-like-comment");
           const tcDm = document.getElementById("toggle-dm-comment");

           if(tcDelete) tcDelete.checked = false;
           if(tcReply) tcReply.checked = true;
           if(tcLike) tcLike.checked = false;
           if(tcDm) tcDm.checked = true;
           
           showToast("Engagement template applied successfully!");
        });
     }
  }

  // Initialize new module
  initEngagementTemplateEvents();
  initSummaryFeatureEvents();

  // Start
  init();
</script>
