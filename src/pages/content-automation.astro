  function renderScheduledMonthly(scheduled) {
    const year = scheduledMonthDate.getFullYear();
    const month = scheduledMonthDate.getMonth();

    els.calMonthLabel.textContent = scheduledMonthDate.toLocaleDateString(
      "en-US",
      {
        month: "long",
        year: "numeric",
      },
    );

    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const daysInMonth = lastDay.getDate();
    const startDayOfWeek = firstDay.getDay();

    // Build a map of scheduled items by day
    const itemsByDay = {};
    scheduled.forEach((item) => {
      const dateField =
        item.status === "published" ? item.publishedAt : item.scheduledAt;
      const d = new Date(dateField);
      if (d.getFullYear() === year && d.getMonth() === month) {
        const day = d.getDate();
        if (!itemsByDay[day]) itemsByDay[day] = [];
        itemsByDay[day].push(item);
      }
    });

    const today = new Date();
    const isCurrentMonth =
      today.getFullYear() === year && today.getMonth() === month;

    let html = "";
    // Empty cells before the first day
    for (let i = 0; i < startDayOfWeek; i++) {
      html += `<div class="aspect-square rounded-xl"></div>`;
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const isToday = isCurrentMonth && day === today.getDate();
      const dayItems = itemsByDay[day] || [];
      const hasItems = dayItems.length > 0;
      const dateKey = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;

      html += `
        <div class="aspect-square p-2 rounded-xl border ${isToday ? "border-[#8B5CF6] bg-[#F5F3FF]" : "border-[#eaecf0] bg-white"} flex flex-col gap-1 cursor-pointer hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-[#98a2b3] transition-all" onclick="openCalendarDayModal('${dateKey}')">
          <div class="flex items-center justify-between">
            <span class="text-[13px] font-bold ${isToday ? "text-[#7C3AED]" : "text-[#111827]"}">${day}</span>
            ${
              hasItems
                ? (() => {
                    const allPublished = dayItems.every(
                      (i) => i.status === "published",
                    );
                    const dotColor = allPublished ? "bg-[#9CA3AF]" : "bg-[#2563EB]";
                    return `<span class="w-2 h-2 rounded-full ${dotColor}"></span>`;
                  })()
                : ""
            }
          </div>
          ${dayItems
            .slice(0, 2)
            .map((item) => {
              const isPublished = item.status === "published";
              return `
            <div class="px-1.5 py-0.5 rounded-md ${isPublished ? "bg-[#F3F4F6] text-[#667085] border border-transparent" : "bg-[#EFF6FF] text-[#2563EB] border border-[#DBEAFE]"} text-[9px] font-medium truncate leading-tight">
              ${escapeHtml(item.title)}
            </div>
          `;
            })
            .join("")}
          ${dayItems.length > 2 ? `<div class="px-1.5 py-0.5 text-[9px] text-[#98a2b3]">+${dayItems.length - 2} more</div>` : ""}
        </div>
      `;
    }

    els.calMonthGrid.innerHTML = html;
  }

  function renderScheduledWeekly(scheduled) {
    // Get the start of the week (Sunday)
    const weekStart = getStartOfWeek(scheduledWeekDate);

    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 6);
    weekEnd.setHours(23, 59, 59, 999);

    els.schedCalWeekLabel.textContent = `${weekStart.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${weekEnd.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    // Build a map of scheduled items by day
    const itemsByDay = {};
    scheduled.forEach((item) => {
      const dateField =
        item.status === "published" ? item.publishedAt : item.scheduledAt;
      const d = new Date(dateField);
      // Find which day of this week it belongs to
      for (let i = 0; i < 7; i++) {
        const checkDay = new Date(weekStart);
        checkDay.setDate(checkDay.getDate() + i);
        if (d.toDateString() === checkDay.toDateString()) {
          if (!itemsByDay[i]) itemsByDay[i] = [];
          itemsByDay[i].push(item);
          break;
        }
      }
    });

    const dayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    let html = "";
    for (let i = 0; i < 7; i++) {
      const dayDate = new Date(weekStart);
      dayDate.setDate(dayDate.getDate() + i);
      const isToday = dayDate.toDateString() === new Date().toDateString();
      const isPast = dayDate < today;
      const dayItems = itemsByDay[i] || [];
      const hasItems = dayItems.length > 0;
      const dateKey = `${dayDate.getFullYear()}-${String(dayDate.getMonth() + 1).padStart(2, '0')}-${String(dayDate.getDate()).padStart(2, '0')}`;

      html += `
        <div class="flex flex-col gap-2">
          <!-- Date Header: Bento style white bg -->
          <div class="text-center p-3 rounded-2xl bg-white border ${isToday ? "border-[#8B5CF6]" : "border-[#eaecf0]"} ${isPast ? "opacity-70" : ""} cursor-pointer hover:bg-gray-50 hover:border-[#98a2b3] hover:shadow-sm transition-all active:scale-[0.98]" onclick="openCalendarDayModal('${dateKey}')">
            <div class="text-[11px] font-semibold ${isToday ? "text-[#7C3AED]" : "text-[#667085]"}">${dayNames[i]}</div>
            <div class="text-[18px] font-bold ${isToday ? "text-[#7C3AED]" : "text-[#111827]"}">${dayDate.getDate()}</div>
          </div>
          <!-- Items column -->
          <div class="flex flex-col gap-2 min-h-[200px]">
            ${
              hasItems
                ? dayItems
                    .map((item) => {
                      const timeStr = new Date(
                        item.status === "published"
                          ? item.publishedAt
                          : item.scheduledAt,
                      ).toLocaleTimeString("en-US", {
                        hour: "2-digit",
                        minute: "2-digit",
                      });
                      const isItemPast =
                        new Date(
                          item.status === "published"
                            ? item.publishedAt
                            : item.scheduledAt,
                        ) < new Date();
                      const isPublished = item.status === "published";
                      const cardStyle = isPublished 
                        ? "bg-[#F3F4F6] border-[#D1D5DB]" 
                        : "bg-[#EFF6FF] border-[#DBEAFE]";
                      return `
                <div class="group p-2 rounded-2xl ${cardStyle} border hover:border-[#111827] hover:shadow-[0_4px_20px_rgba(0,0,0,0.04)] transition-all cursor-pointer ${isItemPast ? "opacity-60 grayscale-[0.3]" : ""}" onclick="openPreviewModal('${item.id}')">
                  <!-- Unified Plain Dark Gray Image Thumbnail -->
                  <div class="w-full ${item.contentType === "Story" ? "aspect-[9/16]" : "aspect-[3/4]"} bg-[#1f2937] rounded-xl flex items-center justify-center mb-2 relative overflow-hidden shadow-inner">
                    <span class="absolute bottom-1.5 right-1.5 px-1.5 h-4 rounded-full bg-black/40 backdrop-blur-sm text-[8px] font-bold text-white tracking-wider flex items-center">
                      ${item.contentType === "Story" ? "9:16" : "3:4"}
                    </span>
                  </div>
                  
                  <!-- Info -->
                  <div class="text-[10px] font-bold ${isPublished ? "text-[#9CA3AF]" : "text-[#2563EB]"} mb-1 flex items-center gap-1">
                    <i class="ti ${platformIconMap[item.platform] || "ti-brand-instagram"} text-[10px]"></i>
                    <span>${timeStr}</span>
                  </div>
                  
                  <div class="text-[11px] font-bold text-[#111827] truncate leading-tight mb-1">${escapeHtml(item.brand)}</div>
                  
                  <div class="flex items-center gap-1 mb-1">
                    <span class="px-1.5 h-4 rounded-full ${isPublished ? "bg-[#F3F4F6] text-[#667085] border-[#D1D5DB]" : "bg-[#EFF6FF] text-[#2563EB] border-[#DBEAFE]"} text-[8px] font-bold border flex items-center">
                      ${escapeHtml(item.contentType)}
                    </span>
                    ${
                      item.autoEngagement &&
                      Object.values(item.autoEngagement).some((v) => v)
                        ? `
                    <span class="inline-flex items-center gap-1 px-1.5 h-4 rounded-full bg-[#ECFDF3] text-[8px] font-bold text-[#027A48] border border-[#D1FADF]" title="Engagement settings active">
                      <span class="w-1 h-1 rounded-full bg-[#22C55E]"></span>
                      Engagement
                    </span>
                    `
                        : ""
                    }
                  </div>
                  
                  <div class="text-[9px] text-[#667085] line-clamp-2 leading-tight">${escapeHtml(item.caption || "")}</div>
                </div>
              `;
                    })
                    .join("")
                : `<div class="flex-1 flex flex-col items-center justify-center text-[11px] text-[#D1D5DB] py-8">
              <i class="ti ti-calendar-event text-[24px] mb-1"></i>
              <span>No items</span>
            </div>`
            }
          </div>
        </div>
      `;
    }

    els.schedCalWeekGrid.innerHTML = html;
  }

  function cancelScheduleItem(id) {
    const item = generatedContent.find((g) => g.id === id);
    if (!item) return;
    item.status = "approved";
    item.scheduledAt = null;
    saveGenerated();
    renderScheduled();
    renderGenerated();
    showToast("Schedule cancelled");
  }

  function formatRelativeDate(dateStr) {
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    const date = new Date(dateStr);
    date.setHours(0, 0, 0, 0);
    const diffMs = now - date;
    const diffDays = Math.floor(diffMs / (24 * 60 * 60 * 1000));

    if (diffDays === 0) return "Hari ini";
    if (diffDays === 1) return "Kemarin";
    if (diffDays < 7) {
      const days = [
        "Minggu",
        "Senin",
        "Selasa",
        "Rabu",
        "Kamis",
        "Jumat",
        "Sabtu",
      ];
      return days[date.getDay()];
    }
    return date.toLocaleDateString("id-ID", {
      day: "numeric",
      month: "short",
    });
  }

  function formatScheduledTime(dateStr) {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = date - now;
    const diffMins = Math.floor(diffMs / (60 * 1000));
    const diffHours = Math.floor(diffMs / (60 * 60 * 1000));

    if (diffMins <= 0) return "Publishing now";
    if (diffMins < 60) return `${diffMins}m`;
    if (diffHours < 24) return `${diffHours}h`;
    return date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    });
  }

