  }

  function closeCommentModal() {
    const modal = document.getElementById("modal-auto-engagement");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    
    // Contextual Back: If we came from preview, reopen it!
    const wasFromPrev = engOpenedFromPreview;
    const prevId = editingAutomationId;
    
    editingAutomationId = null;
    engOpenedFromPreview = false; // reset

    if (wasFromPrev && prevId) {
       // Small delay to ensure transition feels seamless replacement
       setTimeout(() => {
          if (typeof openPreviewModal === 'function') {
             openPreviewModal(prevId);
          }
       }, 10);
    }
  }

  function saveComment() {
    if (!editingAutomationId) return;

    const eng = {
      deleteComment: document.getElementById("toggle-delete-comment").checked,
      replyComment: document.getElementById("toggle-reply-comment").checked,
      likeComment: document.getElementById("toggle-like-comment").checked,
      dmComment: document.getElementById("toggle-dm-comment").checked,
      replyStory: document.getElementById("toggle-reply-story").checked,
      replyDm: document.getElementById("toggle-reply-dm").checked,
    };

    const auto = automations.find((a) => a.id === editingAutomationId);
    if (auto) {
      auto.autoEngagement = eng;
      saveAutomations();
      renderAutomations();
    }

    const gen = generatedContent.find((g) => g.id === editingAutomationId);
    if (gen) {
      gen.autoEngagement = eng;
      saveGenerated();
      // Update preview modal indicator
      const indicator = document.getElementById("preview-engagement-indicator");
      if (indicator) {
        const isActive = Object.values(eng).some((v) => v);
        indicator.classList.toggle("hidden", !isActive);
        indicator.classList.toggle("flex", isActive);
      }
    }

    // Update single schedule engagement state and indicator
    singleScheduleEngagement = { ...eng };
    updateSingleScheduleEngagementIndicator();

    // Update bulk schedule engagement state and indicator
    bulkScheduleEngagement = { ...eng };
    updateBulkScheduleEngagementIndicator();

    closeCommentModal();
    showToast("Engagement settings saved!");
  }

  // ═══════════════════════════════════════════
  // AUTOMATION ACTIONS
  // ═══════════════════════════════════════════
  function toggleAutomationStatus(id) {
    const auto = automations.find((a) => a.id === id);
    if (!auto) return;
    auto.status = auto.status === "active" ? "paused" : "active";
    saveAutomations();
    renderAutomations();
  }

  function deleteAutomation(id) {
    if (!confirm("Yakin ingin menghapus automation ini?")) return;
    automations = automations.filter((a) => a.id !== id);
    saveAutomations();
    renderAutomations();
  }

  function startAutomation() {
    if (!wizardData.name) {
      alert("Please enter a task name.");
      return;
    }
    if (!wizardData.dna) {
      alert("Please select a Business DNA.");
      return;
    }
    if (Object.keys(wizardData.selectedDates).length === 0) {
      alert("Please select at least one date in the schedule.");
      return;
    }

    if (editingAutoId) {
      const idx = automations.findIndex((a) => a.id === editingAutoId);
      if (idx !== -1) {
        automations[idx].name = wizardData.name;
        automations[idx].dna = wizardData.dna;
        automations[idx].recurring = wizardData.recurring;
        automations[idx].selectedDates = JSON.parse(
          JSON.stringify(wizardData.selectedDates),
        );
      }
    } else {
      const newAuto = {
        id: "auto_" + Date.now(),
        name: wizardData.name,
        dna: wizardData.dna,
        recurring: wizardData.recurring,
        selectedDates: JSON.parse(JSON.stringify(wizardData.selectedDates)),
        status: "active",
        createdAt: new Date().toISOString(),
      };
      automations.push(newAuto);
    }
    saveAutomations();
    renderAutomations();
    closeAddModal();
  }

  // ═══════════════════════════════════════════
  // MODAL OPEN/CLOSE
  // ═══════════════════════════════════════════
  function openAddModal() {
    editingAutoId = null;
    const titleEl = document.getElementById("wizard-title");
    if (titleEl) titleEl.textContent = "Create Automation";
    const btnStart = document.getElementById("btn-start-automation");
    if (btnStart) btnStart.textContent = "Start Automation";
    // Reset wizard
    wizardData = {
      name: "",
      dna: null,
      selectedDates: {},
      recurring: "once",
      repeatFor: 3,
      scheduleMode: "monthly",
      currentWeekDate: (() => {
        const d = new Date();
        d.setDate(d.getDate() - d.getDay());
        d.setHours(0, 0, 0, 0);
        return d;
      })(),
    };
    currentStep = 1;
    currentCalendarDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);

    // Reset inputs
    els.inputName.value = "";
    els.dnaSelectedName.textContent = "Select Business DNA";
    els.dnaSelectedDesc.textContent =
      "Choose a business profile for AI grounding";
    els.recurringRadios.forEach((r) => {
      r.checked = r.value === "once";
    });
    els.recurringInfo.textContent =
      "Content will be generated once on selected dates.";
    if (els.repeatForSelect) els.repeatForSelect.value = "3";
    els.repeatForWrapper.classList.add("hidden");
    els.weeklyRepeatWrapper.classList.add("hidden");
    els.recurringPreview.classList.add("hidden");

    // Reset schedule mode toggle
    if (els.btnModeMonthly && els.btnModeWeekly) {
      els.btnModeMonthly.classList.add("bg-[#111827]", "text-white");
      els.btnModeMonthly.classList.remove(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
      els.btnModeWeekly.classList.remove("bg-[#111827]", "text-white");
      els.btnModeWeekly.classList.add(
        "text-[#667085]",
        "hover:text-[#111827]",
        "hover:bg-[#F9FAFB]",
      );
    }
    if (els.monthlyCalendar) els.monthlyCalendar.classList.remove("hidden");
    if (els.weeklyCalendar) els.weeklyCalendar.classList.add("hidden");

    renderCalendar();
    renderWeeklyCalendar();
    goToStep(1);

    els.modalAdd.classList.remove("hidden");
    els.modalAdd.classList.add("flex");
  }

  function closeAddModal() {
    els.modalAdd.classList.add("hidden");
    els.modalAdd.classList.remove("flex");
    closeSlotPopover();
  }

  // ═══════════════════════════════════════════
  // EVENT BINDING
  // ═══════════════════════════════════════════
  function bindEvents() {
    // Open modal
    els.btnAdd.addEventListener("click", openAddModal);
    els.btnEmptyAdd.addEventListener("click", openAddModal);

    // Close modal
    els.closeAddModal.addEventListener("click", closeAddModal);
    els.modalAdd.addEventListener("click", (e) => {
      if (e.target === els.modalAdd) closeAddModal();
    });

    // Wizard navigation
    els.btnBack.addEventListener("click", () => {
      if (currentStep > 1) goToStep(currentStep - 1);
    });
    els.btnNext.addEventListener("click", () => {
      if (validateStep(currentStep) && currentStep < 3)
        goToStep(currentStep + 1);
    });
    els.btnStart.addEventListener("click", () => {
      if (validateStep(3)) startAutomation();
    });

    // Step 1 inputs
    els.inputName.addEventListener("input", (e) => {
      wizardData.name = e.target.value;
    });

    // DNA dropdown
    els.btnSelectDna.addEventListener("click", (e) => {
      e.stopPropagation();
      els.dnaDropdown.classList.toggle("hidden");
    });
    document.addEventListener("click", (e) => {
      if (
        !els.dnaDropdown.contains(e.target) &&
        e.target !== els.btnSelectDna
      ) {
        els.dnaDropdown.classList.add("hidden");
      }
    });
    document.querySelectorAll(".dna-option").forEach((opt) => {
      opt.addEventListener("click", () => {
        wizardData.dna = { name: opt.dataset.name, desc: opt.dataset.desc };
        els.dnaSelectedName.textContent = opt.dataset.name;
        els.dnaSelectedDesc.textContent = opt.dataset.desc;
        els.dnaDropdown.classList.add("hidden");
      });
    });

    // Calendar navigation
    els.calPrev.addEventListener("click", () => {
      currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1);
      renderCalendar();
    });
    els.calNext.addEventListener("click", () => {
      currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1);
      renderCalendar();
    });

    // Schedule mode toggle (Monthly / Weekly)
    if (els.btnModeMonthly && els.btnModeWeekly) {
      els.btnModeMonthly.addEventListener("click", () => {
        wizardData.scheduleMode = "monthly";
        els.btnModeMonthly.classList.add("bg-[#111827]", "text-white");
        els.btnModeMonthly.classList.remove(
          "text-[#667085]",
          "hover:text-[#111827]",
          "hover:bg-[#F9FAFB]",
        );
        els.btnModeWeekly.classList.remove("bg-[#111827]", "text-white");
        els.btnModeWeekly.classList.add(
          "text-[#667085]",
          "hover:text-[#111827]",
          "hover:bg-[#F9FAFB]",
        );
        els.monthlyCalendar.classList.remove("hidden");
        els.weeklyCalendar.classList.add("hidden");
        renderCalendar();
      });
      els.btnModeWeekly.addEventListener("click", () => {
        wizardData.scheduleMode = "weekly";
        els.btnModeWeekly.classList.add("bg-[#111827]", "text-white");
        els.btnModeWeekly.classList.remove(
          "text-[#667085]",
          "hover:text-[#111827]",
          "hover:bg-[#F9FAFB]",
        );
        els.btnModeMonthly.classList.remove("bg-[#111827]", "text-white");
        els.btnModeMonthly.classList.add(
          "text-[#667085]",
          "hover:text-[#111827]",
          "hover:bg-[#F9FAFB]",
        );
        els.weeklyCalendar.classList.remove("hidden");
        els.monthlyCalendar.classList.add("hidden");
        renderWeeklyCalendar();
      });
    }

    // Weekly calendar navigation
    if (els.calWeekPrev) {
      els.calWeekPrev.addEventListener("click", () => {
        wizardData.currentWeekDate.setDate(
          wizardData.currentWeekDate.getDate() - 7,
        );
        renderWeeklyCalendar();
      });
    }
    if (els.calWeekNext) {
      els.calWeekNext.addEventListener("click", () => {
        wizardData.currentWeekDate.setDate(
          wizardData.currentWeekDate.getDate() + 7,
        );
        renderWeeklyCalendar();
      });
    }

    // AI Suggestion for weekly
    if (els.btnAiSuggestionWeekly) {
      els.btnAiSuggestionWeekly.addEventListener(
        "click",
        applyAiSuggestionWeekly,
      );
    }

    // Recurring
    els.recurringRadios.forEach((radio) => {
      radio.addEventListener("change", (e) => {
        wizardData.recurring = e.target.value;
        if (e.target.value === "once") {
          els.recurringInfo.textContent =
            "Content will be generated once on selected dates.";
          els.repeatForWrapper.classList.add("hidden");
          els.weeklyRepeatWrapper.classList.add("hidden");
          els.recurringPreview.classList.add("hidden");
        } else if (e.target.value === "monthly") {
          els.recurringInfo.textContent =
            "Selected dates will repeat every month. If a date doesn't exist in a month, it will be scheduled on the last day of that month.";
          els.repeatForWrapper.classList.remove("hidden");
          els.weeklyRepeatWrapper.classList.add("hidden");
          els.recurringPreview.classList.remove("hidden");
          renderRecurringPreview();
        } else if (e.target.value === "weekly") {
          els.recurringInfo.textContent =
            "Content will repeat every week on the selected days.";
          els.repeatForWrapper.classList.remove("hidden");
          els.weeklyRepeatWrapper.classList.remove("hidden");
          els.recurringPreview.classList.remove("hidden");
          renderRecurringPreview();
        }
      });
    });

    // Repeat for input
    if (els.repeatForSelect) {
      els.repeatForSelect.addEventListener("change", (e) => {
        let val = parseInt(e.target.value) || 3;
        val = Math.max(1, Math.min(12, val));
        wizardData.repeatFor = val;
        e.target.value = val;
        renderRecurringPreview();
      });
    }

    // Content type description
    if (els.slotContentType && els.contentTypeDesc) {
      els.slotContentType.addEventListener("change", (e) => {
        els.contentTypeDesc.textContent =
          CONTENT_TYPE_DESCS[e.target.value] || "";
      });
    }

    // Automation popover
    if (els.closeSlotPopover)
      els.closeSlotPopover.addEventListener("click", closeAutomationPopover);
    if (els.btnAddSlot) els.btnAddSlot.addEventListener("click", addAutomation);

    // Automation References Dropdown
    if (els.btnAutomationReferences && els.automationReferencesDropdown) {
      els.btnAutomationReferences.addEventListener("click", (e) => {
        e.stopPropagation();
        els.automationReferencesDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !els.automationReferencesDropdown.contains(e.target) &&
          e.target !== els.btnAutomationReferences
        ) {
          els.automationReferencesDropdown.classList.add("hidden");
        }
      });
    }
    if (els.btnAutomationAddLocal && els.automationLocalFileInput) {
      els.btnAutomationAddLocal.addEventListener("click", () => {
        els.automationLocalFileInput.click();
        els.automationReferencesDropdown.classList.add("hidden");
      });
      els.automationLocalFileInput.addEventListener("change", () => {
        if (
          els.automationLocalFileInput.files &&
          els.automationLocalFileInput.files.length > 0
        ) {
          Array.from(els.automationLocalFileInput.files).forEach((file) => {
            addAutomationRefTag(file.name);
          });
          els.automationLocalFileInput.value = "";
        }
      });
    }
    if (els.btnAutomationAddCatalog) {
      els.btnAutomationAddCatalog.addEventListener("click", () => {
        const referencesModal = document.getElementById("references-modal");
        if (referencesModal) {
          referencesModal.classList.remove("hidden");
          els.automationReferencesDropdown.classList.add("hidden");
        }
      });
    }

    // Catalog modal submit handler for automation popover
    const referencesModal = document.getElementById("references-modal");
    if (referencesModal) {
      const submitRefsBtn = referencesModal.querySelector(".btn-active-dark");
      const selectedRefs = new Set();
      const refItems = referencesModal.querySelectorAll(".ref-item");

      refItems.forEach((item) => {
        item.addEventListener("click", () => {
          const id = item.getAttribute("data-id");
          const overlay = item.querySelector(".selected-overlay");
          if (selectedRefs.has(id)) {
            selectedRefs.delete(id);
            overlay.classList.add("hidden");
          } else {
            selectedRefs.add(id);
            overlay.classList.remove("hidden");
          }
        });
      });

      if (submitRefsBtn) {
        submitRefsBtn.addEventListener("click", () => {
          selectedRefs.forEach((id) => {
            const item = referencesModal.querySelector(
              `.ref-item[data-id="${id}"]`,
            );
            if (item) {
              const name = item.getAttribute("data-name");
              addAutomationRefTag(name);
            }
          });
          selectedRefs.clear();
          refItems.forEach((i) =>
            i.querySelector(".selected-overlay").classList.add("hidden"),
          );
          referencesModal.classList.add("hidden");
        });
      }

      const closeRefs = document.getElementById("close-references");
      const cancelRefs = document.getElementById("cancel-references");
      const closeModal = () => {
        referencesModal.classList.add("hidden");
        selectedRefs.clear();
        refItems.forEach((i) =>
          i.querySelector(".selected-overlay").classList.add("hidden"),
        );
      };
      if (closeRefs) closeRefs.addEventListener("click", closeModal);
      if (cancelRefs) cancelRefs.addEventListener("click", closeModal);
      referencesModal.addEventListener("click", (e) => {
        if (e.target === referencesModal) closeModal();
      });
    }

    // Date detail popover
    if (els.closeDateDetailPopover)
      els.closeDateDetailPopover.addEventListener(
        "click",
        closeDateDetailPopover,
      );
    if (els.btnAddNewAutomation)
      els.btnAddNewAutomation.addEventListener("click", () => {
        closeDateDetailPopover();
        if (activePopoverDate) {
          const btn = document.querySelector(
            `.cal-day[data-date="${activePopoverDate}"]`,
          );
          if (btn) openAutomationPopover(activePopoverDate, btn);
        }
      });

    // Variations +/-
    els.btnVarMinus.addEventListener("click", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.max(1, val - 1);
    });
    els.btnVarPlus.addEventListener("click", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.min(10, val + 1);
    });
    els.automationVariations.addEventListener("change", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.max(1, Math.min(10, val));
    });

    // Engagement / Auto Comment Modal Listeners (Enhanced flow)
    if (els.closeEngagementModal)
      els.closeEngagementModal.addEventListener("click", closeCommentModal);
    if (els.btnCancelEngagement)
      els.btnCancelEngagement.addEventListener("click", closeCommentModal);
    if (els.btnSaveEngagement)
      els.btnSaveEngagement.addEventListener("click", saveComment);

    // Back buttons in engagement modal (properly routed to support back tracking)
    const btnBackEngagement = document.getElementById("btn-back-engagement");
    const btnBackEngagementFooter = document.getElementById("btn-back-engagement-footer");
    
    if (btnBackEngagement) {
      btnBackEngagement.addEventListener("click", closeCommentModal);
    }
    if (btnBackEngagementFooter) {
      btnBackEngagementFooter.addEventListener("click", closeCommentModal);
    }
    
    if (els.modalEngagement) {
      els.modalEngagement.addEventListener("click", (e) => {
        if (e.target === els.modalEngagement) closeCommentModal();
      });
    }
    if (els.commentToggle) {
      els.commentToggle.addEventListener("change", (e) => {
        if (els.commentFields)
          els.commentFields.classList.toggle("hidden", !e.target.checked);
      });
    }
    if (els.dmToggle) {
      els.dmToggle.addEventListener("change", (e) => {
        if (els.dmFields)
          els.dmFields.classList.toggle("hidden", !e.target.checked);
      });
    }

    // Schedule modal
    if (els.closeScheduleModal)
      els.closeScheduleModal.addEventListener("click", closeScheduleModalFn);
    if (els.btnCancelScheduleModal)
      els.btnCancelScheduleModal.addEventListener(
        "click",
        closeScheduleModalFn,
      );
    if (els.btnConfirmSchedule)
      els.btnConfirmSchedule.addEventListener("click", confirmSchedule);
    if (els.btnPublishNow)
      els.btnPublishNow.addEventListener("click", publishNow);
    if (els.btnPublish1h)
      els.btnPublish1h.addEventListener("click", publishIn1Hour);
    if (els.modalSchedule) {
      els.modalSchedule.addEventListener("click", (e) => {
        if (e.target === els.modalSchedule) closeScheduleModalFn();
      });
    }

    // Business filter dropdown
    const btnBusinessFilter = document.getElementById("btn-business-filter");
    const businessFilterDropdown = document.getElementById(
      "business-filter-dropdown",
    );
    if (btnBusinessFilter && businessFilterDropdown) {
      btnBusinessFilter.addEventListener("click", (e) => {
        e.stopPropagation();
        businessFilterDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !businessFilterDropdown.contains(e.target) &&
          e.target !== btnBusinessFilter
        ) {
          businessFilterDropdown.classList.add("hidden");
        }
      });
      document.querySelectorAll(".business-filter-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          const brand = opt.dataset.brand;
          document.getElementById("business-filter-label").textContent =
            brand === "all" ? "All Business" : brand;
          businessFilterDropdown.classList.add("hidden");
          // Filter automations
          if (brand === "all") {
            renderAutomations();
          } else {
            const filtered = automations.filter((a) => a.dna?.name === brand);
            els.tbody.innerHTML = filtered
              .map((auto) => {
                // ... reuse render logic
                const dateCount = Object.keys(auto.selectedDates).length;
                const contentTypes = [
                  ...new Set(
                    Object.values(auto.selectedDates)
                      .flat()
                      .map((s) => s.contentType),
                  ),
                ];
                const typeIcons = contentTypes
                  .map(
                    (t) =>
                      `<i class="ti ${CONTENT_ICONS[t] || "ti-file"} text-[13px] text-[#667085]" title="${t}"></i>`,
                  )
                  .join("");
                return `
                <tr class="border-b border-[#eaecf0] hover:bg-[#F9FAFB] transition-colors group">
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0">
                        <i class="ti ti-brand-abstract text-[18px] text-[#667085]"></i>
                      </div>
                      <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.dna?.name || "-")}</span>
                    </div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.name)}</span>
                  </td>
                  <td class="px-5 py-4">
                    <span class="text-[13px] text-[#667085]">${dateCount} tanggal · ${recurringLabel(auto.recurring)}</span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-1.5">${typeIcons}</div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="inline-flex items-center px-2.5 h-6 rounded-full text-[11px] font-bold ${auto.status === "active" ? "bg-[#ECFDF3] text-[#027A48] border border-[#D1FADF]" : "bg-[#FEF3F2] text-[#B42318] border border-[#FECDCA]"}">
                      ${auto.status === "active" ? "Active" : "Paused"}
                    </span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center justify-end gap-1">
                      <button class="action-btn w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer" onclick="toggleAutomationStatus('${auto.id}')">
                        <i class="ti ${auto.status === "active" ? "ti-player-pause" : "ti-player-play"} text-[15px]"></i>
                      </button>
                      <button class="action-btn w-8 h-8 rounded-lg hover:bg-[#FEF3F2] flex items-center justify-center text-[#667085] hover:text-[#D92D20] transition-colors cursor-pointer" onclick="deleteAutomation('${auto.id}')">
                        <i class="ti ti-trash text-[15px]"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              `;
              })
              .join("");
          }
        });
      });
    }

    // Automation search
    const automationSearch = document.getElementById("automation-search");
    if (automationSearch) {
      automationSearch.addEventListener("input", (e) => {
        const query = e.target.value.toLowerCase();
        const rows = els.tbody.querySelectorAll("tr");
        rows.forEach((row) => {
          const text = row.textContent.toLowerCase();
          row.style.display = text.includes(query) ? "" : "none";
        });
      });
    }

    // Tab switching
    els.tabAutomations.addEventListener("click", () =>
      switchTab("automations"),
    );
    els.tabGenerated.addEventListener("click", () => switchTab("generated"));
    els.tabScheduled.addEventListener("click", () => switchTab("scheduled"));

    const btnDraftShowMore = document.getElementById("btn-draft-show-more");
    if (btnDraftShowMore) {
      btnDraftShowMore.addEventListener("click", () => {
        draftLimit += 10;
        renderGenerated();
      });
    }

    // ── Scheduled Tab: Filter ──
    if (els.btnScheduledFilter && els.scheduledFilterDropdown) {
      els.btnScheduledFilter.addEventListener("click", (e) => {
        e.stopPropagation();
        els.scheduledFilterDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !els.scheduledFilterDropdown.contains(e.target) &&
          e.target !== els.btnScheduledFilter
        ) {
          els.scheduledFilterDropdown.classList.add("hidden");
        }
      });
      document.querySelectorAll(".scheduled-filter-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          scheduledFilter = opt.dataset.filter;
          els.scheduledFilterLabel.textContent = opt.textContent;
          els.scheduledFilterDropdown.classList.add("hidden");
          renderScheduled();
        });
      });
    }

    // ── Scheduled Tab: Search ──
    if (els.scheduledSearch) {
