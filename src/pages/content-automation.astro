---
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="Content Automation - Xeni" activePage="content-automation">
  <div class="w-full min-h-full flex flex-col px-6 pb-32 -mt-12">
    <!-- Title + Controls Row -->
    <div
      class="max-w-6xl mx-auto w-full pt-1 pb-8 flex items-center justify-between gap-4"
    >
      <!-- Left: Title + Info -->
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-wand text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Content Automation
        </h1>
        <i
          class="ti ti-info-circle text-[16px] text-[#98a2b3] cursor-help"
          title="Konten dibuat setiap jam 2 pagi WIB. Kredit hanya terpotong saat konten dibuat."
        ></i>
      </div>

      <!-- Right: Status Mini Badges -->
      <div class="flex items-center gap-2">
        <span
          class="flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E]"></span>
          <span id="status-active">0</span> Active
        </span>
        <span
          class="flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#ffd900]"></span>
          <span id="status-scheduled"></span> Scheduled
        </span>
      </div>
    </div>

    <!-- Tabs Row -->
    <div class="max-w-6xl mx-auto w-full mb-6 flex items-center gap-4">
      <div
        class="flex items-center gap-1 p-1 bg-white rounded-xl border border-[#eaecf0] w-fit"
      >
        <button
          id="tab-automations"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold bg-[#111827] text-white transition-all cursor-pointer"
          data-tab="automations"
        >
          Automations
        </button>
        <button
          id="tab-generated"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          data-tab="generated"
        >
          Outputs
          <span
            id="generated-badge"
            class="ml-1.5 px-1.5 h-4 rounded-full bg-[#FEF3C7] text-[#B45309] text-[10px] font-bold hidden"
            >0</span
          >
        </button>
      </div>
    </div>

    <!-- TAB: AUTOMATIONS -->
    <div id="tab-content-automations" class="max-w-6xl mx-auto w-full flex-1">
      <!-- Automation Filters -->
      <div class="flex items-center justify-between gap-2 mb-4">
        <div class="flex items-center gap-2">
          <div class="relative" id="business-filter-wrapper">
            <button
              id="btn-business-filter"
              class="flex items-center gap-1.5 px-4 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
            </button>
            <div
              id="business-filter-dropdown"
              class="hidden absolute top-full left-0 mt-1.5 w-48 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
            >
              <div class="flex flex-col p-1.5">
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="all"
                >
                  All Business
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Fresh Juice Co."
                >
                  Fresh Juice Co.
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Tech Startup"
                >
                  Tech Startup
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Luxe Beauty"
                >
                  Luxe Beauty
                </button>
              </div>
            </div>
          </div>

          <!-- Search -->
          <div class="relative flex-1 max-w-xs">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="automation-search"
              type="text"
              placeholder="Search by campaign or business..."
              class="w-80 h-9 pl-8 pr-2 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>
        </div>

        <!-- Create Button (only for Automations tab) -->
        <button
          id="btn-add-automation"
          class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer flex items-center gap-2"
        >
          <i class="ti ti-plus text-[14px]"></i>
          Create Automation
        </button>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="w-full hidden">
        <div class="text-center space-y-4">
          <div
            class="w-16 h-16 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center mx-auto"
          >
            <i class="ti ti-calendar text-[32px] text-[#D1D5DB]"></i>
          </div>
          <div class="space-y-1">
            <h2 class="text-[18px] font-bold text-[#344054]">
              No automation yet
            </h2>
            <p class="text-[14px] text-[#667085] font-medium">
              Create your first automation to start scheduling content.
            </p>
          </div>
          <button
            id="btn-empty-add"
            class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer flex items-center gap-2 mx-auto"
          >
            <i class="ti ti-plus text-[14px]"></i>
            Add Automation
          </button>
        </div>
      </div>

      <!-- Table -->
      <div id="automations-table" class="w-full hidden">
        <div
          class="bg-white rounded-3xl border border-[#eaecf0] overflow-hidden"
        >
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#eaecf0]">
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >BUSINESS</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Task Name</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Schedule</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Content Types</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Status</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider text-right"
                    >Actions</th
                  >
                </tr>
              </thead>
              <tbody id="automations-tbody">
                <!-- Rows injected via JS -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: GENERATED -->
    <div
      id="tab-content-generated"
      class="max-w-6xl mx-auto w-full flex-1 hidden"
    >
      <!-- Filter Bar -->
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <!-- Status Filter -->
        <div class="relative">
          <button
            id="btn-status-filter"
            class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <span id="status-filter-label">All Status</span>
            <i class="ti ti-chevron-down text-[12px]"></i>
          </button>
          <div
            id="status-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-40 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="all">All Status</button>
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="draft">Draft</button>
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="approved">Approved</button>
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="scheduled">Scheduled</button>
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="published">Published</button>
              <button class="status-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-status="failed">Failed</button>
            </div>
          </div>
        </div>

        <!-- Channel Filter -->
        <div class="relative">
          <button
            id="btn-channel-filter"
            class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <span id="channel-filter-label">All Channels</span>
            <i class="ti ti-chevron-down text-[12px]"></i>
          </button>
          <div
            id="channel-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-40 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="channel-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-channel="all">All Channels</button>
              <button class="channel-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-channel="Instagram">Instagram</button>
              <button class="channel-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-channel="TikTok">TikTok</button>
              <button class="channel-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-channel="LinkedIn">LinkedIn</button>
            </div>
          </div>
        </div>

        <!-- Type Filter -->
        <div class="relative">
          <button
            id="btn-type-filter"
            class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <span id="type-filter-label">All Types</span>
            <i class="ti ti-chevron-down text-[12px]"></i>
          </button>
          <div
            id="type-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-40 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="type-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-type="all">All Types</button>
              <button class="type-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-type="Single Post">Single Post</button>
              <button class="type-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-type="Carousel">Carousel</button>
              <button class="type-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-type="Ad Creatives">Ad Creatives</button>
              <button class="type-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-type="Story">Story</button>
            </div>
          </div>
        </div>

        <!-- Search -->
        <div class="relative flex-1 min-w-50 max-w-xs">
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"></i>
          <input
            id="output-search"
            type="text"
            placeholder="Search outputs..."
            class="w-full h-9 pl-8 pr-3 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
          />
        </div>

        <!-- Sort -->
        <div class="relative">
          <button
            id="btn-sort"
            class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <span id="sort-label">Sort: Newest</span>
            <i class="ti ti-chevron-down text-[12px]"></i>
          </button>
          <div
            id="sort-dropdown"
            class="hidden absolute top-full right-0 mt-1.5 w-40 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="sort-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-sort="newest">Newest</button>
              <button class="sort-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-sort="oldest">Oldest</button>
              <button class="sort-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-sort="name">Name</button>
            </div>
          </div>
        </div>

        <!-- View Toggle -->
        <div class="flex items-center p-0.5 rounded-xl border border-[#D0D5DD] bg-white">
          <button
            id="view-grid"
            class="view-toggle-btn w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            data-view-mode="grid"
          >
            <i class="ti ti-layout-grid text-[14px]"></i>
          </button>
          <button
            id="view-list"
            class="view-toggle-btn w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            data-view-mode="list"
          >
            <i class="ti ti-list text-[14px]"></i>
          </button>
        </div>
      </div>

      <!-- Generated Grid -->
      <div
        id="generated-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"
      >
        <!-- Cards injected via JS -->
      </div>

      <!-- Generated Empty State -->
      <div id="generated-empty" class="w-full hidden">
        <div class="text-center space-y-4 py-24">
          <div
            class="w-16 h-16 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center mx-auto"
          >
            <i class="ti ti-photo text-[32px] text-[#D1D5DB]"></i>
          </div>
          <div class="space-y-1">
            <h2 class="text-[18px] font-bold text-[#344054]">
              Belum ada konten
            </h2>
            <p class="text-[14px] text-[#667085] font-medium">
              Konten akan muncul di sini setelah automation berjalan.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MODAL: ADD AUTOMATION (3 STEP WIZARD) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="modal-add-automation"
    class="hidden fixed inset-0 z-100 items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200"
  >
    <div
      class="bg-white w-full max-w-3xl h-160 rounded-4xl shadow-2xl flex flex-col overflow-hidden animate-in zoom-in-95 duration-300 relative"
    >
      <!-- Close Button -->
      <button
        id="close-add-modal"
        class="absolute top-5 right-5 w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer"
      >
        <i class="ti ti-x text-[20px]"></i>
      </button>

      <!-- Header -->
      <div class="px-7 pt-7 pb-3 bg-white relative z-20">
        <h2 class="text-[20px] font-bold text-[#111827] tracking-tight mb-0.5">
          Create Automation
        </h2>
        <p class="text-[13px] text-[#667085]">
          Set up your automated content schedule.
        </p>
        <!-- Step Indicator -->
        <div class="flex items-center gap-2 mt-4">
          <div class="step-dot flex items-center gap-2" data-step="1">
            <div
              class="w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center"
            >
              1
            </div>
            <span class="text-[12px] font-semibold text-[#111827]">General</span
            >
          </div>
          <div class="w-6 h-px bg-[#eaecf0]"></div>
          <div class="step-dot flex items-center gap-2" data-step="2">
            <div
              class="w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center"
            >
              2
            </div>
            <span class="text-[12px] font-semibold text-[#667085]"
              >Schedule</span
            >
          </div>
          <div class="w-6 h-px bg-[#eaecf0]"></div>
          <div class="step-dot flex items-center gap-2" data-step="3">
            <div
              class="w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center"
            >
              3
            </div>
            <span class="text-[12px] font-semibold text-[#667085]">Review</span>
          </div>
        </div>
      </div>

      <!-- Scrollable Content -->
      <div
        id="wizard-content"
        class="flex-1 px-7 pb-24 overflow-y-auto scroll-smooth relative pt-2"
      >
        <!-- STEP 1: General Setup -->
        <div id="step-1" class="step-panel space-y-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-[#344054]"
              >Task Name</label
            >
            <input
              id="input-name"
              type="text"
              placeholder="e.g. Summer Campaign 2026"
              class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>

          <div class="space-y-1.5 relative">
            <label class="text-[13px] font-semibold text-[#344054]"
              >Business DNA</label
            >
            <button
              id="btn-select-dna"
              class="w-full flex items-center gap-3 p-3.5 rounded-2xl border border-[#eaecf0] bg-white text-left transition-all hover:border-[#d0d5dd] hover:bg-gray-50 cursor-pointer"
            >
              <div
                class="w-10 h-10 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
              >
                <i class="ti ti-building text-[20px] text-[#667085]"></i>
              </div>
              <div class="flex-1 min-w-0">
                <p
                  id="dna-selected-name"
                  class="text-[14px] font-bold text-[#111827]"
                >
                  Select Business DNA
                </p>
                <p
                  id="dna-selected-desc"
                  class="text-[12px] text-[#667085] truncate"
                >
                  Choose a business profile for AI grounding
                </p>
              </div>
              <i class="ti ti-chevron-right text-[16px] text-[#98a2b3]"></i>
            </button>
            <!-- DNA Dropdown -->
            <div
              id="dna-dropdown"
              class="hidden absolute left-0 right-0 mt-1 bg-white rounded-2xl border border-[#eaecf0] shadow-[0_8px_30px_rgba(0,0,0,0.08)] z-40 overflow-hidden"
            >
              <div
                class="p-2 space-y-1 max-h-60 overflow-y-auto"
                style="scrollbar-width: none;"
              >
                <button
                  class="dna-option w-full flex items-center gap-3 p-3 rounded-xl text-left hover:bg-[#F9FAFB] transition-colors cursor-pointer"
                  data-name="Fresh Juice Co."
                  data-desc="Organic beverage & lifestyle brand"
                >
                  <div
                    class="w-9 h-9 rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                  >
                    <i class="ti ti-brand-abstract text-[18px] text-[#667085]"
                    ></i>
                  </div>
                  <div>
                    <p class="text-[13px] font-bold text-[#111827]">
