  // ═══════════════════════════════════════════
  // SCHEDULED TAB
  // ═══════════════════════════════════════════
  function renderScheduled() {
    // Get scheduled/published items from generatedContent based on status filter
    let scheduled = generatedContent.filter((item) => {
      if (scheduledStatusFilter === "all") {
        return item.status === "scheduled" || item.status === "published";
      }
      return item.status === scheduledStatusFilter;
    });

    // Apply date filter (use publishedAt for published items, scheduledAt for others)
    const now = new Date();
    if (scheduledFilter === "upcoming") {
      scheduled = scheduled.filter((item) => {
        const dateField =
          item.status === "published" ? item.publishedAt : item.scheduledAt;
        return new Date(dateField) >= now;
      });
    } else if (scheduledFilter === "past") {
      scheduled = scheduled.filter((item) => {
        const dateField =
          item.status === "published" ? item.publishedAt : item.scheduledAt;
        return new Date(dateField) < now;
      });
    }

    // Apply search
    if (scheduledSearchQuery) {
      const q = scheduledSearchQuery.toLowerCase();
      scheduled = scheduled.filter((item) => {
        const haystack =
          `${item.title} ${item.brand} ${item.platform} ${item.contentType}`.toLowerCase();
        return haystack.includes(q);
      });
    }

    // Sort by scheduledAt ascending
    scheduled.sort((a, b) => new Date(a.scheduledAt) - new Date(b.scheduledAt));

    // Update badge
    const upcomingCount = generatedContent.filter(
      (g) => g.status === "scheduled" && new Date(g.scheduledAt) >= now,
    ).length;
    els.scheduledBadge.textContent = upcomingCount;
    els.scheduledBadge.classList.toggle("hidden", upcomingCount === 0);
    if (els.scheduledCountDisplay) els.scheduledCountDisplay.textContent = scheduled.length;

    // Toggle visibility of view containers
    const hasItems = scheduled.length > 0;
    els.scheduledTimeline.classList.toggle(
      "hidden",
      !hasItems || scheduledViewMode !== "list",
    );
    els.scheduledMonthly.classList.toggle(
      "hidden",
      !hasItems || scheduledViewMode !== "monthly",
    );
    els.scheduledWeekly.classList.toggle(
      "hidden",
      !hasItems || scheduledViewMode !== "weekly",
    );
    els.scheduledEmpty.classList.toggle("hidden", hasItems);

    if (!hasItems) return;

    if (scheduledViewMode === "list") {
      renderScheduledList(scheduled);
    } else if (scheduledViewMode === "monthly") {
      renderScheduledMonthly(scheduled);
    } else if (scheduledViewMode === "weekly") {
      renderScheduledWeekly(scheduled);
    }
  }

