  function renderGenerated() {
    // Apply all filters
    let filtered = generatedContent.filter((item) => {
      // Status filter
      if (currentFilter !== "all" && item.status !== currentFilter) return false;
      // Channel filter
      if (currentChannel !== "all" && item.platform !== currentChannel) return false;
      // Type filter
      if (currentType !== "all" && item.contentType !== currentType) return false;
      // Search
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        const haystack = `${item.title} ${item.brand} ${item.caption}`.toLowerCase();
        if (!haystack.includes(q)) return false;
      }
      return true;
    });

    // Apply sort
    filtered.sort((a, b) => {
      if (currentSort === "newest") return new Date(b.createdAt) - new Date(a.createdAt);
      if (currentSort === "oldest") return new Date(a.createdAt) - new Date(b.createdAt);
      if (currentSort === "name") return a.title.localeCompare(b.title);
      return 0;
    });

    // Update badge (draft + approved + failed = needs attention)
    const needsAttentionCount = generatedContent.filter(
      (g) => g.status === "draft" || g.status === "approved" || g.status === "failed",
    ).length;
    els.generatedBadge.textContent = needsAttentionCount;
    els.generatedBadge.classList.toggle("hidden", needsAttentionCount === 0);

    // Update grid/list classes
    if (currentViewMode === "grid") {
      els.generatedGrid.className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4";
    } else {
      els.generatedGrid.className = "flex flex-col gap-3";
    }

    if (filtered.length === 0) {
      els.generatedGrid.classList.add("hidden");
      els.generatedEmpty.classList.remove("hidden");
      els.generatedEmpty.classList.add(
        "flex",
        "flex-col",
        "items-center",
        "justify-center",
        "py-24",
      );
      return;
    }

    els.generatedGrid.classList.remove("hidden");
    els.generatedEmpty.classList.add("hidden");
    els.generatedEmpty.classList.remove(
      "flex",
      "flex-col",
      "items-center",
      "justify-center",
      "py-24",
    );

    const statusConfig = {
      draft: { dot: "bg-[#F59E0B]", label: "Draft" },
      approved: { dot: "bg-[#22C55E]", label: "Approved" },
      scheduled: { dot: "bg-[#8B5CF6]", label: "Scheduled" },
      published: { dot: "bg-[#3B82F6]", label: "Published" },
      failed: { dot: "bg-[#EF4444]", label: "Failed" },
    };

    const platformIconMap = {
      Instagram: "ti-brand-instagram",
      TikTok: "ti-brand-tiktok",
      LinkedIn: "ti-brand-linkedin",
      Facebook: "ti-brand-facebook",
      X: "ti-brand-x",
    };

    if (currentViewMode === "grid") {
      els.generatedGrid.innerHTML = filtered.map((item) => renderGridCard(item, statusConfig, platformIconMap)).join("");
    } else {
      els.generatedGrid.innerHTML = filtered.map((item) => renderListRow(item, statusConfig, platformIconMap)).join("");
    }
  }

  function renderGridCard(item, statusConfig, platformIconMap) {
    const cfg = statusConfig[item.status];
    const dateStr = formatRelativeDate(item.createdAt);
    const platformIcon = platformIconMap[item.platform] || "ti-file";

    const statsRow = item.status === "published" && (item.views > 0 || item.likes > 0 || item.comments > 0)
      ? `<div class="flex items-center gap-3 pt-2 border-t border-[#eaecf0]">
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-eye text-[12px]"></i>
            ${item.views >= 1000 ? (item.views / 1000).toFixed(1) + "K" : item.views}
          </div>
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-heart text-[12px]"></i>
            ${item.likes >= 1000 ? (item.likes / 1000).toFixed(1) + "K" : item.likes}
          </div>
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-message text-[12px]"></i>
            ${item.comments}
          </div>
        </div>`
      : "";

    const failBadge = item.status === "failed" && item.failReason
      ? `<span class="text-[10px] text-[#EF4444] font-medium">${item.failReason}</span>`
      : "";

    return `
    <div class="group relative bg-white rounded-3xl border border-[#eaecf0] overflow-hidden hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:border-transparent transition-all cursor-pointer" onclick="openPreviewModal('${item.id}')">
      <!-- Image Placeholder -->
      <div class="aspect-square bg-white flex items-center justify-center relative">
        <!-- Status Dot -->
        <span class="absolute top-3 left-3 flex items-center gap-1.5 px-2 h-5 rounded-full bg-white/90 backdrop-blur-sm border border-[#eaecf0] text-[10px] font-bold text-[#667085]">
          <span class="w-1.5 h-1.5 rounded-full ${cfg.dot}"></span>
          ${cfg.label}
        </span>
        <!-- Auto Engagement Indicator -->
        ${
          item.autoComment?.enabled || item.autoDm?.enabled
            ? `<span class="absolute top-3 right-3 w-6 h-6 rounded-full bg-[#EFF6FF] border border-[#dbeafe] flex items-center justify-center" title="Auto Engagement active">
          <i class="ti ti-message-share text-[12px] text-[#2563EB]"></i>
        </span>`
            : ""
        }
      </div>
      <!-- Info -->
      <div class="p-4 space-y-2">
        <h3 class="text-[14px] font-bold text-[#111827] truncate">${escapeHtml(item.title)}</h3>
        <div class="flex items-center justify-between">
          <span class="text-[12px] text-[#667085]">${escapeHtml(item.brand)}</span>
          <span class="text-[11px] text-[#98a2b3]">${dateStr}</span>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-1.5">
            <i class="ti ${platformIcon} text-[12px] text-[#98a2b3]"></i>
            <span class="text-[11px] text-[#98a2b3]">${item.platform || item.contentType}</span>
          </div>
          ${item.status === "published" || item.status === "scheduled" ? `<span class="text-[10px] text-[#2563EB] font-medium">${formatScheduledTime(item.scheduledAt)}</span>` : ""}
          ${failBadge}
        </div>
        ${statsRow}
      </div>
    </div>
  `;
  }

  function renderListRow(item, statusConfig, platformIconMap) {
    const cfg = statusConfig[item.status];
    const dateStr = formatRelativeDate(item.createdAt);
    const platformIcon = platformIconMap[item.platform] || "ti-file";

    const statsRow = item.status === "published" && (item.views > 0 || item.likes > 0 || item.comments > 0)
      ? `<div class="flex items-center gap-3 ml-auto">
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-eye text-[12px]"></i>
            ${item.views >= 1000 ? (item.views / 1000).toFixed(1) + "K" : item.views}
          </div>
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-heart text-[12px]"></i>
            ${item.likes >= 1000 ? (item.likes / 1000).toFixed(1) + "K" : item.likes}
          </div>
          <div class="flex items-center gap-1 text-[11px] text-[#667085]">
            <i class="ti ti-message text-[12px]"></i>
            ${item.comments}
          </div>
        </div>`
      : "";

    const failBadge = item.status === "failed" && item.failReason
      ? `<span class="text-[10px] text-[#EF4444] font-medium ml-auto">${item.failReason}</span>`
      : "";

    const engagementIcon = item.autoComment?.enabled || item.autoDm?.enabled
      ? `<span class="w-6 h-6 rounded-full bg-[#EFF6FF] border border-[#dbeafe] flex items-center justify-center ml-2" title="Auto Engagement active">
          <i class="ti ti-message-share text-[12px] text-[#2563EB]"></i>
        </span>`
      : "";

    return `
    <div class="group flex items-center gap-4 bg-white rounded-2xl border border-[#eaecf0] p-3 hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:border-transparent transition-all cursor-pointer" onclick="openPreviewModal('${item.id}')">
      <!-- Thumbnail -->
      <div class="w-14 h-14 rounded-xl bg-white border border-[#eaecf0] flex-shrink-0 flex items-center justify-center relative">
        <span class="absolute -top-1.5 -left-1.5 flex items-center gap-1 px-1.5 h-4 rounded-full bg-white border border-[#eaecf0] text-[9px] font-bold text-[#667085]">
          <span class="w-1 h-1 rounded-full ${cfg.dot}"></span>
          ${cfg.label}
        </span>
      </div>
      <!-- Info -->
      <div class="flex-1 min-w-0">
        <h3 class="text-[13px] font-bold text-[#111827] truncate">${escapeHtml(item.title)}</h3>
        <div class="flex items-center gap-2 mt-0.5">
          <span class="text-[11px] text-[#667085]">${escapeHtml(item.brand)}</span>
          <span class="text-[10px] text-[#98a2b3]">• ${dateStr}</span>
        </div>
      </div>
      <!-- Meta -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <div class="flex items-center gap-1.5">
          <i class="ti ${platformIcon} text-[12px] text-[#98a2b3]"></i>
          <span class="text-[11px] text-[#98a2b3]">${item.platform || item.contentType}</span>
        </div>
        ${engagementIcon}
        ${item.status === "published" || item.status === "scheduled" ? `<span class="text-[10px] text-[#2563EB] font-medium">${formatScheduledTime(item.scheduledAt)}</span>` : ""}
        ${failBadge}
        ${statsRow}
      </div>
    </div>
  `;
  }

  function formatRelativeDate(dateStr) {
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    const date = new Date(dateStr);
    date.setHours(0, 0, 0, 0);
    const diffMs = now - date;
    const diffDays = Math.floor(diffMs / (24 * 60 * 60 * 1000));

    if (diffDays === 0) return "Hari ini";
    if (diffDays === 1) return "Kemarin";
    if (diffDays < 7) {
      const days = [
        "Minggu",
        "Senin",
        "Selasa",
        "Rabu",
        "Kamis",
        "Jumat",
        "Sabtu",
      ];
      return days[date.getDay()];
    }
    return date.toLocaleDateString("id-ID", {
      day: "numeric",
      month: "short",
    });
  }

  function formatScheduledTime(dateStr) {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = date - now;
    const diffMins = Math.floor(diffMs / (60 * 1000));
    const diffHours = Math.floor(diffMs / (60 * 60 * 1000));

    if (diffMins <= 0) return "Publishing now";
    if (diffMins < 60) return `${diffMins}m`;
    if (diffHours < 24) return `${diffHours}h`;
    return date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    });
  }

  // ═══════════════════════════════════════════
  // PREVIEW MODAL
  // ═══════════════════════════════════════════
  function openPreviewModal(genId) {
    previewingContentId = genId;
    const item = generatedContent.find((g) => g.id === genId);
    if (!item) return;

    const statusConfig = {
      draft: {
        bg: "bg-[#FEF3C7]",
        text: "text-[#B45309]",
        border: "border-[#FDE68A]",
        label: "Draft",
      },
      approved: {
        bg: "bg-[#ECFDF3]",
        text: "text-[#027A48]",
        border: "border-[#D1FADF]",
        label: "Approved",
      },
      scheduled: {
        bg: "bg-[#F5F3FF]",
        text: "text-[#7C3AED]",
        border: "border-[#DDD6FE]",
        label: "Scheduled",
      },
      published: {
        bg: "bg-[#EFF6FF]",
        text: "text-[#2563EB]",
        border: "border-[#DBEAFE]",
        label: "Published",
      },
      failed: {
        bg: "bg-[#FEF3F2]",
        text: "text-[#B42318]",
        border: "border-[#FECDCA]",
        label: "Failed",
      },
    };
    const cfg = statusConfig[item.status];
    const dateStr = new Date(item.createdAt).toLocaleDateString("id-ID", {
      day: "numeric",
      month: "long",
      year: "numeric",
    });

    els.previewStatusBadge.className = `inline-flex items-center px-2.5 h-6 rounded-full text-[11px] font-bold ${cfg.bg} ${cfg.text} border ${cfg.border}`;
    els.previewStatusBadge.textContent = cfg.label;

    // Platform icon map (used below)
    const platformIconMap = {
      Instagram: "ti-brand-instagram",
      TikTok: "ti-brand-tiktok",
      LinkedIn: "ti-brand-linkedin",
      Facebook: "ti-brand-facebook",
      X: "ti-brand-x",
    };

    // Header info
    els.previewTitleHeader.textContent = item.title;
    els.previewPlatformIconHeader.className = `ti ${platformIconMap[item.platform] || "ti-file"} text-[14px] text-[#E1306C]`;
    els.previewPlatformHeader.textContent = item.platform || "-";
    els.previewBrandHeader.textContent = item.brand;
    els.previewDateHeader.textContent = formatRelativeDate(item.createdAt);

    // Body content
    els.previewDate.textContent = dateStr;
    els.previewTitle.textContent = item.title;
    els.previewBrand.textContent = item.brand;
    els.previewCaption.textContent = item.caption;
    els.previewTypeIcon.className = `ti ${CONTENT_ICONS[item.contentType] || "ti-file"} text-[16px] text-[#667085]`;
    els.previewType.textContent = item.contentType;
    els.previewAutomation.textContent = item.automationName;

    // Platform
    els.previewPlatformIcon.className = `ti ${platformIconMap[item.platform] || "ti-file"} text-[16px] text-[#667085]`;
    els.previewPlatform.textContent = item.platform || "-";

    // Stats (published only)
    if (item.status === "published" && (item.views > 0 || item.likes > 0 || item.comments > 0)) {
      els.previewStatsSection.classList.remove("hidden");
      els.previewViews.textContent = item.views >= 1000 ? (item.views / 1000).toFixed(1) + "K" : item.views;
      els.previewLikes.textContent = item.likes >= 1000 ? (item.likes / 1000).toFixed(1) + "K" : item.likes;
      els.previewComments.textContent = item.comments;
    } else {
      els.previewStatsSection.classList.add("hidden");
    }

    // Fail reason (failed only)
    if (item.status === "failed" && item.failReason) {
      els.previewFailSection.classList.remove("hidden");
      els.previewFailReason.textContent = item.failReason;
    } else {
      els.previewFailSection.classList.add("hidden");
    }

    // Show/hide actions based on status
    if (item.status === "draft") {
      els.previewActions.classList.remove("hidden");
      els.previewActions.classList.add("flex");
      els.previewApprovedActions.classList.add("hidden");
      els.previewApprovedActions.classList.remove("flex");
      els.previewScheduledActions.classList.add("hidden");
      els.previewScheduledActions.classList.remove("flex");
    } else if (item.status === "approved") {
      els.previewActions.classList.add("hidden");
      els.previewActions.classList.remove("flex");
      els.previewApprovedActions.classList.remove("hidden");
      els.previewApprovedActions.classList.add("flex");
      els.previewScheduledActions.classList.add("hidden");
      els.previewScheduledActions.classList.remove("flex");
    } else if (item.status === "scheduled") {
      els.previewActions.classList.add("hidden");
      els.previewActions.classList.remove("flex");
      els.previewApprovedActions.classList.add("hidden");
      els.previewApprovedActions.classList.remove("flex");
      els.previewScheduledActions.classList.remove("hidden");
      els.previewScheduledActions.classList.add("flex");
      // Show scheduled time
      const scheduledAt = item.scheduledAt ? new Date(item.scheduledAt) : null;
      if (scheduledAt) {
        els.previewScheduledTime.textContent = scheduledAt.toLocaleString(
          "en-US",
          {
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          },
        );
      } else {
        els.previewScheduledTime.textContent = "Now";
      }
    } else if (item.status === "published") {
      els.previewActions.classList.add("hidden");
      els.previewActions.classList.remove("flex");
      els.previewApprovedActions.classList.add("hidden");
      els.previewApprovedActions.classList.remove("flex");
      els.previewScheduledActions.classList.remove("hidden");
      els.previewScheduledActions.classList.add("flex");
      // Show scheduled time
      const scheduledAt = item.scheduledAt ? new Date(item.scheduledAt) : null;
      if (scheduledAt) {
        els.previewScheduledTime.textContent = scheduledAt.toLocaleString(
          "en-US",
          {
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          },
        );
      } else {
        els.previewScheduledTime.textContent = "Now";
      }
    } else if (item.status === "failed") {
      // Failed: show Edit button to duplicate as draft
      els.previewActions.classList.add("hidden");
      els.previewActions.classList.remove("flex");
      els.previewApprovedActions.classList.remove("hidden");
      els.previewApprovedActions.classList.add("flex");
      els.previewScheduledActions.classList.add("hidden");
      els.previewScheduledActions.classList.remove("flex");
    } else {
      els.previewActions.classList.add("hidden");
      els.previewActions.classList.remove("flex");
      els.previewApprovedActions.classList.add("hidden");
      els.previewApprovedActions.classList.remove("flex");
      els.previewScheduledActions.classList.add("hidden");
      els.previewScheduledActions.classList.remove("flex");
    }

    // Open slide-over
    els.modalPreview.classList.remove("hidden");
    els.modalPreview.classList.add("flex");
    requestAnimationFrame(() => {
      els.previewBackdrop.classList.remove("opacity-0");
      els.previewPanel.classList.remove("translate-x-full");
    });
  }

  function closePreviewModal() {
    els.previewBackdrop.classList.add("opacity-0");
    els.previewPanel.classList.add("translate-x-full");
    setTimeout(() => {
      els.modalPreview.classList.add("hidden");
      els.modalPreview.classList.remove("flex");
      previewingContentId = null;
    }, 300);
  }

  function approveContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "approved";
    saveGenerated();
    renderGenerated();
    openPreviewModal(previewingContentId);
  }

  function rejectContent() {
    if (!previewingContentId) return;
    if (
      !confirm(
        "Are you sure you want to reject this content? It will be deleted.",
      )
    )
      return;
    generatedContent = generatedContent.filter(
      (g) => g.id !== previewingContentId,
    );
    saveGenerated();
    renderGenerated();
    closePreviewModal();
  }

  // ═══════════════════════════════════════════
  // EDIT & DUPLICATE CONTENT
  // ═══════════════════════════════════════════
  function editAndDuplicateContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    // Create a duplicate as new draft
    const newItem = {
      ...item,
      id: "gen_" + Date.now(),
      status: "draft",
      scheduledAt: null,
      createdAt: new Date().toISOString(),
      title: item.title + " (Copy)",
    };

    generatedContent.push(newItem);
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content duplicated as new draft!");
  }

  // ═══════════════════════════════════════════
  // SCHEDULE MODAL
  // ═══════════════════════════════════════════
  function openScheduleModal() {
    if (!previewingContentId) return;
    // Set default to tomorrow at 9am
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    tomorrow.setHours(9, 0, 0, 0);
    els.scheduleDate.value = tomorrow.toISOString().split("T")[0];
    els.scheduleTime.value = "09:00";
    els.modalSchedule.classList.remove("hidden");
    els.modalSchedule.classList.add("flex");
  }

  function closeScheduleModalFn() {
    els.modalSchedule.classList.add("hidden");
    els.modalSchedule.classList.remove("flex");
  }

  function confirmSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const dateVal = els.scheduleDate.value;
    const timeVal = els.scheduleTime.value;
    if (dateVal && timeVal) {
      item.scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();
    }
    item.status = "published";
    saveGenerated();
    renderGenerated();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled successfully!");
  }

  function publishNow() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "published";
    item.scheduledAt = new Date().toISOString();
    saveGenerated();
    renderGenerated();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content will be published now!");
  }

  function publishIn1Hour() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const in1h = new Date(Date.now() + 60 * 60 * 1000);
    item.status = "published";
    item.scheduledAt = in1h.toISOString();
    saveGenerated();
    renderGenerated();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled for 1 hour from now!");
  }

  function cancelSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    if (!confirm("Cancel this scheduled upload?")) return;
    item.status = "approved";
    item.scheduledAt = null;
    saveGenerated();
    renderGenerated();
    openPreviewModal(previewingContentId);
    showToast("Schedule cancelled.");
  }

  function rescheduleContent() {
    openScheduleModal();
  }

  // ═══════════════════════════════════════════
  // AUTO ENGAGEMENT MODAL
  // ═══════════════════════════════════════════
  function openEngagementFromPreview() {
    if (!previewingContentId) return;
    // Open engagement modal for this generated content
    editingAutomationId = previewingContentId;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    const ac = item.autoComment || {
      enabled: false,
      text: "",
      link: "",
      keywords: "",
    };
    const dm = item.autoDm || {
      enabled: false,
      text: "",
      link: "",
      keywords: "",
    };

    els.commentToggle.checked = ac.enabled;
    els.commentText.value = ac.text || "";
    els.commentLink.value = ac.link || "";
    els.commentKeywords.value = ac.keywords || "";
    els.commentFields.classList.toggle("hidden", !ac.enabled);

    els.dmToggle.checked = dm.enabled;
    els.dmText.value = dm.text || "";
    els.dmLink.value = dm.link || "";
    els.dmKeywords.value = dm.keywords || "";
    els.dmFields.classList.toggle("hidden", !dm.enabled);

    els.modalEngagement.classList.remove("hidden");
    els.modalEngagement.classList.add("flex");
  }

  function closeEngagementModalFn() {
    els.modalEngagement.classList.add("hidden");
    els.modalEngagement.classList.remove("flex");
    editingAutomationId = null;
  }

  function saveEngagement() {
    if (!editingAutomationId) return;
    const item = generatedContent.find((g) => g.id === editingAutomationId);
    if (!item) return;

    item.autoComment = {
      enabled: els.commentToggle.checked,
      text: els.commentText.value.trim(),
      link: els.commentLink.value.trim(),
      keywords: els.commentKeywords.value.trim(),
    };
    item.autoDm = {
      enabled: els.dmToggle.checked,
      text: els.dmText.value.trim(),
      link: els.dmLink.value.trim(),
      keywords: els.dmKeywords.value.trim(),
    };

    saveGenerated();
    renderGenerated();
    closeEngagementModalFn();
    showToast("Auto Engagement settings saved!");
  }

  function loadAutomations() {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) automations = JSON.parse(stored);
    } catch (e) {
      automations = [];
    }
  }

  function saveAutomations() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(automations));
  }

  // ═══════════════════════════════════════════
  // RENDER AUTOMATIONS TABLE
  // ═══════════════════════════════════════════
  function renderAutomations() {
    const activeCount = automations.filter((a) => a.status === "active").length;
    const scheduledCount = automations.filter(
      (a) => a.status === "paused",
    ).length;
    els.activeCount.textContent = activeCount;
    els.scheduledCount.textContent = scheduledCount;

    if (automations.length === 0) {
      els.emptyState.classList.remove("hidden");
      els.emptyState.classList.add(
        "flex",
        "flex-col",
        "items-center",
        "justify-center",
        "py-24",
      );
      els.table.classList.add("hidden");
      return;
    }

    els.emptyState.classList.add("hidden");
    els.emptyState.classList.remove(
      "flex",
      "flex-col",
      "items-center",
      "justify-center",
      "py-24",
    );
    els.table.classList.remove("hidden");

    els.tbody.innerHTML = automations
      .map((auto) => {
        const dateCount = Object.keys(auto.selectedDates).length;
        const contentTypes = [
          ...new Set(
            Object.values(auto.selectedDates)
              .flat()
              .map((s) => s.contentType),
          ),
        ];
        const typeLabels = contentTypes
          .map(
            (t) =>
              `<span class="inline-flex items-center gap-1 px-2 h-6 rounded-full bg-[#F9FAFB] border border-[#eaecf0] text-[11px] font-medium text-[#667085]">
                <i class="ti ${CONTENT_ICONS[t] || "ti-file"} text-[12px]"></i>
                ${t}
              </span>`,
          )
          .join("");

        return `
