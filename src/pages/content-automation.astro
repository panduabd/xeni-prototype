  function toggleSelectCard(id) {
    const idx = selectedApprovedIds.indexOf(id);
    if (idx > -1) {
      selectedApprovedIds.splice(idx, 1);
    } else {
      selectedApprovedIds.push(id);
    }
    updateBulkHeader();

    const cb = document.getElementById(`cb-select-${id}`);
    const card = document.getElementById(`card-approved-${id}`);
    const container = document.getElementById(`checkbox-container-${id}`);
    const isSel = selectedApprovedIds.includes(id);

    if (cb) {
      cb.checked = isSel;
    }
    if (container) {
      if (isSel) {
        container.classList.add("opacity-100");
        container.classList.remove("opacity-0", "group-hover:opacity-100");
      } else {
        container.classList.remove("opacity-100");
        container.classList.add("opacity-0", "group-hover:opacity-100");
      }
    }
    if (card) {
      if (isSel) {
        card.classList.add("border-[#2563EB]", "ring-2", "ring-[#2563EB]/10");
        card.classList.remove("border-[#eaecf0]");
      } else {
        card.classList.remove(
          "border-[#2563EB]",
          "ring-2",
          "ring-[#2563EB]/10",
        );
        card.classList.add("border-[#eaecf0]");
      }
    }
  }

  function updateBulkHeader() {
    const bulkHeader = document.getElementById("approved-bulk-header");
    const selectedCount = document.getElementById("selected-count");
    if (selectedApprovedIds.length > 0) {
      if (bulkHeader) {
        bulkHeader.classList.remove("hidden");
        bulkHeader.classList.add("flex");
      }
      if (selectedCount)
        selectedCount.textContent = `${selectedApprovedIds.length} terpilih`;
    } else {
      if (bulkHeader) {
        bulkHeader.classList.add("hidden");
        bulkHeader.classList.remove("flex");
      }
    }
  }

  function deselectAllApproved() {
    selectedApprovedIds = [];
    updateBulkHeader();
    renderGenerated();
  }

  function bulkPublishSelected() {
    if (selectedApprovedIds.length === 0) return;

    generatedContent.forEach((item) => {
      if (selectedApprovedIds.includes(item.id)) {
        item.status = "published";
      }
    });

    localStorage.setItem(
      GENERATED_STORAGE_KEY,
      JSON.stringify(generatedContent),
    );

    showToast(
      `Berhasil menerbitkan ${selectedApprovedIds.length} konten secara bulk!`,
    );
    selectedApprovedIds = [];
    updateBulkHeader();
    renderGenerated();
  }

  // ═══════════════════════════════════════════
  // BULK SCHEDULE MODAL
  // ═══════════════════════════════════════════
  function openBulkScheduleModal() {
    if (selectedApprovedIds.length === 0) return;

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    const dateStr = tomorrow.toISOString().split("T")[0];

    document.getElementById("bulk-same-date").value = dateStr;
    document.getElementById("bulk-daily-start").value = dateStr;
    document.getElementById("bulk-schedule-count").textContent =
      selectedApprovedIds.length;

    bulkScheduleData.sameDate = dateStr;
    bulkScheduleData.dailyStartDate = dateStr;
    bulkScheduleData.customAssignments = {};

    // Load engagement settings from first selected item
    const firstItem = generatedContent.find(
      (g) => g.id === selectedApprovedIds[0],
    );
    bulkScheduleEngagement = firstItem?.autoEngagement
      ? { ...firstItem.autoEngagement }
      : {};
    updateBulkScheduleEngagementIndicator();

    renderBulkCustomList();
    switchBulkScheduleTab("same-time");

    const modal = document.getElementById("modal-bulk-schedule");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  function closeBulkScheduleModal() {
    const modal = document.getElementById("modal-bulk-schedule");
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  function switchBulkScheduleTab(mode) {
    bulkScheduleMode = mode;

    document.querySelectorAll(".bulk-schedule-tab").forEach((btn) => {
      const isActive = btn.dataset.tab === mode;
      if (isActive) {
        btn.classList.add("bg-white", "text-[#111827]", "shadow-sm");
        btn.classList.remove("text-[#667085]", "hover:bg-white/50");
      } else {
        btn.classList.remove("bg-white", "text-[#111827]", "shadow-sm");
        btn.classList.add("text-[#667085]", "hover:bg-white/50");
      }
    });

    document
      .getElementById("bulk-panel-same-time")
      .classList.toggle("hidden", mode !== "same-time");
    document
      .getElementById("bulk-panel-daily-post")
      .classList.toggle("hidden", mode !== "daily-post");
    document
      .getElementById("bulk-panel-custom")
      .classList.toggle("hidden", mode !== "custom");

    renderBulkSchedulePreview();
  }

  function renderBulkCustomList() {
    const container = document.getElementById("bulk-custom-list");
    const items = generatedContent.filter((g) =>
      selectedApprovedIds.includes(g.id),
    );

    container.innerHTML = items
      .map((item, idx) => {
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1 + idx);
        const defaultDate = tomorrow.toISOString().split("T")[0];

        return `
      <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#FEF3C7] to-[#FDE68A] flex items-center justify-center shrink-0">
          <i class="ti ti-photo text-[14px] text-[#B45309]"></i>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[12px] font-semibold text-[#111827] truncate">${escapeHtml(item.title)}</p>
          <p class="text-[10px] text-[#98a2b3]">${escapeHtml(item.brand)}</p>
        </div>
        <input
          type="date"
          value="${defaultDate}"
          onchange="updateBulkCustomDate('${item.id}', this.value)"
          class="w-32 h-8 px-2 rounded-lg border border-[#eaecf0] bg-white text-[11px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
        />
        <input
          type="time"
          value="08:00"
          onchange="updateBulkCustomTime('${item.id}', this.value)"
          class="w-24 h-8 px-2 rounded-lg border border-[#eaecf0] bg-white text-[11px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
        />
      </div>
      `;
      })
      .join("");
  }

  function updateBulkCustomDate(id, val) {
    if (!bulkScheduleData.customAssignments[id])
      bulkScheduleData.customAssignments[id] = {};
    bulkScheduleData.customAssignments[id].date = val;
    renderBulkSchedulePreview();
  }

  function updateBulkCustomTime(id, val) {
    if (!bulkScheduleData.customAssignments[id])
      bulkScheduleData.customAssignments[id] = {};
    bulkScheduleData.customAssignments[id].time = val;
    renderBulkSchedulePreview();
  }

  function adjustBulkDailyPosts(delta) {
    const input = document.getElementById("bulk-daily-posts");
    let val = parseInt(input.value) || 1;
    val = Math.max(1, Math.min(24, val + delta));
    input.value = val;
    bulkScheduleData.dailyPostsPerDay = val;
    renderBulkSchedulePreview();
  }

  function renderBulkSchedulePreview() {
    const preview = document.getElementById("bulk-schedule-preview");
    const items = generatedContent.filter((g) =>
      selectedApprovedIds.includes(g.id),
    );
    const assignments = [];

    if (bulkScheduleMode === "same-time") {
      const dateVal = document.getElementById("bulk-same-date")?.value;
      const timeVal = document.getElementById("bulk-same-time")?.value;
      if (dateVal && timeVal) {
        items.forEach((item) => {
          assignments.push({
            title: item.title,
            date: `${dateVal} ${timeVal}`,
          });
        });
      }
    } else if (bulkScheduleMode === "daily-post") {
      const startVal = document.getElementById("bulk-daily-start")?.value;
      const timeVal = document.getElementById("bulk-daily-time")?.value;
      const postsPerDay =
        parseInt(document.getElementById("bulk-daily-posts")?.value) || 1;

      if (startVal && timeVal) {
        const startDate = new Date(startVal);
        let currentIndex = 0;

        items.forEach((item) => {
          const dayOffset = Math.floor(currentIndex / postsPerDay);
          const d = new Date(startDate);
          d.setDate(d.getDate() + dayOffset);
          const dateStr = d.toISOString().split("T")[0];
          assignments.push({
            title: item.title,
            date: `${dateStr} ${timeVal}`,
          });
          currentIndex++;
        });
      }
    } else if (bulkScheduleMode === "custom") {
      items.forEach((item) => {
        const custom = bulkScheduleData.customAssignments[item.id] || {};
        const dateStr = custom.date || "Not set";
        const timeStr = custom.time || "";
        assignments.push({
          title: item.title,
          date: `${dateStr} ${timeStr}`.trim(),
        });
      });
    }

    preview.innerHTML = assignments
      .map(
        (a) => `
      <div class="flex items-center gap-2 text-[12px]">
        <i class="ti ti-calendar text-[#98a2b3]"></i>
        <span class="text-[#667085] truncate flex-1">${escapeHtml(a.title)}</span>
        <span class="text-[#111827] font-medium">${a.date}</span>
      </div>
    `,
      )
      .join("");
  }

  function confirmBulkSchedule() {
    const items = generatedContent.filter((g) =>
      selectedApprovedIds.includes(g.id),
    );

    if (bulkScheduleMode === "same-time") {
      const dateVal = document.getElementById("bulk-same-date").value;
      const timeVal = document.getElementById("bulk-same-time").value;
      if (!dateVal || !timeVal) {
        showToast("Please fill in date and time");
        return;
      }
      const scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();
      items.forEach((item) => {
        item.status = "scheduled";
        item.scheduledAt = scheduledAt;
      });
    } else if (bulkScheduleMode === "daily-post") {
      const startVal = document.getElementById("bulk-daily-start").value;
      const timeVal = document.getElementById("bulk-daily-time").value;
      const postsPerDay =
        parseInt(document.getElementById("bulk-daily-posts").value) || 1;

      if (!startVal || !timeVal) {
        showToast("Please fill in start date and time");
        return;
      }

      const startDate = new Date(startVal);
      let currentIndex = 0;

      items.forEach((item) => {
        const dayOffset = Math.floor(currentIndex / postsPerDay);
        const d = new Date(startDate);
        d.setDate(d.getDate() + dayOffset);
        d.setHours(
          parseInt(timeVal.split(":")[0]),
          parseInt(timeVal.split(":")[1]),
        );
        item.status = "scheduled";
        item.scheduledAt = d.toISOString();
        currentIndex++;
      });
    } else if (bulkScheduleMode === "custom") {
      items.forEach((item) => {
        const custom = bulkScheduleData.customAssignments[item.id] || {};
        if (custom.date && custom.time) {
          item.status = "scheduled";
          item.scheduledAt = new Date(
            `${custom.date}T${custom.time}`,
          ).toISOString();
        }
      });
    }

    // Apply engagement settings to all scheduled items if any were set
    if (Object.keys(bulkScheduleEngagement).length > 0) {
      items.forEach((item) => {
        item.autoEngagement = { ...bulkScheduleEngagement };
      });
      saveGenerated();
    }

    showToast(`Scheduled ${items.length} items successfully!`);
    selectedApprovedIds = [];
    updateBulkHeader();
    closeBulkScheduleModal();
    renderGenerated();
    renderScheduled();
  }

  function bulkDeleteSelected() {
    if (selectedApprovedIds.length === 0) return;
    if (!confirm(`Delete ${selectedApprovedIds.length} selected items?`))
      return;

    generatedContent = generatedContent.filter(
      (g) => !selectedApprovedIds.includes(g.id),
    );
    saveGenerated();
    showToast(`Deleted ${selectedApprovedIds.length} items`);
    selectedApprovedIds = [];
    updateBulkHeader();
    renderGenerated();
  }

