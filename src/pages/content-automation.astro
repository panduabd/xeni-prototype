          <td class="px-5 py-4">
            <div class="flex items-center justify-end gap-1">
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#EFF6FF] flex items-center justify-center text-[#667085] hover:text-[#2563EB] transition-colors cursor-pointer"
