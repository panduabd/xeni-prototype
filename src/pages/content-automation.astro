  function addAutomation() {
    if (!activePopoverDate) return;

    // Create date array if doesn't exist
    if (!wizardData.selectedDates[activePopoverDate]) {
      wizardData.selectedDates[activePopoverDate] = [];
    }

    const slots = wizardData.selectedDates[activePopoverDate];
    const variations = parseInt(els.automationVariations.value) || 1;
    const editIndex = parseInt(els.btnAddSlot.dataset.editIndex);

    if (!isNaN(editIndex) && editIndex >= 0 && slots[editIndex]) {
      // Update existing
      slots[editIndex] = {
        contentType: els.slotContentType.value,
        category: els.slotCategory.value.trim(),
        prompt: els.slotPrompt.value.trim(),
        variations: Math.max(1, Math.min(10, variations)),
      };
    } else {
      // Add new
      slots.push({
        contentType: els.slotContentType.value,
        category: els.slotCategory.value.trim(),
        prompt: els.slotPrompt.value.trim(),
        variations: Math.max(1, Math.min(10, variations)),
      });
    }

    renderCalendar();
    closeAutomationPopover();
  }

