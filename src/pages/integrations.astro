---
import AppLayout from "../layouts/AppLayout.astro";

const dnaList = [
  { id: "all", name: "All Business" },
  { id: "1", name: "Fresh Juice Co." },
  { id: "2", name: "Acme Corp" },
  { id: "3", name: "Luxe Beauty" },
  { id: "4", name: "TechStart Inc" },
  { id: "tech", name: "TechFlow Systems" },
  { id: "brew", name: "Daily Brew Cafe" },
  { id: "fit", name: "FitLife Gym" },
  { id: "eco", name: "EcoGreen Solutions" },
  { id: "urban", name: "Urban Outfitters" },
  { id: "pixel", name: "Pixel Perfect Studio" },
  { id: "nova", name: "Nova Logistics" },
  { id: "summit", name: "Summit Outdoors" },
  { id: "glow", name: "Glow Skincare" },
  { id: "byte", name: "Byte Labs" },
  { id: "vista", name: "Vista Real Estate" },
  { id: "peak", name: "Peak Performance" },
  { id: "swift", name: "Swift Delivery" },
  { id: "bloom", name: "Bloom Florist" },
  { id: "ocean", name: "Oceanic Seafood" },
  { id: "apex", name: "Apex Consulting" }
];

const platforms = [
  { id: "facebook", name: "Facebook", icon: "ti-brand-facebook", color: "#1877F2" },
  { id: "threads", name: "Threads", icon: "ti-brand-threads", color: "#000000" },
  { id: "instagram", name: "Instagram", icon: "ti-brand-instagram", color: "#E4405F" },
  { id: "tiktok", name: "TikTok", icon: "ti-brand-tiktok", color: "#000000" },
];

const accounts = [
  {
    id: "ig-1",
    handle: "@freshjuice.co",
    platformId: "instagram",
    dnaId: "1",
    status: "connected",
    automations: {
      reply_comment: { enabled: true, mode: "text", text: "Terima kasih atas masukannya!", keywordMatching: false, delay: "instant" },
      like_comment: { enabled: true }
    }
  },
  {
    id: "ig-2",
    handle: "@acmecorp.official",
    platformId: "instagram",
    dnaId: "2",
    status: "connected",
    automations: {}
  },
  {
    id: "tt-1",
    handle: "@freshjuice",
    platformId: "tiktok",
    dnaId: "1",
    status: "connected",
    automations: {
      delete_comment: { enabled: true, filterMode: "keyword", keywords: ["spam", "promo", "scam"] }
    }
  },
  {
    id: "tt-2",
    handle: "@acmecorp",
    platformId: "tiktok",
    dnaId: "2",
    status: "error",
    automations: {}
  },
  {
    id: "fb-1",
    handle: "Fresh Juice Co.",
    platformId: "facebook",
    dnaId: "1",
    status: "connected",
    automations: {
      reply_comment: { enabled: true, mode: "text", text: "Kami sangat menghargai feedback Anda.", keywordMatching: false, delay: "30s" },
      dm_comment: { enabled: true, mode: "text", text: "Hi {name}! Silakan cek detail promonya di sini: https://freshjuice.co/promo", delay: "instant", keywordMatching: true, matchingKeywords: ["promo", "diskon"] }
    }
  },
  {
    id: "fb-2",
    handle: "Acme Corp",
    platformId: "facebook",
    dnaId: "2",
    status: "connected",
    automations: {}
  },
  {
    id: "fb-3",
    handle: "Luxe Beauty Official",
    platformId: "facebook",
    dnaId: "3",
    status: "connected",
    automations: {
      like_comment: { enabled: true },
      reply_story: { enabled: true, mode: "text", text: "Terima kasih sudah mention kami!", keywordMatching: false, delay: "instant" }
    }
  },
  {
    id: "th-1",
    handle: "@freshjuice",
    platformId: "threads",
    dnaId: "1",
    status: "connected",
    automations: {
      reply_comment: { enabled: true, mode: "text", text: "Halo! Terima kasih ya.", keywordMatching: false, delay: "10s" }
    }
  },
  {
    id: "th-2",
    handle: "@acmecorp.threads",
    platformId: "threads",
    dnaId: "2",
    status: "connected",
    automations: {}
  },
];

const totalConnected = accounts.filter((a) => a.status === "connected").length;
const totalError = accounts.filter((a) => a.status === "error").length;
---

<AppLayout title="Integrations - Xeni" activePage="integrations">
  <div class="w-full min-h-full flex flex-col px-6 pb-32 -mt-12">
    <!-- Title + Controls Row -->
    <div class="w-full pt-1 pb-5 flex items-center justify-between gap-4 shrink-0">
      <!-- Left: Title -->
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-link text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Integrations
        </h1>
      </div>

      <!-- Right: Add Account -->
      <button
        onclick="document.getElementById('add-account-modal').hidden = false;"
        class="inline-flex items-center gap-2 rounded-xl font-bold transition-all duration-100 cursor-pointer select-none whitespace-nowrap justify-center px-4 h-9 text-[13px] bg-[#111827] text-white border border-[#374151] hover:bg-black active:translate-y-[1px]"
      >
        <i class="ti ti-plus text-[14px]"></i>
        Add Account
      </button>
    </div>

    <!-- Stats + Filters -->
    <div class="w-full pb-6 flex flex-col gap-4">
      <!-- Stats Cards -->
      <div class="grid grid-cols-2 gap-4">
        <div class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-[#eaecf0]">
          <div class="w-10 h-10 rounded-xl bg-[#ECFDF3] flex items-center justify-center shrink-0">
            <i class="ti ti-plug text-[20px] text-[#12B76A]"></i>
          </div>
          <div>
            <p class="text-[20px] font-bold text-[#111827]">{totalConnected}</p>
            <p class="text-[12px] text-[#667085] font-medium">Connected</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-[#eaecf0]">
          <div class="w-10 h-10 rounded-xl bg-[#FEF3F2] flex items-center justify-center shrink-0">
            <i class="ti ti-alert-circle text-[20px] text-[#F04438]"></i>
          </div>
          <div>
            <p class="text-[20px] font-bold text-[#111827]">{totalError}</p>
            <p class="text-[12px] text-[#667085] font-medium">Needs Attention</p>
          </div>
        </div>
      </div>

      <!-- Filters Bar: Dropdowns Left, Search Right (fills remaining) -->
      <div class="flex items-center gap-2">
        <!-- Platform Filter -->
        <div class="relative" id="platform-filter-wrapper">
          <button
            id="btn-platform-filter"
            class="flex items-center gap-1.5 px-4 h-10 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <i class="ti ti-apps text-[14px]"></i>
            <span id="platform-filter-label">All Platforms</span>
            <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
          </button>
          <div
            id="platform-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-52 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="platform-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer bg-[#F9FAFB]" data-value="all">
                All Platforms
              </button>
              {platforms.map((p) => (
                <button class="platform-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center gap-2" data-value={p.id}>
                  <i class={`ti ${p.icon} text-[14px]`} style={`color: ${p.color}`}></i>
                  {p.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- DNA Filter -->
        <div class="relative" id="dna-filter-wrapper">
          <button
            id="btn-dna-filter"
            class="flex items-center gap-1.5 px-4 h-10 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <i class="ti ti-building text-[14px]"></i>
            <span id="dna-filter-label">All Business</span>
            <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
          </button>
          <div id="dna-filter-dropdown" class="hidden absolute top-full left-0 mt-1.5 w-56 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden flex flex-col">
            <!-- Mini Search Bar for Filter -->
            <div class="p-2 border-b border-[#eaecf0] bg-[#F9FAFB]">
              <div class="relative">
                <i class="ti ti-search absolute left-2.5 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[11px]"></i>
                <input type="text" class="biz-search-input w-full h-8 pl-7 pr-2 text-[12px] bg-white border border-[#D0D5DD] rounded-lg focus:outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827]" placeholder="Search..." />
              </div>
            </div>
            <!-- Scrollable List -->
            <div class="flex flex-col p-1 max-h-[220px] overflow-y-auto custom-scrollbar biz-options-container">
              {dnaList.map((dna) => (
                <button class="dna-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer" data-value={dna.id}>
                  {dna.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Status Tabs -->
        <div class="flex items-center h-10 rounded-xl border border-[#D0D5DD] bg-white overflow-hidden shrink-0">
          <button class="status-tab active px-4 h-full text-[13px] font-semibold text-[#111827] bg-[#F9FAFB] border-r border-[#eaecf0] transition-all cursor-pointer" data-status="all">All</button>
          <button class="status-tab px-4 h-full text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] border-r border-[#eaecf0] transition-all cursor-pointer" data-status="connected">Connected</button>
          <button class="status-tab px-4 h-full text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer" data-status="error">Needs Attention</button>
        </div>

        <!-- Search (fills remaining space) -->
        <div class="relative flex-1 min-w-50">
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"></i>
          <input
            id="integration-search"
            type="text"
            placeholder="Search accounts, platforms..."
            class="w-full h-10 pl-9 pr-3 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Accounts Table -->
    <div class="w-full flex-1 pb-16">
      <div class="bg-white rounded-2xl border border-[#eaecf0] overflow-hidden">
        <!-- Table Header -->
        <div class="grid grid-cols-[1fr_120px_130px_90px_160px_220px] gap-4 px-5 py-3 bg-[#F9FAFB] border-b border-[#eaecf0] text-[12px] font-semibold text-[#667085] uppercase tracking-wide">
          <div>Account</div>
          <div>Platform</div>
          <div>Business DNA</div>
          <div>Status</div>
          <div>Automations</div>
          <div class="text-right">Action</div>
        </div>

        <!-- Table Body -->
        <div id="accounts-list">
          {accounts.map((account) => {
            const platform = platforms.find((p) => p.id === account.platformId);
            const dna = dnaList.find((d) => d.id === account.dnaId);
            return (
              <div
                class="account-row grid grid-cols-[1fr_120px_130px_90px_160px_220px] gap-4 px-5 py-3.5 border-b border-[#eaecf0] last:border-b-0 hover:bg-[#F9FAFB] transition-all items-center"
                data-id={account.id}
                data-platform={account.platformId}
                data-dna={account.dnaId}
                data-status={account.status}
                data-handle={account.handle.toLowerCase()}
                data-automations={JSON.stringify(account.automations)}
              >
                <!-- Account -->
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style={`background-color: ${platform?.color}10`}>
                    <i class={`ti ${platform?.icon} text-[16px]`} style={`color: ${platform?.color}`}></i>
                  </div>
                  <span class="text-[13px] font-semibold text-[#111827] truncate">{account.handle}</span>
                </div>

                <!-- Platform -->
                <div class="flex items-center gap-2">
                  <span class="text-[13px] text-[#667085] font-medium">{platform?.name}</span>
                </div>

                <!-- DNA -->
                <div class="flex items-center gap-1.5">
                  <div class="w-2 h-2 rounded-full" style={`background-color: ${dna?.color}`}></div>
                  <span class="text-[13px] text-[#667085] font-medium truncate">{dna?.name}</span>
                </div>

                <!-- Status -->
                <div>
                  {account.status === "connected" ? (
                    <div class="inline-flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#ECFDF3] text-[#12B76A] text-[12px] font-semibold">
                      <div class="w-1.5 h-1.5 rounded-full bg-[#12B76A]"></div>
                      Active
                    </div>
                  ) : (
                    <div class="inline-flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#FEF3F2] text-[#F04438] text-[12px] font-semibold">
                      <div class="w-1.5 h-1.5 rounded-full bg-[#F04438]"></div>
                      Error
                    </div>
                  )}
                </div>

                <!-- Automations Badges -->
                <div>
                  {(() => {
                    const iconMap = {
                      delete_comment: { label: "Delete Comment", icon: "ti-trash" },
                      reply_comment: { label: "Reply Comment", icon: "ti-message-dots" },
                      like_comment: { label: "Like Comment", icon: "ti-thumb-up" },
                      dm_comment: { label: "DM Comment", icon: "ti-message-share" },
                      reply_story: { label: "Reply Story", icon: "ti-history" },
                      reply_dm: { label: "Reply DM", icon: "ti-messages" },
                    };

                    const activeKeys = Object.keys(account.automations).filter(
                      (key) => account.automations[key]?.enabled === true
                    );

                    return (
                      <div class="automations-badges flex flex-wrap gap-1.5 max-w-full">
                        {activeKeys.length > 0 ? (
                          activeKeys.map((key) => {
                            const config = iconMap[key];
                            if (!config) return null;
                            return (
                              <div class="relative group flex items-center">
                                <div class="w-7 h-7 rounded-lg flex items-center justify-center border border-[#eaecf0] bg-[#F9FAFB] text-[#475467] transition-all hover:bg-[#F2F4F7] cursor-help">
                                  <i class={`ti ${config.icon} text-[14px]`}></i>
                                </div>
                                <!-- Tooltip -->
                                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:flex flex-col items-center pointer-events-none z-50">
                                  <div class="bg-gray-900 text-white text-[10px] font-semibold px-2 py-1 rounded-md shadow-md whitespace-nowrap">
                                    {config.label}
                                  </div>
                                  <div class="w-1.5 h-1.5 bg-gray-900 rotate-45 -mt-0.75"></div>
                                </div>
                              </div>
                            );
                          })
                        ) : (
                          <span class="text-[12px] text-[#98a2b3] italic font-medium">None active</span>
                        )}
                      </div>
                    );
                  })()}
                </div>

                <!-- Action -->
                <div class="flex items-center justify-end gap-2">
                  <button
                    class="btn-set-automation inline-flex items-center gap-1.5 rounded-xl font-bold transition-all duration-100 cursor-pointer select-none whitespace-nowrap justify-center px-3.5 h-8.5 text-[12px] bg-white text-[#344054] border border-[#eaecf0] hover:bg-[#F9FAFB] active:translate-y-[1px]"
                    onclick={`window.openSettingsModal('${account.id}')`}
                  >
                    <i class="ti ti-settings text-[14px]"></i>
                    Set Automation
                  </button>
                  <div class="relative action-dropdown-wrapper">
                    <button
                      class="btn-action-dropdown w-8.5 h-8.5 rounded-xl border border-[#eaecf0] bg-white flex items-center justify-center text-[#98a2b3] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
                    >
                      <i class="ti ti-dots-vertical text-[15px]"></i>
                    </button>
                    <!-- Dropdown -->
                    <div class="action-dropdown hidden absolute right-0 top-full mt-1.5 w-36 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] p-1.5 z-40 text-left">
                      <button
                        class="w-full flex items-center gap-2 px-2.5 py-2 rounded-lg text-[12px] font-semibold text-[#344054] hover:bg-[#F9FAFB] hover:text-[#111827] transition-all cursor-pointer text-left"
                        onclick="alert('Reconnecting account...')"
                      >
                        <i class="ti ti-refresh text-[13px] text-[#98a2b3]"></i>
                        Reconnect
                      </button>
                      <button
                        class="w-full flex items-center gap-2 px-2.5 py-2 rounded-lg text-[12px] font-semibold text-[#D92D20] hover:bg-[#FEF3F2] hover:text-[#D92D20] transition-all cursor-pointer text-left"
                        onclick={`if(confirm('Are you sure you want to delete this integration?')) { this.closest('.account-row').remove(); }`}
                      >
                        <i class="ti ti-trash text-[13px] text-[#F04438]"></i>
                        Delete
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // --- Global Filter Elements ---
    const searchInput = document.getElementById('integration-search');
    const accountRows = document.querySelectorAll('.account-row');

    // Filter Dropdown Toggles
    function setupFilterDropdown(btnId, dropdownId, optionClass, labelId, onSelect) {
      const btn = document.getElementById(btnId);
      const dropdown = document.getElementById(dropdownId);
      const label = document.getElementById(labelId);
      if (!btn || !dropdown) return;

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown.classList.toggle('hidden');
      });

      const bizSearchInput = dropdown.querySelector('.biz-search-input');
      if (bizSearchInput) {
        bizSearchInput.addEventListener('click', (e) => e.stopPropagation());
        bizSearchInput.addEventListener('input', (e) => {
          const term = e.target.value.toLowerCase();
          dropdown.querySelectorAll('.' + optionClass).forEach(opt => {
            const text = opt.textContent.toLowerCase();
            opt.style.display = text.includes(term) ? 'block' : 'none';
          });
        });
      }

      dropdown.querySelectorAll('.' + optionClass).forEach((opt) => {
        opt.addEventListener('click', () => {
          const value = opt.dataset.value;
          const text = opt.textContent.trim();
          label.textContent = text;
          dropdown.querySelectorAll('.' + optionClass).forEach((o) => o.classList.remove('bg-[#F9FAFB]', 'text-[#111827]'));
          opt.classList.add('bg-[#F9FAFB]', 'text-[#111827]');
          dropdown.classList.add('hidden');
          onSelect(value);
        });
      });
    }

    let activePlatform = 'all';
    let activeDNA = 'all';
    let activeStatus = 'all';
    let searchQuery = '';

    function applyFilters() {
      accountRows.forEach((row) => {
        const platform = row.dataset.platform;
        const dna = row.dataset.dna;
        const status = row.dataset.status;
        const handle = row.dataset.handle || '';

        const matchPlatform = activePlatform === 'all' || platform === activePlatform;
        const matchDNA = activeDNA === 'all' || dna === activeDNA;
        const matchStatus = activeStatus === 'all' || status === activeStatus;
        const matchSearch = !searchQuery || handle.includes(searchQuery);

        row.style.display = matchPlatform && matchDNA && matchStatus && matchSearch ? '' : 'none';
      });
    }

    setupFilterDropdown('btn-platform-filter', 'platform-filter-dropdown', 'platform-option', 'platform-filter-label', (val) => {
      activePlatform = val;
      applyFilters();
    });

    setupFilterDropdown('btn-dna-filter', 'dna-filter-dropdown', 'dna-option', 'dna-filter-label', (val) => {
      activeDNA = val;
      applyFilters();
    });

    // Status tabs
    document.querySelectorAll('.status-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.status-tab').forEach((t) => {
          t.classList.remove('active', 'bg-[#F9FAFB]', 'text-[#111827]', 'font-semibold');
          t.classList.add('text-[#667085]', 'font-medium');
        });
        tab.classList.add('active', 'bg-[#F9FAFB]', 'text-[#111827]', 'font-semibold');
        tab.classList.remove('text-[#667085]', 'font-medium');
        activeStatus = tab.dataset.status;
        applyFilters();
      });
    });

    // Search
    searchInput?.addEventListener('input', (e) => {
      searchQuery = e.target.value.toLowerCase().trim();
      applyFilters();
    });

    // Add Account Modal Functions
    const addAccountModal = document.getElementById('add-account-modal');
    const btnConnect = document.getElementById('btn-connect');
    const selectedPlatformLabel = document.getElementById('selected-platform-label');
    let selectedPlatform = null;
    let selectedDNA = null;

    window.openModal = function() {
      if (!addAccountModal) return;
      addAccountModal.hidden = false;
      selectedPlatform = null;
      selectedDNA = null;
      window.showStep('platform');
      window.updateConnectButton();
    };

    window.closeModal = function() {
      if (!addAccountModal) return;
      addAccountModal.hidden = true;
    };

    window.showStep = function(step) {
      const stepPlatform = document.getElementById('modal-step-platform');
      const stepDNA = document.getElementById('modal-step-dna');
      const backBtn = document.getElementById('modal-back-btn');
      if (step === 'platform') {
        stepPlatform?.classList.remove('hidden');
        stepDNA?.classList.add('hidden');
        backBtn?.classList.add('hidden');
        backBtn?.classList.remove('flex');
      } else {
        stepPlatform?.classList.add('hidden');
        stepDNA?.classList.remove('hidden');
        backBtn?.classList.remove('hidden');
        backBtn?.classList.add('flex');
      }
    };

    window.updateConnectButton = function() {
      if (!btnConnect) return;
      if (selectedPlatform && selectedDNA) {
        btnConnect.classList.remove('opacity-50', 'cursor-not-allowed');
        btnConnect.disabled = false;
      } else {
        btnConnect.classList.add('opacity-50', 'cursor-not-allowed');
        btnConnect.disabled = true;
      }
    };

    window.selectPlatform = function(item) {
      selectedPlatform = item.dataset.platform;
      const platformName = item.dataset.name;
      if (selectedPlatformLabel) selectedPlatformLabel.textContent = platformName || '-';
      window.showStep('dna');
    };

    window.selectDNA = function(item) {
      selectedDNA = item.dataset.dna;
      document.querySelectorAll('.modal-dna-item').forEach((i) => i.classList.remove('border-[#2563EB]', 'bg-blue-50'));
      item.classList.add('border-[#2563EB]', 'bg-blue-50');
      window.updateConnectButton();
    };

    window.connectAccount = function() {
      if (selectedPlatform && selectedDNA) {
        window.closeModal();
      }
    };


    // --- Three-Dots Action Dropdown Handling ---
