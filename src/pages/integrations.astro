                          <span class="text-[12px] font-bold text-[#344054]">Pencocokan Persis</span>
                          <div class="relative group flex items-center">
                            <i class="ti ti-info-circle text-[14px] text-[#98a2b3] cursor-help"></i>
                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:flex flex-col items-center pointer-events-none z-50 w-52">
                              <div class="bg-gray-900 text-white text-[10px] font-semibold px-2.5 py-1.5 rounded-lg shadow-lg w-full text-center leading-normal whitespace-normal">
                                Aktifkan agar balasan hanya dikirim jika komentar sama persis dengan kata kunci.
                              </div>
                              <div class="w-1.5 h-1.5 bg-gray-900 rotate-45 -mt-0.75"></div>
                            </div>
                          </div>
                        </div>
                        <div class="matching-keywords-container tag-input-container flex flex-wrap gap-1.5 p-1.5 rounded-xl border border-[#D0D5DD] bg-white min-h-9">
                          <input type="text" class="tag-input flex-1 min-w-[80px] text-[13px] outline-none placeholder:text-[#98a2b3] bg-transparent" placeholder="Masukan keyword...">
                        </div>
                        <p class="text-[10px] text-[#667085] font-medium leading-normal">
                          *Ketik kata kunci lalu tekan <b>Enter</b>. Jika dinonaktifkan, balasan dikirim jika komentar mengandung salah satu kata kunci.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- VIEW 2: KEYWORD MODE -->
                <div class="dm-view-section dm-view-keyword hidden space-y-3">
                  <div class="p-3 bg-[#F4F6FB] border border-[#d0d5dd]/50 rounded-xl text-[12px] text-[#344054] flex gap-2 font-medium shadow-sm">
                    <i class="ti ti-info-circle text-[16px] text-[#2563EB] shrink-0 mt-0.5"></i>
                    <span>Biarkan kolom "Masukan keyword" kosong untuk digunakan sebagai balasan default</span>
                  </div>
                  
                  <div class="dm-keywords-list space-y-3.5">
                    <!-- Dynamic keyword pairs will be added here -->
                  </div>
                  
                  <button type="button" class="btn-add-dm-keyword w-full py-2.5 rounded-xl border border-dashed border-[#d0d5dd] hover:border-[#98a2b3] bg-white hover:bg-gray-50 text-[13px] font-bold text-[#344054] flex items-center justify-center gap-1.5 transition-all cursor-pointer border-[#D0D5DD]">
                    <i class="ti ti-plus text-[13px]"></i>
                    Keyword
                  </button>
                </div>

                <!-- VIEW 3: AI MODE -->
                <div class="dm-view-section dm-view-ai hidden space-y-3">
                  <textarea class="dm-ai-prompt-input w-full rounded-xl border border-[#D0D5DD] p-3 text-[13px] text-[#344054] outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827] placeholder:text-[#98a2b3] min-h-[90px] resize-y bg-white" placeholder="Masukan prompt"></textarea>
                  <div class="space-y-2.5 pt-1">
                    <!-- Jeda Select directly -->
                    <div class="flex items-center justify-between py-1 border-b border-[#eaecf0] pb-2.5">
                      <span class="text-[13px] font-bold text-[#344054]">Jeda</span>
                      <select class="dm-delay-select h-8 rounded-lg border border-[#D0D5DD] bg-white px-2 text-[12px] font-semibold text-[#344054] outline-none focus:border-[#111827] focus:ring-1 focus:ring-[#111827]">
                        <option value="instant">Instant</option>
                        <option value="10s">10 Seconds</option>
                        <option value="30s">30 Seconds</option>
                        <option value="1min">1 Minute</option>
                        <option value="5min">5 Minutes</option>
                        <option value="15min">15 Minutes</option>
                        <option value="30min">30 Minutes</option>
                      </select>
                    </div>

                    <!-- Pencocokan Keyword Toggle & Content -->
                    <div class="keyword-matching-section space-y-2.5">
                      <div class="flex items-center justify-between py-1">
                        <span class="text-[13px] font-bold text-[#344054]">Pencocokan Keyword</span>
                        <button
                          class="sub-toggle-switch relative inline-flex h-4.5 w-8 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-gray-200 transition-colors duration-200 ease-in-out focus:outline-none"
                          role="switch"
                          data-field="keywordMatching"
                          aria-checked="false"
                        >
                          <span class="toggle-handle pointer-events-none inline-block h-3.5 w-3.5 transform rounded-full bg-white transition duration-200 ease-in-out translate-x-0"></span>
                        </button>
                      </div>

                      <!-- Collapsible content -->
                      <div class="keyword-matching-content hidden space-y-3 p-3 bg-gray-50 border border-[#eaecf0] rounded-2xl">
                        <div class="flex items-center gap-2">
                          <button
                            class="sub-toggle-switch relative inline-flex h-4.5 w-8 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-gray-200 transition-colors duration-200 ease-in-out focus:outline-none"
                            role="switch"
                            data-field="precisionMatching"
                            aria-checked="false"
                          >
                            <span class="toggle-handle pointer-events-none inline-block h-3.5 w-3.5 transform rounded-full bg-white transition duration-200 ease-in-out translate-x-0"></span>
                          </button>
                          <span class="text-[12px] font-bold text-[#344054]">Pencocokan Persis</span>
                          <div class="relative group flex items-center">
                            <i class="ti ti-info-circle text-[14px] text-[#98a2b3] cursor-help"></i>
                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:flex flex-col items-center pointer-events-none z-50 w-52">
                              <div class="bg-gray-900 text-white text-[10px] font-semibold px-2.5 py-1.5 rounded-lg shadow-lg w-full text-center leading-normal whitespace-normal">
                                Aktifkan agar balasan hanya dikirim jika komentar sama persis dengan kata kunci.
                              </div>
                              <div class="w-1.5 h-1.5 bg-gray-900 rotate-45 -mt-0.75"></div>
                            </div>
                          </div>
                        </div>
                        <div class="matching-keywords-container tag-input-container flex flex-wrap gap-1.5 p-1.5 rounded-xl border border-[#D0D5DD] bg-white min-h-9">
                          <input type="text" class="tag-input flex-1 min-w-[80px] text-[13px] outline-none placeholder:text-[#98a2b3] bg-transparent" placeholder="Masukan keyword...">
                        </div>
                        <p class="text-[10px] text-[#667085] font-medium leading-normal">
                          *Ketik kata kunci lalu tekan <b>Enter</b>. Jika dinonaktifkan, balasan dikirim jika komentar mengandung salah satu kata kunci.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-[#eaecf0] flex items-center justify-end gap-3 bg-[#F9FAFB]">
          <button
            onclick="window.closeSettingsModal();"
            class="inline-flex items-center gap-2 rounded-xl font-bold transition-all duration-100 cursor-pointer select-none whitespace-nowrap justify-center px-4 h-9.5 text-[13px] bg-white text-[#344054] border border-[#D0D5DD] hover:bg-[#F9FAFB] active:translate-y-[1px]"
          >
            Cancel
          </button>
          <button
            id="btn-save-automation-settings"
            class="inline-flex items-center gap-2 rounded-xl font-bold transition-all duration-100 cursor-pointer select-none whitespace-nowrap justify-center px-4.5 h-9.5 text-[13px] bg-[#111827] text-white border border-[#374151] hover:bg-black active:translate-y-[1px]"
          >
            Save Settings
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Save Template Sub-Modal -->
  <div id="save-template-modal" class="hidden transition-opacity duration-200 ease-out opacity-0"
    style="position: fixed; inset: 0; z-index: 10001;"
  >
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
      onclick="window.closeSaveTemplateModal();"
    ></div>
    <div class="absolute inset-0 flex items-center justify-center p-4"
      onclick="if(event.target === this) window.closeSaveTemplateModal();"
    >
      <div class="relative bg-white w-full max-w-[380px] rounded-[24px] shadow-2xl p-5 flex flex-col gap-4 transition-transform duration-200 ease-out scale-95"
        onclick="event.stopPropagation();"
      >
        <div>
          <h3 class="text-[15px] font-bold text-[#111827]">Save as Template</h3>
          <p class="text-[11.5px] text-[#667085] mt-0.5">Save current automation settings as a reusable template.</p>
        </div>
        
        <div>
          <label class="text-[11.5px] font-bold text-[#344054] block mb-1.5">Template Name</label>
          <input type="text" id="save-template-name-input" class="w-full h-9 rounded-xl border border-[#D0D5DD] px-3 text-[12px] font-semibold text-[#344054] placeholder:text-[#98a2b3] outline-none focus:border-[#111827] bg-white" placeholder="e.g. Ramadhan Promo, CS Standard...">
        </div>

        <div class="flex items-center justify-end gap-2 mt-1">
          <button onclick="window.closeSaveTemplateModal();" type="button" class="inline-flex items-center justify-center rounded-xl font-bold px-3.5 h-8.5 text-[12px] bg-white text-[#344054] border border-[#D0D5DD] hover:bg-[#F9FAFB] cursor-pointer">
            Cancel
          </button>
          <button id="btn-save-template-submit" type="button" class="inline-flex items-center justify-center rounded-xl font-bold px-4 h-8.5 text-[12px] bg-[#111827] text-white hover:bg-black cursor-pointer">
            Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Load Template Sub-Modal -->
  <div id="load-template-modal" class="hidden transition-opacity duration-200 ease-out opacity-0"
    style="position: fixed; inset: 0; z-index: 10001;"
  >
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
      onclick="window.closeLoadTemplateModal();"
    ></div>
    <div class="absolute inset-0 flex items-center justify-center p-4"
      onclick="if(event.target === this) window.closeLoadTemplateModal();"
    >
      <div class="relative bg-white w-full max-w-[420px] rounded-[24px] shadow-2xl p-5 flex flex-col gap-4 transition-transform duration-200 ease-out scale-95"
        onclick="event.stopPropagation();"
      >
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-[15px] font-bold text-[#111827]">Load Template</h3>
            <p class="text-[11.5px] text-[#667085] mt-0.5">Select a template to apply to your current settings.</p>
          </div>
          <button onclick="window.closeLoadTemplateModal();" class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer">
            <i class="ti ti-x text-[16px]"></i>
          </button>
        </div>
        
        <div class="border-t border-[#eaecf0] my-0.5"></div>

        <!-- Default Templates Accordion -->
        <div class="border border-[#eaecf0] rounded-2xl overflow-hidden bg-white">
          <button type="button" id="accordion-default-trigger" class="w-full flex items-center justify-between p-3.5 bg-gray-50 hover:bg-gray-100/70 transition-all text-left cursor-pointer border-none outline-none">
            <div class="flex items-center gap-2">
              <i class="ti ti-template text-[15px] text-[#475467]"></i>
              <span class="text-[12.5px] font-bold text-[#344054]">Default Templates</span>
            </div>
            <i id="accordion-default-icon" class="ti ti-chevron-down text-[13px] text-[#667085] transition-transform duration-200"></i>
          </button>
          
          <div id="accordion-default-content" class="hidden border-t border-[#eaecf0] p-3 space-y-2 bg-[#F9FAFB]">
            <!-- Default templates list populated dynamically -->
          </div>
        </div>

        <!-- Custom Templates Section -->
        <div class="flex flex-col gap-2">
          <p class="text-[12px] font-bold text-[#344054]">Custom Templates</p>
          <div id="modal-template-list" class="space-y-2 max-h-[160px] overflow-y-auto pr-1.5 custom-scrollbar">
            <!-- Dynamically populated custom template options -->
          </div>
        </div>

        <div class="flex items-center justify-end mt-1">
          <button onclick="window.closeLoadTemplateModal();" type="button" class="inline-flex items-center justify-center rounded-xl font-bold px-3.5 h-8.5 text-[12px] bg-white text-[#344054] border border-[#D0D5DD] hover:bg-[#F9FAFB] cursor-pointer">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
