---
import AppLayout from "../layouts/AppLayout.astro";

const dnaList = [
  { id: "1", name: "Fresh Juice Co.", color: "#34D399" },
  { id: "2", name: "Acme Corp", color: "#2563EB" },
  { id: "3", name: "Luxe Beauty", color: "#F472B6" },
  { id: "4", name: "TechStart Inc", color: "#8B5CF6" },
];

const platforms = [
  { id: "instagram", name: "Instagram", icon: "ti-brand-instagram", color: "#E4405F" },
  { id: "tiktok", name: "TikTok", icon: "ti-brand-tiktok", color: "#000000" },
  { id: "facebook", name: "Facebook", icon: "ti-brand-facebook", color: "#1877F2" },
  { id: "twitter", name: "X (Twitter)", icon: "ti-brand-x", color: "#0F1419" },
  { id: "linkedin", name: "LinkedIn", icon: "ti-brand-linkedin", color: "#0A66C2" },
  { id: "youtube", name: "YouTube", icon: "ti-brand-youtube", color: "#FF0000" },
  { id: "pinterest", name: "Pinterest", icon: "ti-brand-pinterest", color: "#BD081C" },
  { id: "threads", name: "Threads", icon: "ti-brand-threads", color: "#0F1419" },
];

const accounts = [
  { id: "ig-1", handle: "@freshjuice.co", platformId: "instagram", dnaId: "1", status: "connected" },
  { id: "ig-2", handle: "@acmecorp.official", platformId: "instagram", dnaId: "2", status: "connected" },
  { id: "tt-1", handle: "@freshjuice", platformId: "tiktok", dnaId: "1", status: "connected" },
  { id: "tt-2", handle: "@acmecorp", platformId: "tiktok", dnaId: "2", status: "error" },
  { id: "fb-1", handle: "Fresh Juice Co.", platformId: "facebook", dnaId: "1", status: "connected" },
  { id: "fb-2", handle: "Acme Corp", platformId: "facebook", dnaId: "2", status: "connected" },
  { id: "fb-3", handle: "Luxe Beauty Official", platformId: "facebook", dnaId: "3", status: "connected" },
  { id: "tw-1", handle: "@freshjuice", platformId: "twitter", dnaId: "1", status: "connected" },
  { id: "li-1", handle: "Fresh Juice Co.", platformId: "linkedin", dnaId: "1", status: "connected" },
  { id: "li-2", handle: "Acme Corp", platformId: "linkedin", dnaId: "2", status: "connected" },
  { id: "yt-1", handle: "Fresh Juice", platformId: "youtube", dnaId: "1", status: "connected" },
  { id: "pt-1", handle: "@freshjuice", platformId: "pinterest", dnaId: "1", status: "connected" },
  { id: "pt-2", handle: "@luxebeauty", platformId: "pinterest", dnaId: "3", status: "connected" },
  { id: "th-1", handle: "@freshjuice", platformId: "threads", dnaId: "1", status: "connected" },
];

const totalConnected = accounts.filter((a) => a.status === "connected").length;
const totalError = accounts.filter((a) => a.status === "error").length;
---

<AppLayout title="Integrations - Xeni" activePage="integrations">
  <div class="w-full min-h-full flex flex-col px-6 pb-32 -mt-12">
    <!-- Title + Controls Row -->
    <div class="max-w-6xl mx-auto w-full pt-1 pb-6 flex items-center justify-between gap-4">
      <!-- Left: Title -->
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-link text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Integrations
        </h1>
      </div>

      <!-- Right: Add Account -->
      <button onclick="document.getElementById('add-account-modal').hidden = false;" class="flex items-center gap-2 px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-semibold hover:bg-black transition-all cursor-pointer shrink-0">
        <i class="ti ti-plus text-[14px]"></i>
        Add Account
      </button>
    </div>

    <!-- Stats + Filters -->
    <div class="max-w-6xl mx-auto w-full pb-6 flex flex-col gap-4">
      <!-- Stats Cards -->
      <div class="grid grid-cols-2 gap-4">
        <div class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-[#eaecf0]">
          <div class="w-10 h-10 rounded-xl bg-[#ECFDF3] flex items-center justify-center shrink-0">
            <i class="ti ti-plug text-[20px] text-[#12B76A]"></i>
          </div>
          <div>
            <p class="text-[20px] font-bold text-[#111827]">{totalConnected}</p>
            <p class="text-[12px] text-[#667085] font-medium">Connected</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-[#eaecf0]">
          <div class="w-10 h-10 rounded-xl bg-[#FEF3F2] flex items-center justify-center shrink-0">
            <i class="ti ti-alert-circle text-[20px] text-[#F04438]"></i>
          </div>
          <div>
            <p class="text-[20px] font-bold text-[#111827]">{totalError}</p>
            <p class="text-[12px] text-[#667085] font-medium">Needs Attention</p>
          </div>
        </div>
      </div>

      <!-- Filters Bar: Dropdowns Left, Search Right (fills remaining) -->
      <div class="flex items-center gap-2">
        <!-- Platform Filter -->
        <div class="relative" id="platform-filter-wrapper">
          <button
            id="btn-platform-filter"
            class="flex items-center gap-1.5 px-4 h-10 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <i class="ti ti-apps text-[14px]"></i>
            <span id="platform-filter-label">All Platforms</span>
            <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
          </button>
          <div
            id="platform-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-52 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="platform-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer bg-[#F9FAFB]" data-value="all">
                All Platforms
              </button>
              {platforms.map((p) => (
                <button class="platform-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center gap-2" data-value={p.id}>
                  <i class={`ti ${p.icon} text-[14px]`} style={`color: ${p.color}`}></i>
                  {p.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- DNA Filter -->
        <div class="relative" id="dna-filter-wrapper">
          <button
            id="btn-dna-filter"
            class="flex items-center gap-1.5 px-4 h-10 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >
            <i class="ti ti-building text-[14px]"></i>
            <span id="dna-filter-label">All Business</span>
            <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
          </button>
          <div
            id="dna-filter-dropdown"
            class="hidden absolute top-full left-0 mt-1.5 w-52 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
          >
            <div class="flex flex-col p-1.5">
              <button class="dna-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer bg-[#F9FAFB]" data-value="all">
                All Business
              </button>
              {dnaList.map((dna) => (
                <button class="dna-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center gap-2" data-value={dna.id}>
                  <div class="w-2 h-2 rounded-full" style={`background-color: ${dna.color}`}></div>
                  {dna.name}
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Status Tabs -->
        <div class="flex items-center h-10 rounded-xl border border-[#D0D5DD] bg-white overflow-hidden shrink-0">
          <button class="status-tab active px-4 h-full text-[13px] font-semibold text-[#111827] bg-[#F9FAFB] border-r border-[#eaecf0] transition-all cursor-pointer" data-status="all">All</button>
          <button class="status-tab px-4 h-full text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] border-r border-[#eaecf0] transition-all cursor-pointer" data-status="connected">Connected</button>
          <button class="status-tab px-4 h-full text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer" data-status="error">Needs Attention</button>
        </div>

        <!-- Search (fills remaining space) -->
        <div class="relative flex-1 min-w-50">
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"></i>
          <input
            id="integration-search"
            type="text"
            placeholder="Search accounts, platforms..."
            class="w-full h-10 pl-9 pr-3 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Accounts Table -->
    <div class="max-w-6xl mx-auto w-full flex-1 pb-16">
      <div class="bg-white rounded-2xl border border-[#eaecf0] overflow-hidden">
        <!-- Table Header -->
        <div class="grid grid-cols-[1fr_140px_140px_100px_80px] gap-4 px-5 py-3 bg-[#F9FAFB] border-b border-[#eaecf0] text-[12px] font-semibold text-[#667085] uppercase tracking-wide">
          <div>Account</div>
          <div>Platform</div>
          <div>Business DNA</div>
          <div>Status</div>
          <div class="text-right">Action</div>
        </div>

        <!-- Table Body -->
        <div id="accounts-list">
          {accounts.map((account) => {
            const platform = platforms.find((p) => p.id === account.platformId);
            const dna = dnaList.find((d) => d.id === account.dnaId);
            return (
              <div
                class="account-row grid grid-cols-[1fr_140px_140px_100px_80px] gap-4 px-5 py-3.5 border-b border-[#eaecf0] last:border-b-0 hover:bg-[#F9FAFB] transition-all items-center"
                data-platform={account.platformId}
                data-dna={account.dnaId}
                data-status={account.status}
                data-handle={account.handle.toLowerCase()}
              >
                <!-- Account -->
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style={`background-color: ${platform?.color}10`}>
                    <i class={`ti ${platform?.icon} text-[16px]`} style={`color: ${platform?.color}`}></i>
                  </div>
                  <span class="text-[13px] font-semibold text-[#111827] truncate">{account.handle}</span>
                </div>

                <!-- Platform -->
                <div class="flex items-center gap-2">
                  <span class="text-[13px] text-[#667085] font-medium">{platform?.name}</span>
                </div>

                <!-- DNA -->
                <div class="flex items-center gap-1.5">
                  <div class="w-2 h-2 rounded-full" style={`background-color: ${dna?.color}`}></div>
                  <span class="text-[13px] text-[#667085] font-medium truncate">{dna?.name}</span>
                </div>

                <!-- Status -->
                <div>
                  {account.status === "connected" ? (
                    <div class="inline-flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#ECFDF3] text-[#12B76A] text-[12px] font-semibold">
                      <div class="w-1.5 h-1.5 rounded-full bg-[#12B76A]"></div>
                      Active
                    </div>
                  ) : (
                    <div class="inline-flex items-center gap-1.5 px-2.5 h-6 rounded-full bg-[#FEF3F2] text-[#F04438] text-[12px] font-semibold">
                      <div class="w-1.5 h-1.5 rounded-full bg-[#F04438]"></div>
                      Error
                    </div>
                  )}
                </div>

                <!-- Action -->
                <div class="flex items-center justify-end">
                  <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[#98a2b3] hover:text-[#F04438] hover:bg-[#FEF3F2] transition-all cursor-pointer" title="Disconnect">
                    <i class="ti ti-trash text-[14px]"></i>
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const searchInput = document.getElementById('integration-search');
    const accountRows = document.querySelectorAll('.account-row');

    // Dropdown toggles
    function setupDropdown(btnId, dropdownId, optionClass, labelId, onSelect) {
      const btn = document.getElementById(btnId);
      const dropdown = document.getElementById(dropdownId);
      const label = document.getElementById(labelId);
      if (!btn || !dropdown) return;

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown.classList.toggle('hidden');
      });

      dropdown.querySelectorAll('.' + optionClass).forEach((opt) => {
        opt.addEventListener('click', () => {
          const value = opt.dataset.value;
          const text = opt.textContent.trim();
          label.textContent = text;
          dropdown.querySelectorAll('.' + optionClass).forEach((o) => o.classList.remove('bg-[#F9FAFB]', 'text-[#111827]'));
          opt.classList.add('bg-[#F9FAFB]', 'text-[#111827]');
          dropdown.classList.add('hidden');
          onSelect(value);
        });
      });
    }

    let activePlatform = 'all';
    let activeDNA = 'all';
    let activeStatus = 'all';
    let searchQuery = '';

    function applyFilters() {
      accountRows.forEach((row) => {
        const platform = row.dataset.platform;
        const dna = row.dataset.dna;
        const status = row.dataset.status;
        const handle = row.dataset.handle || '';

        const matchPlatform = activePlatform === 'all' || platform === activePlatform;
        const matchDNA = activeDNA === 'all' || dna === activeDNA;
        const matchStatus = activeStatus === 'all' || status === activeStatus;
        const matchSearch = !searchQuery || handle.includes(searchQuery);

        row.style.display = matchPlatform && matchDNA && matchStatus && matchSearch ? '' : 'none';
      });
    }

    setupDropdown('btn-platform-filter', 'platform-filter-dropdown', 'platform-option', 'platform-filter-label', (val) => {
      activePlatform = val;
      applyFilters();
    });

    setupDropdown('btn-dna-filter', 'dna-filter-dropdown', 'dna-option', 'dna-filter-label', (val) => {
      activeDNA = val;
      applyFilters();
    });

    // Status tabs
    document.querySelectorAll('.status-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.status-tab').forEach((t) => {
          t.classList.remove('active', 'bg-[#F9FAFB]', 'text-[#111827]', 'font-semibold');
          t.classList.add('text-[#667085]', 'font-medium');
        });
        tab.classList.add('active', 'bg-[#F9FAFB]', 'text-[#111827]', 'font-semibold');
        tab.classList.remove('text-[#667085]', 'font-medium');
        activeStatus = tab.dataset.status;
        applyFilters();
      });
    });

    // Search
    searchInput?.addEventListener('input', (e) => {
      searchQuery = e.target.value.toLowerCase().trim();
      applyFilters();
    });

    // Close dropdowns on outside click
    document.addEventListener('click', () => {
      document.getElementById('platform-filter-dropdown')?.classList.add('hidden');
      document.getElementById('dna-filter-dropdown')?.classList.add('hidden');
    });

    // Add Account Modal
    const modal = document.getElementById('add-account-modal');
    const btnConnect = document.getElementById('btn-connect');
    const selectedPlatformLabel = document.getElementById('selected-platform-label');
    let selectedPlatform = null;
    let selectedDNA = null;

    window.openModal = function() {
      if (!modal) return;
      modal.showModal();
      selectedPlatform = null;
      selectedDNA = null;
      window.showStep('platform');
      window.updateConnectButton();
    };

    window.closeModal = function() {
      if (!modal) return;
      modal.close();
    };

    window.showStep = function(step) {
      const stepPlatform = document.getElementById('modal-step-platform');
      const stepDNA = document.getElementById('modal-step-dna');
      const backBtn = document.getElementById('modal-back-btn');
      if (step === 'platform') {
        stepPlatform?.classList.remove('hidden');
        stepDNA?.classList.add('hidden');
        backBtn?.classList.add('hidden');
        backBtn?.classList.remove('flex');
      } else {
        stepPlatform?.classList.add('hidden');
        stepDNA?.classList.remove('hidden');
        backBtn?.classList.remove('hidden');
        backBtn?.classList.add('flex');
      }
    };

    window.updateConnectButton = function() {
      if (!btnConnect) return;
      if (selectedPlatform && selectedDNA) {
        btnConnect.classList.remove('opacity-50', 'cursor-not-allowed');
        btnConnect.disabled = false;
      } else {
        btnConnect.classList.add('opacity-50', 'cursor-not-allowed');
        btnConnect.disabled = true;
      }
    };

    window.selectPlatform = function(item) {
      selectedPlatform = item.dataset.platform;
      const platformName = item.dataset.name;
      if (selectedPlatformLabel) selectedPlatformLabel.textContent = platformName || '-';
      window.showStep('dna');
    };

    window.selectDNA = function(item) {
      selectedDNA = item.dataset.dna;
      document.querySelectorAll('.modal-dna-item').forEach((i) => i.classList.remove('border-[#2563EB]', 'bg-blue-50'));
      item.classList.add('border-[#2563EB]', 'bg-blue-50');
      window.updateConnectButton();
    };

    window.connectAccount = function() {
      if (selectedPlatform && selectedDNA) {
        window.closeModal();
      }
    };
  </script>

  <!-- Add Account Modal -->
  <div id="add-account-modal" hidden
    style="position: fixed; inset: 0; z-index: 9999;"
  >
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
      onclick="document.getElementById('add-account-modal').hidden = true;"
    ></div>
    <div class="absolute inset-0 flex items-center justify-center p-4"
      onclick="if(event.target === this) document.getElementById('add-account-modal').hidden = true;"
    >
      <div class="relative bg-white w-full max-w-120 rounded-[28px] shadow-2xl flex flex-col overflow-hidden"
        onclick="event.stopPropagation();"
      >
        <!-- Header -->
        <div class="px-6 pt-6 pb-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <button id="modal-back-btn" onclick="document.getElementById('modal-step-platform').classList.remove('hidden'); document.getElementById('modal-step-dna').classList.add('hidden'); this.classList.add('hidden'); this.classList.remove('flex');" class="hidden w-8 h-8 rounded-lg items-center justify-center text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer">
              <i class="ti ti-arrow-left text-[16px]"></i>
            </button>
            <div>
              <h2 class="text-[18px] font-bold text-[#111827] tracking-tight">Add Account</h2>
              <p class="text-[12px] text-[#667085] mt-0.5">Connect a social media account to your Business DNA</p>
            </div>
          </div>
          <button onclick="document.getElementById('add-account-modal').hidden = true;" class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer">
            <i class="ti ti-x text-[18px]"></i>
          </button>
        </div>

        <!-- Step 1: Select Platform -->
        <div id="modal-step-platform" class="px-6 pb-6">
          <p class="text-[13px] font-semibold text-[#344054] mb-3">Select Platform</p>
          <div class="grid grid-cols-4 gap-3">
            {platforms.map((p) => (
              <button
                onclick="document.getElementById('selected-platform-label').textContent = this.dataset.name || '-'; document.getElementById('modal-step-platform').classList.add('hidden'); document.getElementById('modal-step-dna').classList.remove('hidden'); document.getElementById('modal-back-btn').classList.remove('hidden'); document.getElementById('modal-back-btn').classList.add('flex');"
                class="modal-platform-item flex flex-col items-center gap-2 p-4 rounded-2xl border border-[#eaecf0] bg-white hover:border-[#D0D5DD] hover:bg-[#F9FAFB] transition-all cursor-pointer"
                data-platform={p.id}
                data-name={p.name}
              >
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={`background-color: ${p.color}10`}>
                  <i class={`ti ${p.icon} text-[20px]`} style={`color: ${p.color}`}></i>
                </div>
                <span class="text-[12px] font-medium text-[#344054]">{p.name}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Step 2: Select DNA -->
        <div id="modal-step-dna" class="hidden px-6 pb-6">
          <div class="flex items-center gap-2 mb-4 p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
            <i class="ti ti-share text-[14px] text-[#667085]"></i>
            <span class="text-[13px] text-[#667085]">Platform: <span id="selected-platform-label" class="font-semibold text-[#111827]">-</span></span>
          </div>
          <p class="text-[13px] font-semibold text-[#344054] mb-3">Assign to Business DNA</p>
          <div class="space-y-2">
            {dnaList.map((dna) => (
              <button
                onclick="document.querySelectorAll('.modal-dna-item').forEach(i => i.classList.remove('border-[#2563EB]', 'bg-blue-50')); this.classList.add('border-[#2563EB]', 'bg-blue-50'); document.getElementById('btn-connect').disabled = false; document.getElementById('btn-connect').classList.remove('opacity-50', 'cursor-not-allowed');"
                class="modal-dna-item w-full flex items-center gap-3 p-3.5 rounded-2xl border border-[#eaecf0] bg-white text-left hover:border-[#D0D5DD] hover:bg-[#F9FAFB] transition-all cursor-pointer"
                data-dna={dna.id}
              >
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style={`background-color: ${dna.color}15`}>
                  <span class="text-[13px] font-bold" style={`color: ${dna.color}`}>{dna.name.charAt(0)}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-[14px] font-bold text-[#111827]">{dna.name}</p>
                  <p class="text-[12px] text-[#667085]">Content will be generated using this DNA profile</p>
                </div>
                <div class="w-5 h-5 rounded-full border-2 border-[#D0D5DD] flex items-center justify-center check-circle">
                  <div class="w-2.5 h-2.5 rounded-full bg-[#2563EB] hidden"></div>
                </div>
              </button>
            ))}
          </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-[#eaecf0] flex items-center justify-end gap-3">
          <button onclick="document.getElementById('add-account-modal').hidden = true;" class="px-5 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-semibold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer">
            Cancel
          </button>
          <button id="btn-connect" onclick="document.getElementById('add-account-modal').hidden = true;" disabled class="px-6 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-semibold hover:bg-black transition-all opacity-50 cursor-not-allowed">
            Connect Account
          </button>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
