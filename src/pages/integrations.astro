      customList.innerHTML = '';
      
      const currentConfig = collectModalConfig();

      let templates = {};
      try {
        const stored = localStorage.getItem('xeni_automation_templates');
        if (stored) {
          templates = JSON.parse(stored);
        } else {
          templates = defaultTemplates;
          localStorage.setItem('xeni_automation_templates', JSON.stringify(templates));
        }
      } catch (e) {
        console.error("Error loading templates", e);
        templates = defaultTemplates;
      }

      // Default template names
      const defaultNames = ["Promo & Giveaway", "Customer Service AI"];
      
