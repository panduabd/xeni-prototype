      modal.querySelector('.relative')?.classList.add('scale-95');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 200);
    };

    function isConfigEqual(c1, c2) {
      if (!c1 || !c2) return false;
      const keys = ['delete_comment', 'like_comment', 'reply_comment', 'dm_comment', 'reply_story', 'reply_dm'];
      for (const k of keys) {
        const o1 = c1[k] || { enabled: false };
        const o2 = c2[k] || { enabled: false };
        if (o1.enabled !== o2.enabled) return false;
        if (o1.enabled) {
          if (k === 'delete_comment') {
            if (o1.filterMode !== o2.filterMode) return false;
            if (o1.filterMode === 'keyword') {
              const kw1 = (o1.keywords || []).slice().sort().join(',');
              const kw2 = (o2.keywords || []).slice().sort().join(',');
              if (kw1 !== kw2) return false;
            } else {
              if ((o1.aiPrompt || '').trim() !== (o2.aiPrompt || '').trim()) return false;
            }
          } else if (k === 'like_comment') {
            // only enabled status is checked
          } else {
            // reply_comment, dm_comment, reply_story, reply_dm
            if (o1.mode !== o2.mode) return false;
            if (o1.mode === 'text' || o1.mode === 'opening') {
              if ((o1.text || '').trim() !== (o2.text || '').trim()) return false;
              if (o1.keywordMatching !== o2.keywordMatching) return false;
              if (o1.keywordMatching) {
                if (o1.precisionMatching !== o2.precisionMatching) return false;
                const kw1 = (o1.matchingKeywords || []).slice().sort().join(',');
                const kw2 = (o2.matchingKeywords || []).slice().sort().join(',');
                if (kw1 !== kw2) return false;
              }
            } else if (o1.mode === 'ai') {
              if ((o1.aiPrompt || '').trim() !== (o2.aiPrompt || '').trim()) return false;
              if (o1.keywordMatching !== o2.keywordMatching) return false;
              if (o1.keywordMatching) {
                if (o1.precisionMatching !== o2.precisionMatching) return false;
                const kw1 = (o1.matchingKeywords || []).slice().sort().join(',');
                const kw2 = (o2.matchingKeywords || []).slice().sort().join(',');
                if (kw1 !== kw2) return false;
              }
            }
            if (o1.delay !== o2.delay) return false;
          }
        }
      }
      return true;
    }

    function renderLoadTemplatesList() {
      const defaultContent = document.getElementById('accordion-default-content');
