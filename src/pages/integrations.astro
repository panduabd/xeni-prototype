              dm_comment: { enabled: false },
              reply_story: { enabled: false },
              reply_dm: { enabled: false }
            });
            activeTemplateName = null;
            window.closeLoadTemplateModal();
          });
        }

        defaultContent.appendChild(div);
      });

      // Render Custom Templates
      const customKeys = Object.keys(templates).filter(name => !defaultNames.includes(name));
      
      if (customKeys.length === 0) {
        customList.innerHTML = '<p class="text-[11px] text-[#667085] text-center py-4 italic">Belum ada template kustom.</p>';
      } else {
        customKeys.forEach(name => {
          const tConfig = templates[name];
          const isActive = (name === activeTemplateName);
          
          const div = document.createElement('div');
          div.className = "flex items-center justify-between p-3 rounded-xl border border-[#eaecf0] hover:border-[#D0D5DD] bg-white transition-all";
          
          let actionHTML = '';
          if (isActive) {
            actionHTML = `
              <div class="flex items-center gap-1.5 shrink-0">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-xl text-[10px] font-bold bg-green-50 text-green-700 border border-green-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Active
                </span>
                <button type="button" class="btn-disable-template h-7 px-2.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 text-[10px] font-bold transition-all cursor-pointer">
                  Disable
                </button>
              </div>
            `;
          } else {
            actionHTML = `
              <button type="button" class="btn-apply-template h-7 px-3 rounded-lg bg-[#111827] text-white hover:bg-black text-[10px] font-bold transition-all cursor-pointer" data-name="${name}">
                Load
              </button>
