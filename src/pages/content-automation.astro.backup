---
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout title="Content Automation - Xeni" activePage="content-automation">
  <div class="w-full min-h-full flex flex-col px-6 pb-32 -mt-12">
    <!-- Title + Controls Row -->
    <div
      class="max-w-6xl mx-auto w-full pt-1 pb-8 flex items-center justify-between gap-4"
    >
      <!-- Left: Title + Info -->
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-wand text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Content Automation
        </h1>
        <i
          class="ti ti-info-circle text-[16px] text-[#98a2b3] cursor-help"
          title="Konten dibuat setiap jam 2 pagi WIB. Kredit hanya terpotong saat konten dibuat."
        ></i>
      </div>

      <!-- Right: Status Mini Badges -->
      <div class="flex items-center gap-2">
        <span
          class="flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E]"></span>
          <span id="status-active">0</span> Active
        </span>
        <span
          class="flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[#ffd900]"></span>
          <span id="status-scheduled"></span> Scheduled
        </span>
      </div>
    </div>

    <!-- Tabs Row -->
    <div class="max-w-6xl mx-auto w-full mb-6 flex items-center gap-4">
      <div
        class="flex items-center gap-1 p-1 bg-white rounded-xl border border-[#eaecf0] w-fit"
      >
        <button
          id="tab-automations"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold bg-[#111827] text-white transition-all cursor-pointer"
          data-tab="automations"
        >
          Automations
        </button>
        <button
          id="tab-generated"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          data-tab="generated"
        >
          Outputs
          <span
            id="generated-badge"
            class="ml-1.5 px-1.5 h-4 rounded-full bg-[#FEF3C7] text-[#B45309] text-[10px] font-bold hidden"
            >0</span
          >
        </button>
        <button
          id="tab-scheduled"
          class="tab-btn px-4 h-8 rounded-lg text-[13px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          data-tab="scheduled"
        >
          Scheduled
          <span
            id="scheduled-badge"
            class="ml-1.5 px-1.5 h-4 rounded-full bg-[#F5F3FF] text-[#7C3AED] text-[10px] font-bold hidden"
            >0</span
          >
        </button>
      </div>
    </div>

    <!-- TAB: AUTOMATIONS -->
    <div id="tab-content-automations" class="max-w-6xl mx-auto w-full flex-1">
      <!-- Automation Filters -->
      <div class="flex items-center justify-between gap-2 mb-4">
        <div class="flex items-center gap-2">
          <div class="relative" id="business-filter-wrapper">
            <button
              id="btn-business-filter"
              class="flex items-center gap-1.5 px-4 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px] text-[#98a2b3]"></i>
            </button>
            <div
              id="business-filter-dropdown"
              class="hidden absolute top-full left-0 mt-1.5 w-48 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
            >
              <div class="flex flex-col p-1.5">
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="all"
                >
                  All Business
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Fresh Juice Co."
                >
                  Fresh Juice Co.
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Tech Startup"
                >
                  Tech Startup
                </button>
                <button
                  class="business-filter-option w-full text-left px-3 py-2 rounded-lg text-[13px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Luxe Beauty"
                >
                  Luxe Beauty
                </button>
              </div>
            </div>
          </div>

          <!-- Search -->
          <div class="relative flex-1 max-w-xs">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="automation-search"
              type="text"
              placeholder="Search by campaign or business..."
              class="w-80 h-9 pl-8 pr-2 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>
        </div>

        <!-- Create Button (only for Automations tab) -->
        <button
          id="btn-add-automation"
          class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer flex items-center gap-2"
        >
          <i class="ti ti-plus text-[14px]"></i>
          Create Automation
        </button>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="w-full hidden">
        <div class="text-center space-y-4">
          <div
            class="w-16 h-16 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center mx-auto"
          >
            <i class="ti ti-calendar text-[32px] text-[#D1D5DB]"></i>
          </div>
          <div class="space-y-1">
            <h2 class="text-[18px] font-bold text-[#344054]">
              No automation yet
            </h2>
            <p class="text-[14px] text-[#667085] font-medium">
              Create your first automation to start scheduling content.
            </p>
          </div>
          <button
            id="btn-empty-add"
            class="px-4 h-9 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer flex items-center gap-2 mx-auto"
          >
            <i class="ti ti-plus text-[14px]"></i>
            Add Automation
          </button>
        </div>
      </div>

      <!-- Table -->
      <div id="automations-table" class="w-full hidden">
        <div
          class="bg-white rounded-3xl border border-[#eaecf0] overflow-hidden"
        >
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#eaecf0]">
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >BUSINESS</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Task Name</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Schedule</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Content Types</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider"
                    >Status</th
                  >
                  <th
                    class="px-5 py-3.5 text-[12px] font-bold text-[#667085] uppercase tracking-wider text-right"
                    >Actions</th
                  >
                </tr>
              </thead>
              <tbody id="automations-tbody">
                <!-- Rows injected via JS -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: GENERATED -->
    <div
      id="tab-content-generated"
      class="max-w-6xl mx-auto w-full flex-1 hidden"
    >
      <!-- Filter Bar -->
      <div class="flex items-center justify-between gap-4 mb-4 flex-wrap w-full">
        <!-- Left Side: Filters & Search -->
        <div class="flex items-center gap-2">
          <!-- Business Filter -->
          <div class="relative">
            <button
              id="btn-output-business-filter"
              class="flex items-center gap-1.5 px-3 h-9 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
            >
              <i class="ti ti-building text-[14px]"></i>
              <span id="output-business-filter-label">All Business</span>
              <i class="ti ti-chevron-down text-[12px]"></i>
            </button>
            <div
              id="output-business-filter-dropdown"
              class="hidden absolute top-full left-0 mt-1.5 w-48 bg-white rounded-xl border border-[#eaecf0] shadow-[0_4px_24px_rgba(0,0,0,0.08)] z-30 overflow-hidden"
            >
              <div class="flex flex-col p-1.5">
                <button
                  class="output-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="all">All Business</button
                >
                <button
                  class="output-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Fresh Juice Co.">Fresh Juice Co.</button
                >
                <button
                  class="output-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Tech Startup">Tech Startup</button
                >
                <button
                  class="output-business-filter-option w-full text-left px-3 py-2 rounded-lg text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] hover:text-[#111827] transition-colors cursor-pointer"
                  data-brand="Luxe Beauty">Luxe Beauty</button
                >
              </div>
            </div>
          </div>

          <!-- Search -->
          <div class="relative w-64">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="output-search"
              type="text"
              placeholder="Search outputs..."
              class="w-full h-9 pl-8 pr-3 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>
        </div>

        <!-- Right Side: Bulk Actions (Subtle Dark Component Style) -->
        <div id="approved-bulk-header" class="hidden items-center gap-2">
          <span id="selected-count" class="text-[12px] font-semibold text-[#344054] bg-[#F2F4F7] px-3 h-9 rounded-xl border border-[#D0D5DD] flex items-center justify-center">0 terpilih</span>
          
          <button onclick="bulkPublishSelected()" class="h-9 px-3.5 rounded-xl bg-[#111827] hover:bg-[#1f2937] text-white text-[12px] font-bold transition-all cursor-pointer flex items-center gap-1.5 shadow-sm">
            <i class="ti ti-send text-[12px]"></i>
            Bulk Publish
          </button>
          
          <button onclick="deselectAllApproved()" class="h-9 px-3 rounded-xl border border-[#D0D5DD] bg-white text-[#344054] text-[12px] font-semibold hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center justify-center shadow-sm">
            Deselect All
          </button>
        </div>
      </div>

      <!-- Two Panel Layout: Draft (left 25%) + Approved (right 75%) -->
      <div class="flex gap-4 w-full">
        <!-- LEFT PANEL: Draft List (25%) -->
        <div class="w-[25%] min-w-60 flex flex-col gap-3">
          <div class="flex items-center justify-between px-1">
            <h3 class="text-[13px] font-bold text-[#111827]">Draft</h3>
            <span id="draft-count" class="text-[11px] font-medium text-[#667085] bg-[#F3F4F6] px-2 py-0.5 rounded-full">0</span>
          </div>
          <div id="draft-list" class="flex flex-col gap-2">
            <!-- Draft items injected via JS -->
          </div>
          <div id="draft-show-more-container" class="hidden justify-center pt-2">
            <button id="btn-draft-show-more" class="w-full h-8 rounded-xl border border-[#eaecf0] bg-white text-[11px] font-semibold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer flex items-center justify-center gap-1 shadow-sm">
              <i class="ti ti-chevron-down text-[12px]"></i>
              Show More
            </button>
          </div>
          <div id="draft-empty" class="hidden flex-col items-center justify-center py-8 text-center">
            <i class="ti ti-clipboard-check text-[24px] text-[#D1D5DB] mb-2"></i>
            <p class="text-[12px] text-[#98a2b3]">No drafts pending</p>
          </div>
        </div>

        <!-- RIGHT PANEL: Approved Grid (75%) -->
        <div class="w-[75%] flex flex-col gap-3">
          <div class="flex items-center justify-between px-1 h-8">
            <div id="approved-normal-header" class="flex items-center gap-2">
              <h3 class="text-[13px] font-bold text-[#111827]">Approved</h3>
              <span id="approved-count" class="text-[11px] font-medium text-[#667085] bg-[#F3F4F6] px-2 py-0.5 rounded-full">0</span>
            </div>
          </div>
          <div id="approved-grid" class="columns-3 gap-3">
            <!-- Approved cards injected via JS -->
          </div>
          <div id="approved-empty" class="hidden flex-col items-center justify-center py-16 text-center">
            <i class="ti ti-photo text-[32px] text-[#D1D5DB] mb-2"></i>
            <p class="text-[14px] text-[#667085] font-medium">No approved content yet</p>
            <p class="text-[12px] text-[#98a2b3]">Approved content will appear here</p>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: SCHEDULED -->
    <div id="tab-content-scheduled" class="max-w-6xl mx-auto w-full flex-1 hidden">
      <!-- Scheduled Header -->
      <div class="flex items-center justify-between gap-2 mb-4">
        <div class="flex items-center gap-2">
          <div class="relative flex-1 min-w-50 max-w-xs">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="scheduled-search"
              type="text"
              placeholder="Search scheduled content..."
              class="w-full h-9 pl-8 pr-3 rounded-xl border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>
        </div>
        <div class="flex items-center gap-2">
          <!-- View Toggle: List / Monthly / Weekly -->
          <div class="flex items-center p-0.5 rounded-xl border border-[#D0D5DD] bg-white">
            <button
              id="view-scheduled-list"
              class="scheduled-view-btn px-3 h-7 rounded-lg flex items-center justify-center gap-1.5 text-[11px] font-semibold bg-[#F3F4F6] text-[#111827] transition-all cursor-pointer"
              data-view="list"
            >
              <i class="ti ti-list text-[13px]"></i>
              List
            </button>
            <button
              id="view-scheduled-monthly"
              class="scheduled-view-btn px-3 h-7 rounded-lg flex items-center justify-center gap-1.5 text-[11px] font-semibold text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
              data-view="monthly"
            >
              <i class="ti ti-calendar text-[13px]"></i>
              Monthly
            </button>
            <button
              id="view-scheduled-weekly"
              class="scheduled-view-btn px-3 h-7 rounded-lg flex items-center justify-center gap-1.5 text-[11px] font-semibold text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
              data-view="weekly"
            >
              <i class="ti ti-calendar-week text-[13px]"></i>
              Weekly
            </button>
          </div>
          <span class="text-[12px] text-[#667085]">
            <span id="scheduled-count-display" class="font-bold text-[#111827]">0</span> items scheduled
          </span>
        </div>
      </div>

      <!-- VIEW: Scheduled List (Timeline) -->
      <div id="scheduled-timeline" class="space-y-6">
        <!-- Timeline items injected via JS -->
      </div>

      <!-- VIEW: Monthly Calendar -->
      <div id="scheduled-monthly" class="hidden bg-white rounded-3xl border border-[#eaecf0] p-6">
        <!-- Calendar Header -->
        <div class="flex items-center justify-between mb-6">
          <button
            id="cal-month-prev"
            class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
          >
            <i class="ti ti-chevron-left text-[16px]"></i>
          </button>
          <span
            id="cal-month-label"
            class="text-[16px] font-bold text-[#111827]"
          >May 2026</span>
          <button
            id="cal-month-next"
            class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
          >
            <i class="ti ti-chevron-right text-[16px]"></i>
          </button>
        </div>
        <!-- Weekday Headers -->
        <div class="grid grid-cols-7 gap-2 mb-2">
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Sun</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Mon</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Tue</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Wed</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Thu</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Fri</div>
          <div class="text-center text-[11px] font-semibold text-[#667085] py-2">Sat</div>
        </div>
        <!-- Calendar Grid -->
        <div id="cal-month-grid" class="grid grid-cols-7 gap-2">
          <!-- Days injected via JS -->
        </div>
      </div>

      <!-- VIEW: Weekly Calendar -->
      <div id="scheduled-weekly" class="hidden">
        <!-- Week Header -->
        <div class="flex items-center justify-between mb-4">
          <button
            id="cal-week-prev"
            class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
          >
            <i class="ti ti-chevron-left text-[16px]"></i>
          </button>
          <span
            id="cal-week-label"
            class="text-[16px] font-bold text-[#111827]"
          >May 4 – May 10, 2026</span>
          <button
            id="cal-week-next"
            class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
          >
            <i class="ti ti-chevron-right text-[16px]"></i>
          </button>
        </div>
        <!-- Week Grid -->
        <div id="cal-week-grid" class="grid grid-cols-7 gap-3">
          <!-- Days injected via JS -->
        </div>
      </div>

      <!-- Scheduled Empty State -->
      <div id="scheduled-empty" class="w-full hidden">
        <div class="text-center space-y-4 py-24">
          <div
            class="w-16 h-16 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center mx-auto"
          >
            <i class="ti ti-calendar-event text-[32px] text-[#D1D5DB]"></i>
          </div>
          <div class="space-y-1">
            <h2 class="text-[18px] font-bold text-[#344054]">
              No scheduled content
            </h2>
            <p class="text-[14px] text-[#667085] font-medium">
              Approve content from Outputs to schedule them for publishing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MODAL: ADD AUTOMATION (3 STEP WIZARD) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="modal-add-automation"
    class="hidden fixed inset-0 z-100 items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200"
  >
    <div
      class="bg-white w-full max-w-3xl h-160 rounded-4xl shadow-2xl flex flex-col overflow-hidden animate-in zoom-in-95 duration-300 relative"
    >
      <!-- Close Button -->
      <button
        id="close-add-modal"
        class="absolute top-5 right-5 w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer"
      >
        <i class="ti ti-x text-[20px]"></i>
      </button>

      <!-- Header -->
      <div class="px-7 pt-7 pb-3 bg-white relative z-20">
        <h2 class="text-[20px] font-bold text-[#111827] tracking-tight mb-0.5">
          Create Automation
        </h2>
        <p class="text-[13px] text-[#667085]">
          Set up your automated content schedule.
        </p>
        <!-- Step Indicator -->
        <div class="flex items-center gap-2 mt-4">
          <div class="step-dot flex items-center gap-2" data-step="1">
            <div
              class="w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center"
            >
              1
            </div>
            <span class="text-[12px] font-semibold text-[#111827]">General</span
            >
          </div>
          <div class="w-6 h-px bg-[#eaecf0]"></div>
          <div class="step-dot flex items-center gap-2" data-step="2">
            <div
              class="w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center"
            >
              2
            </div>
            <span class="text-[12px] font-semibold text-[#667085]"
              >Schedule</span
            >
          </div>
          <div class="w-6 h-px bg-[#eaecf0]"></div>
          <div class="step-dot flex items-center gap-2" data-step="3">
            <div
              class="w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center"
            >
              3
            </div>
            <span class="text-[12px] font-semibold text-[#667085]">Review</span>
          </div>
        </div>
      </div>

      <!-- Scrollable Content -->
      <div
        id="wizard-content"
        class="flex-1 px-7 pb-24 overflow-y-auto scroll-smooth relative pt-2"
      >
        <!-- STEP 1: General Setup -->
        <div id="step-1" class="step-panel space-y-5">
          <div class="space-y-1.5">
            <label class="text-[13px] font-semibold text-[#344054]"
              >Task Name</label
            >
            <input
              id="input-name"
              type="text"
              placeholder="e.g. Summer Campaign 2026"
              class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>

          <div class="space-y-1.5 relative">
            <label class="text-[13px] font-semibold text-[#344054]"
              >Business DNA</label
            >
            <button
              id="btn-select-dna"
              class="w-full flex items-center gap-3 p-3.5 rounded-2xl border border-[#eaecf0] bg-white text-left transition-all hover:border-[#d0d5dd] hover:bg-gray-50 cursor-pointer"
            >
              <div
                class="w-10 h-10 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
              >
                <i class="ti ti-building text-[20px] text-[#667085]"></i>
              </div>
              <div class="flex-1 min-w-0">
                <p
                  id="dna-selected-name"
                  class="text-[14px] font-bold text-[#111827]"
                >
                  Select Business DNA
                </p>
                <p
                  id="dna-selected-desc"
                  class="text-[12px] text-[#667085] truncate"
                >
                  Choose a business profile for AI grounding
                </p>
              </div>
              <i class="ti ti-chevron-right text-[16px] text-[#98a2b3]"></i>
            </button>
            <!-- DNA Dropdown -->
            <div
              id="dna-dropdown"
              class="hidden absolute left-0 right-0 mt-1 bg-white rounded-2xl border border-[#eaecf0] shadow-[0_8px_30px_rgba(0,0,0,0.08)] z-40 overflow-hidden"
            >
              <div
                class="p-2 space-y-1 max-h-60 overflow-y-auto"
                style="scrollbar-width: none;"
              >
                <button
                  class="dna-option w-full flex items-center gap-3 p-3 rounded-xl text-left hover:bg-[#F9FAFB] transition-colors cursor-pointer"
                  data-name="Fresh Juice Co."
                  data-desc="Organic beverage & lifestyle brand"
                >
                  <div
                    class="w-9 h-9 rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                  >
                    <i class="ti ti-brand-abstract text-[18px] text-[#667085]"
                    ></i>
                  </div>
                  <div>
                    <p class="text-[13px] font-bold text-[#111827]">
                      Fresh Juice Co.
                    </p>
                    <p class="text-[11px] text-[#667085]">
                      Organic beverage & lifestyle brand
                    </p>
                  </div>
                </button>
                <button
                  class="dna-option w-full flex items-center gap-3 p-3 rounded-xl text-left hover:bg-[#F9FAFB] transition-colors cursor-pointer"
                  data-name="Tech Startup"
                  data-desc="B2B SaaS platform for automation"
                >
                  <div
                    class="w-9 h-9 rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                  >
                    <i class="ti ti-rocket text-[18px] text-[#667085]"></i>
                  </div>
                  <div>
                    <p class="text-[13px] font-bold text-[#111827]">
                      Tech Startup
                    </p>
                    <p class="text-[11px] text-[#667085]">
                      B2B SaaS platform for automation
                    </p>
                  </div>
                </button>
                <button
                  class="dna-option w-full flex items-center gap-3 p-3 rounded-xl text-left hover:bg-[#F9FAFB] transition-colors cursor-pointer"
                  data-name="Luxe Beauty"
                  data-desc="Premium skincare & cosmetics"
                >
                  <div
                    class="w-9 h-9 rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                  >
                    <i class="ti ti-sparkles text-[18px] text-[#667085]"></i>
                  </div>
                  <div>
                    <p class="text-[13px] font-bold text-[#111827]">
                      Luxe Beauty
                    </p>
                    <p class="text-[11px] text-[#667085]">
                      Premium skincare & cosmetics
                    </p>
                  </div>
                </button>
              </div>
            </div>
          </div>

          <!-- Draft Mode Info Banner -->
          <div
            class="flex items-start gap-3 p-4 rounded-2xl bg-[#EFF6FF] border border-[#DBEAFE]"
          >
            <i
              class="ti ti-file-check text-[18px] text-[#2563EB] shrink-0 mt-0.5"
            ></i>
            <div class="space-y-1">
              <p class="text-[13px] font-bold text-[#2563EB]">Draft Mode</p>
              <p class="text-[12px] text-[#667085] leading-relaxed">
                Automation ini akan menghasilkan draft konten untuk review manual Anda. Setiap konten perlu di-approve sebelum dipublish.
              </p>
            </div>
          </div>
        </div>

        <!-- STEP 2: Schedule -->
        <div id="step-2" class="step-panel hidden space-y-5">
          <!-- Schedule Mode Toggle -->
          <div class="flex items-center justify-between">
            <label class="text-[13px] font-semibold text-[#344054]">Select Dates</label>
            <div class="flex items-center gap-1 p-1 bg-white rounded-xl border border-[#eaecf0]">
              <button
                id="btn-mode-monthly"
                class="schedule-mode-btn px-3 h-7 rounded-lg text-[11px] font-semibold bg-[#111827] text-white transition-all cursor-pointer"
                data-mode="monthly"
              >
                Monthly
              </button>
              <button
                id="btn-mode-weekly"
                class="schedule-mode-btn px-3 h-7 rounded-lg text-[11px] font-semibold text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
                data-mode="weekly"
              >
                Weekly
              </button>
            </div>
          </div>

          <!-- Monthly Calendar -->
          <div id="monthly-calendar" class="space-y-1.5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <button
                  id="btn-ai-suggestion"
                  class="flex items-center gap-1.5 px-2.5 h-6 rounded-lg border border-[#dbeafe] bg-[#EFF6FF] text-[11px] font-medium text-[#2563EB] hover:bg-[#DBEAFE] transition-all cursor-pointer"
                  title="AI will suggest optimal posting dates"
                >
                  <i class="ti ti-sparkles text-[12px]"></i>
                  Auto-Fill
                </button>
                <span
                  id="selected-dates-count"
                  class="text-[11px] text-[#667085]">0 dates selected</span
                >
              </div>
            </div>
            <div class="p-4 rounded-2xl bg-white border border-[#eaecf0]">
              <!-- Calendar Header -->
              <div class="flex items-center justify-between mb-4">
                <button
                  id="cal-prev"
                  class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
                >
                  <i class="ti ti-chevron-left text-[16px]"></i>
                </button>
                <span
                  id="cal-month-year"
                  class="text-[14px] font-bold text-[#111827]">May 2026</span
                >
                <button
                  id="cal-next"
                  class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
                >
                  <i class="ti ti-chevron-right text-[16px]"></i>
                </button>
              </div>
              <!-- Weekday Headers -->
              <div class="grid grid-cols-7 gap-1 mb-1">
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Sun
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Mon
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Tue
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Wed
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Thu
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Fri
                </div>
                <div
                  class="text-center text-[10px] font-semibold text-[#98a2b3] py-1"
                >
                  Sat
                </div>
              </div>
              <!-- Calendar Grid -->
              <div id="cal-grid" class="grid grid-cols-7 gap-1">
                <!-- Days injected via JS -->
              </div>
            </div>
          </div>

          <!-- Weekly Calendar (hidden by default) -->
          <div id="weekly-calendar" class="space-y-1.5 hidden">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <button
                  id="btn-ai-suggestion-weekly"
                  class="flex items-center gap-1.5 px-2.5 h-6 rounded-lg border border-[#dbeafe] bg-[#EFF6FF] text-[11px] font-medium text-[#2563EB] hover:bg-[#DBEAFE] transition-all cursor-pointer"
                  title="AI will suggest optimal posting dates"
                >
                  <i class="ti ti-sparkles text-[12px]"></i>
                  Auto-Fill
                </button>
                <span
                  id="selected-weekly-dates-count"
                  class="text-[11px] text-[#667085]"
                  >0 dates selected</span
                >
              </div>
            </div>
            <div class="p-4 rounded-2xl bg-white border border-[#eaecf0]">
              <!-- Week Header -->
              <div class="flex items-center justify-between mb-4">
                <button
                  id="wizard-cal-week-prev"
                  class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
                >
                  <i class="ti ti-chevron-left text-[16px]"></i>
                </button>
                <span
                  id="wizard-cal-week-label"
                  class="text-[14px] font-bold text-[#111827]"
                  >May 4 – May 10, 2026</span
                >
                <button
                  id="wizard-cal-week-next"
                  class="w-8 h-8 rounded-lg hover:bg-[#F9FAFB] flex items-center justify-center text-[#667085] cursor-pointer transition-colors"
                >
                  <i class="ti ti-chevron-right text-[16px]"></i>
                </button>
              </div>
              <!-- Weekday Headers -->
              <div class="grid grid-cols-7 gap-1 mb-1">
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Sun</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Mon</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Tue</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Wed</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Thu</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Fri</div>
                <div class="text-center text-[10px] font-semibold text-[#98a2b3] py-1">Sat</div>
              </div>
              <!-- Week Grid -->
              <div id="wizard-cal-week-grid" class="grid grid-cols-7 gap-1">
                <!-- Days injected via JS -->
              </div>
            </div>
          </div>
        </div>

        <!-- STEP 3: Review & Confirm -->
        <div id="step-3" class="step-panel hidden space-y-5">
          <div class="space-y-4">
            <h3 class="text-[14px] font-bold text-[#344054]">Review Summary</h3>

            <!-- Basic Info -->
            <div
              class="space-y-3 p-4 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0]"
            >
              <div class="flex justify-between items-center">
                <span class="text-[12px] text-[#667085]">Task Name</span>
                <span
                  id="review-name"
                  class="text-[13px] font-bold text-[#111827]">-</span
                >
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[12px] text-[#667085]">Business DNA</span>
                <span
                  id="review-dna"
                  class="text-[13px] font-bold text-[#111827]">-</span
                >
              </div>
              <!-- All automations are draft-only — no publishing mode info needed -->
            </div>

            <!-- Recurring -->
            <div class="space-y-3 pt-2">
              <h4 class="text-[12px] font-semibold text-[#344054]">Repeat</h4>
              <div class="flex gap-2">
                <label class="flex-1 cursor-pointer">
                  <input
                    type="radio"
                    name="recurring"
                    value="once"
                    class="peer hidden"
                    checked
                  />
                  <div
                    class="px-3 py-2.5 rounded-xl border border-[#eaecf0] bg-white text-center text-[12px] font-medium text-[#667085] peer-checked:bg-[#111827] peer-checked:text-white peer-checked:border-[#111827] transition-all"
                  >
                    One Time Only
                  </div>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input
                    type="radio"
                    name="recurring"
                    value="monthly"
                    class="peer hidden"
                  />
                  <div
                    class="px-3 py-2.5 rounded-xl border border-[#eaecf0] bg-white text-center text-[12px] font-medium text-[#667085] peer-checked:bg-[#111827] peer-checked:text-white peer-checked:border-[#111827] transition-all"
                  >
                    Monthly
                  </div>
                </label>
                <label id="label-recurring-weekly" class="flex-1 cursor-pointer opacity-60">
                  <input
                    type="radio"
                    name="recurring"
                    value="weekly"
                    id="radio-recurring-weekly"
                    class="peer hidden"
                    disabled
                  />
                  <div
                    id="div-recurring-weekly"
                    class="px-3 py-2.5 rounded-xl border border-[#eaecf0] bg-white text-center text-[12px] font-medium text-[#667085] peer-checked:bg-[#111827] peer-checked:text-white peer-checked:border-[#111827] transition-all"
                  >
                    Weekly
                  </div>
                </label>
              </div>

              <p id="recurring-mode-info" class="text-[11px] text-[#667085]">
                Pilih mode schedule di Step 2. Jika Monthly dipilih, Weekly repetition akan dinonaktifkan.
              </p>

              <!-- Repeat For (hidden when One Time Only) -->
              <div id="repeat-for-wrapper" class="hidden space-y-1.5">
                <label class="text-[11px] font-semibold text-[#344054]"
                  >Repeat for</label
                >
                <select
                  id="repeat-for-select"
                  class="w-full h-9 px-3 rounded-xl border border-[#eaecf0] bg-white text-[12px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
                >
                  <option value="3">3 months</option>
                  <option value="6">6 months</option>
                  <option value="12">12 months</option>
                </select>
              </div>

              <!-- Weekly Repetition (hidden when not Weekly) -->
              <div id="weekly-repeat-wrapper" class="hidden space-y-1.5">
                <label class="text-[11px] font-semibold text-[#344054]"
                  >Repeat every week of month</label
                >
                <select
                  id="weekly-week-select"
                  class="w-full h-9 px-3 rounded-xl border border-[#eaecf0] bg-white text-[12px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
                >
                  <option value="1">Week 1 (days 1–7)</option>
                  <option value="2">Week 2 (days 8–14)</option>
                  <option value="3">Week 3 (days 15–21)</option>
                  <option value="4">Week 4 (days 22–28)</option>
                  <option value="5">Week 5 (if exists, days 29–31)</option>
                </select>
                <p class="text-[11px] text-[#667085]">
                  Konten akan di-generate setiap minggu ke-N di bulan berikutnya. Jika minggu tersebut tidak memiliki tanggal yang dipilih, konten akan di-generate di hari terakhir minggu tersebut.
                </p>
              </div>

              <p id="recurring-info" class="text-[11px] text-[#667085]">
                Content will be generated once on selected dates.
              </p>

              <!-- Live Preview Timeline (hidden when One Time Only) -->
              <div id="recurring-preview" class="hidden space-y-2">
                <p class="text-[11px] font-semibold text-[#344054]">
                  Next months preview
                </p>
                <div id="recurring-preview-grid" class="grid grid-cols-3 gap-2">
                  <!-- Injected via JS -->
                </div>
              </div>
            </div>

            <!-- Schedule Cards -->
            <div class="space-y-2">
              <h4 class="text-[12px] font-semibold text-[#344054]">Schedule</h4>
              <div id="review-schedule-cards" class="grid grid-cols-2 gap-2">
                <!-- Cards injected via JS -->
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating Footer Buttons -->
      <div
        class="absolute bottom-0 left-0 right-0 flex items-center justify-between z-30 pointer-events-none px-7 py-5 bg-white border-t border-[#eaecf0]"
      >
        <!-- Left: Total Credit Estimate -->
        <div class="flex items-center gap-2 pointer-events-auto">
          <span
            class="text-[11px] font-medium text-[#667085] uppercase tracking-wider"
            >Total</span
          >
          <div
            class="flex items-center gap-1.5 px-3 h-8 rounded-full bg-[#F9FAFB] border border-[#eaecf0]"
          >
            <i class="ti ti-sparkles text-[14px] text-[#111827]"></i>
            <span class="text-[13px] font-bold text-[#111827]">
              <span id="footer-credit">0</span>
            </span>
            <span class="text-[12px] text-[#667085]">credits</span>
          </div>
          <!-- Tooltip -->
          <div class="relative group">
            <i class="ti ti-info-circle text-[14px] text-[#98a2b3] cursor-help"
            ></i>
            <div
              class="hidden group-hover:block absolute bottom-full left-0 mb-2 w-64 p-3 rounded-xl bg-[#111827] text-white text-[11px] leading-relaxed shadow-[0_8px_30px_rgba(0,0,0,0.2)] z-50"
            >
              Total credits that will be consumed when AI generates all
              scheduled content. One credit = one piece of content (image +
              caption).
            </div>
          </div>
        </div>
        <!-- Right: Buttons -->
        <div class="flex items-center gap-3 pointer-events-auto">
          <button
            id="btn-wizard-back"
            class="btn-active-plate btn-active-bottom px-6 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer hidden"
            >Back</button
          >
          <button
            id="btn-wizard-next"
            class="btn-active-plate btn-active-dark btn-active-bottom px-8 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer"
            >Next</button
          >
          <button
            id="btn-start-automation"
            class="btn-active-plate btn-active-dark btn-active-bottom px-8 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer hidden"
            >Start Automation</button
          >
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MODAL: AUTO ENGAGEMENT (Comment + DM) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="modal-auto-engagement"
    class="hidden fixed inset-0 z-100 items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200"
  >
    <div
      class="bg-white w-full max-w-120 rounded-4xl shadow-2xl flex flex-col overflow-hidden animate-in zoom-in-95 duration-300 relative max-h-[85vh]"
    >
      <!-- Close Button -->
      <button
        id="close-engagement-modal"
        class="absolute top-5 right-5 w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer"
      >
        <i class="ti ti-x text-[20px]"></i>
      </button>

      <!-- Header -->
      <div class="px-7 pt-7 pb-3 bg-white relative z-20 shrink-0">
        <h2 class="text-[20px] font-bold text-[#111827] tracking-tight mb-0.5">
          Auto Engagement
        </h2>
        <p class="text-[13px] text-[#667085]">
          Set up automatic responses for comments and DMs.
        </p>
      </div>

      <!-- Content -->
      <div
        class="flex-1 px-7 pb-24 overflow-y-auto scroll-smooth relative pt-2 space-y-5"
      >
        <!-- Auto Comment Section -->
        <div class="space-y-3">
          <div
            class="flex items-center justify-between p-4 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0]"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-[#EFF6FF] border border-[#dbeafe] flex items-center justify-center"
              >
                <i class="ti ti-message text-[18px] text-[#2563EB]"></i>
              </div>
              <div>
                <p class="text-[13px] font-bold text-[#111827]">Auto Comment</p>
                <p class="text-[11px] text-[#667085]">
                  Reply to comments automatically
                </p>
              </div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="comment-toggle" class="sr-only peer" />
              <div
                class="w-11 h-6 bg-[#eaecf0] peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#2563EB]"
              >
              </div>
            </label>
          </div>

          <!-- Comment Fields (hidden when off) -->
          <div id="comment-fields" class="space-y-4 hidden">
            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >Reply Text</label
              >
              <textarea
                id="comment-text"
                rows="2"
                placeholder="Thank you for your comment!"
                class="w-full px-4 py-3 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all resize-none"
              ></textarea>
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >Optional Link</label
              >
              <input
                id="comment-link"
                type="url"
                placeholder="https://..."
                class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
              />
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >Trigger Keywords (Optional)</label
              >
              <input
                id="comment-keywords"
                type="text"
                placeholder="price, info, interested (comma separated)"
                class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
              />
              <p class="text-[11px] text-[#667085]">
                Only replies if comment contains one of these keywords.
              </p>
            </div>
          </div>
        </div>

        <!-- Divider -->
        <div class="h-px bg-[#eaecf0]"></div>

        <!-- Auto DM Section -->
        <div class="space-y-3">
          <div
            class="flex items-center justify-between p-4 rounded-2xl bg-[#F9FAFB] border border-[#eaecf0]"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-[#F5F3FF] border border-[#ddd6fe] flex items-center justify-center"
              >
                <i class="ti ti-send text-[18px] text-[#7C3AED]"></i>
              </div>
              <div>
                <p class="text-[13px] font-bold text-[#111827]">Auto DM</p>
                <p class="text-[11px] text-[#667085]">
                  Send DM to commenters automatically
                </p>
              </div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="dm-toggle" class="sr-only peer" />
              <div
                class="w-11 h-6 bg-[#eaecf0] peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#7C3AED]"
              >
              </div>
            </label>
          </div>

          <!-- DM Fields (hidden when off) -->
          <div id="dm-fields" class="space-y-4 hidden">
            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >DM Message</label
              >
              <textarea
                id="dm-text"
                rows="2"
                placeholder="Hi! Thanks for your interest. Here's more info..."
                class="w-full px-4 py-3 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#7C3AED] focus:shadow-[0_0_0_3px_rgba(124,58,237,0.1)] transition-all resize-none"
              ></textarea>
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >Optional Link</label
              >
              <input
                id="dm-link"
                type="url"
                placeholder="https://..."
                class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#7C3AED] focus:shadow-[0_0_0_3px_rgba(124,58,237,0.1)] transition-all"
              />
            </div>

            <div class="space-y-1.5">
              <label class="text-[13px] font-semibold text-[#344054]"
                >Trigger Keywords (Optional)</label
              >
              <input
                id="dm-keywords"
                type="text"
                placeholder="price, info, interested (comma separated)"
                class="w-full h-10 px-4 rounded-xl border border-[#eaecf0] bg-white text-[13px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#7C3AED] focus:shadow-[0_0_0_3px_rgba(124,58,237,0.1)] transition-all"
              />
              <p class="text-[11px] text-[#667085]">
                Only sends DM if comment contains one of these keywords.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating Footer -->
      <div
        class="absolute bottom-7 right-7 flex items-center gap-3 z-30 pointer-events-none"
      >
        <button
          id="btn-cancel-engagement"
          class="pointer-events-auto btn-active-plate btn-active-bottom px-6 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >Cancel</button
        >
        <button
          id="btn-save-engagement"
          class="pointer-events-auto btn-active-plate btn-active-dark btn-active-bottom px-8 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer"
          >Save</button
        >
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MODAL: PREVIEW CONTENT (Simple) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="modal-preview"
    class="hidden fixed inset-0 z-100 items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200"
  >
    <div
      id="preview-panel"
      class="bg-white w-full max-w-lg max-h-[85vh] rounded-[28px] shadow-2xl flex flex-col overflow-hidden animate-in zoom-in-95 duration-300 relative"
    >
      <!-- Close Button -->
      <button
        id="close-preview-modal"
        class="absolute top-4 right-4 w-9 h-9 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer"
      >
        <i class="ti ti-x text-[18px]"></i>
      </button>

      <!-- Header -->
      <div class="px-6 pt-6 pb-3 shrink-0">
        <div class="flex items-center gap-2">
          <h3
            id="preview-title-header"
            class="text-[18px] font-bold text-[#111827] tracking-tight"
          ></h3>
          <span
            id="preview-status-badge"
            class="inline-flex items-center px-2 h-5 rounded-full text-[10px] font-bold"
          ></span>
        </div>
      </div>

      <!-- Body -->
      <div class="flex-1 overflow-y-auto px-6 pb-6 space-y-4">
        <!-- Image -->
        <div
          id="preview-image-wrapper"
          class="relative rounded-2xl overflow-hidden bg-[#F3F4F6] aspect-4/3"
        >
          <div
            id="preview-image-container"
            class="w-full h-full flex items-center justify-center"
          >
            <div class="text-center space-y-2">
              <i class="ti ti-photo text-[40px] text-[#D0D5DB]"></i>
              <p class="text-[11px] text-[#98a2b3]">1080 × 1080</p>
            </div>
          </div>
        </div>

        <!-- Caption -->
        <div class="space-y-2">
          <h4 class="text-[12px] font-bold text-[#344054] uppercase tracking-wider">Caption</h4>
          <textarea
            id="preview-caption-input"
            rows="3"
            class="w-full p-3 rounded-xl border border-[#eaecf0] text-[13px] text-[#667085] leading-relaxed resize-none focus:outline-none focus:border-[#2563EB] focus:ring-2 focus:ring-[#2563EB]/10 transition-all bg-white"
          ></textarea>
        </div>

        <!-- Meta -->
        <div class="grid grid-cols-2 gap-3">
          <div class="p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
            <p class="text-[10px] text-[#667085] uppercase tracking-wider font-semibold">Platform</p>
            <p id="preview-platform" class="text-[13px] font-bold text-[#111827] mt-0.5"></p>
          </div>
          <div class="p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
            <p class="text-[10px] text-[#667085] uppercase tracking-wider font-semibold">Type</p>
            <p id="preview-type" class="text-[13px] font-bold text-[#111827] mt-0.5"></p>
          </div>
          <div class="p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
            <p class="text-[10px] text-[#667085] uppercase tracking-wider font-semibold">Business</p>
            <p id="preview-brand" class="text-[13px] font-bold text-[#111827] mt-0.5"></p>
          </div>
          <div class="p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]">
            <p class="text-[10px] text-[#667085] uppercase tracking-wider font-semibold">Created</p>
            <p id="preview-date" class="text-[13px] font-bold text-[#111827] mt-0.5"></p>
          </div>
        </div>

        <!-- Actions -->
        <div id="preview-actions" class="flex items-center gap-2 pt-2">
          <button
            id="btn-reject"
            class="flex-1 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >Reject</button>
          <button
            id="btn-approve"
            class="flex-1 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer"
          >Approve</button>
        </div>
        <div id="preview-approved-actions" class="hidden items-center gap-2 pt-2">
          <button
            id="btn-unapprove"
            class="flex-1 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer"
          >Move to Draft</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- TOAST NOTIFICATION -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="toast-container"
    class="fixed bottom-6 right-6 z-200 flex flex-col gap-2 pointer-events-none"
  >
    <div
      id="toast-template"
      class="hidden pointer-events-auto items-center gap-3 px-4 py-3 rounded-2xl bg-[#111827] text-white shadow-[0_8px_30px_rgba(0,0,0,0.12)] transform translate-y-2 opacity-0 transition-all duration-300"
    >
      <i class="ti ti-check text-[18px] text-[#34D399]"></i>
      <span class="text-[13px] font-medium toast-message"></span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- DATE DETAIL POPOVER (list automations per date) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="date-detail-popover"
    class="hidden fixed z-110 bg-white rounded-2xl border border-[#eaecf0] shadow-[0_8px_30px_rgba(0,0,0,0.08)] p-4 w-72 space-y-3"
  >
    <div class="flex items-center justify-between">
      <span id="date-detail-date" class="text-[13px] font-bold text-[#111827]"
        >Date</span
      >
      <button
        id="close-date-detail-popover"
        class="w-6 h-6 rounded-full hover:bg-gray-100 flex items-center justify-center text-[#667085] cursor-pointer"
      >
        <i class="ti ti-x text-[14px]"></i>
      </button>
    </div>
    <div id="date-detail-list" class="space-y-2">
      <!-- Automation list injected via JS -->
    </div>
    <button
      id="btn-add-new-automation"
      class="w-full h-9 rounded-xl border border-dashed border-[#eaecf0] bg-[#F9FAFB] text-[12px] font-medium text-[#667085] hover:border-[#2563EB] hover:text-[#2563EB] hover:bg-[#EFF6FF] transition-all cursor-pointer flex items-center justify-center gap-1.5"
    >
      <i class="ti ti-plus text-[14px]"></i>
      Add New Automation
    </button>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- AUTOMATION FORM POPOVER (add/edit automation) -->
  <!-- ═══════════════════════════════════════ -->
  <div
    id="automation-popover"
    class="hidden fixed z-110 bg-white rounded-2xl border border-[#eaecf0] shadow-[0_8px_30px_rgba(0,0,0,0.08)] p-4 w-72 space-y-3"
  >
    <div class="flex items-center justify-between">
      <span
        id="automation-popover-date"
        class="text-[13px] font-bold text-[#111827]">Date</span
      >
      <button
        id="close-automation-popover"
        class="w-6 h-6 rounded-full hover:bg-gray-100 flex items-center justify-center text-[#667085] cursor-pointer"
      >
        <i class="ti ti-x text-[14px]"></i>
      </button>
    </div>
    <div class="space-y-2">
      <label class="text-[11px] font-semibold text-[#344054]"
        >Content Type</label
      >
      <select
        id="automation-content-type"
        class="w-full h-9 px-3 rounded-xl border border-[#eaecf0] bg-white text-[12px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
      >
        <option value="Single Post">Single Post</option>
        <option value="Story">Story</option>
        <option value="Single Post & Story">Single Post & Story</option>
        <option value="Mix Single Post or Story">Mix Single Post or Story</option>
        <option value="Mix Single Post or Carousel">Mix Single Post or Carousel</option>
        <option value="Carousel">Carousel</option>
        <option value="Ad Creatives">Ad Creatives</option>
      </select>
      <p id="content-type-desc" class="text-[11px] text-[#667085] leading-relaxed">
        Menghasilkan 1 image post dengan rasio 1:1.
      </p>
    </div>
    <div class="space-y-2">
      <label class="text-[11px] font-semibold text-[#344054]"
        >Content Pillar</label
      >
      <select
        id="automation-category"
        class="w-full h-9 px-3 rounded-xl border border-[#eaecf0] bg-white text-[12px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
      >
        <option value="">Select pillar...</option>
        <option value="Promo">Promo</option>
        <option value="Educational">Educational</option>
        <option value="Behind the Scenes">Behind the Scenes</option>
        <option value="Testimonial">Testimonial</option>
        <option value="Product Highlight">Product Highlight</option>
        <option value="Trending">Trending</option>
        <option value="Public Holiday">Public Holiday</option>
      </select>
    </div>
    <div class="space-y-2">
      <div class="flex items-center justify-between">
        <label class="text-[11px] font-semibold text-[#344054]"
          >Additional AI Instructions</label
        >
        <button
          id="btn-auto-generate-prompt"
          class="flex items-center gap-1 px-2 h-5 rounded-full bg-[#F9FAFB] border border-[#eaecf0] text-[10px] font-medium text-[#667085] hover:bg-[#EFF6FF] hover:text-[#2563EB] hover:border-[#dbeafe] transition-all cursor-pointer"
          title="Auto-generate instructions"
        >
          <i class="ti ti-sparkles text-[11px]"></i>
          Auto
        </button>
      </div>
      <textarea
        id="automation-prompt"
        rows="2"
        placeholder="Optional instructions for AI..."
        class="w-full px-3 py-2 rounded-xl border border-[#eaecf0] bg-white text-[12px] text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] transition-all resize-none"
      ></textarea>
    </div>
    <div class="space-y-2">
      <label class="text-[11px] font-semibold text-[#344054]">Variations</label>
      <div class="flex items-center gap-2">
        <button
          id="btn-var-minus"
          class="w-7 h-7 rounded-lg border border-[#eaecf0] bg-white flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] cursor-pointer transition-colors"
        >
          <i class="ti ti-minus text-[12px]"></i>
        </button>
        <input
          id="automation-variations"
          type="number"
          min="1"
          max="10"
          value="1"
          class="w-12 h-7 text-center rounded-lg border border-[#eaecf0] bg-white text-[12px] text-[#111827] outline-none focus:border-[#2563EB] transition-all"
        />
        <button
          id="btn-var-plus"
          class="w-7 h-7 rounded-lg border border-[#eaecf0] bg-white flex items-center justify-center text-[#667085] hover:bg-[#F9FAFB] cursor-pointer transition-colors"
        >
          <i class="ti ti-plus text-[12px]"></i>
        </button>
      </div>
      <p class="text-[10px] text-[#98a2b3]">
        How many content variations to generate
      </p>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-[11px] text-[#98a2b3]">
        <span id="automation-remaining">0</span>
      </span>
      <button
        id="btn-add-automation-popover"
        class="px-4 h-8 rounded-xl bg-[#111827] text-white text-[12px] font-bold hover:bg-black transition-all cursor-pointer"
        >Add</button
      >
    </div>
  </div>
</AppLayout>

<script is:inline>
  // ═══════════════════════════════════════════
  // STATE
  // ═══════════════════════════════════════════
  const STORAGE_KEY = "xeni_automations";
  let automations = [];
  let currentStep = 1;
  let wizardData = {
    name: "",
    dna: null,
    selectedDates: {}, // { '2026-05-15': [{contentType, category, prompt}] }
    recurring: "once",
    repeatFor: 3,
    weeklyWeek: 1,
    scheduleMode: "monthly", // "monthly" | "weekly"
    currentWeekDate: new Date(2026, 4, 5), // Current week start for weekly view
  };
  let currentCalendarDate = new Date(2026, 4, 1); // May 2026
  let activePopoverDate = null;
  let editingAutomationId = null;

  // Content type icons
  const CONTENT_ICONS = {
    "Single Post": "ti-photo",
    Story: "ti-device-mobile",
    "Single Post & Story": "ti-photo-plus",
    "Mix Single Post or Story": "ti-shuffle",
    "Mix Single Post or Carousel": "ti-shuffle",
    Carousel: "ti-carousel-horizontal",
    "Ad Creatives": "ti-speakerphone",
  };

  // Content type descriptions
  const CONTENT_TYPE_DESCS = {
    "Single Post": "Menghasilkan 1 image post dengan rasio 1:1.",
    Story: "Menghasilkan 1 image story dengan rasio 9:16.",
    "Single Post & Story": "Menghasilkan 2 output (Single Post + Story) dengan prompt dan key visual yang sama, hanya berbeda rasio.",
    "Mix Single Post or Story": "Menghasilkan 1 image. AI akan secara random memilih antara Single Post (1:1) atau Story (9:16).",
    "Mix Single Post or Carousel": "Menghasilkan 1 image. AI akan secara random memilih antara Single Post (1:1) atau Carousel.",
    Carousel: "Menghasilkan multiple images dalam format carousel.",
    "Ad Creatives": "Menghasilkan image untuk keperluan iklan.",
  };

  // Generated content mock data
  const GENERATED_STORAGE_KEY = "xeni_generated";
  let generatedContent = [];
  let currentFilter = "all";
  let currentChannel = "all";
  let currentType = "all";
  let currentSort = "newest";
  let currentViewMode = "grid";
  let currentBusinessFilter = "all";
  let searchQuery = "";
  let previewingContentId = null;
  let draftLimit = 3;
  let selectedApprovedIds = [];

  // Scheduled tab state
  let scheduledFilter = "upcoming";
  let scheduledSearchQuery = "";
  let scheduledViewMode = "list"; // list | monthly | weekly
  let scheduledMonthDate = new Date(2026, 4, 1); // May 2026
  let scheduledWeekDate = new Date(2026, 4, 5); // Current week start

  // Mock captions
  const MOCK_CAPTIONS = [
    "✨ New collection is here! Swipe to see all the colors available. Which one is your favorite?\n\n#newarrival #fashion #style",
    "🌞 Summer vibes only! Refresh your day with our signature blend.\n\n#summer #refresh #lifestyle",
    "💡 Pro tip: Consistency is key! Here's how we stay on top of our game.\n\n#tips #business #growth",
    "🎉 Giveaway alert! Follow + tag 2 friends for a chance to win.\n\n#giveaway #contest #win",
  ];

  // ═══════════════════════════════════════════
  // DOM REFERENCES
  // ═══════════════════════════════════════════
  const els = {
    activeCount: document.getElementById("status-active"),
    scheduledCount: document.getElementById("status-scheduled"),
    emptyState: document.getElementById("empty-state"),
    table: document.getElementById("automations-table"),
    tbody: document.getElementById("automations-tbody"),
    btnAdd: document.getElementById("btn-add-automation"),
    btnEmptyAdd: document.getElementById("btn-empty-add"),
    modalAdd: document.getElementById("modal-add-automation"),
    closeAddModal: document.getElementById("close-add-modal"),
    wizardContent: document.getElementById("wizard-content"),
    btnBack: document.getElementById("btn-wizard-back"),
    btnNext: document.getElementById("btn-wizard-next"),
    btnStart: document.getElementById("btn-start-automation"),
    stepPanels: document.querySelectorAll(".step-panel"),
    stepDots: document.querySelectorAll(".step-dot"),
    inputName: document.getElementById("input-name"),
    btnSelectDna: document.getElementById("btn-select-dna"),
    dnaDropdown: document.getElementById("dna-dropdown"),
    dnaSelectedName: document.getElementById("dna-selected-name"),
    dnaSelectedDesc: document.getElementById("dna-selected-desc"),
    calGrid: document.getElementById("cal-grid"),
    calMonthYear: document.getElementById("cal-month-year"),
    calPrev: document.getElementById("cal-prev"),
    calNext: document.getElementById("cal-next"),
    calWeekGrid: document.getElementById("wizard-cal-week-grid"),
    calWeekLabel: document.getElementById("wizard-cal-week-label"),
    calWeekPrev: document.getElementById("wizard-cal-week-prev"),
    calWeekNext: document.getElementById("wizard-cal-week-next"),
    btnModeMonthly: document.getElementById("btn-mode-monthly"),
    btnModeWeekly: document.getElementById("btn-mode-weekly"),
    monthlyCalendar: document.getElementById("monthly-calendar"),
    weeklyCalendar: document.getElementById("weekly-calendar"),
    selectedDatesContainer: document.getElementById("selected-dates-container"),
    recurringRadios: document.querySelectorAll('input[name="recurring"]'),
    recurringInfo: document.getElementById("recurring-info"),
    reviewName: document.getElementById("review-name"),
    reviewDna: document.getElementById("review-dna"),
    reviewRecurring: document.getElementById("review-recurring"),
    selectedDatesCount: document.getElementById("selected-dates-count"),
    selectedWeeklyDatesCount: document.getElementById("selected-weekly-dates-count"),
    btnAiSuggestion: document.getElementById("btn-ai-suggestion"),
    btnAiSuggestionWeekly: document.getElementById("btn-ai-suggestion-weekly"),
    reviewScheduleCards: document.getElementById("review-schedule-cards"),
    footerCredit: document.getElementById("footer-credit"),
    slotPopover: document.getElementById("automation-popover"),
    closeSlotPopover: document.getElementById("close-automation-popover"),
    slotPopoverDate: document.getElementById("automation-popover-date"),
    slotContentType: document.getElementById("automation-content-type"),
    slotCategory: document.getElementById("automation-category"),
    slotPrompt: document.getElementById("automation-prompt"),
    btnAddSlot: document.getElementById("btn-add-automation-popover"),
    automationVariations: document.getElementById("automation-variations"),
    btnVarMinus: document.getElementById("btn-var-minus"),
    btnVarPlus: document.getElementById("btn-var-plus"),
    dateDetailPopover: document.getElementById("date-detail-popover"),
    closeDateDetailPopover: document.getElementById(
      "close-date-detail-popover",
    ),
    dateDetailDate: document.getElementById("date-detail-date"),
    dateDetailList: document.getElementById("date-detail-list"),
    btnAddNewAutomation: document.getElementById("btn-add-new-automation"),
    // Auto Engagement modal
    modalEngagement: document.getElementById("modal-auto-engagement"),
    closeEngagementModal: document.getElementById("close-engagement-modal"),
    commentToggle: document.getElementById("comment-toggle"),
    commentFields: document.getElementById("comment-fields"),
    commentText: document.getElementById("comment-text"),
    commentLink: document.getElementById("comment-link"),
    commentKeywords: document.getElementById("comment-keywords"),
    dmToggle: document.getElementById("dm-toggle"),
    dmFields: document.getElementById("dm-fields"),
    dmText: document.getElementById("dm-text"),
    dmLink: document.getElementById("dm-link"),
    dmKeywords: document.getElementById("dm-keywords"),
    btnCancelEngagement: document.getElementById("btn-cancel-engagement"),
    btnSaveEngagement: document.getElementById("btn-save-engagement"),
    // Schedule modal
    modalSchedule: document.getElementById("modal-schedule"),
    closeScheduleModal: document.getElementById("close-schedule-modal"),
    scheduleDate: document.getElementById("schedule-date"),
