  // ═══════════════════════════════════════════
  // TOAST NOTIFICATION
  // ═══════════════════════════════════════════
  function showToast(message) {
    const container = document.getElementById("toast-container");
    const template = document.getElementById("toast-template");
    const toast = template.cloneNode(true);
    toast.id = "";
    toast.classList.remove("hidden");
    toast.classList.add("flex");
    toast.querySelector(".toast-message").textContent = message;
    container.appendChild(toast);

    // Animate in
    requestAnimationFrame(() => {
      toast.classList.remove("translate-y-2", "opacity-0");
    });

    // Remove after 3s
    setTimeout(() => {
      toast.classList.add("translate-y-2", "opacity-0");
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  // ═══════════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════════
  function init() {
    loadAutomations();
    loadGenerated();
    renderAutomations();
    renderGenerated();
    renderScheduled();
    bindEvents();
    renderCalendar();
    renderWeeklyCalendar();
  }

  // ═══════════════════════════════════════════
  // TAB SWITCHING
  // ═══════════════════════════════════════════
  function switchTab(tab) {
    // Reset all tabs
    [els.tabAutomations, els.tabGenerated, els.tabScheduled].forEach((btn) => {
      btn.classList.remove("bg-[#111827]", "text-white");
      btn.classList.add("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
    });
    [els.tabContentAutomations, els.tabContentGenerated, els.tabContentScheduled].forEach((content) => {
      content.classList.add("hidden");
    });

    // Activate selected tab
    if (tab === "automations") {
      els.tabAutomations.classList.add("bg-[#111827]", "text-white");
      els.tabAutomations.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
      els.tabContentAutomations.classList.remove("hidden");
      els.btnAdd.classList.remove("hidden");
      els.btnAdd.classList.add("flex");
    } else if (tab === "generated") {
      els.tabGenerated.classList.add("bg-[#111827]", "text-white");
      els.tabGenerated.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
      els.tabContentGenerated.classList.remove("hidden");
      els.btnAdd.classList.add("hidden");
      els.btnAdd.classList.remove("flex");
      draftLimit = 3;
    } else if (tab === "scheduled") {
      els.tabScheduled.classList.add("bg-[#111827]", "text-white");
      els.tabScheduled.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
      els.tabContentScheduled.classList.remove("hidden");
      els.btnAdd.classList.add("hidden");
      els.btnAdd.classList.remove("flex");
      renderScheduled();
    }
  }

  // ═══════════════════════════════════════════
  // GENERATED CONTENT
  // ═══════════════════════════════════════════
  function loadGenerated() {
    // Always use fresh mock data (deterministic, not from localStorage)
    generatedContent = createMockGenerated();
    saveGenerated();
  }

  function saveGenerated() {
    localStorage.setItem(
      GENERATED_STORAGE_KEY,
      JSON.stringify(generatedContent),
    );
  }

  function createMockGenerated() {
    const now = new Date();
    const dayMs = 24 * 60 * 60 * 1000;

    const brands = ["Fresh Juice Co.", "Tech Startup", "Luxe Beauty"];
    const types = ["Single Post", "Carousel", "Ad Creatives", "Story"];
    const platforms = ["Instagram", "TikTok", "LinkedIn"];
    const titles = [
      "Summer Vibes", "New Arrival", "Product Highlight", "Behind the Scenes",
      "Green Boost Tips", "Tech Tips & Tricks", "Skincare Routine", "Weekend Refresh",
      "Customer Love", "Daily Tips", "Summer Campaign", "Product Launch",
      "Morning Routine", "Healthy Living", "Office Tour", "Team Spotlight",
      "Flash Sale", "User Review", "Tutorial", "Quick Tips",
      "Brand Story", "Event Recap", "Meet the Founder", "Sneak Peek",
      "Wellness Wednesday", "Friday Favorites", "Monday Motivation", "How It Works",
      "Before & After", "Top 5 List"
    ];

    const items = [];
    for (let i = 0; i < 30; i++) {
      const brand = brands[i % 3];
      const type = types[i % 4];
      const platform = platforms[i % 3];
      const title = titles[i];
      const statusPool = ["draft", "draft", "approved", "approved", "published", "scheduled", "failed"];
      const status = statusPool[i % statusPool.length];
      const createdAt = new Date(now.getTime() - (i + 1) * 2 * 60 * 60 * 1000).toISOString();

      items.push({
        id: `gen_${status}_${i + 1}`,
        title,
        brand,
        contentType: type,
        platform,
        caption: MOCK_CAPTIONS[i % 4],
        status,
        automationName: "Campaign Mei 2026",
        createdAt,
        scheduledAt: status === "scheduled" ? new Date(2026, 4, 10 + (i % 20), 9 + (i % 6), 0).toISOString() : (status === "published" ? createdAt : null),
        publishedAt: status === "published" ? createdAt : null,
        views: status === "published" ? 500 + i * 100 : 0,
        likes: status === "published" ? 50 + i * 10 : 0,
        comments: status === "published" ? 10 + i * 2 : 0,
        failReason: status === "failed" ? "Upload failed" : null,
        autoComment: { enabled: false, text: "", link: "", keywords: "" },
        autoDm: { enabled: false, text: "", link: "", keywords: "" },
      });
    }
    return items;
  }

  function renderGenerated() {
    // Apply filters
    let filtered = generatedContent.filter((item) => {
      if (currentBusinessFilter !== "all" && item.brand !== currentBusinessFilter) return false;
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        const haystack = `${item.title} ${item.brand} ${item.caption}`.toLowerCase();
        if (!haystack.includes(q)) return false;
      }
      return true;
    });

    // Default sort: newest first
    filtered.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

    // Update badge
    const needsAttentionCount = generatedContent.filter(
      (g) => g.status === "draft" || g.status === "approved"
    ).length;
    els.generatedBadge.textContent = needsAttentionCount;
    els.generatedBadge.classList.toggle("hidden", needsAttentionCount === 0);

    // Split into draft and approved
    const drafts = filtered.filter((item) => item.status === "draft");
    const approved = filtered.filter((item) => item.status === "approved");

    // Render Draft Panel (Left)
    const draftList = document.getElementById("draft-list");
    const draftEmpty = document.getElementById("draft-empty");
    const draftCount = document.getElementById("draft-count");
    const draftShowMoreContainer = document.getElementById("draft-show-more-container");
    if (draftCount) draftCount.textContent = drafts.length;

    if (drafts.length === 0) {
      if (draftList) draftList.innerHTML = "";
      if (draftEmpty) draftEmpty.classList.remove("hidden");
      if (draftShowMoreContainer) {
        draftShowMoreContainer.classList.add("hidden");
        draftShowMoreContainer.classList.remove("flex");
      }
    } else {
      if (draftEmpty) draftEmpty.classList.add("hidden");
      if (draftList) {
        const slicedDrafts = drafts.slice(0, draftLimit);
        draftList.innerHTML = slicedDrafts.map((item) => renderDraftItem(item)).join("");
      }
      if (draftShowMoreContainer) {
        if (drafts.length > draftLimit) {
          draftShowMoreContainer.classList.remove("hidden");
          draftShowMoreContainer.classList.add("flex");
        } else {
          draftShowMoreContainer.classList.add("hidden");
          draftShowMoreContainer.classList.remove("flex");
        }
      }
    }

    // Render Approved Panel (Right) - 3-col Grid
    const approvedGrid = document.getElementById("approved-grid");
    const approvedEmpty = document.getElementById("approved-empty");
    const approvedCount = document.getElementById("approved-count");
    if (approvedCount) approvedCount.textContent = approved.length;

    if (approved.length === 0) {
      if (approvedGrid) approvedGrid.innerHTML = "";
      if (approvedEmpty) approvedEmpty.classList.remove("hidden");
    } else {
      if (approvedEmpty) approvedEmpty.classList.add("hidden");
      if (approvedGrid) {
        approvedGrid.innerHTML = renderApprovedGrid(approved);
      }
    }
  }

  function renderDraftItem(item) {
    const dateStr = formatRelativeDate(item.createdAt);
    const typeIconMap = {
      "Single Post": "ti-photo",
      Carousel: "ti-carousel-horizontal",
      "Ad Creatives": "ti-speakerphone",
      Story: "ti-device-mobile",
    };
    const typeIcon = typeIconMap[item.contentType] || "ti-file";

    return `
    <div class="group flex items-start gap-3 p-3 rounded-xl bg-white border border-[#eaecf0] hover:border-[#2563EB] hover:shadow-sm transition-all cursor-pointer" onclick="openPreviewModal('${item.id}')">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#FEF3C7] to-[#FDE68A] flex items-center justify-center shrink-0">
        <i class="ti ${typeIcon} text-[16px] text-[#B45309]"></i>
      </div>
      <div class="flex-1 min-w-0 space-y-1">
        <p class="text-[12px] font-semibold text-[#111827] truncate leading-tight">${escapeHtml(item.title)}</p>
        <div class="flex items-center gap-1.5">
          <span class="px-1.5 py-0.5 rounded-md bg-[#F3F4F6] text-[10px] font-medium text-[#667085]">${escapeHtml(item.brand)}</span>
          <span class="text-[10px] text-[#98a2b3]">${dateStr}</span>
        </div>
      </div>
    </div>
  `;
  }

  function renderApprovedGrid(items) {
    const sorted = [...items].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

    const typeIconMap = {
      "Single Post": "ti-photo",
      Carousel: "ti-carousel-horizontal",
      "Ad Creatives": "ti-speakerphone",
      Story: "ti-device-mobile",
    };

    const brandGradients = {
      "Fresh Juice Co.": "from-[#34D399] to-[#059669]",
      "Tech Startup": "from-[#60A5FA] to-[#2563EB]",
      "Luxe Beauty": "from-[#F472B6] to-[#DB2777]"
    };

    return sorted.map((item) => {
      const typeIcon = typeIconMap[item.contentType] || "ti-file";
      const dateStr = formatRelativeDate(item.createdAt);
      const brandGrad = brandGradients[item.brand] || "from-[#A78BFA] to-[#7C3AED]";
      const brandChar = item.brand ? item.brand.charAt(0) : "X";
      const isStory = item.contentType === "Story";
      const aspectClass = isStory ? "aspect-[9/16]" : "aspect-[3/4]";

      const isSelected = selectedApprovedIds.includes(item.id);
      const activeBorderClass = isSelected ? "border-[#2563EB] ring-2 ring-[#2563EB]/10" : "border-[#eaecf0]";

      return `
      <div class="inline-block w-full break-inside-avoid mb-3">
        <div id="card-approved-${item.id}" class="group relative bg-white rounded-[24px] border ${activeBorderClass} p-3 flex flex-col gap-3 cursor-pointer" onclick="openPreviewModal('${item.id}')">
          <!-- Image Container (Polosan Abu Tua Tanpa Icon) -->
          <div class="relative w-full ${aspectClass} rounded-[18px] bg-[#1f2937] flex items-center justify-center overflow-hidden shrink-0 shadow-inner">
            
            <!-- Subtle aspect ratio text on bottom right -->
            <span class="absolute bottom-3 right-3 px-2 h-5 rounded-full bg-black/40 backdrop-blur-sm text-[10px] font-bold text-white tracking-wider flex items-center">
              ${isStory ? "9:16" : "3:4"}
            </span>
            
            <!-- Brand Mini Logo on Top Left -->
            <div class="absolute top-3 left-3 flex items-center gap-1.5 px-2 h-5 rounded-full bg-black/40 backdrop-blur-sm text-[9px] font-bold text-white shadow-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br ${brandGrad}"></span>
              ${escapeHtml(item.brand)}
            </div>

            <!-- Bulk Checkbox (Top Right) - Appears on hover or if selected -->
            <div id="checkbox-container-${item.id}" class="absolute top-3 right-3 z-20 transition-opacity duration-200 ${isSelected ? "opacity-100" : "opacity-0 group-hover:opacity-100"}" onclick="event.stopPropagation();">
              <label class="relative flex items-center justify-center cursor-pointer">
                <input type="checkbox" id="cb-select-${item.id}" ${isSelected ? "checked" : ""} class="sr-only peer" onchange="toggleSelectCard('${item.id}')" />
                <div class="w-[18px] h-[18px] rounded-[5px] bg-black/20 backdrop-blur-sm border border-white flex items-center justify-center transition-all peer-checked:bg-[#2563EB] peer-checked:border-transparent peer-checked:[&_i]:opacity-100 shadow-sm">
                  <i class="ti ti-check text-[11px] text-white opacity-0 transition-opacity"></i>
                </div>
              </label>
            </div>
          </div>
          
          <!-- Info & Badges (Matches the width of the card) -->
          <div class="px-1 flex flex-col gap-2">
            <div class="flex flex-wrap items-center gap-1.5">
              <!-- When generated -->
              <span class="inline-flex items-center gap-1 px-2 h-5 rounded-full bg-[#F9FAFB] text-[10px] font-medium text-[#98A2B3]">
                <i class="ti ti-clock text-[10px]"></i>
                ${dateStr}
              </span>
              
              <!-- Content Type -->
              <span class="inline-flex items-center gap-1 px-2 h-5 rounded-full bg-[#EFF6FF] text-[10px] font-bold text-[#2563EB] border border-[#DBEAFE]">
                <i class="ti ${typeIcon} text-[10px]"></i>
                ${escapeHtml(item.contentType)}
              </span>
            </div>
          </div>
        </div>
      </div>
    `;
    }).join("");
  }

  // ═══════════════════════════════════════════
  // SCHEDULED TAB
  // ═══════════════════════════════════════════
  function renderScheduled() {
    // Get scheduled items from generatedContent
    let scheduled = generatedContent.filter((item) => item.status === "scheduled");

    // Apply filter
    const now = new Date();
    if (scheduledFilter === "upcoming") {
      scheduled = scheduled.filter((item) => new Date(item.scheduledAt) >= now);
    } else if (scheduledFilter === "past") {
      scheduled = scheduled.filter((item) => new Date(item.scheduledAt) < now);
    }

    // Apply search
    if (scheduledSearchQuery) {
      const q = scheduledSearchQuery.toLowerCase();
      scheduled = scheduled.filter((item) => {
        const haystack = `${item.title} ${item.brand} ${item.platform} ${item.contentType}`.toLowerCase();
        return haystack.includes(q);
      });
    }

    // Sort by scheduledAt ascending
    scheduled.sort((a, b) => new Date(a.scheduledAt) - new Date(b.scheduledAt));

    // Update badge
    const upcomingCount = generatedContent.filter(
      (g) => g.status === "scheduled" && new Date(g.scheduledAt) >= now
    ).length;
    els.scheduledBadge.textContent = upcomingCount;
    els.scheduledBadge.classList.toggle("hidden", upcomingCount === 0);
    els.scheduledCountDisplay.textContent = scheduled.length;

    // Toggle visibility of view containers
    const hasItems = scheduled.length > 0;
    els.scheduledTimeline.classList.toggle("hidden", !hasItems || scheduledViewMode !== "list");
    els.scheduledMonthly.classList.toggle("hidden", !hasItems || scheduledViewMode !== "monthly");
    els.scheduledWeekly.classList.toggle("hidden", !hasItems || scheduledViewMode !== "weekly");
    els.scheduledEmpty.classList.toggle("hidden", hasItems);

    if (!hasItems) return;

    if (scheduledViewMode === "list") {
      renderScheduledList(scheduled);
    } else if (scheduledViewMode === "monthly") {
      renderScheduledMonthly(scheduled);
    } else if (scheduledViewMode === "weekly") {
      renderScheduledWeekly(scheduled);
    }
  }

  function renderScheduledList(scheduled) {
    // Group by date
    const grouped = {};
    scheduled.forEach((item) => {
      const dateKey = new Date(item.scheduledAt).toLocaleDateString("en-US", {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric",
      });
      if (!grouped[dateKey]) grouped[dateKey] = [];
      grouped[dateKey].push(item);
    });

    const platformIconMap = {
      Instagram: "ti-brand-instagram",
      TikTok: "ti-brand-tiktok",
      LinkedIn: "ti-brand-linkedin",
      Facebook: "ti-brand-facebook",
      X: "ti-brand-x",
    };

    const contentTypeIconMap = {
      "Single Post": "ti-photo",
      Carousel: "ti-carousel-horizontal",
      "Ad Creatives": "ti-speakerphone",
      Story: "ti-device-mobile",
    };

    const now = new Date();

    els.scheduledTimeline.innerHTML = Object.entries(grouped)
      .map(([dateKey, items]) => {
        const dateObj = new Date(items[0].scheduledAt);
        const isToday =
          dateObj.toDateString() === new Date().toDateString();
        const isTomorrow =
          dateObj.toDateString() ===
          new Date(now.getTime() + 24 * 60 * 60 * 1000).toDateString();

        let dateLabel = dateKey;
        if (isToday) dateLabel = "Today";
        if (isTomorrow) dateLabel = "Tomorrow";

        const timeStr = dateObj.toLocaleTimeString("en-US", {
          hour: "2-digit",
          minute: "2-digit",
        });

        return `
        <div class="relative pl-6 border-l-2 border-[#eaecf0] pb-6 last:pb-0">
          <div class="absolute -left-[5px] top-0 w-2.5 h-2.5 rounded-full bg-[#8B5CF6] ring-4 ring-white"></div>
          <div class="flex items-center gap-3 mb-3 -mt-1">
            <h3 class="text-[14px] font-bold text-[#111827]">${dateLabel}</h3>
            ${isToday ? `<span class="px-2 h-5 rounded-full bg-[#F5F3FF] text-[#7C3AED] text-[10px] font-bold flex items-center">Today</span>` : ""}
            <span class="text-[12px] text-[#98a2b3]">${timeStr}</span>
          </div>
          <div class="space-y-2">
            ${items
              .map(
                (item) => {
                  const platformIcon = platformIconMap[item.platform] || "ti-file";
                  const typeIcon = contentTypeIconMap[item.contentType] || "ti-file";
                  const timeItem = new Date(item.scheduledAt).toLocaleTimeString("en-US", {
                    hour: "2-digit",
                    minute: "2-digit",
                  });
                  return `
              <div class="group flex items-center gap-4 bg-white rounded-2xl border border-[#eaecf0] p-3 hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:border-transparent transition-all cursor-pointer" onclick="openPreviewModal('${item.id}')">
                <div class="flex flex-col items-center justify-center w-14 shrink-0">
                  <span class="text-[13px] font-bold text-[#111827]">${timeItem.split(":")[0]}</span>
                  <span class="text-[10px] text-[#98a2b3]">${timeItem.split(":")[1]} ${timeItem.includes("AM") ? "AM" : "PM"}</span>
                </div>
                <div class="w-px h-10 bg-[#eaecf0]"></div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h4 class="text-[13px] font-bold text-[#111827] truncate">${escapeHtml(item.title)}</h4>
                    <span class="px-2 h-5 rounded-full bg-[#F5F3FF] text-[#7C3AED] text-[10px] font-bold flex items-center gap-1">
                      <i class="ti ${typeIcon} text-[10px]"></i>
                      ${item.contentType}
                    </span>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-[11px] text-[#667085]">${escapeHtml(item.brand)}</span>
                    <span class="text-[10px] text-[#98a2b3]">•</span>
                    <div class="flex items-center gap-1">
                      <i class="ti ${platformIcon} text-[11px] text-[#98a2b3]"></i>
                      <span class="text-[11px] text-[#98a2b3]">${item.platform}</span>
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button class="w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer" onclick="event.stopPropagation(); openPreviewModal('${item.id}')" title="Preview">
                    <i class="ti ti-eye text-[14px]"></i>
                  </button>
                  <button class="w-8 h-8 rounded-lg hover:bg-[#FEF3F2] flex items-center justify-center text-[#667085] hover:text-[#D92D20] transition-colors cursor-pointer" onclick="event.stopPropagation(); cancelScheduleItem('${item.id}')" title="Cancel">
                    <i class="ti ti-x text-[14px]"></i>
                  </button>
                </div>
              </div>
            `;
                }
              )
              .join("")}
          </div>
        </div>
      `;
      })
      .join("");
  }

  function renderScheduledMonthly(scheduled) {
    const year = scheduledMonthDate.getFullYear();
    const month = scheduledMonthDate.getMonth();

    els.calMonthLabel.textContent = scheduledMonthDate.toLocaleDateString("en-US", {
      month: "long",
      year: "numeric",
    });

    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const daysInMonth = lastDay.getDate();
    const startDayOfWeek = firstDay.getDay();

    // Build a map of scheduled items by day
    const itemsByDay = {};
    scheduled.forEach((item) => {
      const d = new Date(item.scheduledAt);
      if (d.getFullYear() === year && d.getMonth() === month) {
        const day = d.getDate();
        if (!itemsByDay[day]) itemsByDay[day] = [];
        itemsByDay[day].push(item);
      }
    });

    const today = new Date();
    const isCurrentMonth = today.getFullYear() === year && today.getMonth() === month;

    let html = "";
    // Empty cells before the first day
    for (let i = 0; i < startDayOfWeek; i++) {
      html += `<div class="aspect-square rounded-xl"></div>`;
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const isToday = isCurrentMonth && day === today.getDate();
      const dayItems = itemsByDay[day] || [];
      const hasItems = dayItems.length > 0;

      html += `
        <div class="aspect-square p-2 rounded-xl border ${isToday ? "border-[#8B5CF6] bg-[#F5F3FF]" : "border-[#eaecf0] bg-white"} flex flex-col gap-1 cursor-pointer hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)] transition-all" onclick="${hasItems ? `openPreviewModal('${dayItems[0].id}')` : ""}">
          <div class="flex items-center justify-between">
            <span class="text-[13px] font-bold ${isToday ? "text-[#7C3AED]" : "text-[#111827]"}">${day}</span>
            ${hasItems ? `<span class="w-2 h-2 rounded-full bg-[#8B5CF6]"></span>` : ""}
          </div>
          ${dayItems.slice(0, 2).map((item) => `
            <div class="px-1.5 py-0.5 rounded-md bg-[#F5F3FF] text-[9px] font-medium text-[#7C3AED] truncate leading-tight">
              ${escapeHtml(item.title)}
            </div>
          `).join("")}
          ${dayItems.length > 2 ? `<div class="px-1.5 py-0.5 text-[9px] text-[#98a2b3]">+${dayItems.length - 2} more</div>` : ""}
        </div>
      `;
    }

    els.calMonthGrid.innerHTML = html;
  }

  function renderScheduledWeekly(scheduled) {
    // Get the start of the week (Sunday)
    const weekStart = new Date(scheduledWeekDate);
    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
    weekStart.setHours(0, 0, 0, 0);

    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 6);
    weekEnd.setHours(23, 59, 59, 999);

    els.calWeekLabel.textContent = `${weekStart.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${weekEnd.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    // Build a map of scheduled items by day
    const itemsByDay = {};
    scheduled.forEach((item) => {
      const d = new Date(item.scheduledAt);
      // Find which day of this week it belongs to
      for (let i = 0; i < 7; i++) {
        const checkDay = new Date(weekStart);
        checkDay.setDate(checkDay.getDate() + i);
        if (d.toDateString() === checkDay.toDateString()) {
          if (!itemsByDay[i]) itemsByDay[i] = [];
          itemsByDay[i].push(item);
          break;
        }
      }
    });

    const dayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    let html = "";
    for (let i = 0; i < 7; i++) {
      const dayDate = new Date(weekStart);
      dayDate.setDate(dayDate.getDate() + i);
      const isToday = dayDate.toDateString() === new Date().toDateString();
      const isPast = dayDate < today;
      const dayItems = itemsByDay[i] || [];
      const hasItems = dayItems.length > 0;

      html += `
        <div class="flex flex-col gap-2">
          <!-- Date Header: Bento style white bg -->
          <div class="text-center p-3 rounded-2xl bg-white border ${isToday ? "border-[#8B5CF6]" : "border-[#eaecf0]"} ${isPast ? "opacity-70" : ""}">
            <div class="text-[11px] font-semibold ${isToday ? "text-[#7C3AED]" : "text-[#667085]"}">${dayNames[i]}</div>
            <div class="text-[18px] font-bold ${isToday ? "text-[#7C3AED]" : "text-[#111827]"}">${dayDate.getDate()}</div>
          </div>
          <!-- Items column -->
          <div class="flex flex-col gap-2 min-h-[200px]">
            ${hasItems ? dayItems.map((item) => {
              const timeStr = new Date(item.scheduledAt).toLocaleTimeString("en-US", {
                hour: "2-digit",
                minute: "2-digit",
              });
              const isItemPast = new Date(item.scheduledAt) < new Date();
              return `
                <div class="group p-2 rounded-xl bg-white border border-[#eaecf0] hover:border-[#8B5CF6] hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)] transition-all cursor-pointer ${isItemPast ? "opacity-60 grayscale-[0.3]" : ""}" onclick="openPreviewModal('${item.id}')">
                  <!-- Dummy Image -->
                  <div class="w-full aspect-square bg-gradient-to-tr from-[#f8fafc] via-[#f8fafc] to-[#EFF6FF] rounded-lg flex items-center justify-center mb-1.5 relative">
                    <i class="ti ti-photo text-[20px] text-[#D0D5DB]"></i>
                    <span class="absolute top-1 right-1 px-1.5 h-4 rounded-full bg-white/90 backdrop-blur-sm border border-[#eaecf0] text-[8px] font-bold text-[#667085] flex items-center">
                      ${item.contentType}
                    </span>
                  </div>
                  <!-- Time -->
                  <div class="text-[10px] font-bold text-[#7C3AED] mb-0.5">${timeStr}</div>
                  <!-- Title -->
                  <div class="text-[11px] font-semibold text-[#111827] truncate leading-tight mb-0.5">${escapeHtml(item.title)}</div>
                  <!-- Caption preview -->
                  <div class="text-[9px] text-[#667085] line-clamp-2 leading-tight">${escapeHtml(item.caption?.substring(0, 60) || "")}${item.caption?.length > 60 ? "..." : ""}</div>
                  <!-- Brand + Platform -->
                  <div class="flex items-center gap-1 mt-1 pt-1 border-t border-[#eaecf0]/60">
                    <span class="text-[9px] text-[#98a2b3]">${escapeHtml(item.brand)}</span>
                  </div>
                </div>
              `;
            }).join("") : `<div class="flex-1 flex flex-col items-center justify-center text-[11px] text-[#D1D5DB] py-8">
              <i class="ti ti-calendar-event text-[24px] mb-1"></i>
              <span>No items</span>
            </div>`}
          </div>
        </div>
      `;
    }

    els.calWeekGrid.innerHTML = html;
  }

  function cancelScheduleItem(id) {
    const item = generatedContent.find((g) => g.id === id);
    if (!item) return;
    item.status = "approved";
    item.scheduledAt = null;
    saveGenerated();
    renderScheduled();
    renderGenerated();
    showToast("Schedule cancelled");
  }

  function formatRelativeDate(dateStr) {
    const now = new Date();
    now.setHours(0, 0, 0, 0);
    const date = new Date(dateStr);
    date.setHours(0, 0, 0, 0);
    const diffMs = now - date;
    const diffDays = Math.floor(diffMs / (24 * 60 * 60 * 1000));

    if (diffDays === 0) return "Hari ini";
    if (diffDays === 1) return "Kemarin";
    if (diffDays < 7) {
      const days = [
        "Minggu",
        "Senin",
        "Selasa",
        "Rabu",
        "Kamis",
        "Jumat",
        "Sabtu",
      ];
      return days[date.getDay()];
    }
    return date.toLocaleDateString("id-ID", {
      day: "numeric",
      month: "short",
    });
  }

  function formatScheduledTime(dateStr) {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = date - now;
    const diffMins = Math.floor(diffMs / (60 * 1000));
    const diffHours = Math.floor(diffMs / (60 * 60 * 1000));

    if (diffMins <= 0) return "Publishing now";
    if (diffMins < 60) return `${diffMins}m`;
    if (diffHours < 24) return `${diffHours}h`;
    return date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    });
  }

  // ═══════════════════════════════════════════
  // PREVIEW MODAL (Simplified)
  // ═══════════════════════════════════════════
  function openPreviewModal(genId) {
    previewingContentId = genId;
    const item = generatedContent.find((g) => g.id === genId);
    if (!item) return;

    const statusConfig = {
      draft: { bg: "bg-[#FEF3C7]", text: "text-[#B45309]", border: "border-[#FDE68A]", label: "Draft" },
      approved: { bg: "bg-[#ECFDF3]", text: "text-[#027A48]", border: "border-[#D1FADF]", label: "Approved" },
      scheduled: { bg: "bg-[#F5F3FF]", text: "text-[#7C3AED]", border: "border-[#DDD6FE]", label: "Scheduled" },
      published: { bg: "bg-[#EFF6FF]", text: "text-[#2563EB]", border: "border-[#DBEAFE]", label: "Published" },
      failed: { bg: "bg-[#FEF3F2]", text: "text-[#B42318]", border: "border-[#FECDCA]", label: "Failed" },
    };
    const cfg = statusConfig[item.status];

    // Header
    const titleHeader = document.getElementById("preview-title-header");
    const statusBadge = document.getElementById("preview-status-badge");
    if (titleHeader) titleHeader.textContent = item.title;
    if (statusBadge) {
      statusBadge.className = `inline-flex items-center px-2 h-5 rounded-full text-[10px] font-bold ${cfg.bg} ${cfg.text} border ${cfg.border}`;
      statusBadge.textContent = cfg.label;
    }

    // Image
    const imgContainer = document.getElementById("preview-image-container");
    if (imgContainer) {
      if (item.contentType === "Carousel" && item.images && item.images.length > 1) {
        imgContainer.innerHTML = `
          <div class="text-center space-y-2">
            <i class="ti ti-carousel-horizontal text-[40px] text-[#D0D5DD]"></i>
            <p class="text-[11px] text-[#98a2b3]">Carousel with ${item.images.length} images</p>
          </div>
        `;
      } else {
        imgContainer.innerHTML = `
          <div class="text-center space-y-2">
            <i class="ti ti-photo text-[40px] text-[#D0D5DD]"></i>
            <p class="text-[11px] text-[#98a2b3]">1080 × 1080</p>
          </div>
        `;
      }
    }

    // Caption
    const captionInput = document.getElementById("preview-caption-input");
    if (captionInput) captionInput.value = item.caption;

    // Meta
    const platformEl = document.getElementById("preview-platform");
    const typeEl = document.getElementById("preview-type");
    const brandEl = document.getElementById("preview-brand");
    const dateEl = document.getElementById("preview-date");
    if (platformEl) platformEl.textContent = item.platform || "-";
    if (typeEl) typeEl.textContent = item.contentType;
    if (brandEl) brandEl.textContent = item.brand;
    if (dateEl) dateEl.textContent = formatRelativeDate(item.createdAt);

    // Actions
    const actions = document.getElementById("preview-actions");
    const approvedActions = document.getElementById("preview-approved-actions");
    if (actions) actions.classList.add("hidden");
    if (approvedActions) approvedActions.classList.add("hidden");

    if (item.status === "draft") {
      if (actions) actions.classList.remove("hidden");
    } else if (item.status === "approved") {
      if (approvedActions) approvedActions.classList.remove("hidden");
    }

    // Open modal
    const modal = document.getElementById("modal-preview");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }
  }

  function closePreviewModal() {
    const modal = document.getElementById("modal-preview");
    if (modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
    previewingContentId = null;
  }

  function approveContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "approved";
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content approved!");
  }

  function rejectContent() {
    if (!previewingContentId) return;
    if (!confirm("Are you sure you want to reject this content? It will be deleted.")) return;
    generatedContent = generatedContent.filter((g) => g.id !== previewingContentId);
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content rejected and deleted.");
  }

  function unapproveContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "draft";
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content moved back to draft.");
  }

  // ═══════════════════════════════════════════
  // EDIT & DUPLICATE CONTENT
  // ═══════════════════════════════════════════
  function editAndDuplicateContent() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    // Create a duplicate as new draft
    const newItem = {
      ...item,
      id: "gen_" + Date.now(),
      status: "draft",
      scheduledAt: null,
      createdAt: new Date().toISOString(),
      title: item.title + " (Copy)",
    };

    generatedContent.push(newItem);
    saveGenerated();
    renderGenerated();
    closePreviewModal();
    showToast("Content duplicated as new draft!");
  }

  // ═══════════════════════════════════════════
  // SCHEDULE MODAL
  // ═══════════════════════════════════════════
  function openScheduleModal() {
    if (!previewingContentId) return;
    // Set default to tomorrow at 9am
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    tomorrow.setHours(9, 0, 0, 0);
    els.scheduleDate.value = tomorrow.toISOString().split("T")[0];
    els.scheduleTime.value = "09:00";
    els.modalSchedule.classList.remove("hidden");
    els.modalSchedule.classList.add("flex");
  }

  function closeScheduleModalFn() {
    els.modalSchedule.classList.add("hidden");
    els.modalSchedule.classList.remove("flex");
  }

  function confirmSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const dateVal = els.scheduleDate.value;
    const timeVal = els.scheduleTime.value;
    if (dateVal && timeVal) {
      item.scheduledAt = new Date(`${dateVal}T${timeVal}`).toISOString();
    }
    item.status = "scheduled";
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled successfully!");
  }

  function publishNow() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    item.status = "scheduled";
    item.scheduledAt = new Date().toISOString();
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content will be published now!");
  }

  function publishIn1Hour() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    const in1h = new Date(Date.now() + 60 * 60 * 1000);
    item.status = "scheduled";
    item.scheduledAt = in1h.toISOString();
    saveGenerated();
    renderGenerated();
    renderScheduled();
    closeScheduleModalFn();
    openPreviewModal(previewingContentId);
    showToast("Content scheduled for 1 hour from now!");
  }

  function cancelSchedule() {
    if (!previewingContentId) return;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;
    if (!confirm("Cancel this scheduled upload?")) return;
    item.status = "approved";
    item.scheduledAt = null;
    saveGenerated();
    renderGenerated();
    renderScheduled();
    openPreviewModal(previewingContentId);
    showToast("Schedule cancelled.");
  }

  function rescheduleContent() {
    openScheduleModal();
  }

  // ═══════════════════════════════════════════
  // AUTO ENGAGEMENT MODAL
  // ═══════════════════════════════════════════
  function openEngagementFromPreview() {
    if (!previewingContentId) return;
    // Open engagement modal for this generated content
    editingAutomationId = previewingContentId;
    const item = generatedContent.find((g) => g.id === previewingContentId);
    if (!item) return;

    const ac = item.autoComment || {
      enabled: false,
      text: "",
      link: "",
      keywords: "",
    };
    const dm = item.autoDm || {
      enabled: false,
      text: "",
      link: "",
      keywords: "",
    };

    els.commentToggle.checked = ac.enabled;
    els.commentText.value = ac.text || "";
    els.commentLink.value = ac.link || "";
    els.commentKeywords.value = ac.keywords || "";
    els.commentFields.classList.toggle("hidden", !ac.enabled);

    els.dmToggle.checked = dm.enabled;
    els.dmText.value = dm.text || "";
    els.dmLink.value = dm.link || "";
    els.dmKeywords.value = dm.keywords || "";
    els.dmFields.classList.toggle("hidden", !dm.enabled);

    els.modalEngagement.classList.remove("hidden");
    els.modalEngagement.classList.add("flex");
  }

  function closeEngagementModalFn() {
    els.modalEngagement.classList.add("hidden");
    els.modalEngagement.classList.remove("flex");
    editingAutomationId = null;
  }

  function saveEngagement() {
    if (!editingAutomationId) return;
    const item = generatedContent.find((g) => g.id === editingAutomationId);
    if (!item) return;

    item.autoComment = {
      enabled: els.commentToggle.checked,
      text: els.commentText.value.trim(),
      link: els.commentLink.value.trim(),
      keywords: els.commentKeywords.value.trim(),
    };
    item.autoDm = {
      enabled: els.dmToggle.checked,
      text: els.dmText.value.trim(),
      link: els.dmLink.value.trim(),
      keywords: els.dmKeywords.value.trim(),
    };

    saveGenerated();
    renderGenerated();
    closeEngagementModalFn();
    showToast("Auto Engagement settings saved!");
  }

  function loadAutomations() {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) automations = JSON.parse(stored);
    } catch (e) {
      automations = [];
    }
  }

  function saveAutomations() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(automations));
  }

  // ═══════════════════════════════════════════
  // RENDER AUTOMATIONS TABLE
  // ═══════════════════════════════════════════
  function renderAutomations() {
    const activeCount = automations.filter((a) => a.status === "active").length;
    const scheduledCount = automations.filter(
      (a) => a.status === "paused",
    ).length;
    els.activeCount.textContent = activeCount;
    els.scheduledCount.textContent = scheduledCount;

    if (automations.length === 0) {
      els.emptyState.classList.remove("hidden");
      els.emptyState.classList.add(
        "flex",
        "flex-col",
        "items-center",
        "justify-center",
        "py-24",
      );
      els.table.classList.add("hidden");
      return;
    }

    els.emptyState.classList.add("hidden");
    els.emptyState.classList.remove(
      "flex",
      "flex-col",
      "items-center",
      "justify-center",
      "py-24",
    );
    els.table.classList.remove("hidden");

    els.tbody.innerHTML = automations
      .map((auto) => {
        const dateCount = Object.keys(auto.selectedDates).length;
        const contentTypes = [
          ...new Set(
            Object.values(auto.selectedDates)
              .flat()
              .map((s) => s.contentType),
          ),
        ];
        const typeLabels = contentTypes
          .map(
            (t) =>
              `<span class="inline-flex items-center gap-1 px-2 h-6 rounded-full bg-[#F9FAFB] border border-[#eaecf0] text-[11px] font-medium text-[#667085]">
                <i class="ti ${CONTENT_ICONS[t] || "ti-file"} text-[12px]"></i>
                ${t}
              </span>`,
          )
          .join("");

        return `
        <tr class="border-b border-[#eaecf0] hover:bg-[#F9FAFB] transition-colors group">
          <td class="px-5 py-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0">
                <i class="ti ti-brand-abstract text-[18px] text-[#667085]"></i>
              </div>
              <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.dna?.name || "-")}</span>
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.name)}</span>
          </td>
          <td class="px-5 py-4">
            <span class="text-[13px] text-[#667085]">${dateCount} tanggal · ${recurringLabel(auto.recurring)}</span>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-1.5 flex-wrap">
              ${typeLabels}
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="inline-flex items-center gap-1.5 px-2 h-5 rounded-full bg-white border border-[#eaecf0] text-[10px] font-bold text-[#667085]">
              <span class="w-1.5 h-1.5 rounded-full ${auto.status === "active" ? "bg-[#22C55E]" : "bg-[#F04438]"}"></span>
              ${auto.status === "active" ? "Active" : "Paused"}
            </span>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center justify-end gap-1">
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#EFF6FF] flex items-center justify-center text-[#667085] hover:text-[#2563EB] transition-colors cursor-pointer"
                title="View details"
                onclick="alert('Detail view coming soon')"
              >
                <i class="ti ti-eye text-[15px]"></i>
              </button>
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer"
                title="${auto.status === "active" ? "Pause automation" : "Resume automation"}"
                onclick="toggleAutomationStatus('${auto.id}')"
              >
                <i class="ti ${auto.status === "active" ? "ti-player-pause" : "ti-player-play"} text-[15px]"></i>
              </button>
              <button
                class="action-btn w-8 h-8 rounded-lg hover:bg-[#FEF3F2] flex items-center justify-center text-[#667085] hover:text-[#D92D20] transition-colors cursor-pointer"
                title="Hapus automation"
                onclick="deleteAutomation('${auto.id}')"
              >
                <i class="ti ti-trash text-[15px]"></i>
              </button>
            </div>
          </td>
        </tr>
      `;
      })
      .join("");
  }

  function recurringLabel(value) {
    const labels = { once: "One Time Only", monthly: "Same Dates Every Month" };
    return labels[value] || value;
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  // ═══════════════════════════════════════════
  // WIZARD NAVIGATION
  // ═══════════════════════════════════════════
  function goToStep(step) {
    currentStep = step;
    els.stepPanels.forEach((p) => p.classList.add("hidden"));
    document.getElementById(`step-${step}`).classList.remove("hidden");

    els.stepDots.forEach((dot) => {
      const num = parseInt(dot.dataset.step);
      const circle = dot.querySelector("div");
      const label = dot.querySelector("span");
      if (num === step) {
        circle.className =
          "w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#111827]";
      } else if (num < step) {
        circle.className =
          "w-7 h-7 rounded-full bg-[#111827] text-white text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#667085]";
      } else {
        circle.className =
          "w-7 h-7 rounded-full bg-[#F3F4F6] text-[#667085] text-[12px] font-bold flex items-center justify-center";
        label.className = "text-[12px] font-semibold text-[#667085]";
      }
    });

    els.btnBack.classList.toggle("hidden", step === 1);
    els.btnNext.classList.toggle("hidden", step === 3);
    els.btnStart.classList.toggle("hidden", step !== 3);

    if (step === 3) {
      // Sync recurring with schedule mode from Step 2
      if (wizardData.scheduleMode === "weekly") {
        wizardData.recurring = "weekly";
        if (els.radioRecurringWeekly) {
          els.radioRecurringWeekly.disabled = false;
          els.radioRecurringWeekly.checked = true;
        }
        if (els.labelRecurringWeekly) els.labelRecurringWeekly.classList.remove("opacity-60");
        if (els.divRecurringWeekly) els.divRecurringWeekly.classList.remove("opacity-60");
        if (els.recurringModeInfo) els.recurringModeInfo.textContent = "Weekly repetition aktif karena mode Weekly dipilih di Step 2.";
      } else {
        // Monthly mode: disable weekly radio
        if (els.radioRecurringWeekly) {
          els.radioRecurringWeekly.disabled = true;
          els.radioRecurringWeekly.checked = false;
        }
        if (els.labelRecurringWeekly) els.labelRecurringWeekly.classList.add("opacity-60");
        if (els.divRecurringWeekly) els.divRecurringWeekly.classList.add("opacity-60");
        if (els.recurringModeInfo) els.recurringModeInfo.textContent = "Weekly repetition dinonaktifkan karena mode Monthly dipilih di Step 2. Pilih One Time Only atau Monthly.";
        // If weekly was selected, switch to once
        if (wizardData.recurring === "weekly") {
          wizardData.recurring = "once";
          const onceRadio = document.querySelector('input[name="recurring"][value="once"]');
          if (onceRadio) onceRadio.checked = true;
        }
      }
      updateReview();
    }
  }

  function validateStep(step) {
    if (step === 1) {
      if (!wizardData.name.trim()) {
        showToast("Campaign name is required");
        return false;
      }
      if (!wizardData.dna) {
        showToast("Please select a Business DNA");
        return false;
      }
    }
    if (step === 2) {
      if (Object.keys(wizardData.selectedDates).length === 0) {
        showToast("Please select at least 1 date");
        return false;
      }
    }
    return true;
  }

  function updateReview() {
    els.reviewName.textContent = wizardData.name || "-";
    els.reviewDna.textContent = wizardData.dna?.name || "-";

    // Render recurring preview
    renderRecurringPreview();

    // Render schedule cards
    const dates = Object.keys(wizardData.selectedDates).sort();
    const monthNames = [
      "Jan", "Feb", "Mar", "Apr", "May", "Jun",
      "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
    ];

    if (dates.length === 0) {
      els.reviewScheduleCards.innerHTML = `<div class="col-span-2 text-center py-4 text-[12px] text-[#98a2b3]">No dates selected</div>`;
    } else {
      const grouped = {};
      dates.forEach((dk) => {
        const [y, m, d] = dk.split("-");
        const dayName = new Date(dk).toLocaleDateString("en-US", {
          weekday: "short",
        });
        const key = `${d} ${monthNames[parseInt(m) - 1]}`;
        if (!grouped[key]) {
          grouped[key] = { dayName, automations: [] };
        }
        wizardData.selectedDates[dk].forEach((slot) => {
          grouped[key].automations.push(slot);
        });
      });

      els.reviewScheduleCards.innerHTML = Object.entries(grouped)
        .map(
          ([dateLabel, data]) => `
        <div class="p-3 rounded-xl bg-white border border-[#eaecf0] space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-[12px] font-bold text-[#111827]">${dateLabel}</span>
            <span class="text-[10px] text-[#667085]">${data.dayName}</span>
          </div>
          <div class="space-y-1.5">
            ${data.automations
              .map(
                (a) => `
              <div class="flex items-center gap-2">
                <i class="ti ${CONTENT_ICONS[a.contentType] || "ti-file"} text-[12px] text-[#667085]"></i>
                <span class="text-[11px] text-[#667085]">${a.contentType}${a.category ? " · " + escapeHtml(a.category) : ""}${a.variations > 1 ? " · " + a.variations + "x" : ""}</span>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `,
        )
        .join("");
    }

    // Update footer credit — Single Post & Story counts as 2
    const totalVariations = Object.values(wizardData.selectedDates).reduce(
      (total, slots) => {
        return total + slots.reduce((sum, s) => {
          const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
          return sum + ((s.variations || 1) * multiplier);
        }, 0);
      },
      0,
    );
    els.footerCredit.textContent = totalVariations;

    // Update selected dates count label
    if (els.selectedDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }
  }

  // ═══════════════════════════════════════════
  // RECURRING PREVIEW
  // ═══════════════════════════════════════════
  function renderRecurringPreview() {
    const isMonthly = wizardData.recurring === "monthly";
    const isWeekly = wizardData.recurring === "weekly";

    els.repeatForWrapper.classList.toggle("hidden", !isMonthly && !isWeekly);
    els.weeklyRepeatWrapper.classList.toggle("hidden", !isWeekly);
    els.recurringPreview.classList.toggle("hidden", !isMonthly && !isWeekly);

    if (!isMonthly && !isWeekly) {
      els.recurringInfo.textContent =
        "Content will be generated once on selected dates.";
      return;
    }

    const selectedDateKeys = Object.keys(wizardData.selectedDates).sort();
    if (selectedDateKeys.length === 0) {
      els.recurringPreviewGrid.innerHTML = "";
      return;
    }

    const monthNames = [
      "Jan", "Feb", "Mar", "Apr", "May", "Jun",
      "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
    ];
    const dayNames = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];

    // Parse first date reliably
    const [fy, fm, fd] = selectedDateKeys[0].split("-").map(Number);
    const firstDate = new Date(fy, fm - 1, fd);
    const repeatCount = parseInt(wizardData.repeatFor) || 3;
    let previewHTML = "";

    if (isMonthly) {
      els.recurringInfo.textContent =
        "Selected dates will repeat every month. If a date doesn't exist in a month, it will be scheduled on the last day of that month.";

      const selectedDays = selectedDateKeys.map((dk) => parseInt(dk.split("-")[2]));

      for (let i = 1; i <= repeatCount; i++) {
        const previewMonth = new Date(
          firstDate.getFullYear(),
          firstDate.getMonth() + i,
          1,
        );
        const monthLabel = monthNames[previewMonth.getMonth()];
        const yearLabel = previewMonth.getFullYear();

        const datePills = selectedDays
          .map((day) => {
            const daysInMonth = new Date(
              previewMonth.getFullYear(),
              previewMonth.getMonth() + 1,
              0,
            ).getDate();
            const actualDay = Math.min(day, daysInMonth);
            const dateObj = new Date(
              previewMonth.getFullYear(),
              previewMonth.getMonth(),
              actualDay,
            );
            const dow = dayNames[dateObj.getDay()];

            return `
            <div class="flex flex-col items-center gap-0.5">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#EFF6FF] border border-[#dbeafe] text-[11px] font-bold text-[#2563EB]">
                ${actualDay}
              </span>
              <span class="text-[9px] text-[#98a2b3]">${dow}</span>
            </div>
          `;
          })
          .join("");

        previewHTML += `
          <div class="p-2.5 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] space-y-1.5">
            <div class="text-[11px] font-bold text-[#111827] text-center">${monthLabel} ${yearLabel}</div>
            <div class="flex flex-wrap items-center justify-center gap-1.5">
              ${datePills}
            </div>
          </div>
        `;
      }
    } else if (isWeekly) {
      els.recurringInfo.textContent =
        `Content will repeat every Week ${wizardData.weeklyWeek} of each month.`;

      const weekNum = parseInt(wizardData.weeklyWeek) || 1;
      const weekStartDay = (weekNum - 1) * 7 + 1;
      const weekEndDay = weekNum * 7;

      for (let i = 1; i <= repeatCount; i++) {
        const previewMonth = new Date(
          firstDate.getFullYear(),
          firstDate.getMonth() + i,
          1,
        );
        const monthLabel = monthNames[previewMonth.getMonth()];
        const yearLabel = previewMonth.getFullYear();
        const daysInMonth = new Date(
          previewMonth.getFullYear(),
          previewMonth.getMonth() + 1,
          0,
        ).getDate();

        // Find dates in this month that fall in the selected week
        const weekDates = [];
        for (let d = weekStartDay; d <= Math.min(weekEndDay, daysInMonth); d++) {
          weekDates.push(d);
        }

        const datePills = weekDates
          .map((day) => {
            const dateObj = new Date(
              previewMonth.getFullYear(),
              previewMonth.getMonth(),
              day,
            );
            const dow = dayNames[dateObj.getDay()];
            return `
            <div class="flex flex-col items-center gap-0.5">
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-[#EFF6FF] border border-[#dbeafe] text-[11px] font-bold text-[#2563EB]">
                ${day}
              </span>
              <span class="text-[9px] text-[#98a2b3]">${dow}</span>
            </div>
          `;
          })
          .join("");

        previewHTML += `
          <div class="p-2.5 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] space-y-1.5">
            <div class="text-[11px] font-bold text-[#111827] text-center">${monthLabel} ${yearLabel} · Week ${weekNum}</div>
            <div class="flex flex-wrap items-center justify-center gap-1.5">
              ${datePills}
            </div>
          </div>
        `;
      }
    }

    els.recurringPreviewGrid.innerHTML = previewHTML;
  }

  // ═══════════════════════════════════════════
  // AI SUGGESTION
  // ═══════════════════════════════════════════
  function applyAiSuggestion() {
    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    // Strategy: pick ~8-10 dates, avoid weekends, space ~3-4 days apart
    const suggestedDates = [];
    let lastPicked = 0;
    const minGap = 3;
    const maxGap = 5;

    for (let day = 1; day <= daysInMonth; day++) {
      const date = new Date(year, month, day);
      const dayOfWeek = date.getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
      const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

      // Skip weekends and already selected dates
      if (isWeekend || wizardData.selectedDates[dateKey]) continue;

      // Pick first available weekday
      if (suggestedDates.length === 0) {
        suggestedDates.push(dateKey);
        lastPicked = day;
        continue;
      }

      const gap = day - lastPicked;
      if (gap >= minGap && gap <= maxGap) {
        suggestedDates.push(dateKey);
        lastPicked = day;
      }

      // Stop once we have enough
      if (suggestedDates.length >= 10) break;
    }

    // Fill remaining if we didn't get enough (relax gap constraint)
    if (suggestedDates.length < 8) {
      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day);
        const dayOfWeek = date.getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

        if (
          isWeekend ||
          wizardData.selectedDates[dateKey] ||
          suggestedDates.includes(dateKey)
        )
          continue;

        suggestedDates.push(dateKey);
        if (suggestedDates.length >= 8) break;
      }
    }

    // Add default automation to each suggested date
    suggestedDates.forEach((dateKey) => {
      if (!wizardData.selectedDates[dateKey]) {
        wizardData.selectedDates[dateKey] = [];
      }
      wizardData.selectedDates[dateKey].push({
        contentType: "Single Post",
        category: "",
        prompt: "",
        variations: 1,
      });
    });

    renderCalendar();
    showToast(`AI added ${suggestedDates.length} optimal posting dates!`);
  }

  // ═══════════════════════════════════════════
  // AI SUGGESTION WEEKLY
  // ═══════════════════════════════════════════
  function applyAiSuggestionWeekly() {
    const weekStart = new Date(wizardData.currentWeekDate);
    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
    weekStart.setHours(0, 0, 0, 0);

    const suggestedDates = [];
    for (let i = 1; i <= 5; i++) {
      const weekDate = new Date(weekStart);
      weekDate.setDate(weekDate.getDate() + i);
      const dayOfWeek = weekDate.getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
      const dateKey = `${weekDate.getFullYear()}-${String(weekDate.getMonth() + 1).padStart(2, "0")}-${String(weekDate.getDate()).padStart(2, "0")}`;

      if (isWeekend || wizardData.selectedDates[dateKey]) continue;
      suggestedDates.push(dateKey);
    }

    suggestedDates.forEach((dateKey) => {
      if (!wizardData.selectedDates[dateKey]) {
        wizardData.selectedDates[dateKey] = [];
      }
      wizardData.selectedDates[dateKey].push({
        contentType: "Single Post",
        category: "",
        prompt: "",
        variations: 1,
      });
    });

    renderWeeklyCalendar();
    showToast(`AI added ${suggestedDates.length} optimal posting dates!`);
  }

  // ═══════════════════════════════════════════
  // CALENDAR
  // ═══════════════════════════════════════════
  function renderCalendar() {
    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();
    const monthNames = [
      "January",
      "February",
      "March",
      "April",
      "May",
      "June",
      "July",
      "August",
      "September",
      "October",
      "November",
      "December",
    ];
    els.calMonthYear.textContent = `${monthNames[month]} ${year}`;

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    let html = "";
    // Empty cells before first day
    for (let i = 0; i < firstDay; i++) {
      html += "<div></div>";
    }
    // Days
    for (let day = 1; day <= daysInMonth; day++) {
      const dateKey = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      const isSelected = wizardData.selectedDates[dateKey];
      const hasSlots = isSelected && isSelected.length > 0;
      const slotCount = hasSlots ? isSelected.length : 0;
      const isWeekend = [0, 6].includes(new Date(year, month, day).getDay());
      const totalVariations = isSelected
        ? isSelected.reduce((sum, s) => {
            const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
            return sum + ((s.variations || 1) * multiplier);
          }, 0)
        : 0;

      html += `
        <button
          class="cal-day relative w-full aspect-square rounded-lg flex flex-col items-center justify-center text-[12px] font-medium transition-all cursor-pointer
            ${isSelected ? "bg-[#111827] text-white" : isWeekend ? "text-[#D92D20] hover:bg-[#FEF3F2]" : "text-[#111827] hover:bg-[#F9FAFB]"}"
          data-date="${dateKey}"
        >
          <span>${day}</span>
          ${
            isSelected
              ? `
            <span class="cal-counter absolute -top-2 -right-2 w-7 h-7 rounded-full bg-[#2563EB] text-white text-[11px] font-bold flex items-center justify-center gap-0.5 shadow-sm hover:bg-[#1d4ed8] transition-colors cursor-pointer" data-date="${dateKey}">
              ${totalVariations}
              <i class="ti ti-chevron-right text-[9px]"></i>
            </span>
          `
              : ""
          }
        </button>
      `;
    }
    els.calGrid.innerHTML = html;

    // Update monthly selected dates count
    if (els.selectedDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }

    // Calendar day clicks
    els.calGrid.querySelectorAll(".cal-day").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const dateKey = btn.dataset.date;
        // If clicking the counter badge, open detail dropdown
        if (e.target.closest(".cal-counter")) {
          e.stopPropagation();
          openDateDetailPopover(dateKey, btn);
        } else if (wizardData.selectedDates[dateKey]?.length > 0) {
          // Date has automations - open detail dropdown
          openDateDetailPopover(dateKey, btn);
        } else {
          // Empty date - open form popover
          openAutomationPopover(dateKey, btn);
        }
      });
    });
  }

  // ═══════════════════════════════════════════
  // WEEKLY CALENDAR
  // ═══════════════════════════════════════════
  function renderWeeklyCalendar() {
    const weekStart = new Date(wizardData.currentWeekDate);
    weekStart.setDate(weekStart.getDate() - weekStart.getDay());
    weekStart.setHours(0, 0, 0, 0);

    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekEnd.getDate() + 6);
    weekEnd.setHours(23, 59, 59, 999);

    els.calWeekLabel.textContent = `${weekStart.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${weekEnd.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    let html = "";
    const dayNames = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    for (let i = 0; i < 7; i++) {
      const dayDate = new Date(weekStart);
      dayDate.setDate(dayDate.getDate() + i);
      const isToday = dayDate.toDateString() === new Date().toDateString();
      const isPast = dayDate < today;
      const isWeekend = i === 0 || i === 6;
      const dateKey = `${dayDate.getFullYear()}-${String(dayDate.getMonth() + 1).padStart(2, "0")}-${String(dayDate.getDate()).padStart(2, "0")}`;
      const isSelected = wizardData.selectedDates[dateKey];
      const hasSlots = isSelected && isSelected.length > 0;
      const totalVariations = isSelected
        ? isSelected.reduce((sum, s) => {
            const multiplier = s.contentType === "Single Post & Story" ? 2 : 1;
            return sum + ((s.variations || 1) * multiplier);
          }, 0)
        : 0;

      html += `
        <button
          class="cal-day relative w-full aspect-square rounded-lg flex flex-col items-center justify-center text-[12px] font-medium transition-all cursor-pointer
            ${isSelected ? "bg-[#111827] text-white" : isWeekend ? "text-[#D92D20] hover:bg-[#FEF3F2]" : "text-[#111827] hover:bg-[#F9FAFB]"}"
          data-date="${dateKey}"
        >
          <span class="text-[10px] font-semibold text-[#98a2b3] mb-1">${dayNames[i]}</span>
          <span>${dayDate.getDate()}</span>
          ${
            isSelected
              ? `
            <span class="cal-counter absolute -top-2 -right-2 w-7 h-7 rounded-full bg-[#2563EB] text-white text-[11px] font-bold flex items-center justify-center gap-0.5 shadow-sm hover:bg-[#1d4ed8] transition-colors cursor-pointer" data-date="${dateKey}">
              ${totalVariations}
              <i class="ti ti-chevron-right text-[9px]"></i>
            </span>
          `
              : ""
          }
        </button>
      `;
    }

    els.calWeekGrid.innerHTML = html;

    // Update weekly selected dates count
    if (els.selectedWeeklyDatesCount) {
      const dateCount = Object.keys(wizardData.selectedDates).length;
      els.selectedWeeklyDatesCount.textContent = `${dateCount} date${dateCount !== 1 ? "s" : ""} selected`;
    }

    // Calendar day clicks
    els.calWeekGrid.querySelectorAll(".cal-day").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const dateKey = btn.dataset.date;
        if (e.target.closest(".cal-counter")) {
          e.stopPropagation();
          openDateDetailPopover(dateKey, btn);
        } else if (wizardData.selectedDates[dateKey]?.length > 0) {
          openDateDetailPopover(dateKey, btn);
        } else {
          openAutomationPopover(dateKey, btn);
        }
      });
    });
  }

  // ═══════════════════════════════════════════
  // AUTOMATION POPOVER
  // ═══════════════════════════════════════════
  function openAutomationPopover(dateKey, targetBtn, editIndex = -1) {
    activePopoverDate = dateKey;
    const slots = wizardData.selectedDates[dateKey] || [];
    const [y, m, d] = dateKey.split("-");
    els.slotPopoverDate.textContent = `${d} ${["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"][parseInt(m) - 1]} ${y}`;

    // If editing, populate fields
    if (editIndex >= 0 && slots[editIndex]) {
      const slot = slots[editIndex];
      els.slotContentType.value = slot.contentType;
      els.slotCategory.value = slot.category || "";
      els.slotPrompt.value = slot.prompt || "";
      els.automationVariations.value = slot.variations || 1;
      els.btnAddSlot.textContent = "Update Automation";
      els.btnAddSlot.dataset.editIndex = editIndex;
      if (els.contentTypeDesc) {
        els.contentTypeDesc.textContent = CONTENT_TYPE_DESCS[slot.contentType] || "";
      }
    } else {
      // Reset inputs
      els.slotContentType.value = "Single Post";
      els.slotCategory.value = "";
      els.slotPrompt.value = "";
      els.automationVariations.value = 1;
      els.btnAddSlot.textContent = "Add";
      els.btnAddSlot.dataset.editIndex = "";
      if (els.contentTypeDesc) {
        els.contentTypeDesc.textContent = CONTENT_TYPE_DESCS["Single Post"] || "";
      }
    }

    // Position popover to the right of the clicked button, vertically centered
    const rect = targetBtn.getBoundingClientRect();
    const popoverWidth = 288; // w-72 = 18rem = 288px
    const popoverHeight = 380;
    const gap = 12;

    // Default: place to the right
    let left = rect.right + gap;

    // If too far right, place to the left
    const viewportWidth = window.innerWidth;
    if (left + popoverWidth > viewportWidth - 16) {
      left = rect.left - popoverWidth - gap;
    }

    // Vertically center with the clicked button
    let top = rect.top + rect.height / 2 - popoverHeight / 2;

    // Keep within viewport (don't stick to top/bottom)
    if (top < 16) top = 16;
    if (top + popoverHeight > window.innerHeight - 16) {
      top = window.innerHeight - popoverHeight - 16;
    }

    els.slotPopover.style.left = `${left}px`;
    els.slotPopover.style.top = `${top}px`;
    els.slotPopover.classList.remove("hidden");

    // Update count
    const slotCount = slots.length;
    const totalVars = slots.reduce((sum, s) => sum + (s.variations || 1), 0);
    document.getElementById("automation-remaining").textContent =
      `${slotCount} automation${slotCount !== 1 ? "s" : ""} · ${totalVars} total`;
    els.btnAddSlot.disabled = false;
    els.btnAddSlot.style.opacity = "1";
  }

  function closeAutomationPopover() {
    els.slotPopover.classList.add("hidden");
    activePopoverDate = null;
  }

  // ═══════════════════════════════════════════
  // DATE DETAIL POPOVER (dropdown list)
  // ═══════════════════════════════════════════
  function openDateDetailPopover(dateKey, targetBtn) {
    activePopoverDate = dateKey;
    const slots = wizardData.selectedDates[dateKey] || [];
    const [y, m, d] = dateKey.split("-");
    const monthNames = [
      "Jan",
      "Feb",
      "Mar",
      "Apr",
      "May",
      "Jun",
      "Jul",
      "Aug",
      "Sep",
      "Oct",
      "Nov",
      "Dec",
    ];
    els.dateDetailDate.textContent = `${d} ${monthNames[parseInt(m) - 1]} ${y}`;

    // Build automation list
    if (slots.length === 0) {
      els.dateDetailList.innerHTML = `
        <div class="text-center py-3 text-[12px] text-[#98a2b3]">No automations yet</div>
      `;
    } else {
      els.dateDetailList.innerHTML = slots
        .map(
          (slot, idx) => `
        <div class="flex items-center justify-between p-2.5 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] group">
          <div class="flex items-center gap-2 min-w-0">
            <i class="ti ${CONTENT_ICONS[slot.contentType] || "ti-file"} text-[13px] text-[#667085] shrink-0"></i>
            <div class="min-w-0">
              <div class="text-[12px] font-medium text-[#111827] truncate">${escapeHtml(slot.contentType)}</div>
              <div class="text-[11px] text-[#667085] truncate">${slot.category ? escapeHtml(slot.category) + " · " : ""}${slot.variations || 1}x variations</div>
            </div>
          </div>
          <div class="flex items-center gap-0.5 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
            <button onclick="editAutomation('${dateKey}', ${idx})" class="w-7 h-7 rounded-lg hover:bg-white flex items-center justify-center text-[#98a2b3] hover:text-[#2563EB] cursor-pointer transition-colors" title="Edit">
              <i class="ti ti-pencil text-[12px]"></i>
            </button>
            <button onclick="removeAutomation('${dateKey}', ${idx})" class="w-7 h-7 rounded-lg hover:bg-white flex items-center justify-center text-[#98a2b3] hover:text-[#D92D20] cursor-pointer transition-colors" title="Remove">
              <i class="ti ti-trash text-[12px]"></i>
            </button>
          </div>
        </div>
      `,
        )
        .join("");
    }

    // Position popover below the clicked button
    const rect = targetBtn.getBoundingClientRect();
    const popoverWidth = 288; // w-72
    const gap = 8;

    let left = rect.left + rect.width / 2 - popoverWidth / 2;
    let top = rect.bottom + gap;

    // Keep within viewport
    if (left < 16) left = 16;
    if (left + popoverWidth > window.innerWidth - 16) {
      left = window.innerWidth - popoverWidth - 16;
    }
    if (top + 300 > window.innerHeight - 16) {
      top = rect.top - 300 - gap;
    }

    els.dateDetailPopover.style.left = `${left}px`;
    els.dateDetailPopover.style.top = `${top}px`;
    els.dateDetailPopover.classList.remove("hidden");
  }

  function closeDateDetailPopover() {
    els.dateDetailPopover.classList.add("hidden");
  }

  function addAutomation() {
    if (!activePopoverDate) return;

    // Create date array if doesn't exist
    if (!wizardData.selectedDates[activePopoverDate]) {
      wizardData.selectedDates[activePopoverDate] = [];
    }

    const slots = wizardData.selectedDates[activePopoverDate];
    const variations = parseInt(els.automationVariations.value) || 1;
    const editIndex = parseInt(els.btnAddSlot.dataset.editIndex);

    if (!isNaN(editIndex) && editIndex >= 0 && slots[editIndex]) {
      // Update existing
      slots[editIndex] = {
        contentType: els.slotContentType.value,
        category: els.slotCategory.value.trim(),
        prompt: els.slotPrompt.value.trim(),
        variations: Math.max(1, Math.min(10, variations)),
      };
    } else {
      // Add new
      slots.push({
        contentType: els.slotContentType.value,
        category: els.slotCategory.value.trim(),
        prompt: els.slotPrompt.value.trim(),
        variations: Math.max(1, Math.min(10, variations)),
      });
    }

    renderCalendar();
    closeAutomationPopover();
  }

  function removeDate(dateKey) {
    delete wizardData.selectedDates[dateKey];
    renderCalendar();
  }

  function editDate(dateKey) {
    const targetBtn = document.querySelector(
      `button.cal-day[data-date="${dateKey}"]`,
    );
    if (targetBtn) {
      openAutomationPopover(dateKey, targetBtn);
    }
  }

  function removeAutomation(dateKey, index) {
    wizardData.selectedDates[dateKey].splice(index, 1);
    if (wizardData.selectedDates[dateKey].length === 0) {
      delete wizardData.selectedDates[dateKey];
    }
    renderCalendar();
  }

  function editAutomation(dateKey, index) {
    const targetBtn = document.querySelector(
      `button.cal-day[data-date="${dateKey}"]`,
    );
    if (targetBtn) {
      openAutomationPopover(dateKey, targetBtn, index);
    }
  }

  function renderSelectedDates() {
    const dates = Object.keys(wizardData.selectedDates).sort();
    if (dates.length === 0) {
      els.selectedDatesContainer.innerHTML = "";
      return;
    }

    els.selectedDatesContainer.innerHTML = dates
      .map((dateKey) => {
        const slots = wizardData.selectedDates[dateKey];
        const [y, m, d] = dateKey.split("-");
        const monthNames = [
          "Jan",
          "Feb",
          "Mar",
          "Apr",
          "Mei",
          "Jun",
          "Jul",
          "Agu",
          "Sep",
          "Okt",
          "Nov",
          "Des",
        ];
        const displayDate = `${d} ${monthNames[parseInt(m) - 1]} ${y}`;

        return `
        <div class="p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-[12px] font-bold text-[#111827]">${displayDate}</span>
            <span class="text-[11px] text-[#667085]">${slots.length} automation${slots.length > 1 ? "s" : ""}</span>
          </div>
          <div class="space-y-1.5">
            ${slots
              .map(
                (slot, idx) => `
              <div class="flex items-center justify-between p-2 rounded-lg bg-white border border-[#eaecf0]">
                <div class="flex items-center gap-2">
                  <i class="ti ${CONTENT_ICONS[slot.contentType] || "ti-file"} text-[12px] text-[#667085]"></i>
                  <span class="text-[11px] text-[#667085]">${slot.contentType}${slot.category ? " · " + escapeHtml(slot.category) : ""}${slot.variations > 1 ? " · " + slot.variations + "x" : ""}</span>
                </div>
                <div class="flex items-center gap-1">
                  <button onclick="editAutomation('${dateKey}', ${idx})" class="w-5 h-5 rounded hover:bg-[#EFF6FF] flex items-center justify-center text-[#98a2b3] hover:text-[#2563EB] cursor-pointer transition-colors" title="Edit">
                    <i class="ti ti-pencil text-[11px]"></i>
                  </button>
                  <button onclick="removeAutomation('${dateKey}', ${idx})" class="w-5 h-5 rounded hover:bg-[#FEF3F2] flex items-center justify-center text-[#98a2b3] hover:text-[#D92D20] cursor-pointer transition-colors" title="Remove">
                    <i class="ti ti-x text-[11px]"></i>
                  </button>
                </div>
              </div>
            `,
              )
              .join("")}
          </div>
        </div>
      `;
      })
      .join("");
  }

  // ═══════════════════════════════════════════
  // AUTO COMMENT MODAL
  // ═══════════════════════════════════════════
  function openCommentModal(autoId) {
    editingAutomationId = autoId;
    const auto = automations.find((a) => a.id === autoId);
    if (!auto) return;

    const ac = auto.autoComment || {
      enabled: false,
      text: "",
      link: "",
      keywords: "",
    };
    els.commentToggle.checked = ac.enabled;
    els.commentText.value = ac.text || "";
    els.commentLink.value = ac.link || "";
    els.commentKeywords.value = ac.keywords || "";
    els.commentFields.classList.toggle("hidden", !ac.enabled);

    els.modalComment.classList.remove("hidden");
    els.modalComment.classList.add("flex");
  }

  function closeCommentModal() {
    els.modalComment.classList.add("hidden");
    els.modalComment.classList.remove("flex");
    editingAutomationId = null;
  }

  function saveComment() {
    if (!editingAutomationId) return;

    // Try to find in automations first
    const auto = automations.find((a) => a.id === editingAutomationId);
    if (auto) {
      auto.autoComment = {
        enabled: els.commentToggle.checked,
        text: els.commentText.value.trim(),
        link: els.commentLink.value.trim(),
        keywords: els.commentKeywords.value.trim(),
      };
      saveAutomations();
      renderAutomations();
    }

    // Also try to find in generated content
    const gen = generatedContent.find((g) => g.id === editingAutomationId);
    if (gen) {
      gen.autoComment = {
        enabled: els.commentToggle.checked,
        text: els.commentText.value.trim(),
        link: els.commentLink.value.trim(),
        keywords: els.commentKeywords.value.trim(),
      };
      saveGenerated();
      renderGenerated();
    }

    closeCommentModal();
  }

  // ═══════════════════════════════════════════
  // AUTOMATION ACTIONS
  // ═══════════════════════════════════════════
  function toggleAutomationStatus(id) {
    const auto = automations.find((a) => a.id === id);
    if (!auto) return;
    auto.status = auto.status === "active" ? "paused" : "active";
    saveAutomations();
    renderAutomations();
  }

  function deleteAutomation(id) {
    if (!confirm("Yakin ingin menghapus automation ini?")) return;
    automations = automations.filter((a) => a.id !== id);
    saveAutomations();
    renderAutomations();
  }

  function startAutomation() {
    const newAuto = {
      id: "auto_" + Date.now(),
      name: wizardData.name,
      dna: wizardData.dna,
      selectedDates: { ...wizardData.selectedDates },
      recurring: wizardData.recurring,
      repeatFor: wizardData.repeatFor,
      weeklyWeek: wizardData.weeklyWeek,
      status: "active",
      autoComment: { enabled: false, text: "", link: "", keywords: "" },
      createdAt: new Date().toISOString(),
    };

    automations.push(newAuto);
    saveAutomations();
    renderAutomations();
    closeAddModal();
  }

  // ═══════════════════════════════════════════
  // MODAL OPEN/CLOSE
  // ═══════════════════════════════════════════
  function openAddModal() {
    // Reset wizard
    wizardData = {
      name: "",
      dna: null,
      selectedDates: {},
      recurring: "once",
      repeatFor: 3,
      weeklyWeek: 1,
      scheduleMode: "monthly",
      currentWeekDate: new Date(2026, 4, 5),
    };
    currentStep = 1;
    currentCalendarDate = new Date(2026, 4, 1);

    // Reset inputs
    els.inputName.value = "";
    els.dnaSelectedName.textContent = "Select Business DNA";
    els.dnaSelectedDesc.textContent =
      "Choose a business profile for AI grounding";
    els.recurringRadios.forEach((r) => {
      r.checked = r.value === "once";
    });
    els.recurringInfo.textContent =
      "Content will be generated once on selected dates.";
    if (els.repeatForSelect) els.repeatForSelect.value = "3";
    if (els.weeklyWeekSelect) els.weeklyWeekSelect.value = "1";
    els.repeatForWrapper.classList.add("hidden");
    els.weeklyRepeatWrapper.classList.add("hidden");
    els.recurringPreview.classList.add("hidden");

    // Reset schedule mode toggle
    if (els.btnModeMonthly && els.btnModeWeekly) {
      els.btnModeMonthly.classList.add("bg-[#111827]", "text-white");
      els.btnModeMonthly.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
      els.btnModeWeekly.classList.remove("bg-[#111827]", "text-white");
      els.btnModeWeekly.classList.add("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
    }
    if (els.monthlyCalendar) els.monthlyCalendar.classList.remove("hidden");
    if (els.weeklyCalendar) els.weeklyCalendar.classList.add("hidden");

    renderCalendar();
    renderWeeklyCalendar();
    goToStep(1);

    els.modalAdd.classList.remove("hidden");
    els.modalAdd.classList.add("flex");
  }

  function closeAddModal() {
    els.modalAdd.classList.add("hidden");
    els.modalAdd.classList.remove("flex");
    closeSlotPopover();
  }

  // ═══════════════════════════════════════════
  // EVENT BINDING
  // ═══════════════════════════════════════════
  function bindEvents() {
    // Open modal
    els.btnAdd.addEventListener("click", openAddModal);
    els.btnEmptyAdd.addEventListener("click", openAddModal);

    // Close modal
    els.closeAddModal.addEventListener("click", closeAddModal);
    els.modalAdd.addEventListener("click", (e) => {
      if (e.target === els.modalAdd) closeAddModal();
    });

    // Wizard navigation
    els.btnBack.addEventListener("click", () => {
      if (currentStep > 1) goToStep(currentStep - 1);
    });
    els.btnNext.addEventListener("click", () => {
      if (validateStep(currentStep) && currentStep < 3)
        goToStep(currentStep + 1);
    });
    els.btnStart.addEventListener("click", () => {
      if (validateStep(3)) startAutomation();
    });

    // Step 1 inputs
    els.inputName.addEventListener("input", (e) => {
      wizardData.name = e.target.value;
    });

    // DNA dropdown
    els.btnSelectDna.addEventListener("click", (e) => {
      e.stopPropagation();
      els.dnaDropdown.classList.toggle("hidden");
    });
    document.addEventListener("click", (e) => {
      if (
        !els.dnaDropdown.contains(e.target) &&
        e.target !== els.btnSelectDna
      ) {
        els.dnaDropdown.classList.add("hidden");
      }
    });
    document.querySelectorAll(".dna-option").forEach((opt) => {
      opt.addEventListener("click", () => {
        wizardData.dna = { name: opt.dataset.name, desc: opt.dataset.desc };
        els.dnaSelectedName.textContent = opt.dataset.name;
        els.dnaSelectedDesc.textContent = opt.dataset.desc;
        els.dnaDropdown.classList.add("hidden");
      });
    });

    // Calendar navigation
    els.calPrev.addEventListener("click", () => {
      currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1);
      renderCalendar();
    });
    els.calNext.addEventListener("click", () => {
      currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1);
      renderCalendar();
    });

    // Schedule mode toggle (Monthly / Weekly)
    if (els.btnModeMonthly && els.btnModeWeekly) {
      els.btnModeMonthly.addEventListener("click", () => {
        wizardData.scheduleMode = "monthly";
        els.btnModeMonthly.classList.add("bg-[#111827]", "text-white");
        els.btnModeMonthly.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
        els.btnModeWeekly.classList.remove("bg-[#111827]", "text-white");
        els.btnModeWeekly.classList.add("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
        els.monthlyCalendar.classList.remove("hidden");
        els.weeklyCalendar.classList.add("hidden");
        renderCalendar();
      });
      els.btnModeWeekly.addEventListener("click", () => {
        wizardData.scheduleMode = "weekly";
        els.btnModeWeekly.classList.add("bg-[#111827]", "text-white");
        els.btnModeWeekly.classList.remove("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
        els.btnModeMonthly.classList.remove("bg-[#111827]", "text-white");
        els.btnModeMonthly.classList.add("text-[#667085]", "hover:text-[#111827]", "hover:bg-[#F9FAFB]");
        els.weeklyCalendar.classList.remove("hidden");
        els.monthlyCalendar.classList.add("hidden");
        renderWeeklyCalendar();
      });
    }

    // Weekly calendar navigation
    if (els.calWeekPrev) {
      els.calWeekPrev.addEventListener("click", () => {
        wizardData.currentWeekDate.setDate(wizardData.currentWeekDate.getDate() - 7);
        renderWeeklyCalendar();
      });
    }
    if (els.calWeekNext) {
      els.calWeekNext.addEventListener("click", () => {
        wizardData.currentWeekDate.setDate(wizardData.currentWeekDate.getDate() + 7);
        renderWeeklyCalendar();
      });
    }

    // AI Suggestion for weekly
    if (els.btnAiSuggestionWeekly) {
      els.btnAiSuggestionWeekly.addEventListener("click", applyAiSuggestionWeekly);
    }

    // Recurring
    els.recurringRadios.forEach((radio) => {
      radio.addEventListener("change", (e) => {
        wizardData.recurring = e.target.value;
        if (e.target.value === "once") {
          els.recurringInfo.textContent =
            "Content will be generated once on selected dates.";
          els.repeatForWrapper.classList.add("hidden");
          els.weeklyRepeatWrapper.classList.add("hidden");
          els.recurringPreview.classList.add("hidden");
        } else if (e.target.value === "monthly") {
          els.recurringInfo.textContent =
            "Selected dates will repeat every month. If a date doesn't exist in a month, it will be scheduled on the last day of that month.";
          els.repeatForWrapper.classList.remove("hidden");
          els.weeklyRepeatWrapper.classList.add("hidden");
          els.recurringPreview.classList.remove("hidden");
          renderRecurringPreview();
        } else if (e.target.value === "weekly") {
          els.recurringInfo.textContent =
            `Content will repeat every Week ${wizardData.weeklyWeek} of each month.`;
          els.repeatForWrapper.classList.remove("hidden");
          els.weeklyRepeatWrapper.classList.remove("hidden");
          els.recurringPreview.classList.remove("hidden");
          renderRecurringPreview();
        }
      });
    });

    // Repeat for dropdown
    if (els.repeatForSelect) {
      els.repeatForSelect.addEventListener("change", (e) => {
        wizardData.repeatFor = parseInt(e.target.value) || 3;
        renderRecurringPreview();
      });
    }

    // Weekly week select
    if (els.weeklyWeekSelect) {
      els.weeklyWeekSelect.addEventListener("change", (e) => {
        wizardData.weeklyWeek = parseInt(e.target.value) || 1;
        if (wizardData.recurring === "weekly") {
          els.recurringInfo.textContent =
            `Content will repeat every Week ${wizardData.weeklyWeek} of each month.`;
        }
        renderRecurringPreview();
      });
    }

    // Content type description
    if (els.slotContentType && els.contentTypeDesc) {
      els.slotContentType.addEventListener("change", (e) => {
        els.contentTypeDesc.textContent = CONTENT_TYPE_DESCS[e.target.value] || "";
      });
    }

    // Automation popover
    if (els.closeSlotPopover) els.closeSlotPopover.addEventListener("click", closeAutomationPopover);
    if (els.btnAddSlot) els.btnAddSlot.addEventListener("click", addAutomation);

    // Date detail popover
    if (els.closeDateDetailPopover) els.closeDateDetailPopover.addEventListener(
      "click",
      closeDateDetailPopover,
    );
    if (els.btnAddNewAutomation) els.btnAddNewAutomation.addEventListener("click", () => {
      closeDateDetailPopover();
      if (activePopoverDate) {
        const btn = document.querySelector(
          `.cal-day[data-date="${activePopoverDate}"]`,
        );
        if (btn) openAutomationPopover(activePopoverDate, btn);
      }
    });

    // Variations +/-
    els.btnVarMinus.addEventListener("click", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.max(1, val - 1);
    });
    els.btnVarPlus.addEventListener("click", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.min(10, val + 1);
    });
    els.automationVariations.addEventListener("change", () => {
      const val = parseInt(els.automationVariations.value) || 1;
      els.automationVariations.value = Math.max(1, Math.min(10, val));
    });

    // Auto comment modal (legacy - replaced by engagement)
    if (els.closeEngagementModal) els.closeEngagementModal.addEventListener("click", closeEngagementModalFn);
    if (els.btnCancelEngagement) els.btnCancelEngagement.addEventListener("click", closeEngagementModalFn);
    if (els.btnSaveEngagement) els.btnSaveEngagement.addEventListener("click", saveEngagement);
    if (els.modalEngagement) {
      els.modalEngagement.addEventListener("click", (e) => {
        if (e.target === els.modalEngagement) closeEngagementModalFn();
      });
    }
    if (els.commentToggle) {
      els.commentToggle.addEventListener("change", (e) => {
        if (els.commentFields) els.commentFields.classList.toggle("hidden", !e.target.checked);
      });
    }
    if (els.dmToggle) {
      els.dmToggle.addEventListener("change", (e) => {
        if (els.dmFields) els.dmFields.classList.toggle("hidden", !e.target.checked);
      });
    }

    // Schedule modal
    if (els.closeScheduleModal) els.closeScheduleModal.addEventListener("click", closeScheduleModalFn);
    if (els.btnCancelScheduleModal) els.btnCancelScheduleModal.addEventListener("click", closeScheduleModalFn);
    if (els.btnConfirmSchedule) els.btnConfirmSchedule.addEventListener("click", confirmSchedule);
    if (els.btnPublishNow) els.btnPublishNow.addEventListener("click", publishNow);
    if (els.btnPublish1h) els.btnPublish1h.addEventListener("click", publishIn1Hour);
    if (els.modalSchedule) {
      els.modalSchedule.addEventListener("click", (e) => {
        if (e.target === els.modalSchedule) closeScheduleModalFn();
      });
    }

    // Business filter dropdown
    const btnBusinessFilter = document.getElementById("btn-business-filter");
    const businessFilterDropdown = document.getElementById(
      "business-filter-dropdown",
    );
    if (btnBusinessFilter && businessFilterDropdown) {
      btnBusinessFilter.addEventListener("click", (e) => {
        e.stopPropagation();
        businessFilterDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !businessFilterDropdown.contains(e.target) &&
          e.target !== btnBusinessFilter
        ) {
          businessFilterDropdown.classList.add("hidden");
        }
      });
      document.querySelectorAll(".business-filter-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          const brand = opt.dataset.brand;
          document.getElementById("business-filter-label").textContent =
            brand === "all" ? "All Business" : brand;
          businessFilterDropdown.classList.add("hidden");
          // Filter automations
          if (brand === "all") {
            renderAutomations();
          } else {
            const filtered = automations.filter((a) => a.dna?.name === brand);
            els.tbody.innerHTML = filtered
              .map((auto) => {
                // ... reuse render logic
                const dateCount = Object.keys(auto.selectedDates).length;
                const contentTypes = [
                  ...new Set(
                    Object.values(auto.selectedDates)
                      .flat()
                      .map((s) => s.contentType),
                  ),
                ];
                const typeIcons = contentTypes
                  .map(
                    (t) =>
                      `<i class="ti ${CONTENT_ICONS[t] || "ti-file"} text-[13px] text-[#667085]" title="${t}"></i>`,
                  )
                  .join("");
                return `
                <tr class="border-b border-[#eaecf0] hover:bg-[#F9FAFB] transition-colors group">
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0">
                        <i class="ti ti-brand-abstract text-[18px] text-[#667085]"></i>
                      </div>
                      <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.dna?.name || "-")}</span>
                    </div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="text-[13px] font-semibold text-[#111827]">${escapeHtml(auto.name)}</span>
                  </td>
                  <td class="px-5 py-4">
                    <span class="text-[13px] text-[#667085]">${dateCount} tanggal · ${recurringLabel(auto.recurring)}</span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-1.5">${typeIcons}</div>
                  </td>
                  <td class="px-5 py-4">
                    <span class="inline-flex items-center px-2.5 h-6 rounded-full text-[11px] font-bold ${auto.status === "active" ? "bg-[#ECFDF3] text-[#027A48] border border-[#D1FADF]" : "bg-[#FEF3F2] text-[#B42318] border border-[#FECDCA]"}">
                      ${auto.status === "active" ? "Active" : "Paused"}
                    </span>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center justify-end gap-1">
                      <button class="action-btn w-8 h-8 rounded-lg hover:bg-[#F3F4F6] flex items-center justify-center text-[#667085] hover:text-[#111827] transition-colors cursor-pointer" onclick="toggleAutomationStatus('${auto.id}')">
                        <i class="ti ${auto.status === "active" ? "ti-player-pause" : "ti-player-play"} text-[15px]"></i>
                      </button>
                      <button class="action-btn w-8 h-8 rounded-lg hover:bg-[#FEF3F2] flex items-center justify-center text-[#667085] hover:text-[#D92D20] transition-colors cursor-pointer" onclick="deleteAutomation('${auto.id}')">
                        <i class="ti ti-trash text-[15px]"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              `;
              })
              .join("");
          }
        });
      });
    }

    // Automation search
    const automationSearch = document.getElementById("automation-search");
    if (automationSearch) {
      automationSearch.addEventListener("input", (e) => {
        const query = e.target.value.toLowerCase();
        const rows = els.tbody.querySelectorAll("tr");
        rows.forEach((row) => {
          const text = row.textContent.toLowerCase();
          row.style.display = text.includes(query) ? "" : "none";
        });
      });
    }

    // Tab switching
    els.tabAutomations.addEventListener("click", () =>
      switchTab("automations"),
    );
    els.tabGenerated.addEventListener("click", () => switchTab("generated"));
    els.tabScheduled.addEventListener("click", () => switchTab("scheduled"));

    const btnDraftShowMore = document.getElementById("btn-draft-show-more");
    if (btnDraftShowMore) {
      btnDraftShowMore.addEventListener("click", () => {
        draftLimit += 10;
        renderGenerated();
      });
    }

    // ── Scheduled Tab: Filter ──
    if (els.btnScheduledFilter && els.scheduledFilterDropdown) {
      els.btnScheduledFilter.addEventListener("click", (e) => {
        e.stopPropagation();
        els.scheduledFilterDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !els.scheduledFilterDropdown.contains(e.target) &&
          e.target !== els.btnScheduledFilter
        ) {
          els.scheduledFilterDropdown.classList.add("hidden");
        }
      });
      document.querySelectorAll(".scheduled-filter-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          scheduledFilter = opt.dataset.filter;
          els.scheduledFilterLabel.textContent = opt.textContent;
          els.scheduledFilterDropdown.classList.add("hidden");
          renderScheduled();
        });
      });
    }

    // ── Scheduled Tab: Search ──
    if (els.scheduledSearch) {
      els.scheduledSearch.addEventListener("input", (e) => {
        scheduledSearchQuery = e.target.value.trim().toLowerCase();
        renderScheduled();
      });
    }

    // ── Scheduled Tab: View Toggle ──
    function updateScheduledViewToggle() {
      const btns = [
        els.viewScheduledList,
        els.viewScheduledMonthly,
        els.viewScheduledWeekly,
      ];
      btns.forEach((btn) => {
        if (!btn) return;
        const view = btn.dataset.view;
        if (view === scheduledViewMode) {
          btn.classList.add("bg-[#F3F4F6]", "text-[#111827]");
          btn.classList.remove("text-[#667085]", "hover:bg-[#F9FAFB]");
        } else {
          btn.classList.remove("bg-[#F3F4F6]", "text-[#111827]");
          btn.classList.add("text-[#667085]", "hover:bg-[#F9FAFB]");
        }
      });
    }

    if (els.viewScheduledList) {
      els.viewScheduledList.addEventListener("click", () => {
        scheduledViewMode = "list";
        updateScheduledViewToggle();
        renderScheduled();
      });
    }
    if (els.viewScheduledMonthly) {
      els.viewScheduledMonthly.addEventListener("click", () => {
        scheduledViewMode = "monthly";
        updateScheduledViewToggle();
        renderScheduled();
      });
    }
    if (els.viewScheduledWeekly) {
      els.viewScheduledWeekly.addEventListener("click", () => {
        scheduledViewMode = "weekly";
        updateScheduledViewToggle();
        renderScheduled();
      });
    }
    updateScheduledViewToggle();

    // ── Scheduled Tab: Monthly Calendar Navigation ──
    if (els.calMonthPrev) {
      els.calMonthPrev.addEventListener("click", () => {
        scheduledMonthDate.setMonth(scheduledMonthDate.getMonth() - 1);
        renderScheduled();
      });
    }
    if (els.calMonthNext) {
      els.calMonthNext.addEventListener("click", () => {
        scheduledMonthDate.setMonth(scheduledMonthDate.getMonth() + 1);
        renderScheduled();
      });
    }

    // ── Scheduled Tab: Weekly Calendar Navigation ──
    if (els.calWeekPrev) {
      els.calWeekPrev.addEventListener("click", () => {
        scheduledWeekDate.setDate(scheduledWeekDate.getDate() - 7);
        renderScheduled();
      });
    }
    if (els.calWeekNext) {
      els.calWeekNext.addEventListener("click", () => {
        scheduledWeekDate.setDate(scheduledWeekDate.getDate() + 7);
        renderScheduled();
      });
    }

    // ── Filter Bar: Business ──
    if (els.btnOutputBusinessFilter && els.outputBusinessFilterDropdown) {
      els.btnOutputBusinessFilter.addEventListener("click", (e) => {
        e.stopPropagation();
        els.outputBusinessFilterDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (
          !els.outputBusinessFilterDropdown.contains(e.target) &&
          e.target !== els.btnOutputBusinessFilter
        ) {
          els.outputBusinessFilterDropdown.classList.add("hidden");
        }
      });
      document.querySelectorAll(".output-business-filter-option").forEach((opt) => {
        opt.addEventListener("click", () => {
          currentBusinessFilter = opt.dataset.brand;
          els.outputBusinessFilterLabel.textContent = opt.textContent;
          els.outputBusinessFilterDropdown.classList.add("hidden");
          renderGenerated();
        });
      });
    }

    // ── Filter Bar: Search ──
    if (els.outputSearch) {
      els.outputSearch.addEventListener("input", (e) => {
        searchQuery = e.target.value.trim();
        renderGenerated();
      });
    }

    // Preview modal
    if (els.closePreviewModal) {
      els.closePreviewModal.addEventListener("click", closePreviewModal);
    }
    // Backdrop click handled by modal container
    if (els.btnApprove) {
      els.btnApprove.addEventListener("click", approveContent);
    }
    if (els.btnReject) {
      els.btnReject.addEventListener("click", rejectContent);
    }
    // Unapprove button
    const btnUnapprove = document.getElementById("btn-unapprove");
    if (btnUnapprove) {
      btnUnapprove.addEventListener("click", unapproveContent);
    }
    // Schedule modal
    if (els.btnSchedule) {
      els.btnSchedule.addEventListener("click", openScheduleModal);
    }
    if (els.btnReschedule) {
      els.btnReschedule.addEventListener("click", rescheduleContent);
    }
    // Edit & Duplicate
    const btnEditApproved = document.getElementById("btn-edit-approved");
    if (btnEditApproved) {
      btnEditApproved.addEventListener("click", editAndDuplicateContent);
    }
    const btnEditScheduled = document.getElementById("btn-edit-scheduled");
    if (btnEditScheduled) {
      btnEditScheduled.addEventListener("click", editAndDuplicateContent);
    }
    // Duplicate button
    const btnDuplicate = document.getElementById("btn-duplicate");
    if (btnDuplicate) {
      btnDuplicate.addEventListener("click", editAndDuplicateContent);
    }
  }

  function toggleSelectCard(id) {
    const idx = selectedApprovedIds.indexOf(id);
    if (idx > -1) {
      selectedApprovedIds.splice(idx, 1);
    } else {
      selectedApprovedIds.push(id);
    }
    updateBulkHeader();
    
    const cb = document.getElementById(`cb-select-${id}`);
    const card = document.getElementById(`card-approved-${id}`);
    const container = document.getElementById(`checkbox-container-${id}`);
    const isSel = selectedApprovedIds.includes(id);

    if (cb) {
      cb.checked = isSel;
    }
    if (container) {
      if (isSel) {
        container.classList.add("opacity-100");
        container.classList.remove("opacity-0", "group-hover:opacity-100");
      } else {
        container.classList.remove("opacity-100");
        container.classList.add("opacity-0", "group-hover:opacity-100");
      }
    }
    if (card) {
      if (isSel) {
        card.classList.add("border-[#2563EB]", "ring-2", "ring-[#2563EB]/10");
        card.classList.remove("border-[#eaecf0]");
      } else {
        card.classList.remove("border-[#2563EB]", "ring-2", "ring-[#2563EB]/10");
        card.classList.add("border-[#eaecf0]");
      }
    }
  }

  function updateBulkHeader() {
    const bulkHeader = document.getElementById("approved-bulk-header");
    const selectedCount = document.getElementById("selected-count");
    if (selectedApprovedIds.length > 0) {
      if (bulkHeader) {
        bulkHeader.classList.remove("hidden");
        bulkHeader.classList.add("flex");
      }
      if (selectedCount) selectedCount.textContent = `${selectedApprovedIds.length} terpilih`;
    } else {
      if (bulkHeader) {
        bulkHeader.classList.add("hidden");
        bulkHeader.classList.remove("flex");
      }
    }
  }

  function deselectAllApproved() {
    selectedApprovedIds = [];
    updateBulkHeader();
    renderGenerated();
  }

  function bulkPublishSelected() {
    if (selectedApprovedIds.length === 0) return;
    
    generatedContent.forEach((item) => {
      if (selectedApprovedIds.includes(item.id)) {
        item.status = "published";
      }
    });
    
    localStorage.setItem(GENERATED_STORAGE_KEY, JSON.stringify(generatedContent));
    
    showToast(`Berhasil menerbitkan ${selectedApprovedIds.length} konten secara bulk!`);
    selectedApprovedIds = [];
    updateBulkHeader();
    renderGenerated();
  }

  // ═══════════════════════════════════════════
  // GLOBAL FUNCTIONS (for inline onclick)
  // ═══════════════════════════════════════════
  window.toggleAutomationStatus = toggleAutomationStatus;
  window.deleteAutomation = deleteAutomation;
  window.openCommentModal = openCommentModal;
  window.removeAutomation = removeAutomation;
  window.editAutomation = editAutomation;
  window.removeDate = removeDate;
  window.editDate = editDate;
  window.openPreviewModal = openPreviewModal;
  window.editAndDuplicateContent = editAndDuplicateContent;
  window.cancelScheduleItem = cancelScheduleItem;
  window.toggleSelectCard = toggleSelectCard;
  window.deselectAllApproved = deselectAllApproved;
  window.bulkPublishSelected = bulkPublishSelected;

  // Start
  init();
</script>
