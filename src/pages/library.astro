---
import AppLayout from "../layouts/AppLayout.astro";

// Pre-defined static data for the library files matching the screenshot and new requirements.
const libraryGroups = [
  {
    day: "Wednesday",
    projects: [
      {
        title: "Summer Music Festival Poster Concept",
        files: [
          { id: "1", name: "Commercial Woman Phone" },
          { id: "2", name: "Promo Spesial V2" },
          { id: "3", name: "Hero Banner Wide" },
        ],
      },
      {
        title: "Fall Product Campaign",
        files: [
          { id: "4", name: "New Season Feature" },
          { id: "5", name: "Product Banner Square" },
        ],
      },
    ],
  },
  {
    day: "Tuesday",
    projects: [
      {
        title: "Minimalist Instagram Post Design for T2intelligence",
        files: [
          { id: "6", name: "T2 Instagram 3" },
          { id: "7", name: "T2 Instagram 2" },
          { id: "8", name: "T2 Instagram 1" },
          { id: "9", name: "T2 Story Draft" },
        ],
      },
    ],
  },
];
---

<AppLayout title="Library - Xeni" activePage="library">
  <div class="w-full min-h-full flex flex-col px-6 pb-6 mt-[-48px]">
    <!-- Title + Controls Row -->
    <div class="max-w-6xl mx-auto w-full pt-1 pb-6 flex items-center justify-between gap-4">
      <!-- Left: Title -->
      <div class="flex items-center gap-2 shrink-0 select-none">
        <i class="ti ti-stack-2 text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">Library</h1>
      </div>

      <!-- Right: Favorites & Search Filters -->
      <div class="flex items-center gap-2 shrink-0">
        <!-- Favorites Filter Button -->
        <button
          id="btn-filter-favorites"
          type="button"
          class="flex items-center gap-1.5 px-3.5 h-8 rounded-full border border-[#eaecf0] bg-white text-[12px] font-medium text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer select-none"
        >
          <i class="ti ti-star text-[14px] text-[#667085]"></i>
          <span>My favorites</span>
        </button>

        <!-- Search input -->
        <div class="relative w-[220px]">
          <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"></i>
          <input
            id="file-search"
            type="text"
            placeholder="Search files..."
            class="w-full h-8 pl-8 pr-3 rounded-full border border-[#eaecf0] bg-white text-[12px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Grouped Sections -->
    <div class="max-w-6xl mx-auto w-full space-y-10">
      {libraryGroups.map((group) => (
        <div class="day-group space-y-8 select-none">
          {group.projects.map((project, pIdx) => (
            <div class="project-section space-y-4">
              <!-- Project Header -->
              <div class="flex items-center justify-between border-b border-[#f2f4f7] pb-2 select-none">
                <h2 class="text-[14px] font-bold text-[#344054]">{project.title}</h2>
                {pIdx === 0 && (
                  <span class="text-[12px] font-medium text-[#98a2b3]">{group.day}</span>
                )}
              </div>

              <!-- Project Grid (Files) -->
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                {project.files.map((file) => (
                  <div
                    class="file-card group relative flex flex-col bg-white border border-[#eaecf0] rounded-[24px] hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:border-transparent transition-all h-[230px]"
                    data-id={file.id}
                    data-title={file.name.toLowerCase()}
                  >
                    <!-- File Card Header -->
                    <div class="flex items-center justify-between p-3 select-none bg-white">
                      <span class="file-title text-[12px] font-bold text-[#344054] truncate flex-1">{file.name}</span>
                      <div class="relative shrink-0 flex items-center h-5">
                        <button
                          type="button"
                          class="btn-file-options shrink-0 flex items-center justify-center w-5 h-5 bg-transparent hover:bg-[#F3F4F6] rounded-full transition-all cursor-pointer text-[#667085] hover:text-[#111827]"
                          aria-label="File options"
                        >
                          <i class="ti ti-dots-vertical text-[13px]"></i>
                        </button>

                        <!-- Dropdown menu positioned downwards to avoid cut off -->
                        <div class="file-options-dropdown hidden absolute right-0 top-full mt-1.5 w-[100px] bg-white border border-[#eaecf0] rounded-xl shadow-[0_8px_30px_rgba(0,0,0,0.08)] z-50 overflow-hidden flex flex-col p-1 animate-in fade-in duration-150 pointer-events-auto">
                          <button
                            type="button"
                            class="btn-rename w-full px-2.5 py-1.5 text-[12px] font-medium text-[#344054] hover:bg-[#F3F4F6] rounded-lg transition-colors text-left"
                          >
                            Rename
                          </button>
                          <button
                            type="button"
                            class="btn-delete w-full px-2.5 py-1.5 text-[12px] font-medium text-[#D92D20] hover:bg-[#FEF3F2] rounded-lg transition-colors text-left"
                          >
                            Delete
                          </button>
                        </div>
                      </div>
                    </div>

                    <!-- Image / Overlay -->
                    <div class="flex-1 bg-[#F9FAFB] flex items-center justify-center relative select-none border-t border-[#eaecf0] rounded-b-[24px] overflow-hidden">
                      <div class="absolute inset-0 bg-gradient-to-br from-black/5 to-transparent"></div>
                      <i class="ti ti-photo text-[36px] text-black/10"></i>

                      <!-- Smooth hover overlay with options -->
                      <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center gap-2 pointer-events-none group-hover:pointer-events-auto backdrop-blur-[2px]">
                        <!-- Star Option -->
                        <button
                          type="button"
                          class="btn-favorite-file w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-md flex items-center justify-center text-white cursor-pointer transition-all border border-white/10 hover:scale-105"
                          aria-label="Star file"
                        >
                          <i class="ti ti-star text-[16px]"></i>
                        </button>
                        <!-- Download Option -->
                        <button
                          type="button"
                          class="btn-download-file w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-md flex items-center justify-center text-white cursor-pointer transition-all border border-white/10 hover:scale-105"
                          aria-label="Download file"
                        >
                          <i class="ti ti-download text-[16px]"></i>
                        </button>
                        <!-- Fullscreen/Zoom Option -->
                        <button
                          type="button"
                          class="btn-fullscreen-file w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 backdrop-blur-md flex items-center justify-center text-white cursor-pointer transition-all border border-white/10 hover:scale-105"
                          aria-label="Fullscreen file"
                        >
                          <i class="ti ti-maximize text-[16px]"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</AppLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    let searchQuery = "";
    let showFavoritesOnly = false;
    let savedFavorites = [];

    try {
      const stored = localStorage.getItem("library-favorites");
      if (stored) savedFavorites = JSON.parse(stored);
    } catch (e) {}

    // Initialize initial visual states for favorites
    function updateInitialFavoriteVisuals() {
      document.querySelectorAll(".file-card").forEach((card) => {
        const id = card.getAttribute("data-id");
        if (id && savedFavorites.includes(id)) {
          card.classList.add("is-favorite");
          const starBtn = card.querySelector(".btn-favorite-file");
          const starIcon = starBtn?.querySelector("i");
          if (starIcon) {
            starIcon.className = "ti ti-star-filled text-[#F59E0B]";
          }
        }
      });
    }
    updateInitialFavoriteVisuals();

    // Toggle dropdowns & handle options clicks
    document.addEventListener("click", (e) => {
      const clickedBtn = e.target.closest(".btn-file-options");
      const dropdowns = document.querySelectorAll(".file-options-dropdown");

      if (clickedBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = clickedBtn.closest(".file-card");
        const dropdown = card ? card.querySelector(".file-options-dropdown") : null;
        if (dropdown) {
          dropdowns.forEach((d) => {
            if (d !== dropdown) d.classList.add("hidden");
          });
          dropdown.classList.toggle("hidden");
        }
        return;
      }

      const renameBtn = e.target.closest(".btn-rename");
      const deleteBtn = e.target.closest(".btn-delete");

      if (renameBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = renameBtn.closest(".file-card");
        const dropdown = renameBtn.closest(".file-options-dropdown");
        if (dropdown) dropdown.classList.add("hidden");
        if (card) {
          const titleEl = card.querySelector(".file-title");
          const currentName = titleEl ? titleEl.textContent.trim() : "";
          const newName = prompt("Enter new file name:", currentName);
          if (newName && newName.trim()) {
            if (titleEl) {
              titleEl.textContent = newName.trim();
              card.setAttribute("data-title", newName.trim().toLowerCase());
            }
          }
        }
        return;
      }

      if (deleteBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = deleteBtn.closest(".file-card");
        const dropdown = deleteBtn.closest(".file-options-dropdown");
        if (dropdown) dropdown.classList.add("hidden");
        if (card) {
          if (confirm("Are you sure you want to delete this file from the library?")) {
            card.style.transition = "opacity 0.2s ease, transform 0.2s ease";
            card.style.opacity = "0";
            card.style.transform = "scale(0.95)";
            setTimeout(() => card.remove(), 200);
          }
        }
        return;
      }

      // Hide dropdowns if clicking anywhere else
      dropdowns.forEach((d) => d.classList.add("hidden"));
    });

    // Favorites click handling in the image overlay
    document.querySelectorAll(".btn-favorite-file").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const card = btn.closest(".file-card");
        if (!card) return;
        const id = card.getAttribute("data-id");
        if (!id) return;

        const starIcon = btn.querySelector("i");
        const isFavorite = savedFavorites.includes(id);

        if (isFavorite) {
          savedFavorites = savedFavorites.filter((favId) => favId !== id);
          card.classList.remove("is-favorite");
          if (starIcon) {
            starIcon.className = "ti ti-star text-[16px]";
          }
        } else {
          savedFavorites.push(id);
          card.classList.add("is-favorite");
          if (starIcon) {
            starIcon.className = "ti ti-star-filled text-[16px] text-[#F59E0B]";
          }
        }
        localStorage.setItem("library-favorites", JSON.stringify(savedFavorites));
        if (showFavoritesOnly) filterFiles();
      });
    });

    // Filtering Function
    function filterFiles() {
      document.querySelectorAll(".file-card").forEach((card) => {
        const title = card.getAttribute("data-title") || "";
        const id = card.getAttribute("data-id");
        const isFavorite = savedFavorites.includes(id);

        const matchesSearch = !searchQuery || title.includes(searchQuery);
        const matchesFavorite = !showFavoritesOnly || isFavorite;

        if (matchesSearch && matchesFavorite) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    }

    // Search input
    const input = document.getElementById("file-search");
    if (input) {
      input.addEventListener("input", (e) => {
        searchQuery = e.target.value.trim().toLowerCase();
        filterFiles();
      });
    }

    // Favorites Filter Toggle
    const favBtn = document.getElementById("btn-filter-favorites");
    if (favBtn) {
      favBtn.addEventListener("click", () => {
        showFavoritesOnly = !showFavoritesOnly;
        if (showFavoritesOnly) {
          favBtn.classList.add("border-[#2563EB]", "text-[#2563EB]", "bg-blue-50/10");
          favBtn.classList.remove("border-[#eaecf0]", "text-[#344054]");
        } else {
          favBtn.classList.remove("border-[#2563EB]", "text-[#2563EB]", "bg-blue-50/10");
          favBtn.classList.add("border-[#eaecf0]", "text-[#344054]");
        }
        filterFiles();
      });
    }
  });
</script>
