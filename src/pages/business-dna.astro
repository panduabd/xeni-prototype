<script is:inline>
  const dnaData = [
    {
      id: "1",
      name: "Fresh Juice Co.",
      category: "Food & Beverage",
      color: "#34D399",
      updatedAt: "2h ago",
    },
    {
      id: "2",
      name: "Acme Corp",
      category: "Technology",
      color: "#2563EB",
      updatedAt: "5h ago",
    },
    {
      id: "3",
      name: "Luxe Beauty",
      category: "Beauty & Cosmetics",
      color: "#F472B6",
      updatedAt: "1d ago",
    },
    {
      id: "4",
      name: "TechStart Inc",
      category: "Technology",
      color: "#8B5CF6",
      updatedAt: "2d ago",
    },
    {
      id: "5",
      name: "GreenLeaf Organics",
      category: "Retail",
      color: "#10B981",
      updatedAt: "3d ago",
    },
  ];

  const dnaCards = document.querySelectorAll(".dna-card");
  const detailName = document.getElementById("detail-name");
  const searchInput = document.getElementById("dna-search");
  const btnMoreActions = document.getElementById("btn-more-actions");
  const moreActionsDropdown = document.getElementById("more-actions-dropdown");

  let selectedId = "1";

  function selectDNA(id) {
    selectedId = id;
    const data = dnaData.find((d) => d.id === id);
    if (!data) return;
    dnaCards.forEach((card) => {
      if (card.dataset.id === id) {
        card.classList.remove("border-[#eaecf0]", "hover:bg-[#F9FAFB]");
        card.classList.add("border-[#9CA3AF]", "bg-[#F9FAFB]");
      } else {
        card.classList.remove("border-[#9CA3AF]", "bg-[#F9FAFB]");
        card.classList.add("border-[#eaecf0]", "hover:bg-[#F9FAFB]");
      }
    });
    detailName.textContent = data.name;
  }

  dnaCards.forEach((card) => {
    card.addEventListener("click", () => selectDNA(card.dataset.id));
  });

  searchInput?.addEventListener("input", (e) => {
    const query = e.target.value.toLowerCase();
    dnaCards.forEach((card) => {
      const id = card.dataset.id;
      const data = dnaData.find((d) => d.id === id);
      if (data) {
        const match =
          data.name.toLowerCase().includes(query) ||
          data.category.toLowerCase().includes(query);
        card.style.display = match ? "" : "none";
      }
    });
  });

  // Three-dot dropdown
  btnMoreActions?.addEventListener("click", (e) => {
    e.stopPropagation();
    moreActionsDropdown.classList.toggle("hidden");
  });
  document.addEventListener("click", (e) => {
    if (
      !moreActionsDropdown.contains(e.target) &&
      e.target !== btnMoreActions
    ) {
      moreActionsDropdown.classList.add("hidden");
    }
  });

  // Tab switching
  const tabBtns = document.querySelectorAll(".tab-btn");
  const tabContents = document.querySelectorAll(".tab-content");
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tab = btn.dataset.tab;
      tabBtns.forEach((b) => {
        b.classList.remove(
          "text-[#111827]",
          "font-semibold",
          "border-[#111827]",
        );
        b.classList.add("text-[#667085]", "font-medium", "border-transparent");
      });
      btn.classList.remove(
        "text-[#667085]",
        "font-medium",
        "border-transparent",
      );
      btn.classList.add("text-[#111827]", "font-semibold", "border-[#111827]");
      tabContents.forEach((content) => content.classList.add("hidden"));
      document.getElementById(`tab-${tab}`)?.classList.remove("hidden");
    });
  });

  // ── Helper: open/close modal ──────────────────────────────────────────────
  function openModal(id) {
    document.getElementById(id)?.classList.remove("hidden");
  }
  function closeModal(id) {
    document.getElementById(id)?.classList.add("hidden");
  }
  function bindClose(modalId, ...closeIds) {
    const modal = document.getElementById(modalId);
    if (!modal) return;
    closeIds.forEach((cid) => {
      document
        .getElementById(cid)
        ?.addEventListener("click", () => closeModal(modalId));
    });
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal(modalId);
    });
  }

  // ── New Business DNA button ───────────────────────────────────────────────
  document
    .getElementById("btn-new-dna")
    ?.addEventListener("click", () => openModal("modal-new-dna"));
  bindClose("modal-new-dna", "close-new-dna");

  // New DNA options → open sub-modals and close parent
  document.getElementById("new-dna-extract")?.addEventListener("click", () => {
    closeModal("modal-new-dna");
    openModal("modal-extract-file");
  });
  document.getElementById("new-dna-website")?.addEventListener("click", () => {
    closeModal("modal-new-dna");
    openModal("modal-analyze-website");
  });

  // ── Extract from file (Identity tab button) ───────────────────────────────
  document
    .getElementById("btn-extract-file")
    ?.addEventListener("click", () => openModal("modal-extract-file"));
  bindClose("modal-extract-file", "close-extract-file", "cancel-extract-file");

  // ── Analyze Website (Identity tab button) ─────────────────────────────────
  document
    .getElementById("btn-analyze-website")
    ?.addEventListener("click", () => openModal("modal-analyze-website"));
  bindClose(
    "modal-analyze-website",
    "close-analyze-website",
    "cancel-analyze-website",
  );

  // ── Photography modal ─────────────────────────────────────────────────────
  document
    .getElementById("btn-add-photography")
    ?.addEventListener("click", () => openModal("modal-photography"));
  bindClose("modal-photography", "close-photography", "cancel-photography");

  // ── Moodboard modal ───────────────────────────────────────────────────────
  document
    .getElementById("btn-add-moodboard")
    ?.addEventListener("click", () => openModal("modal-moodboard"));
  bindClose("modal-moodboard", "close-moodboard", "cancel-moodboard");

  // ── Knowledge modal ───────────────────────────────────────────────────────
  document
    .getElementById("btn-add-knowledge")
    ?.addEventListener("click", () => openModal("modal-knowledge"));
  bindClose("modal-knowledge", "close-knowledge", "cancel-knowledge");

  // ── Modals wiring & Global Save Button ────────────────────────────────────
  const btnSaveDna = document.getElementById("btn-save-dna");
  function enableSaveBtn() {
    if (btnSaveDna) {
      btnSaveDna.disabled = false;
      btnSaveDna.classList.remove("opacity-50", "cursor-not-allowed");
    }
  }

  // Bind new sub-modals
  bindClose(
    "modal-analyze-preview",
    "close-analyze-preview",
    "cancel-analyze-preview",
  );
  bindClose("modal-add-product", "close-add-product", "cancel-add-product");
  bindClose("modal-add-integration", "close-add-integration", "cancel-add-integration");

  // Add Integration Flow
  document
    .getElementById("btn-add-integration")
    ?.addEventListener("click", () => {
      openModal("modal-add-integration");
      const searchInput = document.getElementById("search-add-integration");
      if (searchInput) {
        searchInput.value = "";
        document.querySelectorAll(".integration-item-label").forEach(label => label.style.display = "");
      }
    });

  document.getElementById("search-add-integration")?.addEventListener("input", (e) => {
    const query = e.target.value.toLowerCase().trim();
    document.querySelectorAll(".integration-item-label").forEach((label) => {
      const handle = label.dataset.handle || "";
      if (handle.includes(query)) {
        label.style.display = "";
      } else {
        label.style.display = "none";
      }
    });
  });

  document
    .getElementById("btn-submit-add-integration")
    ?.addEventListener("click", () => {
      closeModal("modal-add-integration");
      enableSaveBtn();
    });

  // Add Product Flow
  document
    .getElementById("btn-add-product")
    ?.addEventListener("click", () => openModal("modal-add-product"));

  const productCatSelect = document.getElementById("product-category-select");
  const productDimSection = document.getElementById(
    "product-dimensions-section",
  );
  productCatSelect?.addEventListener("change", (e) => {
    if (e.target.value === "digital") {
      productDimSection.classList.add("hidden");
    } else {
      productDimSection.classList.remove("hidden");
    }
  });

  document
    .getElementById("btn-submit-add-product")
    ?.addEventListener("click", () => {
      closeModal("modal-add-product");
      enableSaveBtn();
    });

  // Extract from File Flow
  const btnExtractSubmit = document.getElementById("btn-submit-extract-file");
  btnExtractSubmit?.addEventListener("click", () => {
    openModal("modal-extract-loading");
    setTimeout(() => {
      closeModal("modal-extract-loading");
      closeModal("modal-extract-file");
      enableSaveBtn();
    }, 1500);
  });

  // Analyze Website Flow
  const btnAnalyzeSubmit = document.getElementById(
    "btn-submit-analyze-website",
  );
  btnAnalyzeSubmit?.addEventListener("click", () => {
    openModal("modal-analyze-scanning");
    setTimeout(() => {
      closeModal("modal-analyze-scanning");
      closeModal("modal-analyze-website");
      openModal("modal-analyze-preview");
    }, 1500);
  });

  document
    .getElementById("confirm-analyze-preview")
    ?.addEventListener("click", () => {
      closeModal("modal-analyze-preview");
      enableSaveBtn();
    });

  // Simulate edit triggering save
  document
    .querySelector("textarea")
    ?.addEventListener("input", () => enableSaveBtn());

  // Existing Knowledge Flow Update
  document.getElementById("save-knowledge")?.addEventListener("click", () => {
    const title = document
      .getElementById("knowledge-title-input")
      ?.value.trim();
    const content = document
      .getElementById("knowledge-content-input")
      ?.value.trim();
    if (!title || !content) return;
    // Append new knowledge card to the list
    const list = document.querySelector("#tab-knowledge .space-y-2");
    if (list) {
      const card = document.createElement("div");
      card.className =
        "p-4 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] group hover:border-[#D0D5DD] transition-all";
      card.innerHTML = `
        <div class="flex items-center justify-between gap-2">
          <h4 class="text-[13px] font-semibold text-[#111827]">${title}</h4>
          <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:text-[#111827] hover:bg-white transition-all cursor-pointer"><i class="ti ti-pencil text-[13px]"></i></button>
            <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:text-[#F04438] hover:bg-[#FEF3F2] transition-all cursor-pointer"><i class="ti ti-trash text-[13px]"></i></button>
          </div>
        </div>
        <p class="text-[12px] text-[#667085] mt-1">${content}</p>
      `;
      list.appendChild(card);
    }
    document.getElementById("knowledge-title-input").value = "";
    document.getElementById("knowledge-content-input").value = "";
    closeModal("modal-knowledge");
    enableSaveBtn();
  });
</script>
