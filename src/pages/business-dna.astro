---
import AppLayout from "../layouts/AppLayout.astro";

const businessDNAList = [
  {
    id: "1",
    name: "Fresh Juice Co.",
    category: "Food & Beverage",
    color: "#34D399",
    updatedAt: "2h ago",
  },
  {
    id: "2",
    name: "Acme Corp",
    category: "Technology",
    color: "#2563EB",
    updatedAt: "5h ago",
  },
  {
    id: "3",
    name: "Luxe Beauty",
    category: "Beauty & Cosmetics",
    color: "#F472B6",
    updatedAt: "1d ago",
  },
  {
    id: "4",
    name: "TechStart Inc",
    category: "Technology",
    color: "#8B5CF6",
    updatedAt: "2d ago",
  },
  {
    id: "5",
    name: "GreenLeaf Organics",
    category: "Retail",
    color: "#10B981",
    updatedAt: "3d ago",
  },
];

const categories = [
  "All",
  "Food & Beverage",
  "Technology",
  "Beauty & Cosmetics",
  "Retail",
  "Healthcare",
  "Finance",
];

const colorPalette = [
  { name: "Primary", hex: "#34D399", usage: "CTA, Links" },
  { name: "Secondary", hex: "#10B981", usage: "Accents" },
  { name: "Neutral", hex: "#6B7280", usage: "Body Text" },
  { name: "Dark", hex: "#111827", usage: "Headings" },
  { name: "Light", hex: "#F9FAFB", usage: "Backgrounds" },
];

const fonts = [
  { name: "Inter", role: "Primary", weights: "400, 500, 600, 700" },
  { name: "Playfair Display", role: "Accent", weights: "400, 700" },
];

const photographyStyle = [
  "Bright, natural lighting",
  "Clean, minimal backgrounds",
  "Vibrant food styling",
  "Lifestyle-oriented shots",
];

const knowledgeItems = [
  {
    id: "k1",
    title: "Company History",
    content: "Founded in 2018 in Bali, started as a small juice bar.",
  },
  {
    id: "k2",
    title: "Product Lines",
    content: "Cold-pressed juices, smoothies, wellness shots, and cleanses.",
  },
  {
    id: "k3",
    title: "Competitors",
    content: "Pressed Juicery, Suja Juice, Blueprint Cleanse.",
  },
  {
    id: "k4",
    title: "Unique Selling Points",
    content: "100% organic, locally sourced, zero-waste packaging.",
  },
];
---

<AppLayout title="Business DNA - Xeni" activePage="business-dna">
  <div class="w-full min-h-full flex flex-col px-6 pb-8 -mt-12">
    {/* ═══════════ HEADER ROW ═══════════ */}
    <div class="max-w-7xl mx-auto w-full pt-1 pb-6 flex items-center gap-4">
      <div class="flex items-center gap-2 shrink-0">
        <i class="ti ti-fingerprint text-[20px] text-[#98a2b3]"></i>
        <h1 class="text-[20px] font-bold text-[#111827] tracking-tight">
          Business DNA
        </h1>
      </div>
    </div>

    {/* ═══════════ BENTO GRID: 2 PANELS ═══════════ */}
    <div class="max-w-7xl mx-auto w-full flex-1 flex gap-4 min-h-0">
      {/* ═══ LEFT PANEL: DNA List (30%) ═══ */}
      <div
        class="w-[30%] min-w-70 max-w-90 flex flex-col gap-3 h-full overflow-hidden"
      >
        {/* Sticky Top Bar: Search + Button */}
        <div class="shrink-0 sticky top-0 z-10 flex flex-col gap-2 pb-2">
          {/* Search */}
          <div class="relative w-full">
            <i
              class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[#98a2b3] text-[14px] pointer-events-none"
            ></i>
            <input
              id="dna-search"
              type="text"
              placeholder="Search business DNA..."
              class="w-full h-10 pl-9 pr-3 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:shadow-[0_0_0_3px_rgba(37,99,235,0.1)] transition-all"
            />
          </div>

          {/* New Business DNA Button */}
          <button
            id="btn-new-dna"
            type="button"
            class="w-full flex items-center justify-center gap-1.5 px-4 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-medium hover:bg-[#374151] transition-all cursor-pointer"
          >
            <i class="ti ti-plus text-[14px]"></i>
            <span>New Business DNA</span>
          </button>
        </div>

        {/* DNA Cards */}
        <div
          id="dna-list"
          class="flex-1 overflow-y-auto flex flex-col gap-3 pb-2"
          style="scrollbar-width: none;"
        >
          {
            businessDNAList.map((dna, index) => (
              <button
                type="button"
                class={`dna-card group w-full text-left p-4 rounded-2xl border bg-white shadow-[0_1px_3px_rgba(0,0,0,0.04)] transition-all cursor-pointer ${index === 0 ? "border-[#9CA3AF] bg-[#F9FAFB]" : "border-[#eaecf0] hover:bg-[#F9FAFB]"}`}
                data-id={dna.id}
                data-category={dna.category}
              >
                <div class="flex items-center gap-3">
                  {/* Color Avatar */}
                  <div
                    class="w-10 h-10 rounded-xl shrink-0 flex items-center justify-center"
                    style={`background-color: ${dna.color}15;`}
                  >
                    <span
                      class="text-[14px] font-bold"
                      style={`color: ${dna.color};`}
                    >
                      {dna.name.charAt(0)}
                    </span>
                  </div>
                  {/* Info */}
                  <div class="flex-1 min-w-0">
                    <h4 class="text-[13px] font-bold text-[#111827] truncate">
                      {dna.name}
                    </h4>
                    <p class="text-[12px] text-[#667085] font-medium truncate mt-0.5">
                      {dna.category}
                    </p>
                  </div>
                </div>
              </button>
            ))
          }
        </div>
      </div>

      {/* ═══ RIGHT PANEL: DNA Detail (70%) ═══ */}
      <div
        class="flex-1 flex flex-col rounded-3xl border border-[#eaecf0] bg-white shadow-[0_1px_3px_rgba(0,0,0,0.04)] overflow-hidden min-h-0"
      >
        {/* Panel Header */}
        <div class="px-6 pt-5 pb-4 flex items-center justify-between shrink-0">
          <h2 id="detail-name" class="text-[16px] font-bold text-[#111827]">
            Fresh Juice Co.
          </h2>
          <div class="flex items-center gap-2">
            <button
              id="btn-save-dna"
              disabled
              class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-[#111827] text-white text-[12px] font-medium opacity-50 cursor-not-allowed transition-all"
            >
              <i class="ti ti-device-floppy text-[13px]"></i> Save Changes
            </button>
            <div class="relative">
              <button
                id="btn-more-actions"
                class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all cursor-pointer"
              >
                <i class="ti ti-dots text-[16px]"></i>
              </button>
              <div
                id="more-actions-dropdown"
                class="hidden absolute right-0 top-full mt-1 w-40 rounded-xl border border-[#eaecf0] bg-white shadow-[0_4px_12px_rgba(0,0,0,0.08)] py-1 z-20"
              >
                <button
                  type="button"
                  class="w-full text-left px-3 h-9 text-[12px] font-medium text-[#667085] hover:text-[#111827] hover:bg-[#F9FAFB] transition-all flex items-center gap-2"
                >
                  <i class="ti ti-pencil text-[13px]"></i> Rename
                </button>
                <button
                  type="button"
                  class="w-full text-left px-3 h-9 text-[12px] font-medium text-[#F04438] hover:bg-[#FEF3F2] transition-all flex items-center gap-2"
                >
                  <i class="ti ti-trash text-[13px]"></i> Delete
                </button>
              </div>
            </div>
          </div>
        </div>

        {/* Tabs */}
        <div class="shrink-0 px-6 border-b border-[#eaecf0]">
          <div class="flex items-center gap-1 -mb-px">
            <button
              type="button"
              class="tab-btn px-4 h-10 text-[13px] font-semibold text-[#111827] border-b-2 border-[#111827] transition-all cursor-pointer"
              data-tab="identity"
            >
              Identity
            </button>
            <button
              type="button"
              class="tab-btn px-4 h-10 text-[13px] font-medium text-[#667085] border-b-2 border-transparent hover:text-[#111827] transition-all cursor-pointer"
              data-tab="product-references"
            >
              Product References
            </button>
            <button
              type="button"
              class="tab-btn px-4 h-10 text-[13px] font-medium text-[#667085] border-b-2 border-transparent hover:text-[#111827] transition-all cursor-pointer"
              data-tab="knowledge"
            >
              Knowledge
            </button>
            <button
              type="button"
              class="tab-btn px-4 h-10 text-[13px] font-medium text-[#667085] border-b-2 border-transparent hover:text-[#111827] transition-all cursor-pointer"
              data-tab="integration"
            >
              Integration
            </button>
          </div>
        </div>

        {/* Settings Content */}
        <div class="flex-1 overflow-y-auto custom-scrollbar px-6 py-6">
          <div class="max-w-3xl">
            {/* ═══════════ TAB: IDENTITY ═══════════ */}
            <div id="tab-identity" class="tab-content space-y-8">
              {/* Brand Kit Upload Card */}
              <div
                class="rounded-2xl border border-[#eaecf0] bg-white p-5 flex items-center gap-4"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                >
                  <i class="ti ti-file-text text-[22px] text-[#667085]"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-[13px] font-bold text-[#111827]">
                    Build your Business DNA with one upload
                  </h3>
                  <p class="text-[12px] text-[#667085] mt-0.5">
                    Auto-fill logos, colors, fonts, and more. <a
                      href="/studio"
                      class="text-[#2563EB] hover:underline"
                      >Or create from scratch in Studio.</a
                    >
                  </p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <button
                    type="button"
                    id="btn-extract-file"
                    class="flex items-center gap-1.5 px-3 h-8 rounded-lg border border-[#D0D5DD] bg-white text-[12px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer"
                  >
                    <i class="ti ti-upload text-[13px]"></i>
                    Extract from file
                  </button>
                  <button
                    type="button"
                    id="btn-analyze-website"
                    class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-[#111827] text-white text-[12px] font-medium hover:bg-[#374151] transition-all cursor-pointer"
                  >
                    <i class="ti ti-world text-[13px]"></i>
                    Analyze Website
                  </button>
                </div>
              </div>

              {/* Section: Logo */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">Logo</h3>
                <div class="grid grid-cols-4 gap-3">
                  <button
                    type="button"
                    class="aspect-square rounded-xl border border-dashed border-[#D1D5DD] flex items-center justify-center text-[#98a2b3] hover:border-[#9CA3AF] hover:text-[#667085] transition-all cursor-pointer"
                  >
                    <i class="ti ti-plus text-[20px]"></i>
                  </button>
                  <div
                    class="aspect-square rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center"
                  >
                    <i class="ti ti-photo text-[24px] text-[#D1D5DB]"></i>
                  </div>
                </div>
                <p class="text-[11px] text-[#98a2b3] mt-2">
                  SVG, PNG, or JPG. Max 2MB.
                </p>
              </div>

              {/* Section: Business Overview */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">
                  Business Overview
                </h3>
                <textarea
                  rows="3"
                  class="w-full px-3 py-2.5 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:ring-1 focus:ring-[#2563EB]/10 transition-all resize-none"
                  >Fresh Juice Co. is a healthy juice brand focused on organic
                  ingredients and sustainable packaging.</textarea
                >
              </div>

              {/* Section: Design Guidance */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">
                  Design Guidance
                </h3>
                <textarea
                  rows="4"
                  placeholder="Describe your brand's design guidelines..."
                  class="w-full px-3 py-2.5 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-medium text-[#111827] placeholder:text-[#98a2b3] outline-none focus:border-[#2563EB] focus:ring-1 focus:ring-[#2563EB]/10 transition-all resize-none"
                  >Clean and minimal layouts. Use ample white space. Avoid
                  clutter. Prioritize readability and accessibility.</textarea
                >
              </div>

              {/* Section: Color */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">Color</h3>
                <div class="flex items-start gap-3">
                  <div class="flex flex-col items-center gap-1.5">
                    <button
                      type="button"
                      class="w-16 h-16 rounded-xl border border-dashed border-[#D1D5DD] flex items-center justify-center text-[#98a2b3] hover:border-[#9CA3AF] hover:text-[#667085] transition-all cursor-pointer"
                    >
                      <i class="ti ti-plus text-[20px]"></i>
                    </button>
                  </div>
                  {
                    colorPalette.map((color) => (
                      <div class="flex flex-col items-center gap-1.5">
                        <div
                          class="w-16 h-16 rounded-xl border border-[#eaecf0]"
                          style={`background-color: ${color.hex};`}
                        />
                        <span class="text-[11px] font-mono text-[#667085]">
                          {color.hex}
                        </span>
                      </div>
                    ))
                  }
                </div>
              </div>

              {/* Section: Fonts */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">Fonts</h3>
                <div class="flex items-start gap-3">
                  <div class="flex flex-col items-center gap-1.5">
                    <button
                      type="button"
                      class="w-16 h-16 rounded-xl border border-dashed border-[#D1D5DD] flex items-center justify-center text-[#98a2b3] hover:border-[#9CA3AF] hover:text-[#667085] transition-all cursor-pointer"
                    >
                      <i class="ti ti-plus text-[20px]"></i>
                    </button>
                  </div>
                  {
                    fonts.map((font) => (
                      <div class="flex flex-col items-center gap-1.5">
                        <div class="w-16 h-16 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center">
                          <span class="text-[14px] font-bold text-[#111827]">
                            Aa
                          </span>
                        </div>
                        <span class="text-[11px] font-medium text-[#667085]">
                          {font.name}
                        </span>
                      </div>
                    ))
                  }
                </div>
              </div>

              {/* Section: Photography */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">
                  Photography
                </h3>
                <div class="grid grid-cols-4 gap-3">
                  <button
                    type="button"
                    id="btn-add-photography"
                    class="aspect-square rounded-xl border border-dashed border-[#D1D5DD] flex items-center justify-center text-[#98a2b3] hover:border-[#9CA3AF] hover:text-[#667085] transition-all cursor-pointer"
                  >
                    <i class="ti ti-plus text-[20px]"></i>
                  </button>
                </div>
              </div>

              {/* Section: Moodboard */}
              <div>
                <h3 class="text-[13px] font-bold text-[#111827] mb-3">
                  Moodboard
                </h3>
                <div class="grid grid-cols-4 gap-3">
                  <button
                    type="button"
                    id="btn-add-moodboard"
                    class="aspect-square rounded-xl border border-dashed border-[#D1D5DD] flex items-center justify-center text-[#98a2b3] hover:border-[#9CA3AF] hover:text-[#667085] transition-all cursor-pointer"
                  >
                    <i class="ti ti-plus text-[20px]"></i>
                  </button>
                  {
                    [1, 2, 3, 4].map((i) => (
                      <div class="aspect-square rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center hover:border-[#D0D5DD] transition-all cursor-pointer group">
                        <i class="ti ti-photo text-[24px] text-[#D1D5DB] group-hover:text-[#9CA3AF] transition-colors" />
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>

            {/* ═══════════ TAB: PRODUCT REFERENCES ═══════════ */}
            <div
              id="tab-product-references"
              class="tab-content hidden space-y-8"
            >
              <div
                class="rounded-2xl border border-[#eaecf0] bg-white p-5 flex items-center gap-4"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                >
                  <i class="ti ti-packages text-[22px] text-[#667085]"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-[13px] font-bold text-[#111827]">
                    Product References
                  </h3>
                  <p class="text-[12px] text-[#667085] mt-0.5">
                    Manage your product references for content generation. <a
                      href="/studio"
                      class="text-[#2563EB] hover:underline"
                      >Or create from scratch in Studio.</a
                    >
                  </p>
                </div>
                <button
                  type="button"
                  id="btn-add-product"
                  class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-[#111827] text-white text-[12px] font-medium hover:bg-[#374151] transition-all cursor-pointer shrink-0"
                >
                  <i class="ti ti-plus text-[13px]"></i>
                  Add Product
                </button>
              </div>
              <div class="grid grid-cols-4 gap-3">
                <div
                  class="aspect-square rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex flex-col items-center justify-center hover:border-[#D0D5DD] transition-all cursor-pointer group gap-2"
                >
                  <i
                    class="ti ti-photo text-[24px] text-[#D1D5DB] group-hover:text-[#9CA3AF] transition-colors"
                  ></i>
                  <span class="text-[11px] font-medium text-[#667085]"
                    >Juice Box</span
                  >
                </div>
                <div
                  class="aspect-square rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex flex-col items-center justify-center hover:border-[#D0D5DD] transition-all cursor-pointer group gap-2"
                >
                  <i
                    class="ti ti-photo text-[24px] text-[#D1D5DB] group-hover:text-[#9CA3AF] transition-colors"
                  ></i>
                  <span class="text-[11px] font-medium text-[#667085]"
                    >Shot Bundle</span
                  >
                </div>
              </div>
            </div>

            {/* ═══════════ TAB: KNOWLEDGE ═══════════ */}
            <div id="tab-knowledge" class="tab-content hidden space-y-6">
              <div
                class="rounded-2xl border border-[#eaecf0] bg-white p-5 flex items-center gap-4"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                >
                  <i class="ti ti-brain text-[22px] text-[#667085]"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-[13px] font-bold text-[#111827]">
                    Knowledge Base
                  </h3>
                  <p class="text-[12px] text-[#667085] mt-0.5">
                    Store key facts about your business for smarter content
                    generation.
                  </p>
                </div>
                <button
                  type="button"
                  id="btn-add-knowledge"
                  class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-[#111827] text-white text-[12px] font-medium hover:bg-[#374151] transition-all cursor-pointer shrink-0"
                >
                  <i class="ti ti-plus text-[13px]"></i>
                  Add Knowledge
                </button>
              </div>
              <div class="space-y-2">
                {
                  knowledgeItems.map((item) => (
                    <div class="p-4 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] group hover:border-[#D0D5DD] transition-all">
                      <div class="flex items-center justify-between gap-2">
                        <h4 class="text-[13px] font-semibold text-[#111827]">
                          {item.title}
                        </h4>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                          <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:text-[#111827] hover:bg-white transition-all cursor-pointer">
                            <i class="ti ti-pencil text-[13px]" />
                          </button>
                          <button class="w-8 h-8 rounded-lg flex items-center justify-center text-[#667085] hover:text-[#F04438] hover:bg-[#FEF3F2] transition-all cursor-pointer">
                            <i class="ti ti-trash text-[13px]" />
                          </button>
                        </div>
                      </div>
                      <p class="text-[12px] text-[#667085] mt-1">
                        {item.content}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            {/* ═══════════ TAB: INTEGRATION ═══════════ */}
            <div id="tab-integration" class="tab-content hidden space-y-6">
              <div
                class="rounded-2xl border border-[#eaecf0] bg-white p-5 flex items-center gap-4"
              >
                <div
                  class="w-12 h-12 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0"
                >
                  <i class="ti ti-share text-[22px] text-[#667085]"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-[13px] font-bold text-[#111827]">
                    Connected Social Accounts
                  </h3>
                  <p class="text-[12px] text-[#667085] mt-0.5">
                    Link your social platforms to publish content directly.
                  </p>
                </div>
                <button
                  type="button"
                  id="btn-add-integration"
                  class="flex items-center gap-1.5 px-3 h-8 rounded-lg bg-[#111827] text-white text-[12px] font-medium hover:bg-[#374151] transition-all cursor-pointer shrink-0"
                >
                  <i class="ti ti-plus text-[13px]"></i>
                  Add Account
                </button>
              </div>
              <div class="space-y-2">
                <div
                  class="flex items-center gap-3 p-3 rounded-xl bg-[#F9FAFB] border border-[#eaecf0]"
                >
                  <div
                    class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0"
                    style="background-color: #E4405F10;"
                  >
                    <i
                      class="ti ti-brand-instagram text-[18px]"
                      style="color: #E4405F;"></i>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-[13px] font-semibold text-[#111827]">
                      @freshjuice.co
                    </p>
                    <p class="text-[11px] text-[#667085]">Instagram Business</p>
                  </div>
                  <div
