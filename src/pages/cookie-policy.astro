---
import "../styles/global.css";
import LandingNavbar from "../components/landing/LandingNavbar.astro";
import LandingFooter from "../components/landing/LandingFooter.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cookie Policy | Xeni</title>
    <meta name="description" content="Cookie Policy for Xeni AI Content Automation platform. Understand how we use cookies and tracking mechanisms." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Geist:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
  </head>
  <body class="bg-[#F8F9FB] text-[#111827] font-sans antialiased">
    <LandingNavbar />

    <main class="pt-24 md:pt-32 pb-20 overflow-x-hidden">
      <!-- Header Section -->
      <div class="max-w-4xl mx-auto px-6 text-center mb-12">
        <div class="flex justify-center mb-4">
          <span class="inline-flex items-center px-3 py-1 rounded-full border border-gray-300 bg-transparent text-[11px] font-semibold text-[#667085] uppercase tracking-wider whitespace-nowrap font-geist">
            Legal & Compliance
          </span>
        </div>
        <h1 class="text-[36px] md:text-[48px] font-normal text-[#111827] font-fraunces tracking-tight leading-tight mb-4">
          Cookie Policy
        </h1>
        <p class="text-[13px] md:text-[14px] text-[#667085] font-medium font-geist">
          Last Updated: June 19, 2026
        </p>
      </div>

      <!-- Main Policy Container -->
      <div class="max-w-4xl mx-auto px-6">
        <div class="bg-white border border-gray-200 rounded-[2rem] p-8 md:p-12 shadow-[0_8px_30px_rgba(0,0,0,0.01)] font-geist">
          
          <!-- Summary/TOC Checklist Box -->
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 mb-10">
            <h3 class="text-[14px] font-bold text-[#111827] mb-3 uppercase tracking-wider">Quick Navigation</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-[13px] text-[#4B5563]">
              <a href="#definition" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-cookie"></i> 1. What Are Cookies?
              </a>
              <a href="#how-we-use" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-eye"></i> 2. How We Use Cookies
              </a>
              <a href="#categories" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-category"></i> 3. Cookie Categories We Serve
              </a>
              <a href="#user-control" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-adjustments"></i> 4. Managing Cookie Choices
              </a>
              <a href="#policy-updates" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-refresh"></i> 5. Policy Updates
              </a>
              <a href="#contact" class="hover:text-[#111827] flex items-center gap-2 font-medium transition-colors">
                <i class="ti ti-mail"></i> 6. Contact Us
              </a>
            </div>
          </div>

          <!-- Document Content -->
          <div class="space-y-10 text-[14px] leading-relaxed text-[#4B5563]">
            
            <!-- Section 1 -->
            <section id="definition" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">01.</span> What Are Cookies?
              </h2>
              <p class="mb-4">
                Cookies are small files containing letters and numbers downloaded onto your computer, smartphone, or tablet when you visit our website. They act as a memory key for websites, allowing pages to recognize your browser, remember login sessions, track navigation logs, and recall configuration settings.
              </p>
              <p>
                We also utilize similar technologies, such as browser Local Storage, session cookies, and persistent cookies, to achieve a fluid experience on our content creation dashboard.
              </p>
            </section>

            <!-- Section 2 -->
            <section id="how-we-use" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">02.</span> How We Use Cookies
              </h2>
              <p class="mb-4">
                Xeni employs cookies to ensure core platform functionality, evaluate usage patterns, customize preferences, and deliver seamless social media pipeline scheduling. Specifically, cookies assist in:
              </p>
              <ul class="list-disc pl-5 space-y-2 mb-4">
                <li>Authenticating users and identifying security anomalies in live sessions.</li>
                <li>Preserving temporary inputs during content assembly stages.</li>
                <li>Tracking dark mode toggle selections and navigation states.</li>
                <li>Analyzing performance bottlenecks and load times using anonymous analytical logs.</li>
              </ul>
            </section>

            <!-- Section 3 -->
            <section id="categories" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">03.</span> Cookie Categories We Serve
              </h2>
              <p class="mb-4">
                We categorize the cookies operating on our domains into three specific groups:
              </p>
              <div class="space-y-4">
                <div class="border-l-4 border-gray-900 pl-4 py-1">
                  <h4 class="text-[14px] font-bold text-[#111827] mb-1">A. Essential Cookies (Strictly Necessary)</h4>
                  <p class="text-gray-600 text-[13px]">
                    These cookies are mandatory for the application to function. They handle user authentication, account verification, CSRF security, and route navigation. Disabling these cookies in your browser settings will prevent you from signing in or using the dashboard.
                  </p>
                </div>
                
                <div class="border-l-4 border-gray-300 pl-4 py-1">
                  <h4 class="text-[14px] font-bold text-[#111827] mb-1">B. Performance & Analytics Cookies</h4>
                  <p class="text-gray-600 text-[13px]">
                    These cookies collect anonymous aggregate data regarding site usage (such as which features are visited most, load-time errors, and traffic sources). We use these insights to optimize our algorithms and user interfaces.
                  </p>
                </div>

                <div class="border-l-4 border-gray-200 pl-4 py-1">
                  <h4 class="text-[14px] font-bold text-[#111827] mb-1">C. Preference & Functional Cookies</h4>
                  <p class="text-gray-600 text-[13px]">
                    These cookies store custom settings, including your language selection, dashboard tab history, and dark mode configuration, so they persist across navigation clicks and subsequent sessions.
                  </p>
                </div>
              </div>
            </section>

            <!-- Section 4 -->
            <section id="user-control" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">04.</span> Managing Cookie Choices
              </h2>
              <p class="mb-4">
                Most web browsers are configured by default to accept cookies. However, you can manage your preferences at any time:
              </p>
              <ul class="list-disc pl-5 space-y-2 mb-4">
                <li><strong class="text-[#111827]">Browser Settings:</strong> You can block or delete cookies directly inside your browser settings (Chrome, Safari, Edge, Firefox). Please refer to your browser's Help documentation.</li>
                <li><strong class="text-[#111827]">Analytics Opt-Out:</strong> To prevent Google Analytics tracking across all websites, you can install the official Google Analytics Opt-out Browser Add-on.</li>
              </ul>
              <p class="bg-yellow-50 border border-yellow-100 rounded-xl p-4 text-[13px] text-yellow-800">
                <strong>Please Note:</strong> If you restrict or block essential cookies, you may experience significant degradation of platform features, and session-based authentication will not function.
              </p>
            </section>

            <!-- Section 5 -->
            <section id="policy-updates" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">05.</span> Policy Updates
              </h2>
              <p class="mb-4">
                We may periodically update this Cookie Policy to reflect changes in our operational procedures or compliance regulations (such as updates to the Indonesian UU PDP, the European ePrivacy Directive, and GDPR).
              </p>
              <p>
                When modifications are made, we will update the "Last Updated" timestamp at the top of this page. We encourage you to review this policy occasionally to stay informed about our tracking mechanisms.
              </p>
            </section>

            <!-- Section 6 -->
            <section id="contact" class="scroll-mt-24">
              <h2 class="text-[18px] font-bold text-[#111827] mb-4 flex items-center gap-2">
                <span class="text-[#9CA3AF] font-light">06.</span> Contact Us
              </h2>
              <p class="mb-4">
                For questions regarding this Cookie Policy or our tracking technologies, please contact us:
              </p>
              <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 inline-block">
                <p class="font-bold text-[#111827] text-[13px] uppercase tracking-wider mb-2">Cookie & Compliance Operations</p>
                <p class="text-[#4B5563] text-[13px]">Email: <a href="mailto:contact@xenilabs.app" class="text-blue-600 hover:underline">contact@xenilabs.app</a></p>
                <p class="text-[#4B5563] text-[13px] mt-1">PT PERSONA DIGITAL KREATIF</p>
              </div>
            </section>

          </div>
        </div>
      </div>
    </main>

    <LandingFooter />
  </body>
</html>
