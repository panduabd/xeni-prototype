---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account - Xeni</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css"
    />
  </head>
  <body class="bg-[#F3F4F6] text-[#111827]">
    <div class="min-h-screen flex flex-col items-center justify-center p-6">
      <div class="text-center space-y-4 max-w-md">
        <div class="w-16 h-16 bg-white rounded-2xl border border-[#eaecf0] shadow-sm flex items-center justify-center mx-auto mb-6">
          <i class="ti ti-user-circle text-[32px] text-[#2563EB]"></i>
        </div>
        <h1 class="text-[32px] font-bold tracking-tight">Account Settings</h1>
        <p class="text-[16px] text-[#667085] leading-relaxed">
          Manage your account profile and subscription on this standalone page.
        </p>
        <div class="pt-8">
          <a href="/studio" class="inline-flex items-center gap-2 px-6 h-11 bg-[#111827] text-white rounded-xl font-bold hover:bg-black transition-all">
            <i class="ti ti-arrow-left"></i>
            Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </body>
</html>
