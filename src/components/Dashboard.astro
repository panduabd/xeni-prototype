---
const recentProjects = [
  { id: 1, name: "Summer Drink Promo", type: "Carousel", slides: 3, status: "completed", date: "2 mins ago", color: "from-blue-400 to-indigo-500" },
  { id: 2, name: "New Arrival Sneaker", type: "Feed", slides: 1, status: "in-progress", date: "1 hr ago", color: "from-orange-400 to-rose-500" },
  { id: 3, name: "Webinar Tech Talk", type: "Story", slides: 1, status: "completed", date: "Yesterday", color: "from-emerald-400 to-teal-500" },
];
---

<div class="flex flex-col h-full">
  
  <!-- Center hero with chat-first approach -->
  <div class="flex-1 flex flex-col items-center justify-center px-6 py-12 max-w-2xl mx-auto w-full">
    
    <!-- AI Avatar & Greeting -->
    <div class="flex flex-col items-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-blue-600 flex items-center justify-center mb-5 shadow-lg shadow-primary/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </div>
      <h1 class="text-2xl font-semibold tracking-tight text-foreground mb-2 text-center">Apa yang mau kita buat hari ini?</h1>
      <p class="text-sm text-muted-foreground text-center max-w-md">Ceritakan ide kamu, dan tim kreatif AI OiCrew akan membantu mengeksekusinya.</p>
    </div>

    <!-- Chat-style Input -->
    <div class="w-full mb-6">
      <div class="relative">
        <div class="w-full bg-muted/50 border border-border rounded-2xl px-5 py-4 flex items-start gap-3 cursor-pointer hover:border-primary/30 hover:bg-muted/30 transition-all group" id="btn-new-project">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground mt-0.5 group-hover:text-primary transition-colors shrink-0"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>
          <div class="flex-1">
            <span class="text-sm text-muted-foreground group-hover:text-foreground transition-colors">Deskripsikan brief kreatif kamu disini...</span>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs text-muted-foreground/60 hidden sm:inline">Atau pilih format</span>
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white shadow-sm group-hover:shadow-md transition-shadow">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Quick Action Chips -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-2">
      <button class="goal-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-border bg-white text-xs font-medium text-muted-foreground hover:border-primary/40 hover:text-primary hover:bg-primary/5 transition-all cursor-pointer" id="card-new-project">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/></svg>
        Feed Post
      </button>
      <button class="goal-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-border bg-white text-xs font-medium text-muted-foreground hover:border-primary/40 hover:text-primary hover:bg-primary/5 transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="3" y="3" rx="1"/></svg>
        Carousel
      </button>
      <button class="goal-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-border bg-white text-xs font-medium text-muted-foreground hover:border-primary/40 hover:text-primary hover:bg-primary/5 transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
        Story / Reels
      </button>
      <button class="goal-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-border bg-white text-xs font-medium text-muted-foreground hover:border-primary/40 hover:text-primary hover:bg-primary/5 transition-all cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16V4a2 2 0 0 1 2-2h11"/><path d="M5 14H4a2 2 0 1 0 0 4h1"/><path d="M22 18H11a2 2 0 1 0 0 4h11V6H11a2 2 0 0 0-2 2v12"/></svg>
        Ads Banner
      </button>
    </div>

  </div>

  <!-- Recent Projects (bottom area, vertical list) -->
  <div class="border-t border-border/50 bg-muted/20">
    <div class="max-w-2xl mx-auto px-6 py-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-foreground">Recent Projects</h3>
        <a href="#" class="text-xs font-medium text-muted-foreground hover:text-primary transition-colors">View all →</a>
      </div>

      <div class="flex flex-col gap-2.5">
        {recentProjects.map((proj) => (
          <a href="#" class="group flex items-center gap-4 p-3 -mx-1 rounded-xl hover:bg-white hover:shadow-sm border border-transparent hover:border-border/50 transition-all cursor-pointer">
            <!-- Thumbnail Preview -->
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${proj.color} flex items-center justify-center shrink-0 shadow-sm`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
              <h4 class="text-sm font-semibold text-foreground truncate group-hover:text-primary transition-colors">{proj.name}</h4>
              <div class="flex items-center gap-2 mt-0.5">
                <span class="text-xs text-muted-foreground">{proj.type}</span>
                {proj.slides > 1 && <span class="text-xs text-muted-foreground">• {proj.slides} slides</span>}
              </div>
            </div>

            <!-- Status & Date -->
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-xs text-muted-foreground">{proj.date}</span>
              <div class={`w-2 h-2 rounded-full ${proj.status === 'completed' ? 'bg-emerald-500' : 'bg-amber-400'}`}></div>
            </div>

            <!-- Arrow -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/40 group-hover:text-primary shrink-0 transition-colors"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>
