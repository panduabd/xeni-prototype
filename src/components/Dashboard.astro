---
import AiInput from "./AiInput.astro";

const recentProjects = [
  {
    id: 1,
    name: "Summer Drink Promo",
    type: "Carousel",
    slides: 3,
    status: "completed",
    date: "2 mins ago",
    color: "from-blue-400 to-indigo-500",
  },
  {
    id: 2,
    name: "New Arrival Sneaker",
    type: "Feed",
    slides: 1,
    status: "in-progress",
    date: "1 hr ago",
    color: "from-orange-400 to-rose-500",
  },
  {
    id: 3,
    name: "Webinar Tech Talk",
    type: "Story",
    slides: 1,
    status: "completed",
    date: "Yesterday",
    color: "from-emerald-400 to-teal-500",
  },
];
---

<style>
  .ai-orb-container {
    perspective: 1000px;
  }
  .ai-orb {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 35%,
      rgba(255, 255, 255, 1) 0%,
      rgba(238, 242, 255, 0.9) 20%,
      rgba(199, 210, 254, 0.6) 50%,
      rgba(165, 180, 252, 0.3) 80%,
      rgba(129, 140, 248, 0.1) 100%
    );
    box-shadow:
      0 10px 30px -5px rgba(129, 140, 248, 0.2),
      inset -2px -2px 8px rgba(99, 102, 241, 0.1),
      inset 4px 4px 12px rgba(255, 255, 255, 0.9);
    backdrop-blur: 4px;
    position: relative;
    animation: float 4s ease-in-out infinite;
  }

  .ai-orb::before {
    content: "";
    position: absolute;
    top: 20%;
    left: 20%;
    width: 25%;
    height: 25%;
    background: white;
    border-radius: 50%;
    filter: blur(3px);
    opacity: 0.9;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-6px) scale(1.02);
    }
  }


</style>

<div class="flex flex-col h-full">
  <!-- Center hero with chat-first approach -->
  <div
    class="flex-1 flex flex-col items-center justify-center px-6 py-12 max-w-2xl mx-auto w-full"
  >
    <!-- AI Orb & Greeting -->
    <div class="flex flex-col items-center mb-10">
      <div class="ai-orb-container mb-6">
        <div class="ai-orb"></div>
      </div>

      <div class="text-center space-y-1">
        <h1 class="text-[20px] font-bold text-foreground tracking-tight">
          Good Morning, Judha
        </h1>
        <h2 class="text-[20px] font-bold tracking-tight">
          <span class="text-foreground">How Can I </span>
          <span class="text-[#515ada]">Assist You Today?</span>
        </h2>
      </div>
    </div>

    <!-- Global AI Input (Hero Variant) -->
    <div class="w-full mb-6">
      <AiInput
        id="dashboard-ai-input"
        variant="hero"
        placeholder="Describe your creative brief here..."
      />
    </div>
  </div>

  <!-- Recent Projects (Seamless Grid View) -->
  <div class="border-t border-border/50 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-10">
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-base font-bold text-foreground tracking-tight">Recent Projects</h3>
        <a
          href="#"
          class="text-xs font-semibold text-muted-foreground hover:text-primary transition-colors flex items-center gap-1"
          >View all <i class="ti ti-arrow-right text-[10px]"></i></a
        >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          recentProjects.map((proj) => (
            <div class="group transition-all duration-300 cursor-pointer flex flex-col">
              
              <!-- Card Image Area (Direct) -->
              <div class="relative flex-1 min-h-[180px] bg-[#f8f9fb] rounded-[14px] border border-black/[0.03] flex items-center justify-center overflow-hidden mb-4">
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-black/[0.02] to-transparent"></div>
                <i class="ti ti-photo text-slate-200 text-[42px] group-hover:scale-110 transition-transform duration-500"></i>
                
                <!-- Date Badge bottom-right -->
                <div class="absolute bottom-3 right-3 px-2 py-1 rounded-md bg-white/90 backdrop-blur-sm text-[9px] font-bold text-slate-400 uppercase tracking-wider leading-none shadow-sm">
                  {proj.date}
                </div>

                <!-- Pagination Dots -->
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
                   <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                   <div class="w-1.5 h-1.5 rounded-full bg-slate-100"></div>
                   <div class="w-1.5 h-1.5 rounded-full bg-slate-100"></div>
                   <div class="w-1.5 h-1.5 rounded-full bg-slate-100"></div>
                </div>

                <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0">
                  <i class="ti ti-arrow-right text-slate-400"></i>
                </div>
              </div>

              <!-- Card Info (Direct) -->
              <div class="flex items-center justify-between px-1">
                <div class="flex flex-col min-w-0">
                  <h4 class="text-[14px] font-bold text-slate-900 truncate tracking-tight mb-1">{proj.name}</h4>
                  <div class="flex items-center gap-2">
                    <span class="text-[11px] font-medium text-slate-400 truncate tracking-tight">{proj.type}</span>
                    <span class="w-0.5 h-0.5 rounded-full bg-slate-300"></span>
                    <span class="text-[11px] font-medium text-slate-400 truncate tracking-tight">{proj.status}</span>
                  </div>
                </div>
                <button class="w-8 h-8 rounded-full bg-black/[0.04] text-black/40 flex items-center justify-center hover:bg-black hover:text-white transition-all shrink-0 ml-4">
                  <i class="ti ti-chevron-right text-[14px]"></i>
                </button>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  const dashInput = document.getElementById("dashboard-ai-input");
  if (dashInput) {
    dashInput.addEventListener("click", () => {
      dashInput.querySelector("textarea")?.focus();
    });
    dashInput.addEventListener("ai-submit", (e: any) => {
      const event = new CustomEvent("nav-to-workspace", {
        detail: { prompt: e.detail.prompt },
        bubbles: true,
      });
      dashInput.dispatchEvent(event);
    });
  }
</script>
