---
---

<div class="flex flex-col h-full bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] overflow-hidden">
  
  <!-- Stick Header -->
  <div class="px-8 py-5 border-b border-black/[0.04] flex items-center justify-between bg-white/80 backdrop-blur-md z-10 shrink-0">
     <div class="flex items-center gap-4">
        <button id="btn-back-brand-list" class="w-8 h-8 rounded-full hover:bg-black/5 flex items-center justify-center text-muted-foreground transition-colors group">
           <i class="ti ti-arrow-left text-[18px] group-hover:-translate-x-0.5 transition-transform"></i>
        </button>
        <div>
           <h1 class="text-[18px] font-bold text-foreground leading-tight flex items-center gap-2">
             Brand DNA Kit
             <span class="bg-emerald-50 border border-emerald-100 text-emerald-600 px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider">Active</span>
           </h1>
           <p class="text-[11px] text-muted-foreground mt-0.5">Define core parameters for AI generation</p>
        </div>
     </div>
     <div class="flex items-center gap-3">
        <button class="px-4 py-2 rounded-[10px] text-[12px] font-bold text-foreground border border-black/10 hover:bg-[#fafafa] bg-white transition-colors shadow-[0_2px_8px_rgb(0,0,0,0.02)]">Discard Changes</button>
        <button class="px-4 py-2 rounded-[10px] text-[12px] font-bold text-white bg-foreground hover:bg-black transition-colors shadow-sm">Save Brand Kit</button>
     </div>
  </div>

  <!-- Scrollable Form Container -->
  <div class="flex-1 overflow-y-auto p-8" style="scrollbar-width: none;">
     
     <div class="w-full max-w-[800px] mx-auto flex flex-col gap-12 pb-20">
        
        <!-- SECTION 1: IDENTITY -->
        <div class="flex flex-col gap-5">
           <h2 class="text-[15px] font-bold border-b border-black/5 pb-2 text-foreground flex items-center gap-2">
             <i class="ti ti-id"></i> 1. Identity & Context
           </h2>
           
           <div class="grid grid-cols-2 gap-5">
              <div>
                 <label class="block text-[11px] font-bold text-muted-foreground uppercase tracking-wider mb-1.5 pl-1">Brand Name</label>
                 <input type="text" value="Fresh Juice Co." class="w-full h-11 px-3.5 rounded-[12px] bg-white border border-black/10 shadow-[0_2px_8px_rgb(0,0,0,0.02)] text-[13px] font-semibold focus:outline-none focus:border-black/30 focus:shadow-md transition-all placeholder:text-muted-foreground/50" />
              </div>
              <div>
                 <label class="block text-[11px] font-bold text-muted-foreground uppercase tracking-wider mb-1.5 pl-1">Slogan / Tagline</label>
                 <input type="text" value="Squeeze the day!" class="w-full h-11 px-3.5 rounded-[12px] bg-white border border-black/10 shadow-[0_2px_8px_rgb(0,0,0,0.02)] text-[13px] font-semibold focus:outline-none focus:border-black/30 focus:shadow-md transition-all placeholder:text-muted-foreground/50" />
              </div>
           </div>

           <div>
              <label class="block text-[11px] font-bold text-muted-foreground uppercase tracking-wider mb-1.5 pl-1">About This Brand (Context for AI)</label>
              <textarea rows="3" class="w-full p-3.5 rounded-[12px] bg-white border border-black/10 shadow-[0_2px_8px_rgb(0,0,0,0.02)] text-[13px] font-medium resize-none focus:outline-none focus:border-black/30 focus:shadow-md transition-all leading-relaxed">A premium organic juice company targeting health-conscious millennials.</textarea>
           </div>
        </div>

        <!-- SECTION 2: AI CREATIVE GUIDELINES (VOICE & TONE) -->
        <div class="flex flex-col gap-5">
           <div class="border-b border-black/5 pb-2">
              <h2 class="text-[15px] font-bold text-foreground flex items-center gap-2">
                <i class="ti ti-message-chatbot"></i> 2. AI Directives
              </h2>
              <p class="text-[11px] text-muted-foreground mt-1">Rules shaping how the AI writes and behaves for this brand.</p>
           </div>
           
           <div>
              <label class="block text-[11px] font-bold text-muted-foreground uppercase tracking-wider mb-1.5 pl-1">Brand Voice (Tone & Attitude)</label>
              <textarea rows="2" class="w-full p-3.5 rounded-[12px] bg-white border border-black/10 shadow-[0_2px_8px_rgb(0,0,0,0.02)] text-[13px] font-medium resize-none focus:outline-none focus:border-black/30 focus:shadow-md transition-all leading-relaxed placeholder:text-muted-foreground/50" placeholder="e.g. Professional and highly academic.">Vibrant, energetic, slightly playful but always welcoming.</textarea>
           </div>
           
           <div>
              <label class="block text-[11px] font-bold text-red-500 uppercase tracking-wider mb-1.5 pl-1">Negative Guidelines ("Do Nots")</label>
              <textarea rows="2" class="w-full p-3.5 rounded-[12px] bg-red-50/50 border border-red-100 shadow-[0_2px_8px_rgb(0,0,0,0.02)] text-[13px] font-semibold text-red-900 resize-none focus:outline-none focus:bg-white focus:border-red-300 focus:shadow-md transition-all placeholder:text-red-300/80 leading-relaxed" placeholder="e.g. Do not use dark colors. Never use complex jargon.">Do not use neon or artificial coloring. Never use formal/corporate jargon.</textarea>
           </div>
        </div>

        <!-- SECTION 3: VISUAL ASSETS -->
        <div class="flex flex-col gap-5">
           
           <div class="border-b border-black/5 pb-2 mb-2">
             <h2 class="text-[15px] font-bold text-foreground flex items-center gap-2">
               <i class="ti ti-color-swatch"></i> 3. Visual Specifications
             </h2>
             <p class="text-[11px] text-muted-foreground mt-1">Design variables used to structure templates and image generation.</p>
           </div>
           
           <div class="grid grid-cols-2 gap-6">
               <!-- Color Palette -->
               <div class="p-5 rounded-[16px] border border-black/5 bg-white shadow-[0_2px_12px_rgb(0,0,0,0.02)]">
                  <h3 class="text-[13px] font-bold mb-4 flex items-center justify-between">Color Palette 
                    <button class="w-6 h-6 rounded-full bg-black/5 hover:bg-black/10 flex items-center justify-center transition-colors">
                      <i class="ti ti-plus text-[12px]"></i>
                    </button>
                  </h3>
                  <div class="flex gap-2">
                     <div class="relative group">
                       <div class="w-[42px] h-[42px] rounded-full bg-orange-500 shadow-sm border border-black/5 cursor-pointer hover:scale-110 transition-transform"></div>
                     </div>
                     <div class="relative group">
                       <div class="w-[42px] h-[42px] rounded-full bg-emerald-500 shadow-sm border border-black/5 cursor-pointer hover:scale-110 transition-transform"></div>
                     </div>
                     <div class="relative group">
                       <div class="w-[42px] h-[42px] rounded-full bg-[#111111] shadow-sm border border-black/5 cursor-pointer hover:scale-110 transition-transform"></div>
                     </div>
                     <div class="relative group">
                       <div class="w-[42px] h-[42px] rounded-full bg-white shadow-sm border border-black/10 cursor-pointer hover:scale-110 transition-transform"></div>
                     </div>
                  </div>
               </div>

               <!-- Typography -->
               <div class="p-5 rounded-[16px] border border-black/5 bg-white shadow-[0_2px_12px_rgb(0,0,0,0.02)]">
                  <h3 class="text-[13px] font-bold mb-4 flex items-center justify-between">Typography 
                    <button class="text-[11px] font-semibold text-primary/80 hover:text-primary">Edit Fonts</button>
                  </h3>
                  <div class="flex flex-col gap-3">
                     <div>
                       <span class="text-[9px] font-bold text-muted-foreground uppercase tracking-widest block mb-1">Heading</span>
                       <p class="text-[16px] font-extrabold text-foreground leading-none" style="font-family: 'Inter', sans-serif;">Inter Bold</p>
                     </div>
                     <div>
                       <span class="text-[9px] font-bold text-muted-foreground uppercase tracking-widest block mb-1">Body Text</span>
                       <p class="text-[13px] font-medium text-foreground/70" style="font-family: 'Inter', sans-serif;">Inter Medium</p>
                     </div>
                  </div>
               </div>
           </div>

           <!-- Logos -->
           <div class="p-5 rounded-[16px] border border-black/5 bg-white shadow-[0_2px_12px_rgb(0,0,0,0.02)] mt-2">
              <h3 class="text-[13px] font-bold mb-4">Logos & Iconography</h3>
              <div class="flex gap-4">
                 <div class="w-[100px] h-[100px] rounded-[14px] bg-[#fafafa] border-2 border-black/5 border-dashed flex flex-col items-center justify-center cursor-pointer hover:border-black/20 hover:bg-[#f0f0f0] transition-colors group">
                    <i class="ti ti-upload text-[24px] text-black/20 group-hover:text-black/40 mb-1 transition-colors"></i>
                    <span class="text-[10px] font-bold text-muted-foreground">Primary Logo</span>
                 </div>
                 <div class="w-[100px] h-[100px] rounded-[14px] bg-[#fafafa] border-2 border-black/5 border-dashed flex flex-col items-center justify-center cursor-pointer hover:border-black/20 hover:bg-[#f0f0f0] transition-colors group">
                    <i class="ti ti-upload text-[24px] text-black/20 group-hover:text-black/40 mb-1 transition-colors"></i>
                    <span class="text-[10px] font-bold text-muted-foreground">Logomark</span>
                 </div>
              </div>
           </div>
           
           <!-- Product Reference -->
           <div class="p-5 rounded-[16px] border border-black/5 bg-white shadow-[0_2px_12px_rgb(0,0,0,0.02)] mt-2">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-[13px] font-bold">Product References</h3>
                <span class="text-[11px] font-bold bg-black/5 text-foreground px-2 py-0.5 rounded-md">2 Uploaded</span>
              </div>
              <p class="text-[11px] text-muted-foreground mb-4 w-3/4 leading-relaxed">Upload isolated images of your products. The AI will preserve their geometry and labels when generating promotional materials.</p>
              
              <div class="flex gap-3">
                 <!-- Populated Product -->
                 <div class="w-[84px] h-[84px] rounded-[10px] bg-[#f0f0f0] border border-black/5 flex items-center justify-center relative group overflow-hidden">
                    <i class="ti ti-bottle text-[24px] text-black/20"></i>
                    <button class="absolute top-1 right-1 w-5 h-5 rounded-full bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 hover:bg-red-500 transition-all">
                      <i class="ti ti-x text-[10px] font-bold"></i>
                    </button>
                 </div>
                 
                 <div class="w-[84px] h-[84px] rounded-[10px] bg-[#f0f0f0] border border-black/5 flex items-center justify-center relative group overflow-hidden">
                    <i class="ti ti-cookie text-[24px] text-black/20"></i>
                    <button class="absolute top-1 right-1 w-5 h-5 rounded-full bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 hover:bg-red-500 transition-all">
                      <i class="ti ti-x text-[10px] font-bold"></i>
                    </button>
                 </div>

                 <!-- Add New Product -->
                 <div class="w-[84px] h-[84px] rounded-[10px] bg-white border-2 border-dashed border-black/10 flex flex-col items-center justify-center cursor-pointer hover:border-black/30 hover:bg-[#fafafa] transition-colors group">
                    <i class="ti ti-plus text-[20px] text-black/20 group-hover:text-black/40 transition-colors"></i>
                 </div>
              </div>
           </div>

        </div>

     </div>

  </div>

</div>
