---
const brandList = [
  { name: "Fresh Juice Co.", type: "F&B / Retail", lastUpdated: "Updated 2 days ago", color: "bg-[#7185ff]", txtColor: "text-white", status: "Active", initials: "F" },
  { name: "Urban Bloom", type: "Coffee Shop", lastUpdated: "Updated 4 days ago", color: "bg-[#e2f17d]", txtColor: "text-[#4a5214]", status: "Draft", initials: "U" },
  { name: "Apex CRM", type: "SaaS / B2B", lastUpdated: "Updated 1 week ago", color: "bg-[#fdc6e7]", txtColor: "text-[#872e61]", status: "Active", initials: "A" },
];
---

<div class="flex flex-col h-full bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] p-6 overflow-y-auto" style="scrollbar-width: none;">

  <!-- Page Header -->
  <div class="flex flex-col gap-5 mb-6 shrink-0">
    <div class="flex items-center justify-between">
      <h1 class="text-[18px] font-bold text-foreground tracking-tight">Brand DNA</h1>
      <button class="w-8 h-8 rounded-full bg-slate-50 hover:bg-slate-100 flex items-center justify-center text-slate-500 transition-colors">
        <i class="ti ti-search text-[16px]"></i>
      </button>
    </div>

    <!-- Create Brand Button -->
    <button id="btn-create-brand" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-[10px] bg-slate-900 text-white hover:bg-slate-800 font-semibold text-[13px] shadow-sm transition-all active:scale-[0.98]">
      <i class="ti ti-plus text-[16px]"></i> Create Brand DNA
    </button>
  </div>

  <!-- Ticket Layout Gallery -->
  <div class="flex flex-col gap-4">
    
    {brandList.map((brand) => (
      <div class="btn-open-brand-detail flex items-center gap-3 p-3 bg-white rounded-xl border border-slate-100 shadow-sm hover:border-slate-300 hover:shadow-md cursor-pointer group transition-all" data-brand-id={brand.name}>
         
         <!-- Icon -->
         <div class={`w-10 h-10 rounded-lg flex items-center justify-center text-[16px] font-bold shrink-0 ${brand.color} ${brand.txtColor}`}>
            {brand.initials}
         </div>

         <!-- Text Content -->
         <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between mb-0.5">
               <h3 class="text-[14px] font-bold text-slate-900 truncate pr-2">{brand.name}</h3>
               <span class={`px-2 py-0.5 rounded text-[9px] font-bold shrink-0
                             ${brand.status === 'Active' ? 'bg-emerald-50 text-emerald-600' : 'bg-slate-100 text-slate-500'}`}>
                  {brand.status}
               </span>
            </div>
            <div class="flex items-center gap-2">
               <span class="text-[11px] font-medium text-slate-500">{brand.type}</span>
               <span class="w-1 h-1 rounded-full bg-slate-300"></span>
               <span class="text-[10px] text-slate-400">{brand.lastUpdated}</span>
            </div>
         </div>
         
         <!-- Chevron -->
         <i class="ti ti-chevron-right text-slate-300 group-hover:text-slate-600 transition-colors"></i>

      </div>
    ))}

  </div>

</div>
