---
interface Props {
  activePage?: string;
}
const { activePage = 'overview' } = Astro.props;
---

<div class="flex flex-col h-full py-4 relative">
  <!-- Logo -->
  <div class="px-5 flex items-center justify-between mb-6 shrink-0">
    <a href="#" class="flex items-center gap-2">
      <div class="w-6 h-6 rounded bg-[#111] flex items-center justify-center">
        <i class="ti ti-bolt text-[14px] text-white"></i>
      </div>
      <span class="text-[14px] font-bold tracking-tight text-foreground">OiCrew</span>
    </a>
    <button class="text-muted-foreground hover:text-foreground transition-colors">
      <i class="ti ti-layout-sidebar-left-collapse text-[18px]"></i>
    </button>
  </div>
  
  <!-- Nav Menu -->
  <nav class="flex flex-col gap-1 px-3 flex-1 overflow-y-auto">
    <!-- Buttons -->
    <button data-nav-target="overview" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium w-full text-left transition-all
      ${activePage === 'overview' ? 'bg-white text-foreground font-semibold shadow-[0_2px_10px_rgb(0,0,0,0.04)] border-[0.5px] border-black/[0.05]' : 'text-muted-foreground hover:bg-[#fafafa] hover:text-foreground'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
      Studio
    </button>
    
    <button data-nav-target="projects" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium w-full text-left transition-all
      ${activePage === 'projects' ? 'bg-white text-foreground font-semibold shadow-[0_2px_10px_rgb(0,0,0,0.04)] border-[0.5px] border-black/[0.05]' : 'text-muted-foreground hover:bg-[#fafafa] hover:text-foreground'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
      Projects
    </button>
    
    <button data-nav-target="brand-dna" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] w-full text-left transition-all
      ${activePage === 'brand-dna' ? 'bg-white text-foreground font-semibold shadow-[0_2px_10px_rgb(0,0,0,0.04)] border-[0.5px] border-black/[0.05]' : 'text-muted-foreground hover:bg-[#fafafa] hover:text-foreground font-medium'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><path d="M2 15c6.667-6 13.333 0 20-6"/><path d="M9 22c1.798-1.998 2.518-3.995 2.807-5.993"/><path d="M15 2c-1.798 1.998-2.518 3.995-2.807 5.993"/><path d="m17 6-2.5-2.5"/><path d="m14 8-1.5-1.5"/><path d="m7 18 2.5 2.5"/><path d="m3.5 14.5.5.5"/><path d="m20 9 .5.5"/><path d="m6.5 12.5 2 2"/><path d="m15.5 11.5 2 2"/></svg>
      Brand DNA
    </button>
    
    <button data-nav-target="library" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] w-full text-left transition-all
      ${activePage === 'library' ? 'bg-white text-foreground font-semibold shadow-[0_2px_10px_rgb(0,0,0,0.04)] border-[0.5px] border-black/[0.05]' : 'text-muted-foreground hover:bg-[#fafafa] hover:text-foreground font-medium'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80"><path d="m16 6 4 14"/><path d="M12 6v14"/><path d="M8 8v12"/><path d="M4 4v16"/></svg>
      Library
    </button>
  </nav>

  <!-- Bottom -->
  <div class="px-3 pt-4 flex flex-col gap-1 shrink-0">
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-[#fafafa] hover:text-foreground w-full text-left transition-all">
      <i class="ti ti-inbox text-[16px]"></i>Inbox
    </button>
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-[#fafafa] hover:text-foreground w-full text-left transition-all">
      <i class="ti ti-settings text-[16px]"></i>Settings
    </button>
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-[#fafafa] hover:text-foreground w-full text-left transition-all">
      <i class="ti ti-help-circle text-[16px]"></i>Help
    </button>
    
    <div class="px-3 py-2 mt-2">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#111] text-[10px] font-semibold text-white">
        <i class="ti ti-bolt text-[11px]"></i>260 AI Credits
      </span>
    </div>

    <div class="flex items-center gap-2.5 px-3 pt-2 pb-1">
      <div class="w-7 h-7 rounded-full border-[0.5px] border-black/[0.08] bg-gray-50 flex items-center justify-center text-[10px] font-bold text-foreground shrink-0 shadow-sm">CN</div>
      <div class="min-w-0">
        <p class="text-[11px] font-semibold text-foreground leading-tight truncate">Jane Cooper</p>
        <p class="text-[9px] text-muted-foreground truncate">jane@apexcrm.io</p>
      </div>
    </div>
  </div>
</div>
