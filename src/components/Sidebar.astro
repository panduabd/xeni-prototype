---
interface Props {
  activePage?: string;
}
const { activePage = 'overview' } = Astro.props;
---

<div class="flex flex-col h-full py-4 relative">
  <!-- Logo -->
  <div class="px-5 flex items-center justify-between mb-6 shrink-0">
    <a href="#" class="flex items-center gap-2">
      <div class="w-6 h-6 rounded bg-[#111] flex items-center justify-center">
        <i class="ti ti-bolt text-[14px] text-white"></i>
      </div>
      <span class="text-[14px] font-bold tracking-tight text-foreground">OiCrew</span>
    </a>
    <button class="text-muted-foreground hover:text-foreground transition-colors">
      <i class="ti ti-layout-sidebar-left-collapse text-[18px]"></i>
    </button>
  </div>
  
  <!-- Nav Menu -->
  <nav class="flex flex-col gap-1 px-3 flex-1 overflow-y-auto">
    <!-- Buttons -->
    {activePage === 'home' && (
      <button data-nav-target="home" class="sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-bold bg-white text-foreground w-full text-left transition-all border border-black/[0.03] shadow-[0_1px_2px_rgba(0,0,0,0.06)]">
        <i class="fa-solid fa-house text-[13px]"></i>
        Home
      </button>
    )}

    {activePage !== 'home' && (
      <>
        <button data-nav-target="overview" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium w-full text-left transition-all
          ${activePage === 'overview' ? 'bg-white text-foreground font-bold border border-black/[0.03] shadow-[0_1px_2px_rgba(0,0,0,0.06)]' : 'text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)]'}`}>
          <i class="fa-solid fa-shapes text-[13px] opacity-80 group-hover:opacity-100"></i>
          Studio
        </button>
        
        <button data-nav-target="projects" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium w-full text-left transition-all
          ${activePage === 'projects' ? 'bg-white text-foreground font-bold border border-black/[0.03] shadow-[0_1px_2px_rgba(0,0,0,0.06)]' : 'text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)]'}`}>
          <i class="fa-solid fa-folder text-[13px] opacity-80 group-hover:opacity-100"></i>
          Projects
        </button>
        
        <button data-nav-target="brand-dna" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] w-full text-left transition-all
          ${activePage === 'brand-dna' ? 'bg-white text-foreground font-bold border border-black/[0.03] shadow-[0_1px_2px_rgba(0,0,0,0.06)]' : 'text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)] font-medium'}`}>
          <i class="fa-solid fa-dna text-[13px] opacity-80 group-hover:opacity-100"></i>
          Brand DNA
        </button>
        
        <button data-nav-target="library" class={`sidebar-nav-btn flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] w-full text-left transition-all
          ${activePage === 'library' ? 'bg-white text-foreground font-bold border border-black/[0.03] shadow-[0_1px_2px_rgba(0,0,0,0.06)]' : 'text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)] font-medium'}`}>
          <i class="fa-solid fa-photo-film text-[13px] opacity-80 group-hover:opacity-100"></i>
          Library
        </button>
      </>
    )}
  </nav>

  <!-- Bottom -->
  <div class="px-3 pt-4 flex flex-col gap-1 shrink-0">
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)] w-full text-left transition-all group">
      <i class="fa-solid fa-envelope text-[13px] opacity-70 group-hover:opacity-100 transition-opacity"></i>Inbox
    </button>
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)] w-full text-left transition-all group">
      <i class="fa-solid fa-gear text-[13px] opacity-70 group-hover:opacity-100 transition-opacity"></i>Settings
    </button>
    <button class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium text-muted-foreground hover:bg-white hover:text-foreground hover:border-black/[0.03] hover:shadow-[0_1px_2px_rgba(0,0,0,0.06)] w-full text-left transition-all group">
      <i class="fa-solid fa-circle-question text-[13px] opacity-70 group-hover:opacity-100 transition-opacity"></i>Help
    </button>
    
    <div class="px-3 py-2 mt-2">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#111] text-[10px] font-semibold text-white">
        <i class="ti ti-bolt text-[11px]"></i>260 AI Credits
      </span>
    </div>

    <div class="flex items-center gap-2.5 px-3 pt-2 pb-1">
      <div class="w-7 h-7 rounded-full border-[0.5px] border-black/[0.08] bg-gray-50 flex items-center justify-center text-[10px] font-bold text-foreground shrink-0 shadow-none">CN</div>
      <div class="min-w-0">
        <p class="text-[11px] font-semibold text-foreground leading-tight truncate">Jane Cooper</p>
        <p class="text-[9px] text-muted-foreground truncate">jane@apexcrm.io</p>
      </div>
    </div>
  </div>
</div>
