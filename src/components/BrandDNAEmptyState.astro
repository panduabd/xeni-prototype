---
// BrandDNAEmptyState.astro
---

<div class="flex flex-col items-center justify-center h-full w-full bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] overflow-y-auto" style="scrollbar-width: none;">
  <div class="max-w-[700px] w-full px-8 py-16 flex flex-col items-center mx-auto text-center mt-10">
    
    <div class="w-16 h-16 rounded-full bg-slate-50 flex items-center justify-center border border-slate-100 mb-6 shadow-sm">
      <i class="ti ti-wand text-[28px] text-slate-700"></i>
    </div>

    <h1 class="text-[28px] font-bold text-slate-900 mb-2 tracking-tight">Automated Brand Setup</h1>
    <p class="text-[15px] text-slate-500 mb-12 max-w-[450px]">Let OiCrew analyze your existing assets to automatically generate your complete Brand DNA.</p>

    <!-- Two Setup Options -->
    <div class="flex flex-col md:flex-row gap-6 w-full text-left mb-12">
      
      <!-- Option 1: URL -->
      <div class="flex-1 bg-white rounded-2xl border border-slate-200 p-6 flex flex-col shadow-sm hover:border-slate-300 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
            <i class="ti ti-link text-[20px]"></i>
          </div>
          <div>
            <h3 class="text-[15px] font-bold text-slate-900">Extract from Website</h3>
            <p class="text-[12px] text-slate-500">We'll scrape your colors, fonts, and tone.</p>
          </div>
        </div>
        <div class="flex flex-col gap-3 mt-auto">
          <input type="url" placeholder="https://yourwebsite.com" class="w-full h-10 px-3 rounded-lg border border-slate-200 text-[13px] focus:outline-none focus:ring-2 focus:ring-slate-900/5 focus:border-slate-400 transition-all bg-slate-50"/>
          <button class="w-full h-10 rounded-lg bg-slate-900 text-white text-[13px] font-semibold hover:bg-slate-800 transition-colors">
            Analyze Website
          </button>
        </div>
      </div>

      <!-- Option 2: Upload -->
      <div class="flex-1 bg-white rounded-2xl border border-slate-200 p-6 flex flex-col shadow-sm hover:border-slate-300 transition-all">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
            <i class="ti ti-file-upload text-[20px]"></i>
          </div>
          <div>
            <h3 class="text-[15px] font-bold text-slate-900">Upload Guidelines</h3>
            <p class="text-[12px] text-slate-500">Drop your brand book or PDF guide.</p>
          </div>
        </div>
        <div class="mt-auto w-full h-24 border border-dashed border-slate-200 rounded-lg bg-slate-50 flex flex-col items-center justify-center cursor-pointer hover:bg-slate-100 transition-colors">
          <i class="ti ti-upload text-[20px] text-slate-400 mb-1"></i>
          <span class="text-[12px] font-medium text-slate-600">Click or drag file here</span>
          <span class="text-[10px] text-slate-400">PDF, max 20MB</span>
        </div>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full flex items-center justify-center gap-4 mb-10">
      <div class="h-px bg-slate-100 flex-1"></div>
      <span class="text-[12px] text-slate-400 font-medium">or</span>
      <div class="h-px bg-slate-100 flex-1"></div>
    </div>

    <!-- Footer Text -->
    <p class="text-[14px] text-slate-600">
      Don't have brand assets yet? <a href="#" class="font-medium text-slate-900 border-b border-slate-400 border-dashed hover:border-solid hover:text-black transition-all pb-0.5">Start from scratch</a> on canvas.
    </p>

  </div>
</div>
