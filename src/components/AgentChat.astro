---
---
<div class="flex h-full">
  
  <!-- Left: Chat Panel -->
  <div class="w-[380px] shrink-0 border-r border-border/50 flex flex-col bg-muted/10">

    <!-- Chat Header -->
    <div class="h-14 px-5 border-b border-border/50 flex items-center gap-3 shrink-0">
      <div class="relative">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary to-blue-600 text-white flex items-center justify-center font-bold text-[10px] shadow-sm">R</div>
        <div class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-emerald-500 border-2 border-white"></div>
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="text-[13px] font-semibold text-foreground leading-tight">Raka</h3>
        <span class="text-[10px] text-muted-foreground">Creative Manager • Online</span>
      </div>
      <button class="w-7 h-7 rounded-md hover:bg-muted flex items-center justify-center text-muted-foreground">
        <i class="ti ti-dots text-[16px]"></i>
      </button>
    </div>
    
    <!-- Chat Messages -->
    <div class="flex-1 px-5 py-5 overflow-y-auto flex flex-col gap-4">
      
      <!-- User message -->
      <div class="flex gap-2 items-start justify-end animate-msg-1">
        <div class="flex-1 flex justify-end">
          <div class="bg-primary text-white rounded-2xl rounded-tr-sm px-4 py-2.5 text-[13px] leading-relaxed shadow-sm max-w-[85%]">
            Buatkan carousel promo diskon 20% untuk Fresh Juice Mangga, target anak muda
          </div>
        </div>
        <div class="w-6 h-6 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-[9px] shrink-0 mt-0.5">P</div>
      </div>

      <!-- Raka 1 -->
      <div class="flex gap-2 items-start opacity-0 animate-msg-2">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-blue-600 text-white flex items-center justify-center font-bold text-[9px] shrink-0 mt-0.5">R</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-2.5 text-[13px] text-foreground leading-relaxed shadow-sm border border-border/30 max-w-[85%]">
          Brief diterima! Saya breakdown dulu ya. 📋
        </div>
      </div>
      
      <!-- Raka 2 -->
      <div class="flex gap-2 items-start opacity-0 animate-msg-3">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-blue-600 text-white flex items-center justify-center font-bold text-[9px] shrink-0 mt-0.5">R</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-2.5 text-[13px] text-foreground leading-relaxed shadow-sm border border-border/30 max-w-[85%]">
          Carousel 3 slide— <span class="text-primary font-semibold">@Bima</span> handle layout, <span class="text-violet-600 font-semibold">@Dina</span> handle copy. Go! 🎨
        </div>
      </div>
      
      <!-- Activity Logs -->
      <div class="flex items-center justify-center gap-2 py-1 opacity-0 animate-msg-4">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/5 border border-primary/10">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          <span class="text-[11px] font-medium text-primary">Bima menyusun layout...</span>
        </div>
      </div>
      <div class="flex items-center justify-center gap-2 py-1 opacity-0 animate-msg-5">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-50 border border-violet-100">
          <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
          <span class="text-[11px] font-medium text-violet-600">Dina menulis copy...</span>
        </div>
      </div>

      <!-- Bima result -->
      <div class="flex gap-2 items-start opacity-0 animate-msg-6">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 text-white flex items-center justify-center font-bold text-[9px] shrink-0 mt-0.5">B</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-2.5 text-[13px] text-foreground leading-relaxed shadow-sm border border-border/30 max-w-[85%]">
          Layout carousel siap ✅ Hero Split slide 1, Card Grid slide 2-3.
        </div>
      </div>

      <!-- Raka final -->
      <div class="flex gap-2 items-start opacity-0 animate-msg-7">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-blue-600 text-white flex items-center justify-center font-bold text-[9px] shrink-0 mt-0.5">R</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-2.5 text-[13px] text-foreground leading-relaxed shadow-sm border border-border/30 max-w-[85%]">
          Ini hasilnya, gimana? 👀
        </div>
      </div>
    </div>
    
    <!-- Chat Input -->
    <div class="px-4 py-3 border-t border-border/50 bg-white shrink-0">
      <div class="flex items-center gap-2">
        <button class="w-8 h-8 rounded-md hover:bg-muted flex items-center justify-center text-muted-foreground shrink-0">
          <i class="ti ti-paperclip text-[17px]"></i>
        </button>
        <input type="text" placeholder="Ketik revisi atau feedback..." class="flex-1 h-9 px-3 text-[13px] rounded-lg border border-border bg-muted/30 placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all" />
        <button class="w-8 h-8 rounded-lg bg-primary hover:bg-primary/90 flex items-center justify-center text-white shadow-sm transition-all shrink-0">
          <i class="ti ti-send-2 text-[15px]"></i>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Right: Canvas Preview -->
  <div class="flex-1 flex flex-col bg-white relative overflow-hidden">
    
    <!-- Canvas Header -->
    <div class="h-14 border-b border-border/50 px-6 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <h4 class="text-[13px] font-semibold tracking-tight text-foreground">Live Canvas</h4>
        <span class="text-[10px] px-2 py-0.5 bg-primary/10 text-primary font-semibold rounded-full">Carousel • 3 Slides</span>
      </div>
      <div class="flex gap-2">
        <button class="h-8 px-3 rounded-lg border border-border bg-white text-[12px] font-medium text-foreground hover:bg-muted transition-colors flex items-center gap-1.5">
          <i class="ti ti-pencil text-[14px]"></i>
          Sunting Manual
        </button>
        <button class="h-8 px-3 rounded-lg bg-primary text-[12px] font-medium text-white hover:bg-primary/90 transition-colors shadow-sm flex items-center gap-1.5">
          <i class="ti ti-download text-[14px]"></i>
          Download
        </button>
      </div>
    </div>
    
    <!-- Canvas Body -->
    <div class="flex-1 bg-[#f0f1f3] flex items-center justify-center p-8 relative overflow-hidden">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle, #d1d5db 0.8px, transparent 0.8px); background-size: 20px 20px;"></div>
      
      <div class="relative flex gap-3 opacity-0 animate-canvas">
        <div class="w-[230px] h-[230px] bg-white shadow-xl rounded-lg overflow-hidden border border-black/5 flex flex-col">
          <div class="h-32 bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center">
            <i class="ti ti-photo text-[36px] text-white opacity-30"></i>
          </div>
          <div class="flex-1 p-3.5 flex flex-col justify-center">
            <div class="w-6 h-0.5 bg-primary/30 mb-1.5"></div>
            <h3 class="text-[14px] font-bold text-foreground leading-tight mb-0.5">Summer Sale 🍹</h3>
            <p class="text-[10px] text-muted-foreground leading-tight">Diskon 20% minuman segar</p>
          </div>
        </div>
        <div class="w-[230px] h-[230px] bg-white shadow-xl rounded-lg overflow-hidden border border-black/5 flex flex-col opacity-80 scale-[0.96]">
          <div class="h-32 bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center">
            <i class="ti ti-photo text-[36px] text-white opacity-30"></i>
          </div>
          <div class="flex-1 p-3.5 flex flex-col justify-center">
            <h3 class="text-[14px] font-bold text-foreground leading-tight mb-0.5">Mangga Tropical</h3>
            <p class="text-[10px] text-muted-foreground leading-tight">Varian baru yang segar</p>
          </div>
        </div>
        <div class="w-[230px] h-[230px] bg-white shadow-xl rounded-lg overflow-hidden border border-black/5 flex flex-col opacity-60 scale-[0.92]">
          <div class="h-32 bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center">
            <i class="ti ti-photo text-[36px] text-white opacity-30"></i>
          </div>
          <div class="flex-1 p-3.5 flex flex-col justify-center">
            <h3 class="text-[14px] font-bold text-foreground leading-tight mb-0.5">Order Now 🚀</h3>
            <p class="text-[10px] text-muted-foreground leading-tight">Free ongkir pertama</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes canvasIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .animate-msg-1 { animation: msgIn 0.4s ease forwards; }
  .animate-msg-2 { animation: msgIn 0.4s ease forwards 0.8s; }
  .animate-msg-3 { animation: msgIn 0.4s ease forwards 2s; }
  .animate-msg-4 { animation: msgIn 0.3s ease forwards 3.5s; }
  .animate-msg-5 { animation: msgIn 0.3s ease forwards 4s; }
  .animate-msg-6 { animation: msgIn 0.4s ease forwards 5.5s; }
  .animate-msg-7 { animation: msgIn 0.4s ease forwards 7s; }
  .animate-canvas { animation: canvasIn 0.6s ease forwards 6s; }
</style>
