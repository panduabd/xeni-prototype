---
import Sidebar from './Sidebar.astro';

interface Props {
  activePage?: string;
}
const { activePage = 'overview' } = Astro.props;
---

<!-- BENTO BOX LAYOUT -->
<div class="flex h-screen w-full overflow-hidden bg-[#FAFBFD] p-3 gap-3">
  
  <!-- 1. SEAMLESS SIDEBAR -->
  <div class="w-[220px] shrink-0 flex flex-col h-full overflow-hidden">
    <Sidebar activePage={activePage} />
  </div>

  <!-- 2. RIGHT WRAPPER -->
  <div class="flex-1 flex flex-col min-w-0 gap-3 h-full">
    
    <!-- 2a. TOP NAV -->
    <div class="h-[52px] shrink-0 bg-white rounded-[10px] shadow-[0_2px_8px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex items-center px-5 relative">
        
        <!-- Home Button (Now merged) -->
        <a href="#" class="flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors mr-6 relative group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-80 group-hover:opacity-100 transition-opacity"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </a>

        <!-- Vert Separator -->
        <div class="w-[1px] h-4 bg-black/10 mr-4"></div>

        <div class="flex items-center gap-1 h-full relative">
          <a href="#" class="px-5 text-[13px] font-bold text-foreground h-full flex items-center relative">
            Studio
            <!-- Thicker, more prominent bottom line -->
            <span class="absolute bottom-0 left-4 right-4 h-[4px] bg-foreground rounded-t-[4px]"></span>
          </a>
          <a href="#" class="px-5 text-[13px] font-bold text-muted-foreground hover:text-foreground h-full flex items-center transition-colors">
            Marketing
          </a>
          <a href="#" class="px-5 text-[13px] font-bold text-muted-foreground hover:text-foreground h-full flex items-center transition-colors">
            Ops
          </a>
          <a href="#" class="px-5 text-[13px] font-bold text-muted-foreground hover:text-foreground h-full flex items-center transition-colors">
            Finance
          </a>
          <a href="#" class="px-5 text-[13px] font-bold text-muted-foreground hover:text-foreground h-full flex items-center transition-colors">
            Code
          </a>
        </div>

    </div>

    <!-- 2b. BOTTOM SECTION -->
    <div class="flex-1 min-h-0 flex gap-3 overflow-hidden">
      <slot />
    </div>

  </div>

</div>
