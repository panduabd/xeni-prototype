---
interface Props {
    id: string;
    title: string;
    business: string;
    time: string;
    href?: string;
    className?: string;
}

const { id, title, business, time, href, className = "" } = Astro.props;
const CardTag = href ? 'a' : 'div';
---

<CardTag
    href={href}
    class={`project-card group relative flex flex-col p-3 rounded-[24px] bg-white border border-[#eaecf0] hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:border-transparent transition-all cursor-pointer w-[250px] shrink-0 ${className || ''}`}
    data-id={id}
>
    <!-- Preview Grid -->
    <div class="flex gap-2 items-center justify-between mb-3 select-none">
        <!-- Large Preview -->
        <div class="flex-1 h-[108px] rounded-[16px] bg-[#F3F4F6] overflow-hidden relative border border-[#eaecf0] min-w-0 flex items-center justify-center">
            <div class="absolute inset-0 bg-gradient-to-br from-black/5 to-transparent"></div>
            <i class="ti ti-photo text-[32px] text-black/10"></i>
        </div>
        <!-- Small Grid -->
        <div class="grid grid-cols-2 gap-2 shrink-0">
            <div class="w-[50px] h-[50px] rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center"><i class="ti ti-photo text-[14px] text-black/5"></i></div>
            <div class="w-[50px] h-[50px] rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center"><i class="ti ti-photo text-[14px] text-black/5"></i></div>
            <div class="w-[50px] h-[50px] rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center"><i class="ti ti-photo text-[14px] text-black/5"></i></div>
            <div class="w-[50px] h-[50px] rounded-lg bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center"><i class="ti ti-photo text-[14px] text-black/5"></i></div>
        </div>
    </div>

    <!-- Info -->
    <div class="px-1 flex flex-col flex-1 select-none relative">
        <h4 class="text-[13px] font-bold text-[#111827] truncate mb-0.5 transition-colors group-hover:text-[#2563EB]">
            {title}
        </h4>
        <div class="relative flex items-center justify-between gap-2 mt-auto">
            <p class="text-[11px] text-[#98a2b3] font-medium flex items-center gap-1.5 min-w-0">
                <span class="text-[#667085] truncate project-business">{business}</span>
                <span class="w-1 h-1 rounded-full bg-[#D1D5DB]"></span>
                <span class="shrink-0">{time}</span>
            </p>

            <div class="relative shrink-0 flex items-center h-7 select-none">
                <button
                    type="button"
                    class="btn-options-menu opacity-0 group-hover:opacity-100 shrink-0 flex items-center justify-center w-7 h-7 bg-transparent hover:bg-[#F3F4F6] rounded-full transition-all cursor-pointer text-[#667085] hover:text-[#111827]"
                    aria-label="Options menu"
                >
                    <i class="ti ti-dots-vertical text-[16px]"></i>
                </button>

                <!-- Dropdown menu positioned downwards -->
                <div class="options-dropdown hidden absolute right-0 top-full mt-1.5 w-[130px] bg-white border border-[#eaecf0] rounded-xl shadow-[0_8px_30px_rgba(0,0,0,0.08)] z-50 overflow-hidden flex flex-col p-1 pointer-events-auto">
                    <button
                        type="button"
                        class="btn-rename w-full px-2.5 py-1.5 text-[12px] font-medium text-[#344054] hover:bg-[#F3F4F6] rounded-lg transition-colors text-left"
                    >
                        Rename
                    </button>
                    <button
                        type="button"
                        class="btn-add-favorite w-full px-2.5 py-1.5 text-[12px] font-medium text-[#344054] hover:bg-[#F3F4F6] rounded-lg transition-colors text-left"
                    >
                        Add to Favorites
                    </button>
                    <button
                        type="button"
                        class="btn-delete w-full px-2.5 py-1.5 text-[12px] font-medium text-[#D92D20] hover:bg-[#FEF3F2] rounded-lg transition-colors text-left"
                    >
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</CardTag>

<script is:inline>
  if (!window.projectCardScriptsInitialized) {
    window.projectCardScriptsInitialized = true;

    document.addEventListener('click', (e) => {
      const clickedBtn = e.target.closest('.btn-options-menu');
      const dropdowns = document.querySelectorAll('.options-dropdown');
      
      if (clickedBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = clickedBtn.closest('.project-card');
        const dropdown = card ? card.querySelector('.options-dropdown') : null;
        if (dropdown) {
          dropdowns.forEach(d => { if (d !== dropdown) d.classList.add('hidden'); });
          dropdown.classList.toggle('hidden');
        }
        return;
      }

      const renameBtn = e.target.closest('.btn-rename');
      const addFavBtn = e.target.closest('.btn-add-favorite');
      const deleteBtn = e.target.closest('.btn-delete');

      if (addFavBtn) {
        e.preventDefault();
        e.stopPropagation();
        const dropdown = addFavBtn.closest('.options-dropdown');
        if (dropdown) dropdown.classList.add('hidden');
        const card = addFavBtn.closest('.project-card');
        if (card) {
          const id = card.getAttribute('data-id');
          if (id) {
            try {
              let favs = [];
              const stored = localStorage.getItem('project-favorites');
              if (stored) favs = JSON.parse(stored);
              if (!favs.includes(id)) {
                favs.push(id);
                localStorage.setItem('project-favorites', JSON.stringify(favs));
              }
            } catch (e) {}
          }
        }
        alert('Project added to favorites!');
        return;
      }

      if (renameBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = renameBtn.closest('.project-card');
        const dropdown = renameBtn.closest('.options-dropdown');
        if (dropdown) dropdown.classList.add('hidden');
        if (card) {
          const titleEl = card.querySelector('h4');
          const currentName = titleEl ? titleEl.textContent.trim() : '';
          const newName = prompt('Enter new project name:', currentName);
          if (newName && newName.trim()) {
            if (titleEl) titleEl.textContent = newName.trim();
          }
        }
        return;
      }

      if (deleteBtn) {
        e.preventDefault();
        e.stopPropagation();
        const card = deleteBtn.closest('.project-card');
        const dropdown = deleteBtn.closest('.options-dropdown');
        if (dropdown) dropdown.classList.add('hidden');
        if (card) {
          if (confirm('Are you sure you want to delete this project?')) {
            card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => card.remove(), 200);
          }
        }
        return;
      }

      // Hide dropdowns if clicking anywhere else
      dropdowns.forEach(d => d.classList.add('hidden'));
    });
  }
</script>
