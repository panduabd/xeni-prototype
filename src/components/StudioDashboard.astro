---
const crew = [
  {
    id: "raka",
    name: "Raka",
    role: "Creative Manager",
    statuses: ["Supervising All Crew...", "Reviewing Analytics...", "Planning Next Campaign..."],
    skills: [
      { name: "Project Management", icon: "ti-briefcase", desc: "Mengelola timeline dan resource kampanye" },
      { name: "Creative Strategy", icon: "ti-bulb", desc: "Merumuskan ide dan konsep kreatif" },
      { name: "Quality Assurance", icon: "ti-check", desc: "Memastikan standar kualitas output" }
    ]
  },
  {
    id: "dina",
    name: "Dina",
    role: "Copywriter",
    statuses: ["Drafting Summer Campaign copy...", "Researching Keywords...", "Polishing Tone of Voice..."],
    skills: [
      { name: "Ad Copywriting", icon: "ti-pencil", desc: "High-converting copy for social & display" },
      { name: "Brand Voice", icon: "ti-message-2", desc: "Consistent tone across all touchpoints" },
      { name: "SEO Content", icon: "ti-search", desc: "Keyword-optimised captions & descriptions" },
      { name: "Social Media Copy", icon: "ti-brand-instagram", desc: "Captions, hashtags & engagement hooks" },
    ]
  },
  {
    id: "bima",
    name: "Bima",
    role: "Designer",
    statuses: ["Building Carousel layout...", "Exporting Assets...", "Refining Visual Hierarchy..."],
    skills: [
      { name: "Social Media Feeds", icon: "ti-layout-grid", desc: "High-quality feed & carousel layouts" },
      { name: "Digital Ads", icon: "ti-ad", desc: "Conversion-focused promotional assets" },
      { name: "Marketplace Banners", icon: "ti-shopping-cart", desc: "Professional store & product banners" },
      { name: "Campaign Graphics", icon: "ti-speakerphone", desc: "Cohesive visual assets for marketing" },
    ]
  },
];

const activityHistory = [
  { role: 'raka', name: 'Raka', text: 'Analyzed brief and initiated "Fresh Juice Co." project timeline.', time: '10:00 AM', hasResult: false },
  { role: 'dina', name: 'Dina', text: 'Researched keywords and finalized draft copy for 5 carousel slides.', time: '10:45 AM', hasResult: true, resultLabel: 'Check Copywriting' },
  { role: 'bima', name: 'Bima', text: 'Applied brand DNA and generated carousel layout graphics.', time: '11:20 AM', hasResult: true, resultLabel: 'View Designs' },
  { role: 'raka', name: 'Raka', text: 'Performed QA check. Final assets meet quality standards.', time: '11:30 AM', hasResult: false },
];

const recentProjects = [
  { name: "Summer Drink Campaign", brand: "Fresh Juice Co.", assets: 4, date: "2 mins ago", bg: "bg-[#f4f5f7]", icon: "ti-cup" },
  { name: "New Arrival Promo",     brand: "Urban Bloom",    assets: 12, date: "1 hr ago",   bg: "bg-[#f4f5f7]", icon: "ti-plant-2" },
  { name: "Webinar Talk",          brand: "Apex CRM",       assets: 2,  date: "Yesterday",  bg: "bg-[#f4f5f7]", icon: "ti-device-desktop" },
];
---

<style>
  #project-slider { scroll-behavior: smooth; scrollbar-width: none; }
  #project-slider::-webkit-scrollbar { display: none; }
</style>

<div class="h-full w-full bg-white rounded-[16px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] p-5 overflow-y-auto flex flex-col gap-6" style="scrollbar-width: none;">

  <!-- Header -->
  <div class="px-1 pt-1 -mb-2 flex items-center justify-between">
    <h2 class="text-[15px] font-bold text-foreground">Your AI Crew</h2>
    <button id="btn-view-activity" class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-black/[0.04] border border-black/[0.04] hover:bg-black/[0.06] text-[10px] font-bold text-muted-foreground hover:text-foreground transition-all">
      <i class="ti ti-history text-[12px]"></i>
      View Crew Activity
    </button>
  </div>

  <!-- Crew Cards (Seamless) -->
  <div class="flex flex-col">
    {crew.map((member) => (
      <div class="flex gap-4 py-4 border-b border-black/[0.04] last:border-0 px-1">
        
        <!-- Avatar -->
        <div class="relative w-[64px] h-[64px] shrink-0">
          <div class="w-full h-full rounded-[10px] bg-slate-100 border border-black/[0.04] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-tr from-black/5 to-transparent rounded-[10px]"></div>
          </div>
          <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-[2.5px] border-white rounded-full z-10"></div>
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0 flex flex-col justify-center">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <h3 class="text-[12.5px] font-bold text-foreground leading-none tracking-tight">{member.name}</h3>
              <span class="px-1.5 py-0.5 rounded-md bg-black/[0.03] border border-black/[0.06] text-[9px] font-bold text-muted-foreground uppercase tracking-tight leading-none">{member.role}</span>
            </div>
            <button class="check-skill-btn flex items-center justify-center w-6 h-6 rounded-full hover:bg-black/[0.04] text-muted-foreground/60 hover:text-foreground transition-all shrink-0" data-member={member.id} title="Crew Skill">
              <i class="ti ti-info-circle text-[13px]"></i>
            </button>
          </div>
          
          <!-- Chat Bubble Status -->
          <div class="bg-[#f8f9fa] rounded-[8px] rounded-tl-none px-3 py-1.5 relative">
            <div class="flex items-center gap-1.5">
              <p class="text-[9.5px] font-medium text-foreground/70 italic leading-relaxed typing-status-text transition-opacity duration-300" data-statuses={JSON.stringify(member.statuses)}>
                {member.statuses[0]}
              </p>
              <div class="gap-0.5 items-center shrink-0 ml-0.5 typing-dots-container hidden">
                <div class="w-1 h-1 bg-muted-foreground/30 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0s"></div>
                <div class="w-1 h-1 bg-muted-foreground/30 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0.2s"></div>
                <div class="w-1 h-1 bg-muted-foreground/30 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0.4s"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Section Header: Recent Projects -->
  <div class="mt-2">
    <div class="flex items-center justify-between px-1 mb-3">
      <h3 class="text-[15px] font-bold text-foreground">Recent Projects</h3>
      <button class="text-[10px] font-medium text-muted-foreground hover:text-foreground tracking-wider transition-colors uppercase">View All</button>
    </div>

    <!-- Horizontal slider -->
    <div class="relative">
      <button id="proj-prev" class="hidden absolute -left-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white border border-black/[0.08] shadow-sm flex items-center justify-center hover:bg-[#f8f9fa] transition-colors">
        <i class="ti ti-chevron-left text-[14px] text-muted-foreground"></i>
      </button>
      <button id="proj-next" class="absolute -right-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 rounded-full bg-white border border-black/[0.08] shadow-sm flex items-center justify-center hover:bg-[#f8f9fa] transition-colors">
        <i class="ti ti-chevron-right text-[14px] text-muted-foreground"></i>
      </button>

      <div id="project-slider" class="flex gap-4 overflow-x-auto pb-6 cursor-grab active:cursor-grabbing px-1 pt-2">
        {recentProjects.map((p) => (
          <div class="group shrink-0 w-[200px] transition-all duration-300 cursor-pointer flex flex-col">
            
            <!-- Card Image Area (Direct) -->
            <div class="relative w-full h-[120px] bg-[#f8f9fb] rounded-[12px] border border-black/[0.03] flex items-center justify-center overflow-hidden mb-3">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-black/[0.02] to-transparent"></div>
              <i class={`ti ${p.icon} text-slate-100 text-[36px] group-hover:scale-110 transition-transform duration-500`}></i>
              
              <!-- Date Badge -->
              <div class="absolute bottom-2 right-2 px-2 py-1 rounded-md bg-white/90 backdrop-blur-sm text-[8px] font-bold text-slate-400 uppercase tracking-wider leading-none shadow-sm">
                {p.date}
              </div>

              <!-- Pagination Dots -->
              <div class="absolute bottom-2.5 left-1/2 -translate-x-1/2 flex gap-1">
                 <div class="w-1.2 h-1.2 rounded-full bg-slate-200"></div>
                 <div class="w-1.2 h-1.2 rounded-full bg-slate-100"></div>
                 <div class="w-1.2 h-1.2 rounded-full bg-slate-100"></div>
              </div>
            </div>

            <!-- Card Info (Direct) -->
            <div class="flex items-center justify-between px-0.5">
              <div class="flex flex-col min-w-0">
                <h4 class="text-[12px] font-bold text-slate-900 truncate tracking-tight leading-tight mb-1">{p.name}</h4>
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-medium text-slate-400 truncate tracking-tight">{p.brand}</span>
                  <span class="w-0.5 h-0.5 rounded-full bg-slate-300"></span>
                  <span class="text-[10px] font-medium text-slate-400 truncate tracking-tight">{p.assets} assets</span>
                </div>
              </div>
              <button class="w-6 h-6 rounded-full bg-black/[0.04] text-black/40 flex items-center justify-center hover:bg-black hover:text-white transition-all shrink-0 ml-2">
                <i class="ti ti-chevron-right text-[12px]"></i>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</div>

<!-- Skill Modal (CV Style) -->
<div id="skill-modal" class="fixed inset-0 z-[100] bg-black/20 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
  <div class="bg-white rounded-[16px] border border-black/[0.08] w-full max-w-[440px] shadow-[0_20px_60px_rgb(0,0,0,0.1)] transform scale-95 transition-transform duration-300 overflow-hidden relative flex flex-col max-h-[90vh]" id="skill-modal-content">
    
    <!-- Close btn -->
    <button id="close-modal" class="absolute top-5 right-5 w-8 h-8 flex items-center justify-center rounded-md hover:bg-black/5 transition-colors z-10">
      <i class="ti ti-x text-foreground"></i>
    </button>
    
    <!-- CV Header -->
    <div class="bg-[#f8f9fa] p-7 border-b border-black/[0.05] flex items-center gap-5 shrink-0">
      <div class="relative w-[84px] h-[84px] rounded-[8px] bg-white border border-black/[0.05] shadow-sm shrink-0">
        <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-emerald-500 border-[3px] border-[#f8f9fa] rounded-full"></div>
      </div>
      <div>
        <h2 id="modal-name" class="text-[20px] font-bold text-foreground leading-none mb-1.5">Name</h2>
        <p id="modal-role" class="text-[14px] font-medium text-muted-foreground">Role</p>
      </div>
    </div>
    
    <!-- Skills -->
    <div class="p-7 overflow-y-auto">
      <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-widest mb-4">Core Competencies</h3>
      <div id="modal-skills" class="flex flex-col gap-2.5">
        <!-- Rendered via JS -->
      </div>
      
      <div class="mt-6 pt-5 border-t border-black/[0.05]">
        <h3 class="text-[11px] font-semibold text-muted-foreground uppercase tracking-widest mb-3">About Crew</h3>
        <p class="text-[12px] text-muted-foreground leading-relaxed">
          AI Crew member dedicated to providing high-quality outputs with rapid turnaround times. Consistently trained on the latest industry standards and brand guidelines to ensure perfect alignment with your creative vision.
        </p>
      </div>
    </div>
    
  </div>
</div>

<!-- Activity Modal (Chat Style) -->
<div id="activity-modal" class="fixed inset-0 z-[100] bg-black/20 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4">
  <div class="bg-white rounded-[16px] border border-black/[0.08] w-full max-w-[480px] shadow-[0_20px_60px_rgb(0,0,0,0.1)] transform scale-95 transition-transform duration-300 overflow-hidden relative flex flex-col max-h-[85vh]" id="activity-modal-content">
    
    <!-- Header -->
    <div class="h-16 px-6 border-b border-black/[0.05] flex items-center justify-between shrink-0 bg-white z-10">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-[#f4f5f7] border border-black/[0.05] flex items-center justify-center text-muted-foreground">
          <i class="ti ti-activity text-[16px]"></i>
        </div>
        <div>
          <h3 class="text-[14px] font-bold text-foreground leading-tight">Activity Log</h3>
          <p class="text-[10px] text-muted-foreground">Real-time crew operations</p>
        </div>
      </div>
      <button id="close-activity-modal" class="w-8 h-8 flex items-center justify-center rounded-md hover:bg-black/5 transition-colors">
        <i class="ti ti-x text-foreground"></i>
      </button>
    </div>

    <!-- Chat-like Body -->
    <div class="flex-1 overflow-y-auto p-6 bg-white" id="activity-chat-body">
      <div class="flex flex-col gap-6">
        {activityHistory.map((log) => (
          <div class="flex items-start gap-4">
            <!-- Avatar Box -->
            <div class="relative w-9 h-9 rounded-[10px] bg-white border border-black/[0.08] shadow-sm shrink-0">
               <div class={`absolute -bottom-1 -right-1 w-3.5 h-3.5 border-[2px] border-white rounded-full ${log.role === 'raka' ? 'bg-emerald-500' : (log.role === 'dina' ? 'bg-blue-500' : 'bg-pink-500')}`}></div>
               <div class={`w-full h-full flex items-center justify-center text-[13px] font-bold ${log.role === 'raka' ? 'text-emerald-700 bg-emerald-50/50' : (log.role === 'dina' ? 'text-blue-700 bg-blue-50/50' : 'text-pink-700 bg-pink-50/50')} rounded-[9px]`}>
                 {log.role.charAt(0).toUpperCase()}
               </div>
            </div>
            
            <!-- Content -->
            <div class="flex flex-col gap-1.5 min-w-0 flex-1 pt-0.5">
              <div class="flex items-center gap-2">
                <span class="text-[12.5px] font-bold text-foreground leading-none">{log.name}</span>
                <span class="text-[10px] text-muted-foreground font-medium leading-none">{log.time}</span>
              </div>
              
              <div class="mt-0.5">
                 <div class="text-[12px] text-foreground/80 leading-relaxed bg-[#f8f9fa] border border-black/[0.04] px-4 py-2.5 rounded-[12px] rounded-tl-[4px] inline-block">
                   {log.text}
                 </div>
              </div>
              
              {log.hasResult && (
                <div class="mt-1 flex">
                  <button class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-black/[0.08] hover:border-black/20 hover:bg-black/[0.02] shadow-[0_2px_8px_rgb(0,0,0,0.02)] rounded-[8px] text-[10.5px] font-bold text-foreground transition-all group">
                    <i class="ti ti-file-search text-muted-foreground group-hover:text-foreground transition-colors text-[14px]"></i>
                    {log.resultLabel}
                  </button>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer Status -->
    <div class="p-4 bg-white border-t border-black/[0.05] text-center shrink-0">
      <p class="text-[10.5px] font-medium text-muted-foreground flex items-center justify-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        Crew instances are active and monitoring queue
      </p>
    </div>

  </div>
</div>

<script define:vars={{ crew }}>
  // Slider logic
  const slider = document.getElementById('project-slider');
  const prevBtn = document.getElementById('proj-prev');
  const nextBtn = document.getElementById('proj-next');
  let isDown = false, startX, scrollLeft;

  if (slider && prevBtn && nextBtn) {
    function updateButtons() {
      if (slider.scrollLeft <= 0) {
        prevBtn.classList.add('hidden');
      } else {
        prevBtn.classList.remove('hidden');
      }
    }

    slider.addEventListener('scroll', updateButtons);
    slider.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - slider.offsetLeft; scrollLeft = slider.scrollLeft; });
    slider.addEventListener('mouseleave', () => isDown = false);
    slider.addEventListener('mouseup', () => isDown = false);
    slider.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      slider.scrollLeft = scrollLeft - (e.pageX - slider.offsetLeft - startX);
    });

    prevBtn.addEventListener('click', () => slider.scrollBy({ left: -200, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => slider.scrollBy({ left: 200, behavior: 'smooth' }));
    updateButtons();
  }

  // Typing Status Logic
  const statusEls = document.querySelectorAll('.typing-status-text');
  statusEls.forEach(el => {
    try {
      const statuses = JSON.parse(el.dataset.statuses);
      let idx = 0;
      const dotsContainer = el.nextElementSibling;
      
      setInterval(() => {
        // Start transition
        el.classList.add('opacity-40');
        dotsContainer.style.display = 'flex';
        
        setTimeout(() => {
          idx = (idx + 1) % statuses.length;
          el.textContent = statuses[idx];
          el.classList.remove('opacity-40');
          dotsContainer.style.display = 'none';
        }, 1500); // Transition duration
        
      }, 5000); // Changes text every 5 seconds
    } catch(e) {}
  });

  // Modal Logic (Skill)
  const skillModal = document.getElementById('skill-modal');
  const skillModalContent = document.getElementById('skill-modal-content');
  const closeSkillBtn = document.getElementById('close-modal');
  const checkBtns = document.querySelectorAll('.check-skill-btn');
  
  const modalName = document.getElementById('modal-name');
  const modalRole = document.getElementById('modal-role');
  const modalSkills = document.getElementById('modal-skills');

  function openSkillModal(memberId) {
    const member = crew.find(c => c.id === memberId);
    if (!member) return;

    modalName.textContent = member.name;
    modalRole.textContent = member.role;
    
    modalSkills.innerHTML = member.skills.map(skill => `
      <div class="flex items-start gap-3 p-3 rounded-[8px] bg-white border border-black/[0.04] shadow-sm">
        <div class="w-8 h-8 rounded-md bg-[#f8f9fa] border border-black/[0.03] flex items-center justify-center shrink-0">
          <i class="ti ${skill.icon} text-[14px] text-foreground"></i>
        </div>
        <div class="min-w-0">
          <h4 class="text-[12.5px] font-bold text-foreground leading-tight mb-0.5">${skill.name}</h4>
          <p class="text-[11px] text-muted-foreground leading-snug">${skill.desc}</p>
        </div>
      </div>
    `).join('');

    skillModal.classList.remove('hidden');
    requestAnimationFrame(() => {
      skillModal.classList.remove('opacity-0');
      skillModalContent.classList.remove('scale-95');
      skillModalContent.classList.add('scale-100');
    });
  }

  function closeSkillModal() {
    skillModal.classList.add('opacity-0');
    skillModalContent.classList.remove('scale-100');
    skillModalContent.classList.add('scale-95');
    setTimeout(() => {
      skillModal.classList.add('hidden');
    }, 300);
  }

  // Activity Modal Logic
  const activityModal = document.getElementById('activity-modal');
  const activityModalContent = document.getElementById('activity-modal-content');
  const btnViewActivity = document.getElementById('btn-view-activity');
  const closeActivityBtn = document.getElementById('close-activity-modal');

  function openActivityModal() {
    activityModal.classList.remove('hidden');
    requestAnimationFrame(() => {
      activityModal.classList.remove('opacity-0');
      activityModalContent.classList.remove('scale-95');
      activityModalContent.classList.add('scale-100');
      
      const chatBody = document.getElementById('activity-chat-body');
      if(chatBody) {
         chatBody.scrollTop = chatBody.scrollHeight;
      }
    });
  }

  function closeActivityModal() {
    activityModal.classList.add('opacity-0');
    activityModalContent.classList.remove('scale-100');
    activityModalContent.classList.add('scale-95');
    setTimeout(() => {
      activityModal.classList.add('hidden');
    }, 300);
  }

  checkBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      openSkillModal(e.currentTarget.dataset.member);
    });
  });

  closeSkillBtn?.addEventListener('click', closeSkillModal);
  skillModal?.addEventListener('click', (e) => {
    if (e.target === skillModal) closeSkillModal();
  });

  btnViewActivity?.addEventListener('click', openActivityModal);
  closeActivityBtn?.addEventListener('click', closeActivityModal);
  activityModal?.addEventListener('click', (e) => {
    if (e.target === activityModal) closeActivityModal();
  });

</script>
