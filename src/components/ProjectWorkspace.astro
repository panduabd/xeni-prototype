            <div class="${bubbleClass} flex items-center gap-2">
              ${isMain ? `<span class="typing-text italic font-medium">Memulai proses...</span>` : ""}
              <div class="flex gap-1 items-center ${isMain ? "ml-1" : ""}">
                <div class="w-1.5 h-1.5 bg-foreground/40 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0s"></div>
                <div class="w-1.5 h-1.5 bg-foreground/40 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0.2s"></div>
                <div class="w-1.5 h-1.5 bg-foreground/40 rounded-full animate-bounce" style="animation-duration: 1s; animation-delay: 0.4s"></div>
              </div>
            </div>
          </div>
        </div>
      `;

      container.insertAdjacentHTML("beforeend", html);
      container.scrollTop = container.scrollHeight;

      const bubbleEl = document.getElementById(id);
      const textEl = bubbleEl?.querySelector(".typing-text");

      // Only cycle status text in main chat, not in group
      let cycleInterval = null;
      if (isMain && textEl) {
        let statuses = [];
        if (role === "raka") {
          statuses = [
            "Menganalisis konteks...",
            "Menyusun instruksi...",
            "Menulis respons...",
          ];
        } else if (role === "dina") {
          statuses = [
            "Membaca brief...",
            "Meracik copywriting...",
            "Memfinalisasi teks...",
          ];
        } else {
          statuses = [
            "Memproses visual...",
            "Merender layer...",
            "Menyimpan aset...",
          ];
        }

        let sIdx = 0;
        textEl.textContent = statuses[0];

        cycleInterval = setInterval(() => {
          sIdx = (sIdx + 1) % statuses.length;
          if (textEl) textEl.textContent = statuses[sIdx];
        }, 700);
      }

      setTimeout(() => {
        clearInterval(cycleInterval);
        if (bubbleEl) bubbleEl.remove();
        onComplete();
      }, 2200);
    }

    const runSeq = (steps, index = 0) => {
      if (index >= steps.length) return;
      const step = steps[index];

      const executeStep = () => {
        if (step.layer === "main") {
          addMainMessage(step.role, step.text, step.action);

          if (step.action === "analysis") {
            // Wait for user to respond before showing format selection
            const wsInput = document.querySelector("#ws-ai-input textarea");
            const wsSubmit =
              document.querySelector("#ws-ai-input .submit-btn") ||
              document.querySelector('#ws-ai-input button[type="submit"]');

            const handleUserResponse = () => {
              const userText = wsInput?.value?.trim() || "Oke, lanjut!";
              if (wsInput) wsInput.value = "";
              addMainMessage("user", userText);
              runSeq(sequencePart1b, 0);
            };

            // Listen for Enter key on textarea
            const keyHandler = (e) => {
              if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                handleUserResponse();
                wsInput?.removeEventListener("keydown", keyHandler);
              }
            };
            wsInput?.addEventListener("keydown", keyHandler);

            // Also listen for submit button click
            const allBtns = document.querySelectorAll("#ws-ai-input button");
            allBtns.forEach((btn) => {
              btn.addEventListener(
                "click",
                (e) => {
                  e.preventDefault();
                  handleUserResponse();
                  wsInput?.removeEventListener("keydown", keyHandler);
                },
                { once: true },
              );
            });
            return;
          }
          if (step.action === "format-selection") {
            const btns = document.querySelectorAll(".ws-btn-format");
            btns.forEach((btn) => {
              btn.addEventListener(
                "click",
                (e) => {
                  const format = e.target.dataset.format;
                  addMainMessage("user", `Saya pilih format ${format}`);
                  runSeq(sequencePart2, 0);
                },
                { once: true },
              );
            });
            return;
          }
          if (step.action === "headline-options") {
            const btns = document.querySelectorAll(".ws-btn-option-v2");
            btns.forEach((btn) => {
              btn.addEventListener(
                "click",
                (e) => {
                  const target = e.currentTarget;
                  const val = target.dataset.val;

                  btns.forEach((b) => {
                    const bEl = b;
                    const labelCat = bEl.querySelector(".label-cat");
                    const headlineText = bEl.querySelector(".headline-text");
                    const checkIcon = bEl.querySelector(".check-icon");

                    if (bEl === target) {
                      labelCat.classList.remove("text-muted-foreground");
                      labelCat.classList.add("text-foreground");
                      headlineText.classList.remove("text-muted-foreground/60");
                      headlineText.classList.add("text-foreground/80");
                      checkIcon.classList.remove("opacity-0");
                      checkIcon.classList.add("opacity-100");
                    } else {
                      bEl.style.opacity = "0.35";
                      bEl.style.pointerEvents = "none";
                    }
                  });

                  setTimeout(() => {
                    addMainMessage("user", `Saya pilih tipe ${val}`);
                    runSeq(sequencePart3, 0);
                  }, 600);
                },
                { once: true },
              );
            });
            return;
          }
          if (step.action === "plan-concept") {
            const btn = document.querySelector(".ws-btn-confirm");
            if (btn)
              btn.addEventListener(
                "click",
                () => {
                  addMainMessage("user", "Mantap! Eksekusi sekarang.");
                  runSeq(sequencePart4, 0);
                },
                { once: true },
              );
            return;
          }
          if (step.action === "check-design") {
            const btn = document.querySelector(".ws-btn-open-canvas");
            if (btn)
              btn.addEventListener("click", () => {
                openCanvas();
              });
          }
          if (step.action === "delivery-result") {
            // Star rating interactions
            document.querySelectorAll(".ti-star-filled").forEach((star) => {
              star.addEventListener("click", (e) => {
                e.stopPropagation();
                const allStars =
                  e.currentTarget.parentElement.querySelectorAll(
                    ".ti-star-filled",
                  );
                const clickedIndex = Array.from(allStars).indexOf(
                  e.currentTarget,
                );
                allStars.forEach((s, idx) => {
                  if (idx <= clickedIndex) {
                    s.classList.remove("text-black/15");
                    s.classList.add("text-amber-400");
                  } else {
                    s.classList.add("text-black/15");
                    s.classList.remove("text-amber-400");
                  }
                });
              });
            });

            // Canvas open handler
            document.querySelectorAll(".ws-btn-open-canvas").forEach((btn) => {
              btn.addEventListener("click", (e) => {
                e.stopPropagation();
                openCanvas();
              });
            });
          }
        } else if (step.layer === "group") {
          addGroupMessage(step.role, step.text);
        }

        runSeq(steps, index + 1);
      };

      if (step.role !== "user") {
        // Typing animation overrides default step delay
        showTyping(step.layer, step.role, executeStep);
      } else {
        seqTimer = setTimeout(executeStep, step.delay);
      }
    };

    // Sequences Definitions
    const sequencePart1 = [
      {
        delay: 400,
        layer: "main",
        role: "user",
        text: "bikin promo jus mangga buat anak nongkrong yak",
      },
      // Backstage: crew gets notified and starts prepping
      {
        delay: 0,
        layer: "group",
        role: "raka",
        text: `Heads up tim! Ada brief masuk dari bos. Saya analisa dulu ya, kalian standby. 📋`,
      },
      {
        delay: 0,
        layer: "group",
        role: "luna",
        text: "Noted, Raka. Copywriting engine warming up... ✍️",
      },
      {
        delay: 0,
        layer: "group",
        role: "vesna",
        text: "Siap! Canvas & design tools ready to go. 🎨",
      },
      // Main chat: Raka delivers analysis
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Baik, saya sudah menganalisa brief Anda secara menyeluruh. Berikut temuan saya:

<div class="mt-3 space-y-2">
  <div class="flex items-start gap-2">
    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-1.5 shrink-0"></div>
    <p class="text-[13px] text-foreground/80"><strong>Objective:</strong> Social media promotion untuk produk minuman — ini cocok untuk pendekatan visual-first dengan warna cerah dan energik.</p>
  </div>
  <div class="flex items-start gap-2">
    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-1.5 shrink-0"></div>
    <p class="text-[13px] text-foreground/80"><strong>Target Audience:</strong> Gen-Z / anak nongkrong — artinya tone-of-voice harus kasual, menggunakan bahasa sehari-hari, dan hindari kesan terlalu formal atau korporat.</p>
  </div>
  <div class="flex items-start gap-2">
    <div class="w-1.5 h-1.5 rounded-full bg-amber-500 mt-1.5 shrink-0"></div>
    <p class="text-[13px] text-foreground/80"><strong>Yang belum ada:</strong> Belum ada informasi format spesifik (feed, story, carousel?) dan belum ditentukan gaya headline yang diinginkan. Saya akan bantu tentukan ini di langkah selanjutnya.</p>
  </div>
</div>

<p class="mt-3 text-[13px] text-foreground/70">Ada tambahan konteks atau preferensi lain sebelum kita lanjut ke pemilihan format?</p>`,
        action: "analysis",
      },
    ];

    // Part 1b: After user responds to analysis, show format selection
    const sequencePart1b = [
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Baik, noted! Sekarang saya perlu tahu preferensi format konten Anda. Masing-masing format punya kelebihan tersendiri — <strong>Portrait 3:4</strong> optimal untuk feed Instagram, <strong>Square 1:1</strong> fleksibel untuk berbagai platform, dan <strong>Story 9:16</strong> cocok untuk reach yang lebih luas via story/reels. Silakan pilih yang paling sesuai:`,
        action: "format-selection",
      },
    ];

    const sequencePart2 = [
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Pilihan format yang bagus! Saya sudah menginstruksikan <strong>@Dina</strong> untuk menyiapkan beberapa alternatif headline berdasarkan analisis brief tadi. Dina sudah melakukan riset persona audiens dan menghasilkan 3 pendekatan berbeda — masing-masing dengan tone dan strategi persuasi yang unik.

<div class="mt-2 text-[12.5px] text-foreground/60 italic">Catatan: Headline yang Anda pilih nanti akan menjadi acuan utama bagi Bima untuk membangun hierarki visual pada desain akhir.</div>`,
      },
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: "Berikut 3 opsi headline dari Dina. Setiap opsi sudah disesuaikan dengan persona target (Gen-Z, kasual, energik). Pilih salah satu yang paling resonan dengan brand Anda:",
        action: "headline-options",
      },
    ];

    const sequencePart3 = [
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Sangat setuju dengan pilihan Anda — pendekatan ini akan memberikan impact yang kuat untuk audiens muda.

Saya sudah menyusun <strong>Project Plan</strong> yang menjabarkan semua deliverable dan resource yang akan digunakan. Berikut yang akan dikerjakan tim:
<div class="mt-2 space-y-1.5">
  <p class="text-[13px] text-foreground/80">• <strong>Dina (Copywriter)</strong> akan memfinalisasi headline, body copy, hashtag, dan CTA berdasarkan pilihan Anda tadi.</p>
  <p class="text-[13px] text-foreground/80">• <strong>Bima (Designer)</strong> akan merender visual menggunakan Brand DNA yang terdaftar, termasuk color palette dan typography guideline.</p>
  <p class="text-[13px] text-foreground/80">• Saya akan mengawasi koordinasi dan quality assurance sebelum hasil dikirimkan ke Anda.</p>
</div>`,
      },
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Jika semua sudah sesuai, klik tombol di bawah untuk memulai eksekusi proyek. Setelah konfirmasi, Anda bisa memantau progress tim secara real-time di panel <strong>Backstage</strong> sebelah kanan.`,
        action: "plan-concept",
      },
    ];

    const sequencePart4 = [
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Proyek sudah berjalan! Saya sedang mendistribusikan tugas ke setiap anggota kru. Anda bisa melihat koordinasi internal mereka di panel <strong>Backstage</strong> di sebelah kanan — semua berjalan transparan.`,
      },
      {
        delay: 0,
        layer: "group",
        role: "raka",
        text: `Tim! Bos sudah <b>Confirm</b> projectnya. Berikut briefing lengkap:

<div class="mt-1.5 space-y-1">
<p>📌 <b>Produk:</b> Jus Mangga — promo diskon</p>
<p>🎯 <b>Audience:</b> Gen-Z, casual tone</p>
<p>📐 <b>Format:</b> Portrait 3:4</p>
</div>

@Dina siapkan copy final sesuai headline yang dipilih, @Bima langsung eksekusi visualnya. Let's go! 🚀`,
      },
      {
        delay: 0,
        layer: "group",
        role: "dina",
        text: `Siap Raka! Brief sudah saya terima. Saya mulai finalisasi:

✍️ Headline → sesuai pilihan bos
✍️ Body copy → persuasif, kasual, ada urgency
✍️ Hashtags → riset trending + brand-relevant
✍️ CTA → "Pesan sekarang" variant

Estimasi selesai dalam beberapa menit...`,
      },
      {
        delay: 0,
        layer: "group",
        role: "bima",
        text: `Canvas ready, Raka! Saya breakdown eksekusinya:

🎨 Color palette → warm tones (amber, orange) sesuai Brand DNA
📐 Layout → portrait 3:4, hero image top, text bottom
🔤 Typography → bold headline, supporting text lebih kecil
📸 Image treatment → gradient overlay untuk depth

Mulai rendering sekarang... ⏳`,
      },
      {
        delay: 0,
        layer: "group",
        role: "dina",
        text: "Copy sudah selesai! Headline, body, dan hashtags sudah di-finalize. Passing ke Bima untuk integrasi ke visual. ✅",
      },
      {
        delay: 0,
        layer: "group",
        role: "bima",
        text: "Copy sudah terintegrasi ke layout. Rendering final asset... hampir selesai! 🎨",
      },
      {
        delay: 0,
        layer: "group",
        role: "bima",
        text: "Done! ✅ Visual sudah dipublikasikan dan siap direview oleh bos.",
      },
      {
        delay: 0,
        layer: "group",
        role: "raka",
        text: "QA check selesai — semua output memenuhi standar kualitas. Mengirim hasil ke bos sekarang. 📤",
      },
      {
        delay: 0,
        layer: "main",
        role: "raka",
        text: `Selesai! 🎉 Tim sudah menyelesaikan semua deliverable untuk proyek promo jus mangga Anda.

<div class="mt-2 space-y-1.5">
  <p class="text-[13px] text-foreground/80">✅ <strong>Visual asset</strong> — desain portrait 3:4 dengan tema warm tropical, siap export dalam high-resolution.</p>
  <p class="text-[13px] text-foreground/80">✅ <strong>Copywriting</strong> — headline, body copy, hashtags, dan CTA sudah dioptimasi untuk engagement Gen-Z.</p>
  <p class="text-[13px] text-foreground/80">✅ <strong>Brand compliance</strong> — semua elemen sudah dicek kesesuaiannya dengan Brand DNA yang terdaftar.</p>
</div>

<p class="mt-2 text-[13px] text-foreground/80">Silakan review hasil di bawah ini. Anda bisa klik pada visual untuk membuka <strong>Canvas Editor</strong> dan melakukan edit lebih lanjut jika diperlukan. Gunakan rating bintang untuk memberikan feedback pada output ini.</p>`,
        action: "delivery-result",
      },
    ];

    // Begin part 1
    runSeq(sequencePart1, 0);
  };
</script>
