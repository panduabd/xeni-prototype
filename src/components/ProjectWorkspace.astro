---
// ProjectWorkspace.astro
---

<!-- BENTO BOX LAYOUT FOR ACTIVE WORKSPACE -->
<div class="flex h-full w-full overflow-hidden gap-3">
  
  <!-- LEFT: MAIN DIRECT CHAT (User & Raka) -->
  <div class="flex-1 min-w-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col h-full overflow-hidden relative z-10">
    
    <!-- Chat Header -->
    <div class="h-14 px-5 border-b border-black/[0.06] flex items-center gap-3 shrink-0 bg-white/80 backdrop-blur-sm z-20">
      <div class="w-8 h-8 rounded-full bg-[#f0f0f0] border border-black/[0.08] flex items-center justify-center text-[12px] font-bold text-foreground">R</div>
      <div class="flex-1 min-w-0">
        <h3 class="text-[13px] font-semibold text-foreground leading-tight">Raka</h3>
        <span class="text-[10px] text-emerald-600 font-medium flex items-center gap-1.5 mt-0.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Online
        </span>
      </div>
    </div>
    
    <!-- Main Chat List -->
    <div id="main-chat-container" class="flex-1 overflow-y-auto px-5 py-6 flex flex-col gap-5">
      <!-- Injected by JS -->
    </div>

    <!-- CHAT & INPUT SECTION (Identical to Studio ChatPanel) -->
    <div class="w-full flex flex-col gap-3 shrink-0 z-10 p-6 pt-0">

      <!-- Top Context Row: Brand DNA + Image reference -->
      <div class="flex items-center gap-2 mb-1">

        <!-- Brand DNA Picker -->
        <button class="inline-flex items-center gap-1.5 h-7 px-3 rounded-full bg-white border border-black/[0.08] hover:border-black/[0.15] text-foreground/70 text-[10.5px] font-bold transition-all shadow-[0_2px_8px_rgb(0,0,0,0.02)]">
          <i class="ti ti-dna-2 text-[12px] text-muted-foreground/60"></i>
          <span class="tracking-tight">Brand DNA</span>
          <i class="ti ti-chevron-down text-[10px] text-muted-foreground/40 ml-0.5"></i>
        </button>

        <!-- Image ref badge -->
        <div class="inline-flex items-center gap-1.5 h-7 pl-1.5 pr-2 rounded-full bg-white border border-black/[0.08] shadow-[0_2px_8px_rgb(0,0,0,0.03)] transition-all hover:border-black/[0.15]">
          <div class="w-4.5 h-4.5 rounded-full bg-black/[0.04] flex items-center justify-center shrink-0">
            <i class="ti ti-photo text-[11px] text-muted-foreground opacity-70"></i>
          </div>
          <span class="text-[10.5px] font-bold text-foreground/60 tracking-tight">product.jpg</span>
          <button class="w-4 h-4 rounded-full flex items-center justify-center hover:bg-red-50 hover:text-red-500 text-muted-foreground/40 transition-all ml-0.5">
            <i class="ti ti-x text-[9px]"></i>
          </button>
        </div>

      </div>

      <!-- AI Input -->
      <div class="bg-white rounded-[22px] border border-black/[0.06] flex flex-col focus-within:border-[#7185ff]/30 transition-all p-5 relative shadow-[0_2px_16px_rgb(0,0,0,0.04)] focus-within:shadow-[0_8px_32px_rgb(0,0,0,0.08)]">
        
        <textarea 
          id="ws-prompt-input"
          rows="1"
          class="w-full text-[14px] font-medium text-foreground bg-transparent placeholder:text-muted-foreground/45 focus:outline-none resize-none pt-1 pb-6 leading-relaxed"
          placeholder="Ask Raka to create new projects..."
          style="min-height: 52px;"
        ></textarea>
        
        <div class="flex items-center justify-between relative z-20">
          
          <div class="flex items-center gap-2">
            
            <!-- Add Reference -->
            <button class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[7px] bg-white border border-black/[0.08] hover:border-black/[0.16] text-foreground transition-all text-left">
              <i class="ti ti-plus text-[12px] text-muted-foreground"></i>
              <span class="text-[11px] font-semibold">Add Reference</span>
            </button>

            <!-- Select Format -->
            <button class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[7px] bg-white border border-black/[0.08] hover:border-black/[0.16] text-foreground transition-all">
              <i class="ti ti-layout-board-split text-[12px] text-emerald-600"></i>
              <span class="text-[11px] font-semibold">Select Format</span>
            </button>

          </div>

          <button id="ws-btn-send" class="w-8 h-8 rounded-[8px] bg-foreground hover:bg-black flex items-center justify-center text-white transition-all shrink-0">
            <i class="ti ti-arrow-up text-[15px]"></i>
          </button>
        </div>

      </div>

      <!-- Feature Reference Cards -->
      <div class="grid grid-cols-2 gap-2 mt-1">
        <!-- Card 1 -->
        <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f4f5f7] hover:bg-[#ecedf2] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
          <div class="relative z-10 w-full pr-10">
            <div class="flex items-center gap-1.5 mb-0.5">
               <span class="feature-title text-[12px] font-bold text-foreground">Single Feed</span>
               <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors"></i>
            </div>
            <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">Desain 1:1 statis untuk post</p>
          </div>
          <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
             <i class="ti ti-square text-[20px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors"></i>
          </div>
        </button>
        <!-- Card 2 -->
        <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f4f5f7] hover:bg-[#ecedf2] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
          <div class="relative z-10 w-full pr-10">
            <div class="flex items-center gap-1.5 mb-0.5">
               <span class="feature-title text-[12px] font-bold text-foreground">Carousel</span>
               <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors"></i>
            </div>
            <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">Konten multi-slide interaktif</p>
          </div>
          <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
             <i class="ti ti-carousel-horizontal text-[20px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors"></i>
          </div>
        </button>
        <!-- Card 3 -->
        <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f4f5f7] hover:bg-[#ecedf2] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
          <div class="relative z-10 w-full pr-10">
            <div class="flex items-center gap-1.5 mb-0.5">
               <span class="feature-title text-[12px] font-bold text-foreground">Story</span>
               <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors"></i>
            </div>
            <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">Format 9:16 layar penuh</p>
          </div>
          <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
             <i class="ti ti-device-mobile text-[20px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors"></i>
          </div>
        </button>
        <!-- Card 4 -->
        <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f4f5f7] hover:bg-[#ecedf2] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
          <div class="relative z-10 w-full pr-10">
            <div class="flex items-center gap-1.5 mb-0.5">
               <span class="feature-title text-[12px] font-bold text-foreground">Banner</span>
               <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors"></i>
            </div>
            <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">Grafis lanskap promosi</p>
          </div>
          <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
             <i class="ti ti-rectangle text-[20px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors"></i>
          </div>
        </button>
      </div>

    </div>
  </div>

  <!-- RIGHT PANEL: Split Bento Box -->
  <div class="w-[340px] xl:w-[380px] shrink-0 h-full overflow-hidden flex flex-col gap-3">
    
    <!-- TOP WIDGET: Crew Backstage / Live Canvas -->
    <div class="flex-[3] min-h-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col overflow-hidden relative">
      
    <!-- CREW BACKSTAGE (WhatsApp Style) - Always visible by default -->
    <div id="ws-crew-backstage" class="w-full h-full flex flex-col bg-[#eef1f6]">
      <!-- Header WA Style -->
      <div class="h-14 px-5 bg-white border-b border-black/[0.06] flex items-center justify-between shrink-0 shadow-sm z-10">
        <div class="flex items-center gap-3">
          <!-- Stacked avatars -->
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full border-2 border-white bg-[#f0f0f0] flex items-center justify-center text-[11px] font-bold z-30 shadow-sm">R</div>
            <div class="w-8 h-8 rounded-full border-2 border-white bg-blue-50 flex items-center justify-center text-[11px] font-bold z-20 shadow-sm text-blue-600">L</div>
            <div class="w-8 h-8 rounded-full border-2 border-white bg-pink-50 flex items-center justify-center text-[11px] font-bold z-10 shadow-sm text-pink-600">V</div>
          </div>
          <div>
            <h3 class="text-[13px] font-bold text-foreground leading-tight">Summer Campaign Crew</h3>
            <p class="text-[10px] text-muted-foreground mt-0.5">Raka, Luna, Vesna</p>
          </div>
        </div>
        <button class="w-8 h-8 rounded-full hover:bg-black/5 flex items-center justify-center text-muted-foreground">
          <i class="ti ti-info-circle text-[16px]"></i>
        </button>
      </div>
      
      <!-- Internal Chat History -->
      <div id="crew-chat-container" class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-3" style="background-image: radial-gradient(circle, #000000 0.5px, transparent 0.5px); background-size: 16px 16px; background-color: #fafbfc;">
        <!-- Secure Enclave badge -->
        <div class="flex justify-center mb-4">
          <div class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]">
             <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
               <i class="ti ti-lock text-[10px] mr-1"></i>
               Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru AI.
             </p>
          </div>
        </div>
        <!-- Injected by JS -->
      </div>
    </div>
    </div>

    <!-- BOTTOM WIDGET: Project History -->
    <div class="flex-[2] min-h-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col overflow-hidden">
      <div class="h-10 px-4 border-b border-black/[0.06] flex items-center justify-between shrink-0 bg-[#fafbfd]">
        <h4 class="text-[11px] font-bold tracking-tight text-foreground uppercase">Project History</h4>
      </div>
      <div class="flex-1 overflow-y-auto px-4 py-3 flex flex-col gap-2">
        <!-- Auto populated by generation -->
        <div class="p-2 border border-black/[0.06] rounded-[8px] flex items-center gap-3 hover:bg-[#fafbfd] transition-colors cursor-pointer group">
          <div class="w-8 h-8 rounded shrink-0 bg-[#f4f5f7] flex items-center justify-center text-muted-foreground"><i class="ti ti-photo"></i></div>
          <div class="flex-1 min-w-0">
             <p class="text-[11px] font-bold text-foreground truncate">Previous_Generated_IMG_1.png</p>
             <p class="text-[9px] text-muted-foreground">Yesterday • Created by Vesna</p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <button class="flex items-center text-muted-foreground hover:text-foreground transition-colors" title="View"><i class="ti ti-eye text-[12px]"></i></button>
            <button class="flex items-center text-muted-foreground hover:text-foreground transition-colors" title="Download"><i class="ti ti-download text-[12px]"></i></button>
          </div>
        </div>
        <div class="p-2 border border-black/[0.06] rounded-[8px] flex items-center gap-3 hover:bg-[#fafbfd] transition-colors cursor-pointer group">
          <div class="w-8 h-8 rounded shrink-0 bg-[#f4f5f7] flex items-center justify-center text-muted-foreground"><i class="ti ti-file-text"></i></div>
          <div class="flex-1 min-w-0">
             <p class="text-[11px] font-bold text-foreground truncate">Copywriting_Draft.txt</p>
             <p class="text-[9px] text-muted-foreground">Yesterday • Created by Luna</p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <button class="flex items-center text-muted-foreground hover:text-foreground transition-colors" title="View"><i class="ti ti-eye text-[12px]"></i></button>
            <button class="flex items-center text-muted-foreground hover:text-foreground transition-colors" title="Download"><i class="ti ti-download text-[12px]"></i></button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- FULLSCREEN CANVAS OVERLAY -->
<div id="ws-live-canvas" class="hidden fixed inset-0 z-[100] bg-white flex flex-col">
  <!-- Canvas Header -->
  <div class="h-14 border-b border-black/[0.06] px-5 flex items-center justify-between shrink-0 z-10 shadow-sm bg-white">
    <div class="flex items-center gap-3">
      <button id="btn-close-canvas" class="flex items-center gap-1.5 h-7 px-2.5 rounded-md hover:bg-black/5 text-muted-foreground hover:text-foreground transition-colors font-medium text-[11px]">
        <i class="ti ti-arrow-left text-[14px]"></i> Back to Project
      </button>
      <div class="w-px h-4 bg-black/[0.1] mx-1"></div>
      <h4 class="text-[13px] font-bold tracking-tight text-foreground">Canvas Editor</h4>
      <span class="text-[9.5px] px-2 py-0.5 bg-[#f4f5f7] text-foreground font-semibold rounded-full border border-black/[0.05]">Instagram Post</span>
    </div>
    <div class="flex gap-2">
      <button class="h-7 px-3 rounded-md bg-[#111] text-[11px] font-semibold text-white hover:bg-black transition-colors shadow-sm flex items-center gap-1.5">
        <i class="ti ti-download text-[13px]"></i>
        Download
      </button>
    </div>
  </div>
  
  <!-- Canvas Body -->
  <div class="flex-1 bg-[#f0f1f3] flex items-center justify-center p-8 relative overflow-hidden" style="background-image: radial-gradient(circle, #d1d5db 0.8px, transparent 0.8px); background-size: 20px 20px;">
    <div class="w-[500px] h-[500px] bg-white shadow-xl rounded-[16px] overflow-hidden border border-black/[0.05] flex flex-col hover:shadow-2xl transition-shadow cursor-crosshair">
      <div class="h-[280px] bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center relative group">
        <i class="ti ti-photo text-[64px] text-white opacity-40"></i>
        <!-- selection outline mock -->
        <div class="absolute inset-0 border-2 border-blue-500 opacity-0 group-hover:opacity-100 z-10 flex items-start justify-end p-2 pointer-events-none">
          <span class="bg-blue-500 text-white text-[10px] font-bold px-2 py-1 rounded-sm">Image Layer</span>
        </div>
      </div>
      <div class="flex-1 p-8 flex flex-col justify-center relative group">
        <div class="w-12 h-1.5 bg-black/80 mb-4 rounded-full"></div>
        <h3 class="text-[36px] font-extrabold text-[#111] leading-none mb-2 tracking-tight">MANGO<br>MADNESS 🍹</h3>
        <p class="text-[16px] font-semibold text-foreground/60 leading-tight">Diskon 20% khusus hari ini!</p>
        
        <div class="absolute inset-0 border-2 border-blue-500 opacity-0 group-hover:opacity-100 z-10 flex items-start justify-end p-2 pointer-events-none">
          <span class="bg-blue-500 text-white text-[10px] font-bold px-2 py-1 rounded-sm">Text Layer</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Base animation tools */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .animate-slide-up { animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-fade-in { animation: fadeIn 0.3s ease forwards; }

  /* Chat Bubble Scopes */
  .chat-bubble-main {
    max-width: 85%;
    width: fit-content;
  }
  
  .chat-bubble-wa {
    max-width: 75%;
    width: fit-content;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
</style>

<script>
  // DOM Elements
  const containerMain = document.getElementById('main-chat-container');
  const containerGroup = document.getElementById('crew-chat-container');

  const stateBackstage = document.getElementById('ws-crew-backstage');
  const stateCanvas = document.getElementById('ws-live-canvas');
  const btnCloseCanvas = document.getElementById('btn-close-canvas');

  btnCloseCanvas?.addEventListener('click', () => {
    stateCanvas.classList.add('hidden');
  });

  // Helpers
  function openCanvas() {
    stateCanvas.classList.remove('hidden');
    stateCanvas.classList.add('animate-fade-in');
  }

  // Add initial welcome messages to crew group
  function addCrewWelcome() {
    const secBadge = `<div class="flex justify-center mb-4">
      <div class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]">
        <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
          <i class="ti ti-lock text-[10px] mr-1"></i>
          Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru AI.
        </p>
      </div>
    </div>`;
    containerGroup.innerHTML = secBadge;
  }

  // --- Templates ---
  
  function getAvatar(role) {
    if(role === 'user') return '';
    const initial = role.charAt(0).toUpperCase();
    let bg = 'bg-[#f0f0f0] border-black/[0.08] text-foreground';
    if(role === 'luna') bg = 'bg-blue-50 border-blue-100 text-blue-700';
    if(role === 'vesna') bg = 'bg-pink-50 border-pink-100 text-pink-700';
    
    return `<div class="w-6 h-6 rounded-full border ${bg} flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5 shadow-sm">${initial}</div>`;
  }

  function addMainMessage(role, text, withAction = null) {
    const isUser = role === 'user';
    const alignClass = isUser ? 'self-end' : 'self-start';
    const layoutClass = isUser ? 'flex-row-reverse' : 'flex-row';
    const bubbleClass = isUser 
      ? 'bg-[#111] text-white rounded-[16px] rounded-tr-[4px] px-4 py-2.5 text-[12.5px] leading-relaxed shadow-sm'
      : 'bg-white border border-black/[0.06] text-foreground rounded-[16px] rounded-tl-[4px] px-4 py-2.5 text-[12.5px] leading-relaxed shadow-[0_2px_8px_rgb(0,0,0,0.02)]';
    
    let actionHtml = '';
    if (withAction === 'acc-brief') {
      actionHtml = `
        <div class="mt-3 flex gap-2 w-full justify-end">
          <button class="ws-btn-acc-brief px-4 py-1.5 rounded-full bg-emerald-50 text-emerald-600 border border-emerald-200 text-[11px] font-bold hover:bg-emerald-100 transition-colors shadow-sm">Ya, Lanjut!</button>
        </div>
      `;
    } else if (withAction === 'acc-copy') {
      actionHtml = `
        <div class="mt-3 flex gap-2 w-full justify-end">
          <button class="ws-btn-acc-copy px-4 py-1.5 rounded-full bg-emerald-50 text-emerald-600 border border-emerald-200 text-[11px] font-bold hover:bg-emerald-100 transition-colors shadow-sm">Pilih Opsi A</button>
        </div>
      `;
    } else if (withAction === 'check-design') {
      actionHtml = `
        <div class="mt-3 w-[240px] rounded-xl overflow-hidden border border-black/[0.08] bg-white group cursor-pointer shadow-sm ws-btn-open-canvas">
          <div class="h-[120px] bg-gradient-to-br from-amber-400 to-orange-500 relative flex items-center justify-center">
            <h3 class="text-[18px] font-bold text-[#111]">MANGO 🍹</h3>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 px-3 py-1.5 bg-white text-black text-[11px] font-bold rounded-full shadow-lg transition-all transform scale-95 group-hover:scale-100 flex items-center gap-1.5">
                <i class="ti ti-pencil"></i> Edit Manual
              </span>
            </div>
          </div>
          <div class="p-2.5 flex items-center justify-between bg-white border-t border-black/[0.05]">
             <span class="text-[11px] font-bold text-foreground">Summer_Mango_Final.fig</span>
          </div>
        </div>
      `;
    }

    const html = `
      <div class="flex gap-2.5 w-full chat-bubble-main animate-slide-up ${alignClass} ${layoutClass} opacity-0" style="animation-delay: 0.1s">
        ${!isUser ? getAvatar('raka') : ''}
        <div class="flex flex-col ${isUser ? 'items-end' : 'items-start'} max-w-[85%]">
          <div class="${bubbleClass}">
            ${text}
          </div>
          ${actionHtml}
        </div>
      </div>
    `;
    containerMain.insertAdjacentHTML('beforeend', html);
    containerMain.scrollTop = containerMain.scrollHeight;
  }

  function addGroupMessage(role, text) {
    const isRaka = role === 'raka';
    const alignClass = isRaka ? 'self-end' : 'self-start';
    const layoutClass = isRaka ? 'flex-row-reverse' : 'flex-row';
    const nameColor = role === 'luna' ? 'text-blue-600' : (role === 'vesna' ? 'text-pink-600' : 'text-emerald-600');
    
    // WA Style Bubbles
    const bubbleBg = isRaka 
      ? 'bg-[#e7fed2] border-[#cbedaf]' 
      : 'bg-white border-black/[0.05]';
    
    const time = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

    const html = `
      <div class="flex gap-2 w-full chat-bubble-wa animate-slide-up ${alignClass} ${layoutClass} opacity-0" style="animation-delay: 0.1s">
        ${getAvatar(role)}
        <div class="flex flex-col">
          <div class="rounded-[12px] px-3 py-2 border ${bubbleBg} shadow-sm relative text-[12px] text-foreground leading-snug">
            ${!isRaka ? `<div class="font-bold text-[10px] mb-0.5 ${nameColor} capitalize">${role}</div>` : ''}
            <div>${text}</div>
            <div class="text-[9px] text-muted-foreground/60 w-full text-right mt-1 ml-2 inline-flex items-center gap-0.5 justify-end">
              ${time} ${isRaka ? '<i class="ti ti-check-all text-blue-500"></i>' : ''}
            </div>
          </div>
        </div>
      </div>
    `;
    containerGroup.insertAdjacentHTML('beforeend', html);
    containerGroup.scrollTop = containerGroup.scrollHeight;
  }

  // Initialize crew welcome messages (must be after addGroupMessage is defined)
  addCrewWelcome();
  addGroupMessage('raka', 'Halo tim! 👋 Standby ya, menunggu instruksi dari bos.');
  addGroupMessage('luna', 'Siap, Raka! Copywriting engine ready. ✍️');
  addGroupMessage('vesna', 'Canvas loaded, tinggal tunggu brief. 🎨');

  // --- Sequence Engine ---
  
  let seqTimer = null;
  
  // Expose function globally to start sequence when view opens
  window._startWorkspaceSequence = function() {
    if (containerMain.dataset.started === "true") return;
    containerMain.dataset.started = "true";
    containerMain.innerHTML = '';
    
    // Reset crew group with secure badge
    const secBadge = `<div class="flex justify-center mb-4">
      <div class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]">
        <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
          <i class="ti ti-lock text-[10px] mr-1"></i>
          Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru AI.
        </p>
      </div>
    </div>`;
    containerGroup.innerHTML = secBadge;
    stateCanvas.classList.add('hidden');

    const runSeq = (steps, index = 0) => {
      if(index >= steps.length) return;
      const step = steps[index];
      
      seqTimer = setTimeout(() => {
        // Execute step
        if(step.layer === 'main') {
          addMainMessage(step.role, step.text, step.action);
          
          // Wire up interactions immediately after injecting
          if(step.action === 'acc-brief') {
            const btn = document.querySelector('.ws-btn-acc-brief');
            if(btn) btn.addEventListener('click', () => {
              btn.parentElement.innerHTML = '<span class="text-[10px] font-bold text-emerald-600 border border-emerald-200 bg-emerald-50 px-2 py-0.5 rounded-md"><i class="ti ti-check"></i> Approved</span>';
              addMainMessage('user', 'Yak sesuai, Lanjut gas!');
              runSeq(sequencePart2, 0); // Branch to part 2
            }, { once: true });
            return; // Pause sequence here
          }
          if(step.action === 'acc-copy') {
            const btn = document.querySelector('.ws-btn-acc-copy');
            if(btn) btn.addEventListener('click', () => {
              btn.parentElement.innerHTML = '<span class="text-[10px] font-bold text-emerald-600 border border-emerald-200 bg-emerald-50 px-2 py-0.5 rounded-md"><i class="ti ti-check"></i> Opsi A Terpilih</span>';
              addMainMessage('user', 'Opsi A keren banget, vibe-nya dapet. Lanjut ke visual!');
              runSeq(sequencePart3, 0); // Branch to part 3
            }, { once: true });
            return; // Pause sequence here
          }
          if(step.action === 'check-design') {
            const btn = document.querySelector('.ws-btn-open-canvas');
            if(btn) btn.addEventListener('click', () => {
              openCanvas();
            });
            return; // End of sequence
          }

        } else if (step.layer === 'cmd') {
          // no-op, backstage is always visible now
        } else if (step.layer === 'group') {
          addGroupMessage(step.role, step.text);
        }

        // Run next
        runSeq(steps, index + 1);
      }, step.delay);
    };

    // Sequences Definitions
    const sequencePart1 = [
      { delay: 0, layer: 'main', role: 'user', text: 'bikin promo jus mangga ke anak nongkrong dong cepet yak' },
      { delay: 500, layer: 'group', role: 'raka', text: 'Tim standby ya! 👋 Brief masuk, aku bikin strategic plan-nya dulu.' },
      { delay: 800, layer: 'group', role: 'luna', text: 'Siap, Raka! Copywriting engine ready. ✍️' },
      { delay: 600, layer: 'group', role: 'vesna', text: 'Canvas loaded, nunggu aba-aba. 🎨' },
      { delay: 1500, layer: 'main', role: 'raka', text: 'Siap! Agar hasilnya berlian, saya bedah dulu instruksi singkat Anda menjadi <b>Strategic Brief</b> yang komprehensif untuk tim:<br><br><div class="p-3 border border-black/10 rounded-md bg-[#fafafa] mt-2 mb-2 space-y-2 text-[12px]"><div class="flex gap-2"><i class="ti ti-target text-emerald-500 mt-0.5"></i><div><b>Objective:</b> Konversi harian (Drive-to-Store/Order) untuk produk Jus Mangga.</div></div><div class="flex gap-2"><i class="ti ti-users text-blue-500 mt-0.5"></i><div><b>Target Audience:</b> Gen-Z & Mahasiswa ("anak nongkrong", usia 18-24) yang butuh penyegaran hemat.</div></div><div class="flex gap-2"><i class="ti ti-message-circle text-orange-500 mt-0.5"></i><div><b>Tone & Angle:</b> Kasual, enerjik, FOMO (Fear Of Missing Out), dan <i>relatable</i>.</div></div><div class="flex gap-2"><i class="ti ti-photo text-purple-500 mt-0.5"></i><div><b>Deliverables:</b> 1x Instagram Feed Post (1:1 Square) lengkap dengan caption.</div></div></div>Apakah arah brief ini sudah sesuai sebelum saya kerahkan kru untuk eksekusi?', action: 'acc-brief' }
    ];

    const sequencePart2 = [
      { delay: 800, layer: 'main', role: 'raka', text: 'Sempurna. Saya segera kumpulkan tim copy dan desain. Anda bisa pantau prosesnya di panel kru.' },
      { delay: 500, layer: 'cmd', cmd: 'open-backstage' },
      { delay: 1200, layer: 'group', role: 'raka', text: '@Luna bos udah acc brief! Tolong siapkan 2 OPSI copy sosmed. Opsi A: Santai/Relatable. Opsi B: Hard Selling / FOMO.' },
      { delay: 2000, layer: 'group', role: 'luna', text: 'Roger! 🏃‍♀️ Menganalisis persona Gen-Z dan menyusun hook...' },
      { delay: 3500, layer: 'group', role: 'luna', text: 'Generate variasi copy... ⏳' },
      { delay: 5500, layer: 'group', role: 'luna', text: 'Done! Opsi A dan B sudah aku serahkan.' },
      { delay: 800, layer: 'group', role: 'raka', text: 'Cakep. Biar gue presentasikan ke bos sekarang.' },
      { delay: 1500, layer: 'main', role: 'raka', text: 'Luna baru saja merampungkan 2 arah copy berdasarkan brief kita:<br><br><div class="flex flex-col gap-2 mt-2"><div class="p-2 border border-black/10 rounded bg-[#fafafa]"><b class="text-emerald-600 text-[11px]">OPSI A (Relatable)</b><br><b class="text-[13px]">MANGO MADNESS 🍹</b><br><span class="text-muted-foreground">Cuaca panas bikin otak ngebul? Dinginin pake yang asli nyegerin harimu tanpa bikin dompet bolong.</span></div><div class="p-2 border border-black/10 rounded bg-[#fafafa]"><b class="text-blue-600 text-[11px]">OPSI B (Hard Selling FOMO)</b><br><b class="text-[13px]">PROMO ALERT: 20% OFF! 🚨</b><br><span class="text-muted-foreground">Daripada jajan sembarangan, sikat diskon spesial varian mangga khusus hari ini aja!</span></div></div><br>Menurut bos, mana yang lebih mewakili kampanye ini?', action: 'acc-copy' }
    ];

    const sequencePart3 = [
      { delay: 800, layer: 'group', role: 'raka', text: '@Vesna bos pilih Opsi A! Sikat visualnya sekarang. Gunakan warna pop-art yang <i>youthful</i> (Kuning/Oranye/Hijau Ceria) dan buat tipografinya super bold.' },
      { delay: 1500, layer: 'group', role: 'vesna', text: 'Noted chief! 🎨 Menyiapkan canvas 1080x1080px...' },
      { delay: 3000, layer: 'group', role: 'vesna', text: 'Menerapkan dynamic background gradient dan mengatur hierarchy tipografi agar "MANGO MADNESS" jadi fokus uatama... ⏳' },
      { delay: 5500, layer: 'group', role: 'vesna', text: 'Melakukan rendering aset visual resolusi tinggi... ✅' },
      { delay: 7000, layer: 'group', role: 'vesna', text: 'Selesai! File <b>Summer_Mango_Final.fig</b> sudah aku publish.' },
      { delay: 1000, layer: 'group', role: 'raka', text: 'Eksekusi yang solid tim! 🔥' },
      { delay: 1500, layer: 'main', role: 'raka', text: 'Berita baik bos, eksekusi visual dari Vesna sudah rampung 100%! Desainnya sangat pop dan nge-jreng, cocok sekali untuk *stop-scrolling* audiens Gen-Z di feed.<br><br>Silakan direview. Jika ada elemen kecil yang ingin langsung Anda geser atau ubah teksnya, Anda bisa membukanya di <b>Live Canvas</b>.', action: 'check-design' }
    ];

    // Begin part 1
    runSeq(sequencePart1, 0);
  }

</script>
