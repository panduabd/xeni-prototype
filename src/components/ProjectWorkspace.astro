      const aiHeader =
        isMain && role !== "user"
          ? `
        <div class="flex items-center gap-2 mb-1.5">
          <span class="font-bold text-[13.5px] text-foreground capitalize">${role}</span>
          <span class="px-1.5 py-0.5 rounded text-[9px] font-bold border border-black/10 text-muted-foreground uppercase tracking-widest leading-none">Creative Manager</span>
        </div>
