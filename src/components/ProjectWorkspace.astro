---
// ProjectWorkspace.astro
import AiInput from "./AiInput.astro";

const features = [
  {
    title: "Single Feed",
    desc: "Desain 1:1 statis untuk post",
    icon: "square",
  },
  {
    title: "Carousel",
    desc: "Konten multi-slide interaktif",
    icon: "carousel-horizontal",
  },
  { title: "Story", desc: "Format 9:16 layar penuh", icon: "device-mobile" },
  { title: "Banner", desc: "Grafis lanskap promosi", icon: "rectangle" },
];
---

<!-- BENTO BOX LAYOUT FOR ACTIVE WORKSPACE -->
<div class="flex h-full w-full overflow-hidden gap-3">
  <!-- LEFT: MAIN DIRECT CHAT (User & Raka) -->
  <div
    class="flex-1 min-w-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col h-full overflow-hidden relative z-10"
  >
    <!-- Chat Header -->
    <div
      class="h-14 px-4 border-b border-black/[0.06] flex items-center gap-2.5 shrink-0 bg-white/80 backdrop-blur-sm z-20"
    >
      <button
        id="btn-back-studio"
        class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-black/5 text-muted-foreground transition-colors shrink-0"
        title="Back to Studio"
      >
        <i class="ti ti-arrow-left text-[18px]"></i>
      </button>
      <div
        class="w-[30px] h-[30px] rounded bg-[#111] flex items-center justify-center text-white shrink-0"
      >
        <i class="ti ti-user text-[16px]"></i>
      </div>
      <div class="flex-1 min-w-0 flex flex-col justify-center">
        <h3
          class="text-[13.5px] font-bold text-foreground leading-tight mb-0.5"
        >
          Raka
        </h3>
        <span
          class="text-[9px] text-muted-foreground font-bold uppercase tracking-widest leading-none"
        >
          Creative Manager
        </span>
      </div>
      <!-- Right Side: Online Status -->
      <div class="flex items-center gap-1.5 shrink-0">
        <span class="text-[11px] font-medium text-muted-foreground">Online</span
        >
        <div
          class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_0_2px_rgba(255,255,255,1)]"
        >
        </div>
      </div>
    </div>

    <!-- Main Chat List -->
    <div
      id="main-chat-container"
      class="flex-1 overflow-y-auto px-5 py-6 flex flex-col gap-5"
    >
      <!-- Injected by JS -->
    </div>

    <!-- CHAT & INPUT SECTION (Global AiInput Component) -->
    <div class="w-full shrink-0 z-10 p-6 pt-0">
      <AiInput
        variant="panel"
        id="ws-ai-input"
        placeholder="Ask Raka to create new projects..."
      />
    </div>
  </div>

  <!-- RIGHT PANEL: Split Bento Box -->
  <div
    class="w-[340px] xl:w-[380px] shrink-0 h-full overflow-hidden flex flex-col gap-3"
  >
    <!-- TOP WIDGET: Crew Backstage / Live Canvas -->
    <div
      class="flex-[3] min-h-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col overflow-hidden relative"
    >
      <!-- CREW BACKSTAGE (WhatsApp Style) - Always visible by default -->
      <div
        id="ws-crew-backstage"
        class="w-full h-full flex flex-col bg-[#eef1f6]"
      >
        <!-- Header WA Style -->
        <div
          class="h-14 px-5 bg-white border-b border-black/[0.06] flex items-center justify-between shrink-0 shadow-sm z-10"
        >
          <div class="flex items-center gap-3">
            <!-- Stacked avatars -->
            <div class="flex -space-x-2">
              <div
                class="w-8 h-8 rounded-full border-2 border-white bg-[#f0f0f0] flex items-center justify-center text-[11px] font-bold z-30 shadow-sm"
              >
                R
              </div>
              <div
                class="w-8 h-8 rounded-full border-2 border-white bg-blue-50 flex items-center justify-center text-[11px] font-bold z-20 shadow-sm text-blue-600"
              >
                L
              </div>
              <div
                class="w-8 h-8 rounded-full border-2 border-white bg-pink-50 flex items-center justify-center text-[11px] font-bold z-10 shadow-sm text-pink-600"
              >
                V
              </div>
            </div>
            <div>
              <div class="flex items-center gap-2 mb-0.5">
                <h3 class="text-[13px] font-bold text-foreground leading-tight">
                  Summer Campaign Crew
                </h3>
              </div>
              <p class="text-[10px] text-muted-foreground">Raka, Luna, Vesna</p>
            </div>
          </div>
          <button
            class="w-8 h-8 rounded-full hover:bg-black/5 flex items-center justify-center text-muted-foreground"
          >
            <i class="ti ti-info-circle text-[16px]"></i>
          </button>
        </div>

        <!-- Internal Chat History -->
        <div
          id="crew-chat-container"
          class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-3"
          style="background-image: radial-gradient(circle, #000000 0.5px, transparent 0.5px); background-size: 16px 16px; background-color: #fafbfc;"
        >
          <!-- Secure Enclave badge -->
          <div class="flex justify-center mb-4">
            <div
              class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]"
            >
              <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
                <i class="ti ti-lock text-[10px] mr-1"></i>
                Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru
                AI.
              </p>
            </div>
          </div>
          <!-- Injected by JS -->
        </div>
      </div>
    </div>

    <!-- BOTTOM WIDGET: Project History -->
    <div
      class="flex-[2] min-h-0 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] flex flex-col overflow-hidden"
    >
      <div
        class="h-10 px-4 border-b border-black/[0.06] flex items-center justify-between shrink-0 bg-[#fafbfd]"
      >
        <h4
          class="text-[11px] font-bold tracking-tight text-foreground uppercase"
        >
          Project History
        </h4>
      </div>
      <div class="flex-1 overflow-y-auto px-4 py-3 flex flex-col gap-2">
        <!-- Auto populated by generation -->
        <div
          class="p-2 border border-black/[0.06] rounded-[8px] flex items-center gap-3 hover:bg-[#fafbfd] transition-colors cursor-pointer group"
        >
          <div
            class="w-8 h-8 rounded shrink-0 bg-[#f4f5f7] flex items-center justify-center text-muted-foreground"
          >
            <i class="ti ti-photo"></i>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[11px] font-bold text-foreground truncate">
              Previous_Generated_IMG_1.png
            </p>
            <p class="text-[9px] text-muted-foreground">
              Yesterday • Created by Vesna
            </p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <button
              class="flex items-center text-muted-foreground hover:text-foreground transition-colors"
              title="View"><i class="ti ti-eye text-[12px]"></i></button
            >
            <button
              class="flex items-center text-muted-foreground hover:text-foreground transition-colors"
              title="Download"
              ><i class="ti ti-download text-[12px]"></i></button
            >
          </div>
        </div>
        <div
          class="p-2 border border-black/[0.06] rounded-[8px] flex items-center gap-3 hover:bg-[#fafbfd] transition-colors cursor-pointer group"
        >
          <div
            class="w-8 h-8 rounded shrink-0 bg-[#f4f5f7] flex items-center justify-center text-muted-foreground"
          >
            <i class="ti ti-file-text"></i>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[11px] font-bold text-foreground truncate">
              Copywriting_Draft.txt
            </p>
            <p class="text-[9px] text-muted-foreground">
              Yesterday • Created by Luna
            </p>
          </div>
          <div class="flex items-center gap-2 ml-2">
            <button
              class="flex items-center text-muted-foreground hover:text-foreground transition-colors"
              title="View"><i class="ti ti-eye text-[12px]"></i></button
            >
            <button
              class="flex items-center text-muted-foreground hover:text-foreground transition-colors"
              title="Download"
              ><i class="ti ti-download text-[12px]"></i></button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- FULLSCREEN CANVAS OVERLAY -->
<div
  id="ws-live-canvas"
  class="hidden fixed inset-0 z-[100] bg-white flex flex-col"
>
  <!-- Canvas Header -->
  <div
    class="h-14 border-b border-black/[0.06] px-5 flex items-center justify-between shrink-0 z-10 shadow-sm bg-white"
  >
    <div class="flex items-center gap-3">
      <button
        id="btn-close-canvas"
        class="flex items-center gap-1.5 h-7 px-2.5 rounded-md hover:bg-black/5 text-muted-foreground hover:text-foreground transition-colors font-medium text-[11px]"
      >
        <i class="ti ti-arrow-left text-[14px]"></i> Back to Project
      </button>
      <div class="w-px h-4 bg-black/[0.1] mx-1"></div>
      <h4 class="text-[13px] font-bold tracking-tight text-foreground">
        Canvas Editor
      </h4>
      <span
        class="text-[9.5px] px-2 py-0.5 bg-[#f4f5f7] text-foreground font-semibold rounded-full border border-black/[0.05]"
        >Instagram Post</span
      >
    </div>
    <div class="flex gap-2">
      <button
        class="h-7 px-3 rounded-md bg-[#111] text-[11px] font-semibold text-white hover:bg-black transition-colors shadow-sm flex items-center gap-1.5"
      >
        <i class="ti ti-download text-[13px]"></i>
        Download
      </button>
    </div>
  </div>

  <!-- Canvas Body -->
  <div
    class="flex-1 bg-[#f0f1f3] flex items-center justify-center p-8 relative overflow-hidden"
    style="background-image: radial-gradient(circle, #d1d5db 0.8px, transparent 0.8px); background-size: 20px 20px;"
  >
    <div
      class="w-[500px] h-[500px] bg-white shadow-xl rounded-[16px] overflow-hidden border border-black/[0.05] flex flex-col hover:shadow-2xl transition-shadow cursor-crosshair"
    >
      <div
        class="h-[280px] bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center relative group"
      >
        <i class="ti ti-photo text-[64px] text-white opacity-40"></i>
        <!-- selection outline mock -->
        <div
          class="absolute inset-0 border-2 border-blue-500 opacity-0 group-hover:opacity-100 z-10 flex items-start justify-end p-2 pointer-events-none"
        >
          <span
            class="bg-blue-500 text-white text-[10px] font-bold px-2 py-1 rounded-sm"
            >Image Layer</span
          >
        </div>
      </div>
      <div class="flex-1 p-8 flex flex-col justify-center relative group">
        <div class="w-12 h-1.5 bg-black/80 mb-4 rounded-full"></div>
        <h3
          class="text-[36px] font-extrabold text-[#111] leading-none mb-2 tracking-tight"
        >
          MANGO<br />MADNESS 🍹
        </h3>
        <p class="text-[16px] font-semibold text-foreground/60 leading-tight">
          Diskon 20% khusus hari ini!
        </p>

        <div
          class="absolute inset-0 border-2 border-blue-500 opacity-0 group-hover:opacity-100 z-10 flex items-start justify-end p-2 pointer-events-none"
        >
          <span
            class="bg-blue-500 text-white text-[10px] font-bold px-2 py-1 rounded-sm"
            >Text Layer</span
          >
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Base animation tools */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .animate-slide-up {
    animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease forwards;
  }

  /* Chat Bubble Scopes */
  .chat-bubble-wa {
    max-width: 75%;
    width: fit-content;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
</style>

<script>
  // DOM Elements
  const containerMain = document.getElementById("main-chat-container");
  const containerGroup = document.getElementById("crew-chat-container");

  const stateBackstage = document.getElementById("ws-crew-backstage");
  const stateCanvas = document.getElementById("ws-live-canvas");
  const btnCloseCanvas = document.getElementById("btn-close-canvas");

  btnCloseCanvas?.addEventListener("click", () => {
    stateCanvas.classList.add("hidden");
  });

  // Helpers
  function openCanvas() {
    stateCanvas.classList.remove("hidden");
    stateCanvas.classList.add("animate-fade-in");
  }

  // Back to studio
  const btnBackStudio = document.getElementById("btn-back-studio");
  if (btnBackStudio) {
    btnBackStudio.addEventListener("click", () => {
      const overviewBtn = document.querySelector(
        '[data-nav-target="overview"]',
      );
      if (overviewBtn) (overviewBtn as HTMLElement).click();
    });
  }

  // Add initial welcome messages to crew group
  function addCrewWelcome() {
    const secBadge = `<div class="flex justify-center mb-4">
      <div class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]">
        <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
          <i class="ti ti-lock text-[10px] mr-1"></i>
          Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru AI.
        </p>
      </div>
    </div>`;
    containerGroup.innerHTML = secBadge;
  }

  // --- Templates ---

  function getAvatar(role) {
    if (role === "user") return "";
    const initial = role.charAt(0).toUpperCase();
    let bg = "bg-[#f0f0f0] border-black/[0.08] text-foreground";
    if (role === "dina") bg = "bg-blue-50 border-blue-100 text-blue-700";
    if (role === "bima") bg = "bg-pink-50 border-pink-100 text-pink-700";

    return `<div class="w-6 h-6 rounded-full border ${bg} flex items-center justify-center text-[9px] font-bold shrink-0 mt-0.5 shadow-sm">${initial}</div>`;
  }

  function addMainMessage(role, text, withAction = null) {
    const isUser = role === "user";

    let actionHtml = "";

    if (withAction === "analysis") {
      actionHtml = `
        <div class="mt-4 p-4 rounded-xl border border-border bg-transparent w-full max-w-[320px]">
          <p class="text-[13px] font-semibold text-foreground mb-3">Analysis Results</p>
          <div class="space-y-2.5">
            <div class="flex items-start gap-2.5">
              <div class="w-1.5 h-1.5 rounded-full bg-foreground mt-1.5 shrink-0"></div>
              <p class="text-[13px] text-muted-foreground"><strong class="font-medium text-foreground">Objective:</strong> Social Media Campaign</p>
            </div>
            <div class="flex items-start gap-2.5">
              <div class="w-1.5 h-1.5 rounded-full bg-foreground mt-1.5 shrink-0"></div>
              <p class="text-[13px] text-muted-foreground"><strong class="font-medium text-foreground">Target:</strong> Gen-Z / Young Adults</p>
            </div>
          </div>
        </div>
      `;
    } else if (withAction === "format-selection") {
      actionHtml = `
        <div class="mt-4 flex flex-col gap-2">
          <button class="ws-btn-format flex items-center justify-between w-full max-w-[280px] px-4 py-3 rounded-xl bg-slate-100 hover:bg-slate-200 text-foreground transition-colors group" data-format="3:4">
            <div class="flex items-center gap-3">
              <i class="ti ti-device-mobile text-[18px] text-muted-foreground"></i>
              <span class="text-[13.5px] font-medium">Portrait (3:4)</span>
            </div>
            <i class="ti ti-arrow-right text-[16px] text-muted-foreground opacity-50 group-hover:opacity-100 transition-opacity"></i>
          </button>
          <button class="ws-btn-format flex items-center justify-between w-full max-w-[280px] px-4 py-3 rounded-xl bg-slate-100 hover:bg-slate-200 text-foreground transition-colors group" data-format="1:1">
            <div class="flex items-center gap-3">
              <i class="ti ti-square text-[18px] text-muted-foreground"></i>
              <span class="text-[13.5px] font-medium">Square (1:1)</span>
            </div>
            <i class="ti ti-arrow-right text-[16px] text-muted-foreground opacity-50 group-hover:opacity-100 transition-opacity"></i>
          </button>
          <button class="ws-btn-format flex items-center justify-between w-full max-w-[280px] px-4 py-3 rounded-xl bg-slate-100 hover:bg-slate-200 text-foreground transition-colors group" data-format="9:16">
            <div class="flex items-center gap-3">
              <i class="ti ti-device-mobile text-[18px] text-muted-foreground"></i>
              <span class="text-[13.5px] font-medium">Story (9:16)</span>
            </div>
            <i class="ti ti-arrow-right text-[16px] text-muted-foreground opacity-50 group-hover:opacity-100 transition-opacity"></i>
          </button>
        </div>
      `;
    } else if (withAction === "headline-options") {
      actionHtml = `
        <div class="mt-4 flex flex-col gap-2 w-full max-w-[360px]">
          <p class="text-[13px] font-medium text-foreground mb-1">Pilih gaya headline utama untuk promo ini:</p>
          
          <button class="ws-btn-option-v2 flex items-center justify-between w-full p-4 rounded-xl bg-slate-100 hover:bg-slate-200 text-left transition-colors group" data-val="Playful">
            <div class="flex-1 pr-4">
              <p class="text-[13px] font-semibold text-foreground mb-1 label-cat">Playful & Fun</p>
              <p class="text-[12.5px] text-muted-foreground leading-snug headline-text">"Mango Madness 🍹 Seger Tanpa Batas!"</p>
            </div>
            <i class="ti ti-check text-[18px] text-foreground opacity-0 transition-opacity check-icon"></i>
          </button>
          
          <button class="ws-btn-option-v2 flex items-center justify-between w-full p-4 rounded-xl bg-slate-100 hover:bg-slate-200 text-left transition-colors group" data-val="Urgency">
            <div class="flex-1 pr-4">
              <p class="text-[13px] font-semibold text-foreground mb-1 label-cat">Urgency & FOMO</p>
              <p class="text-[12.5px] text-muted-foreground leading-snug headline-text">"Diskon 20% Hari Ini Aja — Jangan Sampe Kelewatan!"</p>
            </div>
            <i class="ti ti-check text-[18px] text-foreground opacity-0 transition-opacity check-icon"></i>
          </button>

          <button class="ws-btn-option-v2 flex items-center justify-between w-full p-4 rounded-xl bg-slate-100 hover:bg-slate-200 text-left transition-colors group" data-val="Premium">
            <div class="flex-1 pr-4">
              <p class="text-[13px] font-semibold text-foreground mb-1 label-cat">Premium & Clean</p>
              <p class="text-[12.5px] text-muted-foreground leading-snug headline-text">"Fresh Mango Juice — Crafted for Your Summer"</p>
            </div>
            <i class="ti ti-check text-[18px] text-foreground opacity-0 transition-opacity check-icon"></i>
          </button>
        </div>
      `;
    } else if (withAction === "plan-concept") {
      actionHtml = `
        <div class="mt-4 p-4 rounded-xl border border-border bg-transparent w-full max-w-[360px]">
          <div class="flex items-center justify-between mb-4">
             <span class="text-[13px] font-semibold text-foreground">Project Plan</span>
             <span class="text-[11px] font-medium text-muted-foreground">Ready to Execute</span>
          </div>
          <div class="space-y-3 mb-5">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-muted-foreground shrink-0"><i class="ti ti-typography"></i></div>
              <div>
                <p class="text-[13px] font-medium text-foreground">Copywriting & Tone</p>
                <p class="text-[12px] text-muted-foreground">Kasual, bahasa Gen-Z, urgency (Promo)</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-muted-foreground shrink-0"><i class="ti ti-layout-board-split"></i></div>
              <div>
                <p class="text-[13px] font-medium text-foreground">Design Components</p>
                <p class="text-[12px] text-muted-foreground">Portrait 3:4, Hero top, Text bottom, gradient overlay</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-muted-foreground shrink-0"><i class="ti ti-photo"></i></div>
              <div>
                <p class="text-[13px] font-medium text-foreground">Image to Generate</p>
                <p class="text-[12px] text-muted-foreground">Jus mangga segar, visual terang & tropikal</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-muted-foreground shrink-0"><i class="ti ti-dna-2"></i></div>
              <div>
                <p class="text-[13px] font-medium text-foreground">Brand DNA</p>
                <p class="text-[12px] text-muted-foreground">Warm tones (Amber & Orange), Playful font</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-muted-foreground shrink-0"><i class="ti ti-users"></i></div>
              <div>
                <p class="text-[13px] font-medium text-foreground">Crew Assigned</p>
                <p class="text-[12px] text-muted-foreground">Dina (Copy) & Bima (Design)</p>
              </div>
            </div>
          </div>
          <button class="ws-btn-confirm w-full py-2.5 rounded-lg bg-foreground hover:bg-black text-white text-[13px] font-medium transition-all">
            Confirm & Start Project
          </button>
        </div>
      `;
    } else if (withAction === "check-design") {
      actionHtml = `
        <div class="mt-4 w-full max-w-[260px] rounded-xl overflow-hidden border border-border bg-transparent group cursor-pointer ws-btn-open-canvas">
          <div class="h-[140px] bg-gradient-to-br from-amber-400 to-orange-500 relative flex items-center justify-center">
            <h3 class="text-[20px] font-bold text-[#111]">MANGO 🍹</h3>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 px-3 py-1.5 bg-white text-black text-[12px] font-medium rounded shadow-sm transition-all transform scale-95 group-hover:scale-100">
                Open in Canvas
              </span>
            </div>
          </div>
          <div class="p-3 bg-white border-t border-border">
             <span class="text-[13px] font-medium text-foreground">Summer_Mango_Final.png</span>
          </div>
        </div>
      `;
    } else if (withAction === "delivery-result") {
      actionHtml = `
        <div class="mt-4 w-full max-w-[280px]">
          <div class="mb-2">
            <span class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-slate-100 px-2.5 py-0.5 text-[11px] font-semibold text-slate-900 shadow-sm">1</span>
