    "raka",
    "Halo tim! 👋 Standby ya, menunggu instruksi dari bos.",
  );
  addGroupMessage("dina", "Siap, Raka! Copywriting engine ready. ✍️");
  addGroupMessage("bima", "Canvas loaded, tinggal tunggu brief. 🎨");

  // --- Sequence Engine ---

  let seqTimer = null;

  // Expose function globally to start sequence when view opens
  window._startWorkspaceSequence = function () {
    if (containerMain.dataset.started === "true") return;
    containerMain.dataset.started = "true";
    containerMain.innerHTML = "";

    // Reset crew group with secure badge
    const secBadge = `<div class="flex justify-center mb-4">
      <div class="px-3 py-1.5 rounded-md bg-[#fff9c4] border border-[#fbc02d]/30 shadow-sm text-center max-w-[280px]">
        <p class="text-[10px] text-[#827717] font-medium leading-relaxed">
          <i class="ti ti-lock text-[10px] mr-1"></i>
          Pesan dalam grup ini tertutup hanya untuk koordinasi internal kru AI.
        </p>
      </div>
    </div>`;
    containerGroup.innerHTML = secBadge;
