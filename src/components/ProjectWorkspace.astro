          ? "text-pink-600"
          : "text-emerald-600";

    // All bubbles aligned left
    const bubbleBg =
      role === "raka"
        ? "bg-[#e7fed2] border-[#cbedaf]"
        : "bg-white border-black/[0.05]";

    const time = new Date().toLocaleTimeString("id-ID", {
      hour: "2-digit",
      minute: "2-digit",
    });

    const html = `
      <div class="flex gap-2 w-full chat-bubble-wa animate-slide-up self-start flex-row opacity-0" style="animation-delay: 0.1s">
        ${getAvatar(role)}
        <div class="flex flex-col">
          <div class="rounded-[12px] px-3 py-2 border ${bubbleBg} shadow-sm relative text-[11px] text-foreground leading-snug">
            <div class="font-bold text-[9px] mb-0.5 ${nameColor} capitalize">${role}</div>
            <div>${text}</div>
