---
import AiInput from "./AiInput.astro";
---

<style>
  .ai-orb-container {
    perspective: 1000px;
  }
  .ai-orb {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 35%,
      rgba(255, 255, 255, 1) 0%,
      rgba(238, 242, 255, 0.9) 20%,
      rgba(199, 210, 254, 0.6) 50%,
      rgba(165, 180, 252, 0.3) 80%,
      rgba(129, 140, 248, 0.1) 100%
    );
    box-shadow:
      0 10px 30px -5px rgba(129, 140, 248, 0.2),
      inset -2px -2px 8px rgba(99, 102, 241, 0.1),
      inset 4px 4px 12px rgba(255, 255, 255, 0.9);
    backdrop-blur: 4px;
    position: relative;
    animation: float 4s ease-in-out infinite;
  }

  .ai-orb::before {
    content: "";
    position: absolute;
    top: 20%;
    left: 20%;
    width: 25%;
    height: 25%;
    background: white;
    border-radius: 50%;
    filter: blur(3px);
    opacity: 0.9;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-6px) scale(1.02);
    }
  }
</style>

<!-- WHITE CANVAS -->
<div
  class="flex-1 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] p-6 flex flex-col relative overflow-hidden"
>
  <!-- AI Greeting Scene -->
  <div
    class="flex-1 flex flex-col items-center justify-center relative overflow-hidden select-none pb-8"
    style="min-height: 0;"
  >
    <div class="ai-orb-container mb-6">
      <div class="ai-orb"></div>
    </div>

    <div class="text-center space-y-1">
      <h1 class="text-[20px] font-bold text-foreground tracking-tight">
        Good Morning, User!
      </h1>
      <h2 class="text-[20px] font-bold tracking-tight">
        <span class="text-foreground">How Can I </span>
        <span class="text-[#515ada]">Assist You Today?</span>
      </h2>
    </div>
  </div>

  <!-- CHAT & INPUT SECTION -->
  <div class="w-full shrink-0 z-10">
    <AiInput
      variant="panel"
      id="studio-ai-input"
      placeholder="Ask Raka to create new projects..."
    />
  </div>
</div>

<script>
  document
    .getElementById("studio-ai-input")
    ?.addEventListener("ai-submit", (e: any) => {
      // Re-dispatch to window for studio.astro to handle
    });
</script>
