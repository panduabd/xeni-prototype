---
const features = [
  { title: "Single Feed", desc: "Desain 1:1 statis untuk post", icon: "square" },
  { title: "Carousel", desc: "Konten multi-slide interaktif", icon: "carousel-horizontal" },
  { title: "Story", desc: "Format 9:16 layar penuh", icon: "device-mobile" },
  { title: "Banner", desc: "Grafis lanskap promosi", icon: "rectangle" },
];
---

<style>
  @keyframes blink-cursor {
    0%, 100% { opacity: 1; } 50% { opacity: 0; }
  }
  .monitor-cursor { animation: blink-cursor 1.2s ease-in-out infinite; }
</style>

<!-- WHITE CANVAS -->
<div class="flex-1 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] p-6 flex flex-col relative overflow-hidden">
  
  <!-- Isometric Studio Scene (light palette) -->
  <div class="flex-1 flex items-center justify-center relative overflow-hidden select-none" style="min-height: 0;">
    <svg viewBox="0 0 480 280" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" style="max-height: 200px; opacity: 0.88;">
      <defs>
        <filter id="softglow"><feGaussianBlur stdDeviation="2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
      </defs>

      <!-- Floor -->
      <polygon points="240,258 430,175 240,92 50,175" fill="#e8eaf6" opacity="0.9"/>
      <polygon points="240,258 430,175 430,162 240,245" fill="#c5c9e8" opacity="0.7"/>
      <polygon points="240,258 50,175 50,162 240,245" fill="#d0d4ee" opacity="0.7"/>

      <!-- DESK 1 – Raka -->
      <polygon points="100,170 190,128 230,150 140,192" fill="#c7ccf5" opacity="0.8"/>
      <polygon points="100,170 100,183 60,202 60,189" fill="#a0a8e8" opacity="0.8"/>
      <polygon points="100,170 190,128 190,141 100,183" fill="#b0b8ef" opacity="0.8"/>
      <!-- Monitor -->
      <rect x="130" y="112" width="36" height="26" rx="4" fill="#f8f9ff" stroke="#7185ff" stroke-width="1.2"/>
      <rect x="132" y="114" width="32" height="11" rx="1.5" fill="#7185ff" opacity="0.25"/>
      <rect x="132" y="127" width="20" height="2" rx="1" fill="#7185ff" opacity="0.3"/>
      <rect x="132" y="131" width="14" height="1.5" rx="1" fill="#7185ff" opacity="0.2"/>
      <rect x="146" y="138" width="4" height="5" fill="#c0c4e0"/>
      <rect x="142" y="143" width="12" height="2" rx="1" fill="#c0c4e0"/>
      <rect class="monitor-cursor" x="133" y="132" width="3" height="4" rx="0.5" fill="#7185ff" style="animation-delay:0s"/>
      <!-- Person Raka -->
      <ellipse cx="120" cy="172" rx="11" ry="5" fill="#a0a8e0" opacity="0.7"/>
      <rect x="114" y="152" width="12" height="20" rx="6" fill="#b0baee" opacity="0.75"/>
      <circle cx="120" cy="148" r="10" fill="#7185ff" opacity="0.9" filter="url(#softglow)"/>
      <text x="120" y="152" text-anchor="middle" font-family="system-ui" font-size="10" font-weight="bold" fill="white">R</text>
      <!-- Bubble Raka -->
      <rect x="42" y="94" width="86" height="20" rx="8" fill="white" stroke="#7185ff" stroke-width="1" opacity="0.95"/>
      <polygon points="78,114 84,121 90,114" fill="white" stroke="#7185ff" stroke-width="1"/>
      <text x="85" y="108" text-anchor="middle" font-family="system-ui" font-size="7.5" fill="#4a5aee" font-weight="600">Planning Q2 brief 📋</text>

      <!-- DESK 2 – Luna -->
      <polygon points="210,150 300,108 340,130 250,172" fill="#f5e8a0" opacity="0.8"/>
      <polygon points="210,150 210,163 168,182 168,169" fill="#e0c860" opacity="0.8"/>
      <polygon points="210,150 300,108 300,121 210,163" fill="#e8d880" opacity="0.8"/>
      <!-- Monitor -->
      <rect x="238" y="92" width="36" height="26" rx="4" fill="#fffbf0" stroke="#d4a820" stroke-width="1.2"/>
      <rect x="240" y="94" width="32" height="11" rx="1.5" fill="#f4c842" opacity="0.25"/>
      <rect x="240" y="107" width="22" height="2" rx="1" fill="#c89e10" opacity="0.3"/>
      <rect x="240" y="111" width="15" height="1.5" rx="1" fill="#c89e10" opacity="0.2"/>
      <rect x="254" y="118" width="4" height="5" fill="#d8c880"/>
      <rect x="250" y="123" width="12" height="2" rx="1" fill="#d8c880"/>
      <rect class="monitor-cursor" x="241" y="112" width="3" height="4" rx="0.5" fill="#d4a820" style="animation-delay:0.5s"/>
      <!-- Person Luna -->
      <ellipse cx="228" cy="152" rx="11" ry="5" fill="#c8b040" opacity="0.7"/>
      <rect x="222" y="132" width="12" height="20" rx="6" fill="#d8c050" opacity="0.75"/>
      <circle cx="228" cy="128" r="10" fill="#f4c842" opacity="0.9" filter="url(#softglow)"/>
      <text x="228" y="132" text-anchor="middle" font-family="system-ui" font-size="10" font-weight="bold" fill="#5a4000">L</text>
      <!-- Bubble Luna -->
      <rect x="196" y="62" width="90" height="20" rx="8" fill="white" stroke="#d4a820" stroke-width="1" opacity="0.95"/>
      <polygon points="232,82 238,89 244,82" fill="white" stroke="#d4a820" stroke-width="1"/>
      <text x="241" y="76" text-anchor="middle" font-family="system-ui" font-size="7.5" fill="#8a6800" font-weight="600">Writing CTA copy ✍️</text>

      <!-- DESK 3 – Vesna -->
      <polygon points="318,130 408,88 448,110 358,152" fill="#f5b8c5" opacity="0.8"/>
      <polygon points="318,130 318,143 275,162 275,149" fill="#d88098" opacity="0.8"/>
      <polygon points="318,130 408,88 408,101 318,143" fill="#e898b0" opacity="0.8"/>
      <!-- Monitor -->
      <rect x="344" y="72" width="36" height="26" rx="4" fill="#fff5f7" stroke="#c84060" stroke-width="1.2"/>
      <rect x="346" y="74" width="32" height="11" rx="1.5" fill="#f17285" opacity="0.22"/>
      <rect x="346" y="87" width="18" height="2" rx="1" fill="#c84060" opacity="0.3"/>
      <rect x="346" y="91" width="22" height="1.5" rx="1" fill="#c84060" opacity="0.2"/>
      <rect x="360" y="98" width="4" height="5" fill="#e0a0b0"/>
      <rect x="356" y="103" width="12" height="2" rx="1" fill="#e0a0b0"/>
      <rect class="monitor-cursor" x="347" y="92" width="3" height="4" rx="0.5" fill="#c84060" style="animation-delay:1s"/>
      <!-- Person Vesna -->
      <ellipse cx="335" cy="132" rx="11" ry="5" fill="#d08098" opacity="0.7"/>
      <rect x="329" y="112" width="12" height="20" rx="6" fill="#d890a8" opacity="0.75"/>
      <circle cx="335" cy="108" r="10" fill="#f17285" opacity="0.9" filter="url(#softglow)"/>
      <text x="335" y="112" text-anchor="middle" font-family="system-ui" font-size="10" font-weight="bold" fill="white">V</text>
      <!-- Bubble Vesna -->
      <rect x="342" y="40" width="92" height="20" rx="8" fill="white" stroke="#c84060" stroke-width="1" opacity="0.95"/>
      <polygon points="362,60 368,67 374,60" fill="white" stroke="#c84060" stroke-width="1"/>
      <text x="388" y="54" text-anchor="middle" font-family="system-ui" font-size="7.5" fill="#9a2040" font-weight="600">Building layout 🎨</text>
    </svg>
  </div>

  <!-- CHAT & INPUT SECTION -->
  <div class="w-full flex flex-col gap-3 shrink-0 z-10">

    <!-- Top Context Row: Brand DNA + Image reference -->
    <div class="flex items-center gap-2 mb-1">

      <!-- Brand DNA Picker -->
      <div class="relative" id="brand-dna-wrapper">
        <button
          id="brand-dna-trigger"
          class="inline-flex items-center gap-1.5 h-7 px-3 rounded-full bg-white border border-black/[0.08] hover:border-black/[0.15] text-foreground/70 text-[10.5px] font-bold transition-all shadow-[0_2px_8px_rgb(0,0,0,0.02)] group/dna"
        >
          <i class="ti ti-dna-2 text-[12px] text-muted-foreground/60 group-hover/dna:text-[#7185ff] transition-colors"></i>
          <span id="brand-dna-label" class="tracking-tight">Brand DNA</span>
          <i class="ti ti-chevron-down text-[10px] text-muted-foreground/40 ml-0.5" id="brand-dna-chevron" style="transition: transform 0.2s;"></i>
        </button>

        <div
          id="brand-dna-dropdown"
          class="hidden absolute top-[calc(100%+6px)] left-0 min-w-[196px] bg-white border border-black/[0.08] rounded-[12px] shadow-[0_8px_24px_rgb(0,0,0,0.08)] py-1.5 z-50"
        >
          <p class="px-3 pt-1 pb-1.5 text-[9.5px] font-bold text-muted-foreground uppercase tracking-widest">Your Brands</p>
          {[
            { name: 'Fresh Juice Co.', color: '#ffc1a6' },
            { name: 'Urban Bloom',     color: '#c6e8ff' },
            { name: 'Apex CRM',        color: '#fdc6e7' },
          ].map(brand => (
            <button class="brand-dna-item w-full flex items-center gap-2.5 px-3 py-2 text-left hover:bg-[#f8f9fb] transition-colors" data-brand={brand.name}>
              <div class="w-3.5 h-3.5 rounded-full shrink-0 border border-black/[0.06]" style={`background: ${brand.color};`}></div>
              <span class="text-[12px] font-medium text-foreground">{brand.name}</span>
            </button>
          ))}
          <div class="border-t border-black/[0.05] mt-1 pt-1">
            <button class="w-full flex items-center gap-2 px-3 py-2 text-left hover:bg-[#f8f9fb] transition-colors">
              <i class="ti ti-plus text-[12px] text-muted-foreground"></i>
              <span class="text-[12px] font-medium text-muted-foreground">Create Brand DNA</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Example uploaded image badge (dismissible, reappears on reload) -->
      <div id="img-ref-badge" class="inline-flex items-center gap-1.5 h-7 pl-1.5 pr-2 rounded-full bg-white border border-black/[0.08] shadow-[0_2px_8px_rgb(0,0,0,0.03)] group/img transition-all hover:border-black/[0.15]">
        <div class="w-4.5 h-4.5 rounded-full bg-black/[0.04] flex items-center justify-center shrink-0">
          <i class="ti ti-photo text-[11px] text-muted-foreground opacity-70"></i>
        </div>
        <span class="text-[10.5px] font-bold text-foreground/60 tracking-tight">product.jpg</span>
        <button id="img-ref-close" class="w-4 h-4 rounded-full flex items-center justify-center hover:bg-red-50 hover:text-red-500 text-muted-foreground/40 transition-all ml-0.5">
          <i class="ti ti-x text-[9px]"></i>
        </button>
      </div>

    </div>

    <!-- AI Input -->
    <div class="bg-white rounded-[22px] border border-black/[0.06] flex flex-col focus-within:border-[#7185ff]/30 transition-all p-5 relative shadow-[0_2px_16px_rgb(0,0,0,0.04)] focus-within:shadow-[0_8px_32px_rgb(0,0,0,0.08)]">
      
      <textarea 
        id="prompt-input"
        rows="1"
        class="w-full text-[14px] font-medium text-foreground bg-transparent placeholder:text-muted-foreground/45 focus:outline-none resize-none pt-1 pb-6 leading-relaxed"
        placeholder="Ask Raka to create new projects..."
        style="min-height: 52px;"
      ></textarea>
      
      <div class="flex items-center justify-between relative z-20">
        
        <div class="flex items-center gap-2">
          
          <!-- Add Reference (click dropdown) -->
          <div class="relative" id="add-ref-wrapper">
            <button id="add-ref-trigger" class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[7px] bg-white border border-black/[0.08] hover:border-black/[0.16] text-foreground transition-all text-left">
              <i class="ti ti-plus text-[12px] text-muted-foreground"></i>
              <span class="text-[11px] font-semibold">Add Reference</span>
              <i class="ti ti-chevron-down text-[10px] text-muted-foreground/40 ml-0.5" id="add-ref-chevron" style="transition: transform 0.2s;"></i>
            </button>
            <div id="add-ref-dropdown" class="hidden absolute bottom-[calc(100%+8px)] left-0 w-48 bg-white border border-black/[0.08] shadow-[0_8px_24px_rgb(0,0,0,0.08)] rounded-[12px] py-1 z-50">
               <button class="w-full flex items-center gap-2.5 px-3 py-2.5 text-left hover:bg-[#f8f9fb] transition-colors">
                  <i class="ti ti-upload text-[13px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-foreground">Upload Image</span>
               </button>
               <button class="w-full flex items-center gap-2.5 px-3 py-2.5 text-left hover:bg-[#f8f9fb] transition-colors">
                  <i class="ti ti-box text-[13px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-foreground">From Product Ref.</span>
               </button>
            </div>
          </div>

          <!-- Select Format (click dropdown) -->
          <div class="relative" id="format-wrapper">
            <button id="format-trigger" class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[7px] bg-white border border-black/[0.08] hover:border-black/[0.16] text-foreground transition-all">
              <i class="ti ti-layout-board-split text-[12px] text-emerald-600"></i>
              <span class="text-[11px] font-semibold" id="format-label">Select Format</span>
              <i class="ti ti-chevron-down text-[10px] text-muted-foreground/40 ml-0.5" id="format-chevron" style="transition: transform 0.2s;"></i>
            </button>
            <div id="format-dropdown" class="hidden absolute bottom-[calc(100%+8px)] left-0 w-44 bg-white border border-black/[0.08] shadow-[0_8px_24px_rgb(0,0,0,0.08)] rounded-[12px] py-1 z-50">
               <button class="format-item w-full flex items-center gap-2.5 px-3 py-2.5 text-left hover:bg-[#f8f9fb] transition-colors" data-format="Feed (1:1)" data-icon="ti-square">
                  <i class="ti ti-square text-[13px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-foreground">Feed (1:1)</span>
               </button>
               <button class="format-item w-full flex items-center gap-2.5 px-3 py-2.5 text-left hover:bg-[#f8f9fb] transition-colors" data-format="Story (9:16)" data-icon="ti-device-mobile">
                  <i class="ti ti-device-mobile text-[13px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-foreground">Story (9:16)</span>
               </button>
               <button class="format-item w-full flex items-center gap-2.5 px-3 py-2.5 text-left hover:bg-[#f8f9fb] transition-colors" data-format="Landscape" data-icon="ti-rectangle">
                  <i class="ti ti-rectangle text-[13px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-foreground">Landscape</span>
               </button>
            </div>
          </div>

        </div>

        <button id="btn-submit-prompt" class="w-8 h-8 rounded-[8px] bg-foreground hover:bg-black flex items-center justify-center text-white transition-all shrink-0">
          <i class="ti ti-arrow-up text-[15px]"></i>
        </button>
      </div>

    </div>

    <!-- Feature Reference Cards -->
    <div class="grid grid-cols-2 gap-2 mt-1">
      {features.map((f) => (
        <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f4f5f7] hover:bg-[#ecedf2] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
          <div class="relative z-10 w-full pr-10">
            <div class="flex items-center gap-1.5 mb-0.5">
               <span class="feature-title text-[12px] font-bold text-foreground">{f.title}</span>
               <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors"></i>
            </div>
            <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">{f.desc}</p>
          </div>
          <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
             <i class={`ti ti-${f.icon} text-[20px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors`}></i>
          </div>
        </button>
      ))}
    </div>

  </div>

</div>

<script>
  // ── Shared toggle helper ──────────────────────────────────
  function setupDropdown(triggerId, dropdownId, chevronId) {
    const trigger  = document.getElementById(triggerId);
    const dropdown = document.getElementById(dropdownId);
    const chevron  = document.getElementById(chevronId);
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', e => {
      e.stopPropagation();
      const isOpen = !dropdown.classList.contains('hidden');
      // Close all dropdowns first
      document.querySelectorAll('[data-popup]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[data-chevron]').forEach(el => el.style.transform = '');
      if (!isOpen) {
        dropdown.classList.remove('hidden');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
    dropdown.setAttribute('data-popup', '');
    if (chevron) chevron.setAttribute('data-chevron', '');
  }

  // Close all on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('[data-popup]').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('[data-chevron]').forEach(el => el.style.transform = '');
  });

  setupDropdown('brand-dna-trigger', 'brand-dna-dropdown', 'brand-dna-chevron');
  setupDropdown('add-ref-trigger',   'add-ref-dropdown',   'add-ref-chevron');
  setupDropdown('format-trigger',    'format-dropdown',    'format-chevron');

  // ── Brand DNA selection ───────────────────────────────────
  document.querySelectorAll('.brand-dna-item').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('brand-dna-label').textContent = btn.dataset.brand;
      document.getElementById('brand-dna-dropdown').classList.add('hidden');
    });
  });

  // ── Format selection ──────────────────────────────────────
  document.querySelectorAll('.format-item').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('format-label').textContent = btn.dataset.format;
      document.getElementById('format-dropdown').classList.add('hidden');
      document.getElementById('format-chevron').style.transform = '';
    });
  });

  // ── Image badge dismiss (reappears on reload — no storage) ─
  document.getElementById('img-ref-close')?.addEventListener('click', e => {
    e.stopPropagation();
    document.getElementById('img-ref-badge').style.display = 'none';
  });
</script>

