---
// DocuSign-style flat top navigation
// Logo | Module Tabs | Right Actions
const moduleItems = [
  { label: "Studio", active: true },
  { label: "Marketing", active: false },
  { label: "Ops", active: false },
  { label: "Finance", active: false },
  { label: "Code", active: false },
];
---

<header class="h-14 bg-white border-b border-border flex items-center px-5 shrink-0 z-20">
  
  <!-- Logo -->
  <a href="#" class="flex items-center gap-2 mr-8 shrink-0">
    <div class="w-7 h-7 rounded-lg bg-primary flex items-center justify-center">
      <span class="text-white font-bold text-[11px]">Oi</span>
    </div>
    <span class="text-[15px] font-bold tracking-tight text-foreground">OiCrew</span>
  </a>

  <!-- Module Tabs (flat, like DocuSign) -->
  <nav class="flex items-center gap-1 h-full">
    {moduleItems.map((item) => (
      <a 
        href="#" 
        class={`relative h-full px-4 flex items-center text-[13px] font-medium transition-colors
        ${item.active 
          ? 'text-primary' 
          : 'text-muted-foreground hover:text-foreground'}`}
      >
        {item.label}
        {item.active && (
          <span class="absolute bottom-0 left-3 right-3 h-[2px] bg-primary rounded-t-full"></span>
        )}
      </a>
    ))}
  </nav>

  <!-- Spacer -->
  <div class="flex-1"></div>
  
  <!-- Right Actions -->
  <div class="flex items-center gap-2">
    <!-- AI Credits -->
    <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-amber-50 border border-amber-200/60 text-amber-700 text-[12px] font-semibold">
      <i class="ti ti-bolt-filled text-[14px]"></i>
      250 Credits
    </div>
    
    <!-- Inbox -->
    <button class="w-9 h-9 rounded-lg hover:bg-muted flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors relative">
      <i class="ti ti-bell-filled text-[18px]"></i>
      <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-red-500 border-2 border-white"></span>
    </button>
    
    <!-- User Avatar -->
    <button class="w-8 h-8 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center text-primary text-xs font-bold hover:bg-primary/20 transition-colors">
      P
    </button>
  </div>

</header>
