                     <div class="h-1.5 w-3/4 bg-gray-200 rounded-full"></div>
                     <div class="h-1.5 w-1/2 bg-gray-200 rounded-full"></div>
                  </div>

                  <!-- Refined Text+Icon Action Buttons -->
                  <div class="w-full flex flex-col gap-3 mt-auto pb-2">
                     <!-- Approve Button: Black, Hover Dark Gray, With Heart -->
                     <button class="w-full py-3.5 rounded-xl bg-[#111827] text-white font-bold text-[12px] tracking-wide shadow-sm hover:bg-gray-800 transition-all duration-300 font-geist flex items-center justify-center gap-2 group">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 256 256" class="group-hover:scale-110 transition-transform duration-300"><path d="M240,98a57.63,57.63,0,0,1-17,41L128,232,33,139a58,58,0,0,1,82-82.1l13,13,13-13A58,58,0,0,1,240,98Z"></path></svg>
                        Approve
                     </button>
                     
                     <!-- Reject Button: Text, Hover Red, With X icon -->
                     <button class="w-full py-2 rounded-xl bg-transparent text-[#6B7280] font-bold text-[11px] tracking-wide hover:text-red-500 transition-colors font-geist flex items-center justify-center gap-1.5">
