                     <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#9CA3AF" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40ZM216,200H40V56H216V200Zm-24-88a12,12,0,1,1-12-12A12,12,0,0,1,192,112Z"></path></svg>
                  </div>

