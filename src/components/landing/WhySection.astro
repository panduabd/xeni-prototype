---

---

<section class="w-full py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Header matching reference layout: Further downscaled for pristine hierarchy -->
      <div class="mb-12 md:mb-16 text-center md:text-left">
        <div class="max-w-3xl">
          <h2
            class="text-[26px] md:text-[36px] font-normal text-[#111827] font-fraunces leading-[1.2] tracking-tight mb-4"
          >
            Why Xeni?
          </h2>
          <p
            class="text-[14px] md:text-[16px] text-[#667085] font-geist font-medium max-w-xl leading-relaxed"
          >
            Design tools generate pixels. Schedulers queue posts. Xeni does
            both—and everything in between. One AI agent team, no fragmented
            toolkit.
          </p>
        </div>
      </div>

      <!-- Feature Grid: High-Precision Structural Layout -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6 mb-8"
      >
        <!-- Card 1: Agents Not Tools -->
        <div
          class="flex-shrink-0 h-[420px] bg-[#F3F4F6] rounded-[20px] flex flex-col justify-between relative overflow-hidden group"
        >
          <!-- Top Visual Area: Replaced with Rigid Status Matrix -->
          <div class="relative w-full h-[220px] flex items-center justify-center pt-6">
            <!-- Top-Left Labeling Icon -->
            <div
              class="absolute top-6 left-6 w-8 h-8 rounded-lg bg-[#111827] text-white flex items-center justify-center z-10"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            </div>

            <!-- Core Stack: Zero Rotation, Structured Lines -->
            <div class="w-[80%] bg-white rounded-xl border border-gray-100 flex flex-col divide-y divide-gray-50 overflow-hidden">
               <!-- Node 1 -->
               <div class="p-3.5 flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-[#111827]"></div>
                  <div class="h-1.5 w-24 bg-gray-200 rounded-full"></div>
                  <div class="ml-auto w-4 h-4 text-[#12B76A]">
                     <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l5-5z" clip-rule="evenodd"></path></svg>
                  </div>
               </div>
               <!-- Node 2 -->
               <div class="p-3.5 flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                  <div class="h-1.5 w-32 bg-gray-100 rounded-full"></div>
                  <div class="ml-auto w-4 h-4 text-[#12B76A]">
                     <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l5-5z" clip-rule="evenodd"></path></svg>
                  </div>
               </div>
               <!-- Node 3 -->
               <div class="p-3.5 flex items-center gap-3 bg-gray-50/30">
                  <div class="w-2 h-2 rounded-full bg-indigo-200 animate-pulse"></div>
                  <div class="h-1.5 w-20 bg-gray-200 rounded-full"></div>
               </div>
            </div>
          </div>

          <!-- Content area -->
          <div class="p-8 pt-2">
            <h3
              class="text-[18px] font-bold text-[#111827] font-sans tracking-tight mb-3"
            >
              Agents, Not Tools.
            </h3>
            <p class="text-[13.5px] text-[#667085] font-medium leading-relaxed">
              Brief what you need. Xeni learns your products, speaks in your
              brand voice, and delivers complete posts—visuals and captions
              included.
            </p>
          </div>
        </div>

        <!-- Card 2: HIGHLIGHTED END-TO-END (NOW BLACK REINFORCED) -->
        <div
          class="flex-shrink-0 h-[420px] bg-[#111827] text-white rounded-[20px] flex flex-col justify-between relative overflow-hidden group"
        >
          <!-- Top Visual Area: Replacing messy overlaps with linear timeline -->
          <div class="relative w-full h-[220px] flex items-center justify-center pt-6">
            <!-- Workflow Icon Top Left -->
            <div
              class="absolute top-6 left-6 w-8 h-8 rounded-lg bg-white text-[#111827] flex items-center justify-center z-10 border border-white/20"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
            </div>

            <!-- Pristine Linear Pipeline Layout -->
            <div class="w-[75%] bg-white rounded-xl overflow-hidden border border-white/20 flex flex-col gap-3 p-4 relative z-10">
               <div class="w-full aspect-[16/7] bg-gray-50 rounded-lg flex items-center justify-center gap-3 px-6">
                  <!-- Step 1 Circle -->
                  <div class="w-4 h-4 rounded-full border-2 border-[#111827] bg-white shrink-0"></div>
                  <!-- Linking vector line -->
                  <div class="h-[2px] flex-1 bg-gray-200 relative overflow-hidden">
                     <div class="absolute inset-0 bg-[#111827] w-1/2"></div>
                  </div>
                  <!-- Step 2 Circle -->
                  <div class="w-4 h-4 rounded-full bg-[#111827] flex items-center justify-center shrink-0">
                     <svg width="8" height="8" viewBox="0 0 24 24" fill="white"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"></path></svg>
                  </div>
               </div>
               <div class="flex flex-col gap-2 px-1">
                  <div class="h-1.5 w-full bg-[#F3F4F6] rounded-full"></div>
                  <div class="h-1.5 w-[60%] bg-[#F3F4F6] rounded-full"></div>
               </div>
            </div>
          </div>
          <!-- Content -->
          <div class="p-8 pt-2 text-white">
            <h3 class="text-[18px] font-bold font-sans tracking-tight mb-3">
              True End-to-End.
            </h3>
            <p class="text-[13.5px] text-gray-300 font-medium leading-relaxed">
              From a single brief, your content goes live. Xeni generates the
              visual, writes the caption, schedules publishing, and
              auto-replies.
            </p>
          </div>
        </div>

        <!-- Card 3: Your Brand, Every Time -->
        <div
          class="flex-shrink-0 h-[420px] bg-[#F3F4F6] rounded-[20px] flex flex-col justify-between relative overflow-hidden group"
        >
          <!-- Top Visual Area: Style Matrix (Zero Rotations) -->
          <div class="relative w-full h-[220px] flex flex-col items-center justify-center pt-6 gap-3">
            <!-- DNA Icon Top Left -->
            <div
              class="absolute top-6 left-6 w-8 h-8 rounded-lg bg-[#111827] text-white flex items-center justify-center z-10"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"><path d="M4 18c3 0 5-12 8-12s5 12 8 12"></path><path d="M4 6c3 0 5 12 8 12s5-12 8-12" opacity="0.4"></path><line x1="8" y1="10" x2="8" y2="14"></line><line x1="16" y1="10" x2="16" y2="14"></line></svg>
            </div>

            <!-- DNA Watermark subtle -->
            <div class="absolute inset-0 overflow-hidden opacity-[0.03] pointer-events-none">
              <svg class="absolute w-full h-full text-[#111827] scale-125" fill="none" stroke="currentColor" stroke-width="1"><path d="M0 50 Q 50 0, 100 50 T 200 50 T 300 50"></path><path d="M0 50 Q 50 100, 100 50 T 200 50 T 300 50"></path></svg>
            </div>

            <!-- Style Block 1: Color Spectrums (Flat, Straight) -->
            <div class="w-[80%] bg-white rounded-xl border border-gray-100 p-4 flex items-center justify-between relative z-10">
               <div class="flex gap-2">
                  <div class="w-6 h-6 rounded-md bg-[#111827]"></div>
                  <div class="w-6 h-6 rounded-md bg-[#6366F1]"></div>
                  <div class="w-6 h-6 rounded-md bg-[#94A3B8]"></div>
               </div>
               <div class="h-2 w-16 bg-gray-100 rounded-full"></div>
            </div>

            <!-- Style Block 2: Typography Grid (Flat, Straight) -->
            <div class="w-[80%] bg-white rounded-xl border border-gray-100 p-3.5 flex items-center gap-4 relative z-10">
               <div class="w-8 h-8 rounded-lg bg-[#F8FAFC] text-[#111827] font-bold flex items-center justify-center text-sm border border-gray-100">Aa</div>
               <div class="flex-1 flex flex-col gap-1.5">
                  <div class="h-1.5 w-full bg-gray-200 rounded-full"></div>
                  <div class="h-1.5 w-[70%] bg-gray-100 rounded-full"></div>
               </div>
            </div>
          </div>
          <!-- Content -->
          <div class="p-8 pt-2">
            <h3
              class="text-[18px] font-bold text-[#111827] font-sans tracking-tight mb-3"
            >
              DNA, Every Time.
            </h3>
            <p class="text-[13.5px] text-[#667085] font-medium leading-relaxed">
              With Business DNA. Xeni matches your colors, fonts, and tone.
              Upload your products once, and your identity carries across every
              post.
            </p>
          </div>
        </div>

        <!-- Card 4: Autopilot -->
        <div
          class="flex-shrink-0 h-[420px] bg-[#F3F4F6] rounded-[20px] flex flex-col justify-between relative overflow-hidden group"
        >
          <!-- Top Visual Area: Symmetrical Command Grid -->
          <div class="relative w-full h-[220px] flex items-center justify-center pt-6">
            <!-- Icon Top Left -->
            <div
              class="absolute top-6 left-6 w-8 h-8 rounded-lg bg-[#111827] text-white flex items-center justify-center z-20"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>

            <!-- Perfect Symmetrical Logic Grid -->
            <div class="w-[75%] bg-white rounded-xl border border-gray-100 p-5 flex flex-col items-center gap-4 relative z-10">
               <div class="grid grid-cols-4 gap-2.5 w-full">
                  <div class="aspect-square bg-gray-50 rounded-md"></div>
                  <div class="aspect-square bg-[#111827] rounded-md flex items-center justify-center text-white">
                     <div class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></div>
                  </div>
                  <div class="aspect-square bg-gray-50 rounded-md"></div>
                  <div class="aspect-square bg-gray-50 rounded-md"></div>
               </div>
               <!-- Centered Neutral Timestamp Badge -->
               <div class="px-2.5 py-0.5 bg-gray-50 border border-gray-100 rounded-full flex items-center gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                  <span class="text-[9px] font-bold text-[#64748b] font-mono tracking-tight">02:00 AM</span>
               </div>
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 pt-2">
            <h3
              class="text-[18px] font-bold text-[#111827] font-sans tracking-tight mb-3"
            >
              Runs on Autopilot.
            </h3>
            <p class="text-[13.5px] text-[#667085] font-medium leading-relaxed">
              Set your calendar, and Xeni produces drafts. It scans trends and
              weaves insights in your brand voice. You review, and the engine
              runs.
            </p>
          </div>
        </div>
      </div>

      <!-- Data Metrics Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <!-- Stat 1 -->
        <div
          class="flex flex-col items-center md:items-start text-center md:text-left"
        >
          <div
            class="text-[32px] md:text-[45px] font-bold text-[#111827] font-sans tracking-tight flex items-center gap-1 mb-1"
          >
            <span class="text-[24px] md:text-[32px] transform -translate-y-1"
              >↑</span
            >10x
          </div>
          <p
            class="text-[12px] md:text-[13px] text-[#667085] font-medium font-geist uppercase tracking-wider"
          >
            Faster Content Output
          </p>
        </div>
        <!-- Stat 2 -->
        <div
          class="flex flex-col items-center md:items-start text-center md:text-left"
        >
          <div
            class="text-[32px] md:text-[45px] font-bold text-[#111827] font-sans tracking-tight flex items-center gap-1 mb-1"
          >
            <span class="text-[24px] md:text-[32px] transform -translate-y-1"
              >↓</span
            >85%
          </div>
          <p
            class="text-[12px] md:text-[13px] text-[#667085] font-medium font-geist uppercase tracking-wider"
          >
            Lower Content Costs
          </p>
        </div>
        <!-- Stat 3 -->
        <div
          class="flex flex-col items-center md:items-start text-center md:text-left"
        >
          <div
            class="text-[32px] md:text-[45px] font-bold text-[#111827] font-sans tracking-tight flex items-center gap-1 mb-1"
          >
            <span class="text-[24px] md:text-[32px] transform -translate-y-1"
              >↑</span
            >90%
          </div>
          <p
            class="text-[12px] md:text-[13px] text-[#667085] font-medium font-geist uppercase tracking-wider"
          >
            Operating Efficiency
          </p>
        </div>
        <!-- Stat 4 -->
        <div
          class="flex flex-col items-center md:items-start text-center md:text-left"
        >
          <div
            class="text-[32px] md:text-[45px] font-bold text-[#111827] font-sans tracking-tight flex items-center gap-1 mb-1"
          >
            <span class="text-[24px] md:text-[32px] transform -translate-y-1"
              >↑</span
            >3x
          </div>
          <p
            class="text-[12px] md:text-[13px] text-[#667085] font-medium font-geist uppercase tracking-wider"
          >
            Organic Engagement
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
