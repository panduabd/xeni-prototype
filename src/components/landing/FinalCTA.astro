---
import LandingButton from "./LandingButton.astro";
---

<section
  class="w-full pb-12 md:pb-20 bg-white select-none"
>
  <div class="max-w-7xl mx-auto px-6">
    <!-- Wrapped Grey Capsule Containment -->
    <div class="bg-[#F3F4F6] rounded-[2.5rem] p-10 md:p-16 lg:p-20 flex flex-col items-start border border-gray-200/40">
      <h2
        class="text-[28px] md:text-[42px] font-normal text-[#111827] font-fraunces tracking-tight leading-tight mb-5 max-w-2xl"
      >
        Your content calendar will <br />
        never be empty again.
      </h2>
      <p
        class="text-[15px] md:text-[17px] text-[#4B5563] font-medium font-geist max-w-2xl mb-10 leading-relaxed"
      >
        Join the brands already running on Xeni. Creative work, done overnight.
        Approved by morning. Published on schedule. It's not magic—it's just your
        AI team, working.
      </p>

      <div class="flex flex-col sm:flex-row items-start justify-start gap-3 mb-6">
        <LandingButton variant="primary" size="medium" href="/login"
          >Start for free</LandingButton
        >
      </div>

      <p class="text-[12px] text-[#667085] font-medium font-geist">
        No credit card required
      </p>
    </div>
  </div>
</section>
