---
// AiTrainedOn.astro - Fully synchronized with Hero Badge Anatomy (Including Icons)

const leftItems = [
  {
    label: "Your Business DNA",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5"/><path d="m4 14 8-8 8 8"/><path d="m19 21-7-8-5 5"/></svg>`
  },
  {
    label: "Real-Time Trends Data",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 7L13.5 15.5L8.5 10.5L2 17"/><path d="M16 7H22V13"/></svg>`
  },
  {
    label: "Sample Ads Data",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2V15H6L11 19V5Z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>`
  }
];

const rightItems = [
  {
    label: "Platform Best Practices",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`
  },
  {
    label: "High-Engagement Patterns",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.78-8.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`
  },
  {
    label: "Historical Performance",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/><path d="M3.05 11a9 9 0 1 1 .5 4"/></svg>`
  }
];
---

<section class="w-full py-20 md:py-28 bg-transparent relative select-none overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 lg:px-2">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <h2 class="text-[26px] md:text-[36px] font-normal text-[#111827] tracking-tight leading-[1.1] font-fraunces">
        The Intelligence Layer
        <br />
        <span class="text-[#667085] text-[17px] md:text-[20px] font-geist block mt-2 tracking-tight font-medium">
          AI that knows your brand, your market, and your moment.
        </span>
      </h2>
    </div>

    <!-- The Master Diagram Grid -->
    <div class="relative w-full flex flex-col lg:flex-row items-center justify-between gap-4 min-h-[420px] lg:min-h-[450px]">
      
      <!-- RECALIBRATED SVG OVERLAY -->
      <div class="absolute inset-0 w-full h-full pointer-events-none hidden lg:block z-0">
         <svg class="w-full h-full" viewBox="0 0 1100 450" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g stroke="#94A3B8" stroke-width="2" stroke-linecap="round" opacity="0.7">
               <!-- LEFT CONVERGING LINES TO CENTER -->
               <path d="M 350 133 C 450 133, 450 225, 550 225" />
               <path d="M 350 225 L 550 225" />
               <path d="M 350 317 C 450 317, 450 225, 550 225" />

               <!-- RIGHT RADIATING LINES FROM CENTER -->
               <path d="M 550 225 C 650 225, 650 133, 750 133" />
               <path d="M 550 225 L 750 225" />
               <path d="M 550 225 C 650 225, 650 317, 750 317" />
            </g>
            
            <!-- Terminal Dots -->
            <circle cx="550" cy="225" r="2.5" fill="#64748B" />
         </svg>
      </div>

      <!-- LEFT WING: Cards with Icons -->
      <div class="order-2 lg:order-1 flex flex-col items-center lg:items-end gap-6 w-full lg:w-[32%] relative z-10">
         {leftItems.map((item) => (
            <div class="group w-full max-w-[290px] h-[68px] bg-white/85 backdrop-blur-md border border-gray-200/80 rounded-full shadow-[0_8px_24px_rgba(0,0,0,0.03)] flex items-center gap-3 px-6 transform transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.06)] hover:border-blue-400/40 cursor-default">
               <div class="text-[#667085] flex-shrink-0 group-hover:text-blue-600 transition-colors duration-300" set:html={item.icon}></div>
               <span class="text-[13px] md:text-[14px] font-semibold text-[#111827] font-geist leading-tight group-hover:text-blue-600 transition-colors duration-300 tracking-tight whitespace-nowrap">{item.label}</span>
            </div>
         ))}
      </div>

      <!-- CENTER HUB -->
      <div class="order-1 lg:order-2 flex items-center justify-center w-full lg:w-[20%] relative z-20 py-8 lg:py-0">
         <div class="relative">
            <div class="absolute inset-0 bg-blue-500/10 blur-3xl opacity-60 rounded-full"></div>
            <div class="relative w-28 h-28 md:w-32 md:h-32 rounded-[36px] bg-white shadow-[0_15px_40px_-10px_rgba(0,0,0,0.08)] border-2 border-white flex items-center justify-center transition-transform duration-500 hover:scale-105 hover:rotate-1">
               <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="48"
                  height="48"
                  fill="currentColor"
                  viewBox="0 0 256 256"
                  class="text-blue-600 filter drop-shadow-sm transition-transform duration-700 hover:scale-110"
               >
                  <path
                     d="M200,204.5V232a8,8,0,0,1-16,0V204.5a63.67,63.67,0,0,0-35.38-57.25l-48.4-24.19A79.58,79.58,0,0,1,56,51.5V24a8,8,0,0,1,16,0V51.5a63.67,63.67,0,0,0,35.38,57.25l48.4,24.19A79.58,79.58,0,0,1,200,204.5ZM160,200H72.17a63.59,63.59,0,0,1,3.23-16h72.71a8,8,0,0,0,0-16H83.46a63.71,63.71,0,0,1,14.65-15.08A8,8,0,1,0,88.64,140,80.27,80.27,0,0,0,56,204.5V232a8,8,0,0,0,16,0V216h88a8,8,0,0,0,0-16ZM192,16a8,8,0,0,0-8,8V40H96a8,8,0,0,0,0,16h87.83a63.59,63.59,0,0,1-3.23,16H107.89a8,8,0,1,0,0,16h64.65a63.71,63.71,0,0,1-14.65,15.08,8,8,0,0,0,9.47,12.9A80.27,80.27,0,0,0,200,51.5V24A8,8,0,0,0,192,16Z"
                  ></path>
               </svg>
            </div>
         </div>
      </div>

      <!-- RIGHT WING: Cards with Icons -->
      <div class="order-3 lg:order-3 flex flex-col items-center lg:items-start gap-6 w-full lg:w-[32%] relative z-10">
         {rightItems.map((item) => (
            <div class="group w-full max-w-[290px] h-[68px] bg-white/85 backdrop-blur-md border border-gray-200/80 rounded-full shadow-[0_8px_24px_rgba(0,0,0,0.03)] flex items-center gap-3 px-6 transform transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.06)] hover:border-blue-400/40 cursor-default">
               <div class="text-[#667085] flex-shrink-0 group-hover:text-blue-600 transition-colors duration-300" set:html={item.icon}></div>
               <span class="text-[13px] md:text-[14px] font-semibold text-[#111827] font-geist leading-tight group-hover:text-blue-600 transition-colors duration-300 tracking-tight whitespace-nowrap">{item.label}</span>
            </div>
         ))}
      </div>

    </div>

  </div>
</section>
