---
// Interactive Stepper - Grayscale Aesthetic (Flat, No Shadows)
const steps = [
  {
    id: "dna",
    number: "01",
    title: "Build Your Business DNA.",
    description: "Upload your logo, pick your colors, and add your products. Xeni captures your brand identity—your voice, your visuals, your catalog—so every output consistently feels like you. New? Just create from the scratch with Xeni.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"><path d="M4 18c3 0 5-12 8-12s5 12 8 12"></path><path d="M4 6c3 0 5 12 8 12s5-12 8-12" opacity="0.4"></path><line x1="8" y1="10" x2="8" y2="14"></line><line x1="16" y1="10" x2="16" y2="14"></line></svg>`
  },
  {
    id: "calendar",
    number: "02",
    title: "Set Your Content Calendar.",
    description: "Pick your dates, choose your content types, and set a recurring schedule. Xeni's engine runs daily at 2 AM, generating drafts automatically on the dates you've selected.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>`
  },
  {
    id: "brief",
    number: "03",
    title: "Brief It. Or Let It Run.",
    description: "For one-off content, describe what you need—tone, topic, or format. For scheduled posts, Xeni pulls from your calendar and trending insights. Either way, complete posts land in your queue.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>`
  },
  {
    id: "approve",
    number: "04",
    title: "Approve. Tweak. Go Live.",
    description: "Every draft waits for your approval. Edit captions, tweak visuals, or hit approve. Publishing is automatic across your connected platforms.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
  },
  {
    id: "autopilot",
    number: "05",
    title: "Engagement on Autopilot.",
    description: "While you're offline, Xeni auto-replies to comments—answering FAQs, sharing links, or thanking your audience. Your community stays engaged, hands-free.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m21 11-8-8-8 8"/><path d="M21 21H3"/><path d="M13 3v18"/></svg>`
  }
];
---

<!-- Overflow removed to fully activate browser sticky functionality! -->
<section id="how-it-works" class="w-full py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Navigation: Clean static stack -->
      <div class="lg:col-span-5 flex flex-col gap-8">
        
        <!-- Precision Title Scaled to 36px to match visual hierarchy standard -->
        <div class="mb-4">
          <h2 class="text-[26px] md:text-[36px] font-normal font-fraunces tracking-tight text-[#111827] leading-[1.15]">
            How it works
          </h2>
        </div>

        <div class="flex flex-col space-y-2 relative">
          {steps.map((step, index) => (
            <button
              data-step-id={step.id}
              class={`step-trigger w-full text-left transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] group outline-none
                ${index === 0 ? 'active' : ''}`}
            >
              <!-- Flat pure border, NO SHADOWS -->
              <div class="p-4 rounded-xl border border-transparent flex gap-5 transition-all duration-500 ease-out
                          group-[.active]:bg-[#F9FAFB] group-[.active]:border-[#F2F4F7]">
                
                <!-- Icon Pillar -->
                <div class="pt-1 shrink-0">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center transition-colors duration-300
                              text-zinc-400 bg-transparent border border-zinc-200
                              group-[.active]:bg-[#111827] group-[.active]:text-white group-[.active]:border-[#111827]">
                    <Fragment set:html={step.icon} />
                  </div>
                </div>

                <!-- Text Block -->
                <div class="flex flex-col gap-1 pt-2.5">
                  <h3 class="text-[17px] font-bold text-zinc-500 transition-colors duration-300 group-[.active]:text-[#111827] font-sans leading-tight">
                    {step.title}
                  </h3>
                  <!-- Expanding Description via grid layout -->
                  <div class="grid grid-rows-[0fr] transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] opacity-0 group-[.active]:opacity-100 group-[.active]:grid-rows-[1fr] overflow-hidden">
                    <div class="min-h-0">
                      <p class="text-[14px] font-medium text-[#667085] leading-relaxed mt-2 pr-4">
                        {step.description}
                      </p>
                    </div>
                  </div>
                </div>

              </div>
            </button>
          ))}
        </div>

      </div>

      <!-- Right Stage (Cinematic Grayscale Sandbox - Sticky Enabled) -->
      <div class="lg:col-span-7 w-full lg:sticky lg:top-28 aspect-[4/3] md:aspect-[16/11] relative group/sandbox">
        <div class="absolute inset-0 bg-gradient-to-b from-zinc-900 via-zinc-800 to-zinc-900 rounded-[20px] p-8 md:p-12 flex items-center justify-center overflow-hidden border border-zinc-800">
          
          <!-- Sandbox Glow / Grain -->
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white/10 to-transparent opacity-40 pointer-events-none"></div>

          <!-- Visual Stage Container -->
          <div class="relative w-full h-full max-w-lg mx-auto flex items-center justify-center" id="sandbox-stage">
            
            <!-- [01] Visual: DNA Stage -->
            <div data-visual="dna" class="visual-content absolute inset-0 opacity-0 translate-y-8 scale-95 transition-all duration-700 ease-out flex items-center justify-center pointer-events-none">
              <div class="w-[85%] aspect-[4/3] bg-white rounded-xl border border-gray-100 p-6 flex flex-col gap-5 relative transform rotate-2 hover:rotate-0 transition-transform duration-500">
                <div class="flex justify-between items-center border-b border-gray-100 pb-3">
                  <div class="w-16 h-3 bg-zinc-900 rounded-full"></div>
                  <div class="w-6 h-6 rounded-full border-2 border-zinc-200 flex items-center justify-center text-zinc-800 text-[9px] font-bold">BD</div>
                </div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="aspect-square rounded-lg bg-zinc-900 border border-zinc-800"></div>
                  <div class="aspect-square rounded-lg bg-zinc-500"></div>
                  <div class="aspect-square rounded-lg bg-zinc-200"></div>
                </div>
                <div class="flex-1 border border-gray-100 rounded-lg bg-gray-50/50 p-3 flex flex-col gap-2">
                  <div class="w-[60%] h-2.5 bg-zinc-300 rounded-full"></div>
                  <div class="w-[80%] h-2 bg-zinc-200 rounded-full"></div>
                  <div class="w-[40%] h-2 bg-zinc-200 rounded-full"></div>
                </div>
                <!-- Restoring visual DNA graphic layer -->
                <div class="absolute top-0 right-0 w-24 h-full opacity-5 overflow-hidden pointer-events-none">
                   <svg class="h-full text-black" fill="none" stroke="currentColor" stroke-width="3"><path d="M10 0 Q 30 50, 10 100 T 10 200" /><path d="M30 0 Q 10 50, 30 100 T 30 200" /></svg>
                </div>
              </div>
            </div>

            <!-- [02] Visual: Calendar Stage -->
            <div data-visual="calendar" class="visual-content absolute inset-0 opacity-0 translate-y-8 scale-95 transition-all duration-700 ease-out flex items-center justify-center pointer-events-none">
              <div class="w-[85%] aspect-[4/3] bg-white rounded-xl border border-gray-100 p-6 flex flex-col relative transform -rotate-1">
                 <div class="flex items-center gap-3 mb-5">
                    <div class="w-20 h-3.5 bg-zinc-900 rounded-full"></div>
                    <div class="ml-auto w-6 h-3 bg-zinc-200 rounded-full"></div>
                 </div>
                 <div class="grid grid-cols-7 gap-2 flex-1">
                   {Array.from({length: 28}).map((_, i) => (
                     <div class={`rounded-md flex items-center justify-center text-[10px] font-semibold ${i === 11 || i === 15 ? 'bg-zinc-900 text-white border border-zinc-900 transform scale-105' : 'bg-gray-50 text-zinc-400'}`}>
                        {i + 1}
                     </div>
                   ))}
                 </div>
                 <div class="absolute -bottom-4 -right-4 bg-white p-3 border border-gray-200 rounded-xl flex items-center gap-2 transform rotate-3">
                    <div class="w-2 h-2 rounded-full bg-zinc-900 animate-pulse"></div>
                    <div class="w-16 h-2 bg-zinc-200 rounded-full"></div>
                 </div>
              </div>
            </div>

            <!-- [03] Visual: Brief Stage -->
            <div data-visual="brief" class="visual-content absolute inset-0 opacity-0 translate-y-8 scale-95 transition-all duration-700 ease-out flex items-center justify-center pointer-events-none">
              <div class="w-full flex flex-col items-center gap-4">
                <div class="w-[75%] bg-white p-4 rounded-xl transform -rotate-1 self-start flex flex-col gap-2 relative z-10 border border-gray-100">
                   <div class="h-2 w-full bg-zinc-900 rounded-full"></div>
                   <div class="h-2 w-[70%] bg-zinc-900 rounded-full"></div>
                </div>
                <div class="w-6 h-6 flex items-center justify-center text-white my-[-8px] opacity-50 z-10">
                   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                </div>
                <div class="w-[80%] aspect-video bg-white rounded-lg border border-gray-200 p-4 flex gap-4 relative overflow-hidden transform rotate-1 self-end">
                  <div class="w-[35%] h-full bg-zinc-100 rounded-md flex items-center justify-center">
                     <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="zinc-400" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  </div>
                  <div class="flex-1 flex flex-col justify-center gap-2">
                     <div class="h-2.5 w-full bg-zinc-900 rounded-full"></div>
                     <div class="h-2.5 w-[85%] bg-zinc-400 rounded-full"></div>
                     <div class="h-2 w-[40%] bg-zinc-200 rounded-full mt-2"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- [04] Visual: Approve Stage -->
            <div data-visual="approve" class="visual-content absolute inset-0 opacity-0 translate-y-8 scale-95 transition-all duration-700 ease-out flex items-center justify-center pointer-events-none">
              <div class="w-[70%] aspect-[3/4] bg-white rounded-[20px] border border-gray-200 overflow-hidden flex flex-col relative group-hover/sandbox:scale-[1.02] transition-transform duration-700">
                <div class="w-full aspect-square bg-zinc-100 flex items-center justify-center p-8">
                  <div class="w-full h-full border-[3px] border-dashed border-zinc-300 rounded-xl bg-white flex flex-col items-center justify-center relative">
                      <div class="w-12 h-12 rounded-full bg-zinc-900 text-white flex items-center justify-center mb-2 z-10">
                         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                      </div>
                      <div class="h-1.5 w-16 bg-zinc-200 rounded-full z-10"></div>
                  </div>
                </div>
                <div class="p-5 flex flex-col gap-2 border-t border-gray-100 bg-white">
                   <div class="h-2.5 w-full bg-zinc-900 rounded-full"></div>
                   <div class="h-2 w-[60%] bg-zinc-400 rounded-full mb-3"></div>
                   <div class="grid grid-cols-2 gap-2 pt-2">
                      <div class="h-8 rounded-lg border border-zinc-200 flex items-center justify-center text-[11px] font-bold text-zinc-600">Tweak</div>
                      <div class="h-8 rounded-lg bg-zinc-900 flex items-center justify-center text-[11px] font-bold text-white">Approve</div>
                   </div>
                </div>
              </div>
            </div>

            <!-- [05] Visual: Autopilot Stage -->
            <div data-visual="autopilot" class="visual-content absolute inset-0 opacity-0 translate-y-8 scale-95 transition-all duration-700 ease-out flex items-center justify-center pointer-events-none">
              <div class="w-full relative">
                 <div class="w-[85%] aspect-[16/10] bg-white rounded-xl p-4 mx-auto transform scale-90 border border-gray-100">
                    <div class="flex items-center gap-3 border-b border-gray-100 pb-3">
                       <div class="w-8 h-8 rounded-full bg-zinc-200"></div>
                       <div class="h-2 w-24 bg-zinc-200 rounded-full"></div>
                    </div>
                 </div>
                 <div class="absolute top-6 left-4 w-[70%] bg-zinc-50 rounded-xl p-3 border border-gray-200 transform -rotate-2 z-20">
                    <div class="flex items-center gap-2 mb-1">
                       <div class="w-4 h-4 rounded-full bg-zinc-300"></div>
                       <div class="h-1.5 w-16 bg-zinc-300 rounded-full"></div>
                    </div>
                    <div class="h-1.5 w-[85%] bg-zinc-300 rounded-full ml-6"></div>
                 </div>
                 <div class="absolute top-16 right-4 w-[70%] bg-zinc-900 rounded-xl p-3 border border-zinc-700 transform rotate-1 z-30">
                    <div class="flex items-center gap-2 mb-2">
                       <div class="w-5 h-5 rounded-full bg-white flex items-center justify-center text-[9px] font-bold">X</div>
                       <div class="h-1.5 w-12 bg-white/40 rounded-full"></div>
                       <div class="ml-auto px-1.5 py-0.5 rounded-full bg-white/10 text-[8px] text-white font-bold">Auto</div>
                    </div>
                    <div class="h-1.5 w-[90%] bg-white/90 rounded-full ml-7 mb-1"></div>
                    <div class="h-1.5 w-[60%] bg-white/90 rounded-full ml-7"></div>
                 </div>
                 <div class="absolute top-32 left-8 w-[65%] bg-white rounded-xl p-3 border border-gray-200 transform rotate-1 z-10 opacity-60">
                     <div class="flex items-center gap-2">
                        <div class="w-4 h-4 rounded-full bg-zinc-200"></div>
                        <div class="h-1.5 w-[60%] bg-zinc-200 rounded-full"></div>
                     </div>
                 </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .visual-content.active {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const triggers = document.querySelectorAll(".step-trigger");
    const contents = document.querySelectorAll(".visual-content");

    function setActiveStep(stepId) {
      triggers.forEach(btn => {
        if (btn.getAttribute("data-step-id") === stepId) {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });

      contents.forEach(visual => {
        if (visual.getAttribute("data-visual") === stepId) {
          visual.classList.add("active");
        } else {
          visual.classList.remove("active");
        }
      });
    }

    // Primary State Initialize
    setActiveStep("dna");

    // Assign Event Listeners for Pure Explicit Click Control
    triggers.forEach(trigger => {
      trigger.addEventListener("click", () => {
        const stepId = trigger.getAttribute("data-step-id");
        setActiveStep(stepId);
      });
    });
  });
</script>
