---
// src/components/modals/ManageAccountModal.astro
---

<style is:global>
  #manage-account-modal::-webkit-scrollbar {
    width: 4px;
  }
  #manage-account-content::-webkit-scrollbar {
    width: 4px;
  }
  #manage-account-content::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 10px;
  }
</style>

<div
  id="manage-account-modal"
  class="hidden fixed inset-0 z-[150] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200"
>
  <div
    class="bg-white w-full max-w-5xl h-[640px] rounded-[32px] shadow-2xl flex overflow-hidden animate-in zoom-in-95 duration-300 relative border border-[#eaecf0]"
  >
    <!-- Close Button (Top Right of Content Panel) -->
    <button
      id="close-manage-account"
      class="absolute top-6 right-6 w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer"
    >
      <i class="ti ti-x text-[20px]"></i>
    </button>

    <!-- LEFT SIDEBAR: NAVIGATION -->
    <aside class="w-[240px] bg-[#F9FAFB] border-r border-[#eaecf0] p-6 flex flex-col gap-6 shrink-0">
      <div>
        <h2 class="text-[14px] font-extrabold text-[#98a2b3] uppercase tracking-wider mb-4">Manage Account</h2>
        <div class="flex flex-col gap-1">
          <!-- Profile Tab Button -->
          <button
            id="tab-btn-profile"
            class="manage-account-tab-btn flex items-center gap-3 px-3 h-10 rounded-xl text-[13px] font-bold text-[#111827] bg-[#F3F4F6] transition-all cursor-pointer text-left w-full"
            data-tab="profile"
          >
            <i class="ti ti-user-circle text-[16px]"></i>
            Profile
          </button>
          <!-- Subscription Tab Button -->
          <button
            id="tab-btn-subscription"
            class="manage-account-tab-btn flex items-center gap-3 px-3 h-10 rounded-xl text-[13px] font-medium text-[#667085] hover:bg-[#F3F4F6] hover:text-[#111827] transition-all cursor-pointer text-left w-full"
            data-tab="subscription"
          >
            <i class="ti ti-bolt text-[16px]"></i>
            Subscription
          </button>
          <!-- Billing Tab Button -->
          <button
            id="tab-btn-billing"
            class="manage-account-tab-btn flex items-center gap-3 px-3 h-10 rounded-xl text-[13px] font-medium text-[#667085] hover:bg-[#F3F4F6] hover:text-[#111827] transition-all cursor-pointer text-left w-full"
            data-tab="billing"
          >
            <i class="ti ti-credit-card text-[16px]"></i>
            Billing
          </button>
        </div>
      </div>
    </aside>

    <!-- RIGHT PANEL: CONTENT -->
    <main id="manage-account-content" class="flex-1 p-10 overflow-y-auto bg-white relative">
      
      <!-- ══════════ PROFILE TAB CONTENT ══════════ -->
      <section id="manage-account-tab-profile" class="manage-account-tab-section space-y-8">
        <div>
          <h3 class="text-[18px] font-bold text-[#111827] tracking-tight mb-6">Account Info</h3>
          
          <!-- Avatar Row -->
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 rounded-full bg-[#111827] text-white flex items-center justify-center text-[22px] font-extrabold shadow-sm border-2 border-white relative overflow-hidden">
              <img
                src="https://api.dicebear.com/7.x/avataaars/svg?seed=Jane"
                class="w-full h-full object-cover"
                alt="avatar"
              />
            </div>
            <div>
              <p class="text-[15px] font-bold text-[#111827]">Jane Cooper</p>
              <p class="text-[12px] text-[#667085]">jane@xeni.io</p>
            </div>
            <button class="ml-auto px-4 h-9 rounded-xl border border-[#eaecf0] bg-white text-[12px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer shadow-sm">
              Change avatar
            </button>
          </div>

          <!-- Fields -->
          <div class="space-y-4 border-t border-[#eaecf0] pt-6">
            <div class="flex items-center justify-between py-2">
              <span class="text-[13px] font-bold text-[#344054]">User Name</span>
              <div class="flex items-center gap-1.5">
                <span class="text-[13px] font-medium text-[#111827]">Jane Cooper</span>
                <button class="text-[#98a2b3] hover:text-[#111827] transition-colors"><i class="ti ti-pencil text-[14px]"></i></button>
              </div>
            </div>
            <div class="flex items-center justify-between py-2 border-t border-[#f2f4f7]">
              <span class="text-[13px] font-bold text-[#344054]">Email Address</span>
              <span class="text-[13px] font-medium text-[#667085]">jane@xeni.io</span>
            </div>
          </div>
        </div>

        <!-- Device Management -->
        <div class="border-t border-[#eaecf0] pt-8 space-y-6">
          <div>
            <h4 class="text-[15px] font-bold text-[#111827] mb-1">Device Management</h4>
            <p class="text-[12px] text-[#667085] leading-relaxed max-w-2xl">
              Xeni accounts are for individual use only. To prevent abuse and ensure platform stability, tasks can run simultaneously on up to 2 desktop Web sessions and 1 mobile Web session. For team or multi-user use, please purchase the Team Plan.
            </p>
          </div>

          <div class="flex items-center justify-between p-4 rounded-2xl bg-red-50/50 border border-red-100">
            <div>
              <p class="text-[13px] font-bold text-red-900">Remove all devices</p>
              <p class="text-[11px] text-red-700 mt-0.5">Logout of all other active browser sessions globally.</p>
            </div>
            <button class="px-4 h-9 rounded-xl bg-red-50 text-red-700 text-[12px] font-bold hover:bg-red-100 transition-all cursor-pointer">
              Remove all devices
            </button>
          </div>

          <!-- Devices Table -->
          <div class="border border-[#eaecf0] rounded-2xl overflow-hidden">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-[#F9FAFB] border-b border-[#eaecf0]">
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Online Status</th>
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Device Information</th>
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider text-right">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[#eaecf0] text-[12px]">
                <tr>
                  <td class="px-4 py-3 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    <span class="font-medium text-[#111827]">Active</span>
                  </td>
                  <td class="px-4 py-3 text-[#667085] font-medium">Desktop | macOS | Chrome Browser | 180.252.12.1</td>
                  <td class="px-4 py-3 text-right">
                    <span class="text-[11px] text-[#98a2b3] font-bold uppercase tracking-wider">Current device</span>
                  </td>
                </tr>
                <tr>
                  <td class="px-4 py-3 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                    <span class="font-medium text-[#667085]">Offline</span>
                  </td>
                  <td class="px-4 py-3 text-[#667085] font-medium">Mobile | iOS | Safari Browser | 180.252.12.4</td>
                  <td class="px-4 py-3 text-right">
                    <button class="px-3 py-1 rounded-lg border border-[#eaecf0] bg-white text-[11px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-colors cursor-pointer">
                      Remove device
                    </button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ══════════ SUBSCRIPTION TAB CONTENT ══════════ -->
      <section id="manage-account-tab-subscription" class="manage-account-tab-section space-y-8 hidden">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-[20px] font-bold text-[#111827] tracking-tight">Subscription</h3>
            <p class="text-[13px] text-[#667085] mt-1">Manage your credit plan and billing cycles.</p>
          </div>
          <button class="px-6 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer">
            Upgrade Plan
          </button>
        </div>

        <!-- Plan Info Box -->
        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 rounded-2xl border border-[#eaecf0] bg-[#F9FAFB] space-y-2">
            <span class="text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Current Plan</span>
            <div class="flex items-baseline gap-2">
              <h4 class="text-[24px] font-extrabold text-[#111827]">Free Plan</h4>
              <span class="text-[12px] font-medium text-[#667085]">forever free</span>
            </div>
            <p class="text-[12px] text-[#667085] pt-1">Daily refresh limits are set to 300 credits.</p>
          </div>
          
          <div class="p-6 rounded-2xl border border-[#eaecf0] bg-[#F9FAFB] space-y-2">
            <span class="text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Credit Balance</span>
            <div class="flex items-baseline gap-1.5 text-[#111827]">
              <i class="ti ti-sparkles text-[20px]"></i>
              <h4 class="text-[24px] font-extrabold">300</h4>
              <span class="text-[12px] font-medium text-[#667085] ml-1">Credits left</span>
            </div>
            <p class="text-[12px] text-[#667085] pt-1">Refreshes to 300 credits daily at 00:00 UTC.</p>
          </div>
        </div>

        <!-- Usage Table -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <h4 class="text-[15px] font-bold text-[#111827]">Credits Usage History</h4>
            <div class="relative">
              <button class="flex items-center gap-1 px-3 h-8 rounded-full border border-[#D0D5DD] bg-white text-[11px] font-medium text-[#667085] hover:bg-[#F9FAFB] transition-all cursor-pointer select-none">
                <span>All History</span>
                <i class="ti ti-chevron-down text-[10px] ml-0.5 opacity-50"></i>
              </button>
            </div>
          </div>

          <div class="border border-[#eaecf0] rounded-2xl overflow-hidden">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-[#F9FAFB] border-b border-[#eaecf0]">
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Detail</th>
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Type</th>
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider">Date</th>
                  <th class="px-4 py-2.5 text-[11px] font-extrabold text-[#667085] uppercase tracking-wider text-right">Credits Change</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[#eaecf0] text-[12px]">
                <tr>
                  <td class="px-4 py-3.5 font-bold text-[#111827]">Daily Login Bonus</td>
                  <td class="px-4 py-3.5 text-[#667085]">Acquired</td>
                  <td class="px-4 py-3.5 text-[#98a2b3]">2026-05-08 04:14</td>
                  <td class="px-4 py-3.5 text-right font-extrabold text-green-600">+30</td>
                </tr>
                <tr>
                  <td class="px-4 py-3.5 font-bold text-[#111827]">Daily Bonus Credits Expired</td>
                  <td class="px-4 py-3.5 text-[#667085]">Consumed</td>
                  <td class="px-4 py-3.5 text-[#98a2b3]">2026-05-07 06:59</td>
                  <td class="px-4 py-3.5 text-right font-extrabold text-red-600">-30</td>
                </tr>
                <tr>
                  <td class="px-4 py-3.5 font-bold text-[#111827]">AI Asset Generation (Studio)</td>
                  <td class="px-4 py-3.5 text-[#667085]">Spent</td>
                  <td class="px-4 py-3.5 text-[#98a2b3]">2026-05-07 04:06</td>
                  <td class="px-4 py-3.5 text-right font-extrabold text-red-600">-50</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ══════════ BILLING TAB CONTENT ══════════ -->
      <section id="manage-account-tab-billing" class="manage-account-tab-section space-y-8 hidden">
        <div>
          <h3 class="text-[20px] font-bold text-[#111827] tracking-tight">Billing</h3>
          <p class="text-[13px] text-[#667085] mt-1">Review your invoices and invoice download history.</p>
        </div>

        <div class="h-64 border-2 border-dashed border-[#eaecf0] rounded-3xl flex flex-col items-center justify-center p-6 bg-[#F9FAFB]">
          <div class="w-12 h-12 rounded-full bg-white border border-[#eaecf0] flex items-center justify-center text-[#98a2b3] shadow-sm mb-3">
            <i class="ti ti-cloud text-[22px]"></i>
          </div>
          <span class="text-[14px] font-bold text-[#111827]">Oops.</span>
          <p class="text-[12px] text-[#667085] mt-1">No transaction history found on your account.</p>
        </div>
      </section>

    </main>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("manage-account-modal");
    const closeBtn = document.getElementById("close-manage-account");
    const tabButtons = document.querySelectorAll(".manage-account-tab-btn");
    const tabSections = document.querySelectorAll(".manage-account-tab-section");

    // Tab switcher logic
    function switchTab(tabId) {
      tabButtons.forEach(btn => {
        if (btn.getAttribute("data-tab") === tabId) {
          btn.classList.add("bg-[#F3F4F6]", "text-[#111827]", "font-bold");
          btn.classList.remove("text-[#667085]", "font-medium");
        } else {
          btn.classList.remove("bg-[#F3F4F6]", "text-[#111827]", "font-bold");
          btn.classList.add("text-[#667085]", "font-medium");
        }
      });

      tabSections.forEach(section => {
        if (section.id === `manage-account-tab-${tabId}`) {
          section.classList.remove("hidden");
        } else {
          section.classList.add("hidden");
        }
      });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const tabId = btn.getAttribute("data-tab");
        switchTab(tabId);
      });
    });

    if (closeBtn && modal) {
      closeBtn.addEventListener("click", () => {
        modal.classList.add("hidden");
      });
      modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.classList.add("hidden");
      });
    }

    // Global listener to trigger opening the modal and setting active tab
    window.addEventListener("open-manage-account", (e) => {
      if (modal) {
        modal.classList.remove("hidden");
        const activeTab = e.detail?.tab || "profile";
        switchTab(activeTab);
      }
    });
  });
</script>
