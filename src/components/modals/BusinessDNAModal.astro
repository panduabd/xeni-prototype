---
---
<style is:global>
  #dna-main-content::-webkit-scrollbar {
    width: 4px;
  }
  #dna-main-content::-webkit-scrollbar-track {
    background: transparent;
  }
  #dna-main-content::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 10px;
    transition: background 0.3s ease;
  }
  #dna-main-content.is-scrolling::-webkit-scrollbar-thumb {
    background: #D1D5DB;
  }
  #dna-main-content {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: scrollbar-color 0.3s ease;
  }
  #dna-main-content.is-scrolling {
    scrollbar-color: #D1D5DB transparent;
  }
</style>
<div id="business-dna-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/40 backdrop-blur-sm p-4 animate-in fade-in duration-200">
  <div class="bg-white w-full max-w-[540px] h-[480px] rounded-[32px] shadow-2xl flex flex-col overflow-hidden animate-in zoom-in-95 duration-300 relative">
    
    <!-- Close Button (Top Right Floating) -->
    <button id="close-business-dna" class="absolute top-5 right-5 w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors text-[#667085] z-30 cursor-pointer">
      <i class="ti ti-x text-[20px]"></i>
    </button>

    <!-- Header (No Border) -->
    <div class="px-7 pt-7 pb-3 bg-white relative z-20">
      <h2 class="text-[20px] font-bold text-[#111827] tracking-tight mb-0.5">Business DNA</h2>
      <p class="text-[13px] text-[#667085]">Select a business profile to ground your AI generation.</p>
    </div>

    <!-- Main Content Area (Scrollable) -->
    <div id="dna-main-content" class="flex-1 px-7 pb-24 overflow-y-auto scroll-smooth relative pt-2">
      <div class="space-y-2.5">
        <!-- DNA Item 1 -->
        <button class="dna-item w-full flex items-center gap-4 p-3.5 rounded-2xl border border-[#eaecf0] bg-white text-left transition-all hover:border-[#d0d5dd] hover:bg-gray-50 group cursor-pointer" data-name="Fresh Juice Co.">
          <div class="w-11 h-11 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0 group-hover:bg-white transition-colors">
            <i class="ti ti-brand-abstract text-[22px] text-[#667085]"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="text-[14px] font-bold text-[#111827]">Fresh Juice Co.</h4>
            <p class="text-[12px] text-[#667085] truncate">Organic beverage & lifestyle brand</p>
          </div>
          <div class="w-5 h-5 rounded-full bg-[#2563EB] flex items-center justify-center hidden check-badge">
            <i class="ti ti-check text-[12px] text-white"></i>
          </div>
        </button>

        <!-- DNA Item 2 -->
        <button class="dna-item w-full flex items-center gap-4 p-3.5 rounded-2xl border border-[#eaecf0] bg-white text-left transition-all hover:border-[#d0d5dd] hover:bg-gray-50 group cursor-pointer" data-name="Tech Startup">
          <div class="w-11 h-11 rounded-xl bg-[#F9FAFB] border border-[#eaecf0] flex items-center justify-center shrink-0 group-hover:bg-white transition-colors">
            <i class="ti ti-rocket text-[22px] text-[#667085]"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="text-[14px] font-bold text-[#111827]">Tech Startup</h4>
            <p class="text-[12px] text-[#667085] truncate">B2B SaaS platform for automation</p>
          </div>
          <div class="w-5 h-5 rounded-full bg-[#2563EB] flex items-center justify-center hidden check-badge">
            <i class="ti ti-check text-[12px] text-white"></i>
          </div>
        </button>

        <!-- Add New -->
        <button class="w-full flex items-center justify-center gap-2 p-3.5 rounded-2xl border border-dashed border-[#d0d5dd] text-[13px] font-bold text-[#667085] hover:border-[#2563EB] hover:bg-blue-50/10 hover:text-[#2563EB] transition-all cursor-pointer">
          <i class="ti ti-plus"></i>
          Create Business DNA
        </button>
      </div>
    </div>

    <!-- Floating Footer Buttons -->
    <div class="absolute bottom-7 right-7 flex items-center gap-3 z-30 pointer-events-none">
      <button class="pointer-events-auto btn-active-plate btn-active-bottom px-6 h-10 rounded-xl border border-[#eaecf0] bg-white text-[13px] font-bold text-[#344054] hover:bg-[#F9FAFB] transition-all cursor-pointer" id="cancel-business-dna">
        Cancel
      </button>
      <button class="pointer-events-auto btn-active-plate btn-active-dark btn-active-bottom px-8 h-10 rounded-xl bg-[#111827] text-white text-[13px] font-bold hover:bg-black transition-all cursor-pointer">
        Confirm
      </button>
    </div>

  </div>
</div>
