---
---

<div id="auth-screen" class="fixed inset-0 z-[9999] bg-white flex items-center justify-center p-6 text-foreground hidden">
  
  <div class="w-full max-w-sm relative bg-white border border-border/60 shadow-[0_4px_24px_rgb(0,0,0,0.04)] rounded-xl overflow-hidden shadow-sm">
    
    <div class="px-6 py-8 flex flex-col items-center text-center border-b border-border/40">
      <div class="w-12 h-12 rounded-lg bg-black flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
      </div>
      <h1 class="text-[18px] font-bold tracking-tight text-foreground mb-1">Restricted Area</h1>
      <p class="text-[13px] text-muted-foreground leading-relaxed">Enter your password to access the prototype.</p>
    </div>

    <form id="auth-form" class="p-6 bg-[#fafafa]/50 space-y-4">
      <div class="space-y-1.5 text-left">
        <label for="password-input" class="text-[12px] font-semibold text-foreground">Password</label>
        <input 
          type="password" 
          id="password-input" 
          placeholder="••••••••" 
          class="w-full bg-white border border-border/80 rounded-md py-2.5 px-3 text-[13px] focus:outline-none focus:ring-1 focus:ring-black focus:border-black transition-all placeholder:text-muted-foreground/50 text-foreground font-medium"
          required
        />
        <div id="auth-error" class="text-red-500 text-[11px] font-medium mt-1 hidden">
          Incorrect password.
        </div>
      </div>
      <button 
        type="submit" 
        class="w-full bg-black text-white font-medium text-[13px] py-2.5 rounded-md hover:bg-black/90 active:scale-[0.99] transition-all flex items-center justify-center gap-1.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Sign In
      </button>
    </form>
    
  </div>
  
  <div class="absolute bottom-6 left-0 right-0 text-center">
    <p class="text-[11px] text-muted-foreground/60">OiCrew Internal Prototype • Confidential</p>
  </div>
</div>

<div id="protected-content" class="hidden">
  <slot />
</div>

<script>
  const AUTH_KEY = 'oicrew_auth_success';
  const PASS = 'confidential123';
  
  const authScreen = document.getElementById('auth-screen');
  const content = document.getElementById('protected-content');
  const form = document.getElementById('auth-form');
  const input = document.getElementById('password-input') as HTMLInputElement;
  const error = document.getElementById('auth-error');

  const showContent = () => {
    if (authScreen) authScreen.classList.add('hidden');
    if (content) content.classList.remove('hidden');
  };

  const showAuth = () => {
    if (authScreen) authScreen.classList.remove('hidden');
    if (content) content.classList.add('hidden');
  };

  // Run immediately to prevent flicker
  if (sessionStorage.getItem(AUTH_KEY) === 'true') {
    showContent();
  } else {
    showAuth();
  }

  if (form && input && error) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (input.value === PASS) {
        sessionStorage.setItem(AUTH_KEY, 'true');
        showContent();
      } else {
        // Show error text
        error.classList.remove('hidden');
        input.classList.add('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
        
        // Reset input
        input.value = '';
        input.focus();
        
        // Shake animation effect
        form.parentElement?.classList.add('animate-shake');
        setTimeout(() => {
          form.parentElement?.classList.remove('animate-shake');
        }, 300);
      }
    });

    // Reset error styling on input
    input.addEventListener('input', () => {
      error.classList.add('hidden');
      input.classList.remove('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
    });

    // Keep focus on input for better UX
    if (authScreen) {
      authScreen.addEventListener('click', () => {
        if (!authScreen.classList.contains('hidden')) {
          input.focus();
        }
      });
    }
  }
</script>

<style is:global>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    50% { transform: translateX(4px); }
    75% { transform: translateX(-4px); }
  }
  .animate-shake {
    animation: shake 0.3s ease-in-out;
  }
</style>
