---
<style>
  .category-pill.active {
    background-color: #111;
    color: white;
    border-color: #111;
  }

  .ai-expandable-area {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-expandable-area.expanded {
    grid-template-rows: 1fr;
  }

  .ai-expandable-inner {
    overflow: hidden;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fadeSlideUp {
    animation: fadeSlideUp 0.3s ease-out forwards;
  }

  /* Chat Mode Animations */
  .chat-mode-active .ai-gradient-wrapper {
    padding: 0 !important;
    border-color: rgba(0, 0, 0, 0.08);
  }
  .chat-mode-active .ai-gradient-bg {
    opacity: 0;
  }
  .chat-mode-active .ai-header-text {
    opacity: 0;
    transform: translateY(-5px);
    pointer-events: none;
  }
  .chat-mode-active .ai-inner-box {
    padding: 20px;
    border-radius: 24px;
  }
  .chat-mode-active .img-ref-badge {
    opacity: 0;
    max-width: 0;
    padding-left: 0;
    padding-right: 0;
    margin-right: 0;
    border-width: 0;
    overflow: hidden;
    gap: 0;
  }
  .chat-mode-active .ai-categories-section {
    opacity: 0;
    max-height: 0;
    margin-top: 0;
    pointer-events: none;
  }
</style>

<div
  id={id}
  class={`ai-input-root transition-all flex flex-col ${isHero ? "w-full max-w-2xl" : "w-full"}`}
>
  <!-- Main Input Wrapper -->
  <div
    class="ai-gradient-wrapper relative z-20 rounded-[24px] p-[2.5px] pt-[32px] shadow-[0_4px_20px_rgb(0,0,0,0.06)] focus-within:shadow-[0_8px_32px_rgb(0,0,0,0.12)] transition-all duration-500 border border-transparent"
  >
    <!-- Gradient Background -->
    <div
      class="ai-gradient-bg absolute inset-0 rounded-[24px] bg-gradient-to-r from-[#4facfe] via-[#a855f7] to-[#ec4899] transition-opacity duration-500 z-0 pointer-events-none"
    >
    </div>

    <!-- Gradient Header Text -->
    <div
      class="ai-header-text absolute top-[9px] left-[22px] text-[10.5px] font-medium text-white/95 tracking-wide transition-all duration-500 z-10"
    >
      Define. Align. Design. Precision planning.
    </div>

    <!-- Inner White Box -->
    <div
      class={`ai-inner-box bg-white rounded-[21.5px] flex flex-col relative w-full h-full transition-all duration-500 z-20 ${isHero ? "p-6" : "px-5 pb-5 pt-2"}`}
    >
      <!-- Image Reference Badge (hidden by default, shown when file uploaded) -->
      <div
        id="img-ref-badge"
        class="img-ref-badge inline-flex items-center gap-1.5 h-[30px] pl-2 pr-2.5 rounded-lg bg-slate-50 border border-black/[0.08] text-slate-700 text-[12.5px] font-semibold hover:border-black/[0.15] transition-all duration-500 w-fit mb-2 shrink-0 group/img whitespace-nowrap overflow-hidden max-w-[200px]"
        style="display: none;"
      >
        <i class="ti ti-photo text-[14px] text-muted-foreground/60 shrink-0"
        ></i>
        <span class="tracking-tight shrink-0">product.jpg</span>
        <button
          class="badge-close w-4 h-4 rounded-full flex items-center justify-center hover:bg-red-50 hover:text-red-500 text-muted-foreground/40 transition-all ml-0.5 shrink-0"
        >
          <i class="ti ti-x text-[10px]"></i>
        </button>
      </div>

      <textarea
        class="prompt-textarea w-full font-medium text-foreground bg-transparent placeholder:text-muted-foreground/45 focus:outline-none resize-none pt-0.5 pb-6 leading-relaxed"
        placeholder={placeholder}
        rows="1"
        style={`min-height: ${isHero ? "64px" : "52px"}; font-size: ${isHero ? "16px" : "14px"};`}
      ></textarea>

      <div class="flex items-center justify-between relative z-20">
        <div class="flex items-center gap-2">
          <!-- Add Reference Dropdown -->
          <div class="relative dropdown-container" data-dropdown="add-ref">
            <button
              class="dropdown-trigger w-[30px] h-[30px] rounded-lg bg-[#f1f5f9] flex items-center justify-center text-slate-800 hover:bg-[#e2e8f0] transition-colors shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
              >
            </button>
            <div
              class="dropdown-menu hidden absolute bottom-[calc(100%+8px)] left-0 w-48 bg-white shadow-[0_8px_24px_rgb(0,0,0,0.12)] border border-black/[0.04] rounded-xl py-1.5 z-50"
            >
              <button
                class="w-full flex items-center gap-2.5 px-3 py-2 text-left hover:bg-slate-50 transition-colors"
              >
                <i
                  class="ti ti-upload text-[13px] text-muted-foreground shrink-0"
                ></i>
                <span class="text-[12.5px] font-medium text-slate-700"
                  >Upload Image</span
                >
              </button>
              <button
                class="w-full flex items-center gap-2.5 px-3 py-2 text-left hover:bg-slate-50 transition-colors"
              >
                <i class="ti ti-box text-[13px] text-muted-foreground shrink-0"
                ></i>
                <span class="text-[12.5px] font-medium text-slate-700"
                  >From Product Ref.</span
                >
              </button>
            </div>
          </div>


          <!-- Brand DNA Picker -->
          <div class="relative dropdown-container" data-dropdown="brand-dna">
            <button
              class="dropdown-trigger h-[30px] px-2.5 rounded-lg bg-[#f1f5f9] flex items-center gap-1.5 text-slate-800 text-[13px] font-semibold hover:bg-[#e2e8f0] transition-colors shrink-0 group/dna"
            >
              <i
                class="ti ti-dna-2 text-[14px] text-muted-foreground/80 group-hover/dna:text-[#7185ff] transition-colors"
              ></i>
              <span class="dropdown-label tracking-tight">Brand DNA</span>
              <i
                class="ti ti-chevron-down text-[12px] text-muted-foreground/40 ml-0.5 transition-transform"
              ></i>
            </button>

            <div
              class="dropdown-menu hidden absolute bottom-[calc(100%+8px)] left-0 min-w-[196px] bg-white border border-black/[0.08] rounded-[12px] shadow-[0_8px_24px_rgb(0,0,0,0.08)] py-1.5 z-50"
            >
              <p
                class="px-3 pt-1 pb-1.5 text-[9.5px] font-bold text-muted-foreground uppercase tracking-widest"
              >
                Your Brands
              </p>
              {
                [
                  { name: "Fresh Juice Co.", color: "#ffc1a6" },
                  { name: "Urban Bloom", color: "#c6e8ff" },
                  { name: "Apex CRM", color: "#fdc6e7" },
                ].map((brand) => (
                  <button
                    class="brand-item w-full flex items-center gap-2.5 px-3 py-2 text-left hover:bg-slate-50 transition-colors"
                    data-value={brand.name}
                  >
                    <div
                      class="w-3.5 h-3.5 rounded-full shrink-0 border border-black/[0.06]"
                      style={`background: ${brand.color};`}
                    />
                    <span class="text-[12px] font-medium text-foreground">
                      {brand.name}
                    </span>
                  </button>
                ))
              }
              <div class="border-t border-black/[0.05] mt-1 pt-1">
                <button
                  class="w-full flex items-center gap-2 px-3 py-2 text-left hover:bg-slate-50 transition-colors"
                >
                  <i class="ti ti-plus text-[12px] text-muted-foreground"></i>
                  <span class="text-[12px] font-medium text-muted-foreground"
                    >Create Brand DNA</span
                  >
                </button>
              </div>
            </div>
          </div>

          <!-- Skill Applied Badge -->
          <div
            id="skill-applied-badge"
            class="inline-flex items-center gap-1.5 h-[30px] pl-2.5 pr-2.5 rounded-lg bg-indigo-50 border border-indigo-200 text-indigo-700 text-[12.5px] font-semibold transition-all duration-500 shrink-0 group/skill whitespace-nowrap overflow-hidden max-w-[200px]"
            style="display: none;"
          >
            <span class="tracking-tight shrink-0 skill-name">Skill</span>
            <button
              class="badge-close-skill w-4 h-4 rounded-full flex items-center justify-center hover:bg-indigo-100 hover:text-indigo-600 text-indigo-400 transition-all ml-0.5 shrink-0"
            >
              <i class="ti ti-x text-[10px]"></i>
            </button>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <button
            class="submit-btn w-8 h-8 rounded-[8px] bg-foreground hover:bg-black flex items-center justify-center text-white transition-all shrink-0"
          >
            <i class="ti ti-arrow-up text-[15px]"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Global Category System -->
  <div
    class="ai-categories-section w-full mt-3 flex flex-col z-10 transition-all duration-500 max-h-[800px] overflow-hidden"
  >
    <!-- Category Pills -->
    <div
      class="flex items-center gap-2 overflow-x-auto pb-1 no-scrollbar justify-center"
    >
      {
        categoryData.map((cat) => (
          <button
            class="category-pill flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-black/[0.08] text-[11px] font-bold text-muted-foreground hover:border-black/20 transition-all shrink-0 bg-white shadow-[0_1px_3px_rgb(0,0,0,0.02)]"
            data-category={cat.id}
          >
            <div
              class="flex items-center justify-center opacity-70 w-3.5 h-3.5"
              set:html={cat.icon}
            />
            {cat.label}
          </button>
        ))
      }
    </div>

    <!-- Smooth Expandable Container for Cards -->
    <div class="ai-expandable-area">
      <div class="ai-expandable-inner">
        <div class="pt-3 pb-1 w-full">
          {
            categoryData.map((cat) => (
              <div
                class={`feature-group hidden ${isHero ? "flex flex-wrap items-center justify-center gap-2" : "grid grid-cols-2 gap-2"}`}
                id={`group-${cat.id}`}
              >
                {cat.features.map((f) =>
                  isHero ? (
                    <button class="goal-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-black/[0.08] bg-white shadow-sm text-[11.5px] font-semibold text-foreground hover:border-primary/40 hover:text-primary transition-all cursor-pointer">
                      <div
                        class="flex items-center justify-center w-[14px] h-[14px]"
                        set:html={f.icon}
                      />
                      {f.title}
                    </button>
                  ) : (
                    <button class="example-prompt relative flex items-center p-3.5 rounded-[12px] bg-[#f8f9fa] hover:bg-[#f1f3f5] border border-black/[0.05] hover:border-black/10 transition-all text-left overflow-hidden group">
                      <div class="relative z-10 w-full pr-10">
                        <div class="flex items-center gap-1.5 mb-0.5">
                          <span class="feature-title text-[12px] font-bold text-foreground">
                            {f.title}
                          </span>
                          <i class="ti ti-chevron-right text-[11px] text-muted-foreground/50 group-hover:text-muted-foreground transition-colors" />
                        </div>
                        <p class="text-[10.5px] text-muted-foreground leading-relaxed font-medium line-clamp-1">
                          {f.desc}
                        </p>
                      </div>
                      <div class="absolute right-[-10px] bottom-[-14px] w-[52px] h-[52px] bg-black/[0.04] border border-black/[0.05] rounded-[10px] rotate-[-12deg] flex items-start justify-start pt-2 pl-2 group-hover:rotate-[-5deg] group-hover:translate-y-[-3px] transition-all z-0">
                        <div
                          class="flex items-center justify-center w-[24px] h-[24px] text-muted-foreground/30 group-hover:text-muted-foreground/50 transition-colors"
                          set:html={f.icon}
                        />
                      </div>
                    </button>
                  ),
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function setupAiInput(root: HTMLElement) {
    const triggerButtons = root.querySelectorAll(".dropdown-trigger");
    const dropdownMenus = root.querySelectorAll(".dropdown-menu");
    const textarea = root.querySelector(
      ".prompt-textarea",
    ) as HTMLTextAreaElement;
    const submitBtn = root.querySelector(".submit-btn");

    // ── Dropdown Logic ──────────────────────────────────────
    triggerButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const menu = btn.nextElementSibling as HTMLElement;
        const isOpen = !menu.classList.contains("hidden");

        // Close other menus in THIS root
        dropdownMenus.forEach((m) => m.classList.add("hidden"));

        if (!isOpen) {
          menu.classList.remove("hidden");
          const chevron = btn.querySelector(".ti-chevron-down");
          if (chevron)
            (chevron as HTMLElement).style.transform = "rotate(180deg)";
        }
      });
    });

    document.addEventListener("click", () => {
      dropdownMenus.forEach((m) => m.classList.add("hidden"));
      root
        .querySelectorAll(".ti-chevron-down")
        .forEach((c) => ((c as HTMLElement).style.transform = ""));
    });

    // ── Brand DNA & Format Logic ────────────────────────────
    root.querySelectorAll(".brand-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        const val = (btn as HTMLElement).dataset.value;
        const label = root.querySelector(
          '[data-dropdown="brand-dna"] .dropdown-label',
        );
        if (label && val) label.textContent = val;
      });
    });



    root.querySelector(".badge-close")?.addEventListener("click", (e) => {
      e.stopPropagation();
      const badge = root.querySelector("#img-ref-badge") as HTMLElement;
      if (badge) {
        badge.style.display = "none";
        badge.style.marginBottom = "0";
      }
    });

    if (textarea) {
      textarea.addEventListener("input", () => {
        textarea.style.height = "auto";
        textarea.style.height = textarea.scrollHeight + "px";
      });
    }

    if (submitBtn && textarea) {
      submitBtn.addEventListener("click", () => {
        if (textarea.value.trim()) {
          root.dispatchEvent(
            new CustomEvent("ai-submit", {
              detail: { prompt: textarea.value.trim() },
              bubbles: true,
            }),
          );
        }
      });

      textarea.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          submitBtn.dispatchEvent(new Event("click"));
        }
      });
    }

    // ── Category & Expand Logic ──────────────────────────────
    const pills = root.querySelectorAll(".category-pill");
    const groups = root.querySelectorAll(".feature-group");
    const expandableArea = root.querySelector(".ai-expandable-area");

    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const catId = (pill as HTMLElement).dataset.category;
        const isAlreadyActive = pill.classList.contains("active");

        // Remove active from all
        pills.forEach((p) => p.classList.remove("active"));

        if (isAlreadyActive) {
          // Unclick: close everything
          expandableArea?.classList.remove("expanded");
          // Hide groups after animation finishes
          setTimeout(() => {
            groups.forEach((g) => {
              g.classList.add("hidden");
              g.classList.remove("animate-fadeSlideUp");
            });
          }, 300); // 300ms matches CSS transition
        } else {
          // Make this pill active
          pill.classList.add("active");

          // Show the correct group
          groups.forEach((group) => {
            group.classList.add("hidden");
            group.classList.remove("animate-fadeSlideUp");
            if (group.id === `group-${catId}`) {
              group.classList.remove("hidden");
              // trigger reflow
              void group.offsetWidth;
              group.classList.add("animate-fadeSlideUp");
            }
          });

          // Expand the area
          expandableArea?.classList.add("expanded");
        }
      });
    });

    // ── Skill Badge Logic ──────────────────────────────
    const skillBadge = root.querySelector(
      "#skill-applied-badge",
    ) as HTMLElement;
    const skillBadgeName = root.querySelector(".skill-name") as HTMLElement;
    const skillBadgeClose = root.querySelector(
      ".badge-close-skill",
    ) as HTMLElement;

    if (skillBadgeClose) {
      skillBadgeClose.addEventListener("click", (e) => {
        e.stopPropagation();
        if (skillBadge) {
          skillBadge.style.display = "none";
        }
      });
    }

    const featureButtons = root.querySelectorAll(".goal-chip, .example-prompt");
    featureButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        let title = "";
        const titleSpan = btn.querySelector(".feature-title");
        if (titleSpan) {
          title = titleSpan.textContent?.trim() || "";
        } else {
          title = btn.textContent?.trim() || "";
        }

        if (title && textarea) {
          textarea.value = `Buatkan desain ${title}`;
          textarea.style.height = "auto";
          textarea.style.height = textarea.scrollHeight + "px";
        }

        if (skillBadge && skillBadgeName && title) {
          skillBadgeName.textContent = title;
          skillBadge.style.display = "inline-flex";
        }
      });
    });
  }

  // Initialize all AI inputs
  document.querySelectorAll(".ai-input-root").forEach((root) => {
    setupAiInput(root as HTMLElement);
  });
</script>
