---
const allProjects = [
  { id: 1, name: "Untitled", date: "Updated Apr 16, 2026" },
  { id: 2, name: "Untitled", date: "Updated Apr 15, 2026" },
];
---

<div class="flex-1 bg-white rounded-[14px] shadow-[0_4px_16px_rgb(0,0,0,0.02)] border-[0.5px] border-black/[0.08] p-8 flex flex-col h-full overflow-y-auto" style="scrollbar-width: none;">

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 shrink-0">
    
    <!-- Left: Title -->
    <h1 class="text-[22px] font-bold text-foreground tracking-tight">Projects</h1>
    
    <!-- Right: All Controls -->
    <div class="flex flex-wrap items-center gap-2.5">
       <!-- Filter Button -->
       <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-[8px] border border-black/[0.08] text-[12px] font-semibold text-foreground hover:bg-[#f4f4f4] bg-white transition-all shadow-[0_2px_8px_rgb(0,0,0,0.02)]">
          <i class="ti ti-adjustments-horizontal text-[14px] text-muted-foreground"></i> Filter
       </button>
       
       <!-- Search Block -->
       <div class="relative w-[240px]">
          <i class="ti ti-search text-[14px] text-muted-foreground absolute left-3 top-1/2 -translate-y-1/2"></i>
          <input type="text" placeholder="Search projects..." class="w-full h-8 pl-8 pr-3 text-[12px] font-medium rounded-[8px] border border-black/[0.08] bg-white placeholder:text-muted-foreground focus:outline-none focus:border-black/20 focus:shadow-sm transition-all shadow-[0_2px_8px_rgb(0,0,0,0.02)]" />
       </div>
    </div>
  </div>

  <!-- Grid Gallery Layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    
    <!-- New Project Card -->
    <div class="flex flex-col gap-3 cursor-pointer group" id="btn-new-project-grid">
      <div class="w-full aspect-[16/10] rounded-[16px] bg-[#fafafa] border-[1.5px] border-dashed border-black/15 flex items-center justify-center group-hover:border-black/30 group-hover:bg-[#f0f0f0] transition-colors relative overflow-hidden">
        <i class="ti ti-plus text-[28px] text-black/20 group-hover:text-black/40 transition-colors"></i>
      </div>
      <div class="px-1">
        <h4 class="text-[13px] font-semibold text-foreground">New Project</h4>
      </div>
    </div>

    <!-- Existing Projects Mapping -->
    {allProjects.map((proj) => (
      <div class="flex flex-col gap-3 cursor-pointer group">
        <div class="w-full aspect-[16/10] rounded-[16px] bg-[#ececec] border border-black/5 flex items-center justify-center overflow-hidden hover:shadow-md transition-all">
          <!-- Placeholder icon for image -->
          <i class="ti ti-photo text-[32px] text-black/10"></i>
        </div>
        <div class="px-1">
          <h4 class="text-[13px] font-semibold text-foreground leading-tight">{proj.name}</h4>
          <p class="text-[11px] text-muted-foreground mt-1 font-medium tracking-wide">{proj.date}</p>
        </div>
      </div>
    ))}

  </div>

</div>
