---
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg" | "icon";
  href?: string;
  type?: "button" | "submit";
  class?: string;
  id?: string;
  disabled?: boolean;
  onclick?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className = "",
  id,
  disabled = false,
  onclick,
  ...rest
} = Astro.props;

const sizeClasses = {
  sm: "px-3 h-8 text-[12px]",
  md: "px-4 h-9 text-[13px]",
  lg: "px-6 h-10 text-[14px]",
  icon: "w-9 h-9 items-center justify-center",
};

const variants = {
  primary:
    "bg-[#111827] text-white border border-[#374151] shadow-[0_3px_0_0_#374151] hover:bg-black hover:shadow-[0_3px_0_0_#374151] active:translate-y-[1px] active:shadow-[0_1px_0_0_#374151]",
  secondary:
    "bg-white text-[#344054] border border-[#D0D5DD] shadow-[0_3px_0_0_#D0D5DD] hover:bg-[#F9FAFB] hover:shadow-[0_3px_0_0_#D0D5DD] active:translate-y-[1px] active:shadow-[0_1px_0_0_#D0D5DD]",
  ghost:
    "bg-transparent text-[#667085] hover:bg-[#F3F4F6] hover:text-[#111827] active:translate-y-[1px]",
};

const baseClasses =
  "inline-flex items-center gap-2 rounded-xl font-bold transition-all duration-100 cursor-pointer select-none whitespace-nowrap disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0 disabled:shadow-none justify-center";
const classes = `${baseClasses} ${sizeClasses[size]} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} id={id} {...rest}>
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={classes}
      id={id}
      disabled={disabled}
      onclick={onclick}
      {...rest}
    >
      <slot />
    </button>
  )
}
